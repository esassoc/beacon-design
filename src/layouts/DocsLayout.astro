---
// Thin spoke wrapper around @esa/docs DocsShell. The shell (sidebar, topbar,
// "On this page" rail, all CSS + scroll-spy) is shared with the hub and every
// other spoke; this wrapper supplies only Beacon's axes: the brand theme CSS,
// Beacon's font links, the brand chrome, and the nav data.
// Import DocsShell FIRST — it pulls in @esa/tokens (:root primitives + default
// teal semantics). theme-beacon.css must load AFTER so it wins: a [data-theme]
// block and :root have equal specificity, so source order decides.
import DocsShell from '@esa/docs/DocsShell.astro';
import '../styles/theme-beacon.css';
import { allGroups } from '../data/ds-nav';
import { withBase } from '../lib/base';

interface Props {
  title?: string;
  activeHref?: string; // base-less, e.g. "/design-system/foundations/color"
}
const { title = 'Beacon — Design System', activeHref = '' } = Astro.props;
---
<DocsShell
  title={title}
  activeHref={activeHref}
  groups={allGroups}
  theme="beacon"
  brandMark="B"
  brandName="Beacon"
  brandTag="Design System"
  brandHref="/design-system"
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- DM Sans (body/heading), Roboto Mono (code/ids), Besley (opt-in decorative) —
         matching Beacon's _webfonts.scss font loading. -->
    <link
      href="https://fonts.googleapis.com/css2?family=Besley:ital,wght@0,400..900;1,400..900&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Roboto+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <a class="topbar-action" slot="topbar-actions" href={withBase('/')}>
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    Prototype Library
  </a>

  <slot />
</DocsShell>
