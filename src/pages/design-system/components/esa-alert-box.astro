---
import ComponentDoc from '../../../layouts/ComponentDoc.astro';
import Section from '@esa/docs/Section.astro';
import Preview from '@esa/docs/Preview.astro';
import Api from '@esa/docs/Api.astro';
import AlertBox from '@esa/ecology/esa-alert-box.astro';

const props = [
  { name: 'variant', type: "'info' | 'success' | 'warning' | 'danger'", default: "'info'", description: 'Tone — drives the tint, border, and auto-mapped icon. Maps to Beacon toast contexts (info ≈ primary/info, success, warning, danger).' },
  { name: 'title', type: 'string', description: 'Optional bold heading above the message.' },
  { name: 'dismissable', type: 'boolean', default: 'false', description: 'Shows a close (×) button that hides the alert and emits a dismissed event.' },
];

const events = [
  { name: 'dismissed', type: 'CustomEvent', description: 'Bubbles when the close button is clicked (dismissable only).' },
];
---
<ComponentDoc name="Toast" category="Overlays" slug="esa-alert-box" type=".astro"
  summary="Beacon's transient notification look. In the live app a global host renders these in the top layer with stacking and auto-dismiss; the <strong>visual</strong> — a light tinted card with a tone icon, message, and optional dismiss — is the inherited Ecology <code>esa-alert-box</code> wearing the Beacon skin. (Maps to Beacon's <code>ui-toast</code>; the dark Material <code>esa-snackbar</code> is a different pattern.)">

  <Section id="contexts" title="Contexts">
    <p>One tone per status. Each carries its own tint, border, and icon — the same contexts Beacon's toast exposes (its neutral <code>primary</code> maps to <code>info</code>).</p>
    <Preview align="start" code={`<AlertBox variant="success" title="Saved">Saved successfully.</AlertBox>
<AlertBox variant="danger" title="Error">Something went wrong. Please try again.</AlertBox>
<AlertBox variant="warning" title="Heads up">Review this before continuing.</AlertBox>
<AlertBox variant="info" title="Working">Your export is being prepared.</AlertBox>`}>
      <div style="display: flex; flex-direction: column; gap: 12px; width: 100%;">
        <AlertBox variant="success" title="Saved">Saved successfully.</AlertBox>
        <AlertBox variant="danger" title="Error">Something went wrong. Please try again.</AlertBox>
        <AlertBox variant="warning" title="Heads up">Review this before continuing.</AlertBox>
        <AlertBox variant="info" title="Working">Your export is being prepared.</AlertBox>
      </div>
    </Preview>
  </Section>

  <Section id="states" title="States">
    <p>The title is optional — omit it for a compact single-line notice. With <code>dismissable</code>, a × appears and a <code>dismissed</code> event bubbles on click (Beacon's <code>dismissable = false</code> relies on the auto-dismiss timer instead).</p>
    <Preview align="start" code={`<AlertBox variant="info">A general, neutral notice.</AlertBox>
<AlertBox variant="success" title="Dismissable" dismissable={true}>Click the × to hide this.</AlertBox>`}>
      <div style="display: flex; flex-direction: column; gap: 12px; width: 100%;">
        <AlertBox variant="info">A general, neutral notice.</AlertBox>
        <AlertBox variant="success" title="Dismissable" dismissable={true}>Click the × to hide this.</AlertBox>
      </div>
    </Preview>
  </Section>

  <Section id="api" title="API">
    <Api props={props} events={events} />
  </Section>

  <Section id="tokens" title="Tokens">
    <ul class="tokens">
      <li><code>--color-info</code> / <code>--color-success</code> / <code>--color-warning</code> / <code>--color-danger</code> + their <code>-subtle</code> and <code>-border</code> variants — re-pointed to Beacon's palette by the theme</li>
      <li><code>--color-text-primary</code> (title) · <code>--color-text-secondary</code> (message) · <code>--color-text-muted</code> (dismiss)</li>
      <li><code>--radius-200</code> · <code>--spacing-*</code> · <code>--type-size-150</code></li>
    </ul>
  </Section>
</ComponentDoc>
