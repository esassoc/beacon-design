---
// Foundations specimen — renders Beacon's design tokens straight from the live
// CSS custom properties (hub tokens.css re-skinned by theme-beacon.css). If this
// looks like Beacon, the token pipeline is correct.
import BaseLayout from '../layouts/BaseLayout.astro';

const grays = ['0', '50', '100', '200', '300', '400', '500', '600', '700', '800', '900', '950', '1000'];
const semantic = [
  ['--color-primary', 'primary (teal-900)'],
  ['--color-secondary', 'secondary (teal-500)'],
  ['--color-info', 'info'],
  ['--color-success', 'success'],
  ['--color-warning', 'warning'],
  ['--color-danger', 'danger'],
];
const entity = [
  ['--color-source', 'Source'],
  ['--color-commitment', 'Commitment'],
  ['--color-requirement', 'Requirement'],
  ['--color-action', 'Action'],
];
const types = ['100', '150', '200', '250', '300', '400', '500', '600', '700', '800'];
const spaces = ['100', '150', '200', '250', '300', '400', '500', '600', '700', '800'];
const radii = ['050', '100', '200', '400', 'full'];
const shadows = ['50', '100', '200', '300', '400'];
const formSizes = ['xs', 'sm', 'md', 'lg'];
---
<BaseLayout title="Beacon Design — Foundations">
  <main class="wrap">
    <header class="head">
      <p class="eyebrow">Beacon Design · spoke of ecology</p>
      <h1>Foundations</h1>
      <p class="lede">
        Every value below is read live from the ecology hub tokens
        (<code>@esa/tokens</code>) re-skinned by <code>theme-beacon.css</code>.
        This is Beacon's design system expressed through ecology's vocabulary.
      </p>
    </header>

    <section>
      <h2>Neutral ramp <span class="note">re-pointed to Beacon's warm grays</span></h2>
      <div class="row">
        {grays.map((g) => (
          <div class="swatch">
            <span class="chip" style={`background: var(--bcn-gray-${g})`}></span>
            <span class="lbl">gray-{g}</span>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2>Semantic</h2>
      <div class="row">
        {semantic.map(([v, name]) => (
          <div class="swatch">
            <span class="chip" style={`background: var(${v})`}></span>
            <span class="lbl">{name}</span>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2>Entity step accents <span class="note">Beacon spoke tokens</span></h2>
      <div class="row">
        {entity.map(([v, name]) => (
          <div class="swatch">
            <span class="chip" style={`background: var(${v})`}></span>
            <span class="lbl">{name}</span>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2>Type scale <span class="note">DM Sans · fluid clamp()</span></h2>
      {types.map((t) => (
        <p class="type" style={`font-size: var(--type-size-${t})`}>
          type-{t} — The quick brown fox jumps over the lazy dog
        </p>
      ))}
      <p class="type" style="font-family: var(--font-decorative); font-size: var(--type-size-600)">
        Besley decorative — Setup Wizard voice
      </p>
      <p class="type" style="font-family: var(--font-mono); font-size: var(--type-size-200)">
        Roboto Mono — BCN-1267 · #005862
      </p>
    </section>

    <section>
      <h2>Spacing</h2>
      <div class="stack">
        {spaces.map((s) => (
          <div class="space-row">
            <span class="lbl">{s}</span>
            <span class="bar" style={`width: var(--spacing-${s})`}></span>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2>Radius · Shadow · Form heights</h2>
      <div class="row">
        {radii.map((r) => (
          <div class="swatch">
            <span class="box" style={`border-radius: var(--radius-${r})`}></span>
            <span class="lbl">radius-{r}</span>
          </div>
        ))}
      </div>
      <div class="row" style="margin-top: var(--spacing-500)">
        {shadows.map((s) => (
          <div class="swatch">
            <span class="box box--plain" style={`box-shadow: var(--shadow-${s})`}></span>
            <span class="lbl">shadow-{s}</span>
          </div>
        ))}
      </div>
      <div class="row" style="margin-top: var(--spacing-500); align-items: flex-end">
        {formSizes.map((s) => (
          <div class="swatch">
            <span class="form" style={`height: var(--form-height-${s})`}>{s}</span>
            <span class="lbl">form-{s}</span>
          </div>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .wrap { max-width: var(--content-max-width); margin: 0 auto; padding: var(--spacing-700) var(--spacing-500); }
  .head { margin-bottom: var(--spacing-700); }
  .eyebrow { color: var(--color-secondary); font-weight: var(--font-weight-semibold); font-size: var(--type-size-150); margin: 0 0 var(--spacing-200); }
  h1 { font-size: var(--type-size-800); margin: 0 0 var(--spacing-300); color: var(--color-text-primary); }
  .lede { color: var(--color-text-secondary); font-size: var(--type-size-300); line-height: var(--line-height-normal); max-width: 60ch; }
  code { font-family: var(--font-mono); font-size: 0.9em; background: var(--color-surface-sunken); padding: 0.1em 0.35em; border-radius: var(--radius-100); }
  section { margin-bottom: var(--spacing-700); }
  h2 { font-size: var(--type-size-400); color: var(--color-text-primary); border-bottom: 1px solid var(--color-border); padding-bottom: var(--spacing-200); margin: 0 0 var(--spacing-400); }
  .note { font-size: var(--type-size-150); font-weight: var(--font-weight-regular); color: var(--color-text-muted); margin-left: var(--spacing-200); }
  .row { display: flex; flex-wrap: wrap; gap: var(--spacing-400); }
  .swatch { display: flex; flex-direction: column; gap: var(--spacing-150); align-items: flex-start; }
  .chip { width: 64px; height: 48px; border-radius: var(--radius-200); border: 1px solid var(--color-border); display: block; }
  .box { width: 64px; height: 48px; background: var(--color-secondary); display: block; }
  .box--plain { background: var(--color-surface); border: 1px solid var(--color-border-light); }
  .lbl { font-size: var(--type-size-100); color: var(--color-text-muted); font-family: var(--font-mono); }
  .type { color: var(--color-text-primary); margin: 0 0 var(--spacing-200); line-height: var(--line-height-tight); }
  .stack { display: flex; flex-direction: column; gap: var(--spacing-200); }
  .space-row { display: flex; align-items: center; gap: var(--spacing-300); }
  .space-row .lbl { width: 40px; }
  .bar { height: 16px; background: var(--color-primary); border-radius: var(--radius-050); }
  .form { display: inline-flex; align-items: center; justify-content: center; min-width: 64px; padding: 0 var(--spacing-300); background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--form-radius-md); color: var(--color-text-secondary); font-size: var(--type-size-150); }
</style>
