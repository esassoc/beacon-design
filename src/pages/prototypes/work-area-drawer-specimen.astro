  <script>
    // Concept 2's discipline switcher — the specimen's only interactivity.
    for (const host of document.querySelectorAll<HTMLElement>('[data-workspace]')) {
      host.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[role="tab"][data-dim]');
        if (!btn || !host.contains(btn)) return;
        const dim = btn.dataset.dim;
        for (const tab of host.querySelectorAll<HTMLElement>('[role="tab"][data-dim]'))
          tab.setAttribute('aria-selected', String(tab === btn));
        for (const panel of host.querySelectorAll<HTMLElement>('[data-panel]'))
          panel.hidden = panel.dataset.panel !== dim;
      });
    }
