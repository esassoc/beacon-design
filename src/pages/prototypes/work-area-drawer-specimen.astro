---
// Work Area drawer — Decision-first v2 deep dive (specimen).
//
// Round 1 presented three structural options ("make different choices about
// what the priority data/interfaces need to be"); the client picked
// Decision-first and asked to go deeper. The page now LEADS with the v2 deep
// dive and demotes the round-1 three-option row to a reference section at the
// bottom.
//
// The four v2 directives:
//   1. Dates up high — Notification · Clearance visit · Planned start
//      (+ Blocked until when relevant) as an always-visible band directly
//      under the header. Decision inputs, not detail.
//   2. Streamlined confirm — the provisional banner becomes ONE slim line
//      (obs ID badge · "within buffer · est. through Jul 24" · compact inline
//      Confirm block). The decision block reads in ~2 seconds.
//   3. Disciplines open a STACKED CHILD DRAWER, not tabs — mirroring
//      permit-tracking's segment → permit-editor stacking (the under card
//      slides left via --side-dialog-inset and sits dimmed behind; the top
//      card brings no second backdrop). Depicted statically here.
//   4. Multiple reviews per discipline — the child drawer is a review HISTORY
//      (reverse-chron: date, kind, reviewer, outcome chip, notes); the latest
//      COMPLETED review drives the discipline's board status; future reviews
//      ride the history as scheduled. Mocked statically with DCTR2-DH-010
//      biological: May 18 clearance survey → Blocked (SWHA nest found) →
//      re-survey scheduled Sep 2 (post-fledge est. Jul 24). NO fixture
//      changes — see the data-model note rendered in the page.
//
// Stress cases (REAL, derived live from the fixture):
//   DCRDS-DH-184 — provisional block (the "decide NOW" case)
//   DCRAI-DH-014 — multi-discipline, planned start before its reviews
//   DCTR2-DH-010 — confirmed block + the June → September re-survey story
//
// Static / lightly interactive: structure and hierarchy are the point, not
// working CRUD. The only JS is round-1 concept 2's discipline switcher.
import BaseLayout from '../../layouts/BaseLayout.astro';
import EsaButton from '@esa/ecology/esa-button.astro';
import EsaIcon from '@esa/ecology/esa-icon.astro';
import EsaIconButton from '@esa/ecology/esa-icon-button.astro';
import EsaBadge from '@esa/ecology/esa-badge.astro';
import EsaCollapsible from '@esa/ecology/esa-collapsible.astro';
import BcnStatusChip from '../../components/bcn/BcnStatusChip.astro';
import BcnKeyValue from '../../components/bcn/BcnKeyValue.astro';
import {
  workAreas,
  observations,
  STATUS_META,
  GATE_DIMENSIONS,
  GATE_DIMENSION_LABEL,
  deriveStatus,
  bufferConflicts,
  blockedUntil,
  distanceFt,
  gateFor,
  formatDate,
  daysUntil,
} from '../../data/geotech-fixture';
import type { ClearanceStatus, WorkArea } from '../../data/geotech-fixture';

// SSR :root status vars — same contract as site-clearance: STATUS_META's hexes
// ARE the committed field-map palette; every chip/dot on this page reads the
// runtime --st-* custom properties.
const rootVars =
  `:root{` +
  Object.values(STATUS_META)
    .map((m) => `${m.colorVar}:${m.hex};`)
    .join('') +
  `--st-neutral:#8a9099;}`;

const byId = (id: string): WorkArea => workAreas.find((w) => w.id === id)!;
const wa184 = byId('DCRDS-DH-184');
const wa014 = byId('DCRAI-DH-014');

// Derived — never stored (the same pure helpers the live page uses).
const st184 = deriveStatus(wa184, observations); // → provisional-block
const st014 = deriveStatus(wa014, observations); // → survey-scheduled (worst gate)

const swha = bufferConflicts(wa184, observations)[0]; // SWHA-2289-05182026
const swhaDist = Math.round(distanceFt(wa184.lat, wa184.lng, swha.lat, swha.lng));
const until184 = blockedUntil(wa184, observations)!; // 2026-07-24

const g184bio = gateFor(wa184, 'biological')!; // survey-scheduled Jun 15
const g014bio = gateFor(wa014, 'biological')!; // cleared Jun 3 · C. Anderson
const g014geo = gateFor(wa014, 'geology')!; // survey-scheduled Jun 18
const g014noise = gateFor(wa014, 'noise')!; // survey-scheduled Jun 20

// ── v2 deep-dive additions ────────────────────────────────────────────────────
// DCTR2-DH-010 — the June → September re-survey story (confirmed block).
const wa010 = byId('DCTR2-DH-010');
const st010 = deriveStatus(wa010, observations); // → blocked (gate + live conflict)
const until010 = blockedUntil(wa010, observations)!; // 2026-07-24
const g010bio = gateFor(wa010, 'biological')!; // blocked May 18 · C. Anderson
const swha010Dist = Math.round(distanceFt(wa010.lat, wa010.lng, swha.lat, swha.lng));
// Short obs ID for the slim confirm line (SWHA-2289-05182026 → SWHA-2289).
const swhaShort = swha.id.split('-').slice(0, 2).join('-');
// STATIC MOCK — the post-fledge re-survey is NOT in the fixture (no fixture
// changes for the specimen); see the data-model note in the page.
const RESURVEY = '2026-09-02';
// Review counts per discipline for the v2 board badges (>1 only). Static mock
// for the same reason: the fixture's single-gate shape can't hold two reviews.
const counts010: Partial<Record<string, number>> = { biological: 2 };

const meta = (s: ClearanceStatus) => STATUS_META[s];
const cells = (w: WorkArea) =>
  GATE_DIMENSIONS.map((dim) => ({ dim, label: GATE_DIMENSION_LABEL[dim], gate: gateFor(w, dim) }));

// Compact meta line for a status-board cell / checklist row.
const gateWhen = (g: { status: ClearanceStatus; reviewDate?: string; reviewer?: string } | null): string => {
  if (!g?.reviewDate) return '—';
  if (g.status === 'survey-scheduled') return `Scheduled ${formatDate(g.reviewDate)}`;
  return `${formatDate(g.reviewDate)}${g.reviewer ? ` · ${g.reviewer}` : ''}`;
};

// Lucide paths (same glyphs the live drawer uses).
const ALERT = "<path d='m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3'/><path d='M12 9v4'/><path d='M12 17h.01'/>";
const CLIPBOARD = "<rect width='8' height='4' x='8' y='2' rx='1' ry='1'/><path d='M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2'/><path d='m9 14 2 2 4-4'/>";
const QUOTE = "<path d='M16 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z'/><path d='M5 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z'/>";
const CLOCK = "<circle cx='12' cy='12' r='10'/><polyline points='12 6 12 12 16 14'/>";
const HISTORY = "<path d='M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8'/><path d='M3 3v5h5'/><path d='M12 7v5l4 2'/>";
const SHIELD = "<path d='M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1 1 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z'/><path d='m9 12 2 2 4-4'/>";
const CHEVRON = "<path d='m9 18 6-6-6-6'/>";
---

<!-- bcn-lego-checked: static design specimen — structural mockups of the
     site-clearance work-area drawer (no working CRUD). esa- legos are used
     everywhere they are load-bearing: esa-button (all actions), esa-icon,
     esa-icon-button (the child drawer's close), esa-badge (the >1 review count
     on board cells), esa-collapsible (the demoted sections) + BcnStatusChip
     (value-driven status chips incl. the hollow provisional variant) and
     BcnKeyValue (the v2 date band is a BcnKeyValue grid promoted out of its
     collapsible). The drawer frames are static inline stand-ins for
     esa-side-dialog — checked it: the lego is a fixed full-height overlay and
     cannot render multiple drawers side by side for comparison, which is this
     page's entire job; the v2 parent→child STACK is likewise a static
     depiction of the lego's own committed stacking mechanics (permit-tracking:
     --side-dialog-inset on the under card, no second backdrop on the top
     card). The structures under exploration are the bespoke parts BY DESIGN:
     the 4-cell discipline status board (cells = buttons that open the child
     drawer), the per-discipline review-history list (checked Ecology + Beacon —
     no timeline/history lego exists; same precedent as the discussion-timeline
     and site-clearance Timeline-tab page glue), and round 1's tabbed workspace
     (checked esa-tab-layout — page-level chrome with URL/hash routing, wrong
     shape inside a 420px drawer panel) + lifecycle stepper. The hollow "Not
     reviewed" chip + provisional-block outlined-chip treatments replicate the
     live page's committed idioms so the comparison reads as Beacon. Remaining
     CSS is specimen-page glue. -->
<BaseLayout title="Work Area drawer — Decision-first v2 deep dive">
  <style is:inline set:html={rootVars}></style>

  <main class="spec">
    <header class="spec__head">
      <h1 class="spec__title">Work Area drawer — Decision-first v2</h1>
      <p class="spec__intro">
        Round 1 compared three drawer structures; <strong>Decision-first</strong> was selected
        (<em>"Decision-first seems right"</em>). This page now leads with the v2 deep dive — dates promoted to
        an always-visible band, a confirm that reads in two seconds, discipline cells that open a stacked
        child drawer, and a per-discipline review history that survives the June → September re-survey
        reality. The round-1 exploration is kept at the bottom for reference. All data is real fixture data;
        the only static mock is the September re-survey (flagged in the data-model note).
      </p>
    </header>

    <!-- ═══════════════════════ Decision-first — v2 deep dive ═══════════════════════ -->
    <section class="v2" aria-labelledby="v2-title">
      <header class="v2__head">
        <h2 class="v2__title" id="v2-title">Decision-first — v2 deep dive</h2>
        <ul class="v2__changes">
          <li>
            <strong>Dates up high.</strong> Notification · Clearance visit · Planned start (+ Blocked until
            when relevant) render as a compact band directly under the header — decision inputs, not detail.
          </li>
          <li>
            <strong>A two-second confirm.</strong> The provisional banner is now one slim line — observation
            ID · "within buffer · est. through Jul 24" · a compact Confirm block inline.
          </li>
          <li>
            <strong>Disciplines open a stacked child drawer.</strong> Each board cell is a button that opens
            that discipline's own drawer over the parent (the permit workspace's segment → editor stacking) —
            not tabs, not one long form.
          </li>
          <li>
            <strong>Review history per discipline.</strong> The child drawer holds every review — clearance
            survey, re-survey, management determination — newest first. The latest completed review sets the
            board status; future reviews ride the history as scheduled. Cells show a count when there is more
            than one. Survey records live here now, not in a parent section.
          </li>
        </ul>
      </header>

      <div class="v2__pair">
        <!-- v2 · Case A: DCRDS-DH-184 -->
        <figure class="mockup">
          <figcaption class="mockup__case">
            DCRDS-DH-184 · provisional block — the dates band answers "when", the slim line answers "what now".
          </figcaption>
          <article class="drawer">
            <header class="drawer__head">
              <div class="drawer__headrow">
                <h3 class="drawer__title">{wa184.id}</h3>
                <BcnStatusChip status={st184} label={meta(st184).label} hex={meta(st184).hex} />
              </div>
              <p class="drawer__sub">{wa184.segment} · {wa184.constructionPackage}</p>
            </header>
            <div class="band">
              <BcnKeyValue label="Notification" value={formatDate(wa184.notificationDate)} />
              <BcnKeyValue label="Clearance visit" value={formatDate(wa184.clearanceVisitDate)} />
              <BcnKeyValue label="Planned start" value={formatDate(wa184.plannedStartDate)} />
            </div>
            <div class="drawer__body">
              <div class="decide decide--prov">
                <p class="decide__line decide__line--fact">
                  <span class="obs-id">{swhaShort}</span>
                  <span>within buffer · est. through {formatDate(until184)}</span>
                </p>
                <div class="decide__actions">
                  <EsaButton color="danger" size="sm">Confirm block</EsaButton>
                </div>
              </div>

              <section>
                <h4 class="drawer__section">
                  <EsaIcon name="shield-check" size="sm" paths={SHIELD} />
                  Disciplines
                </h4>
                <div class="board">
                  {
                    cells(wa184).map(({ label, gate }) => (
                      <button type="button" class="board__cell board__cell--btn">
                        <span class="board__cellhead">
                          <span class="board__dim">{label}</span>
                          <span class="board__chev"><EsaIcon name="chevron-right" size="sm" paths={CHEVRON} /></span>
                        </span>
                        {gate ? (
                          <BcnStatusChip status={gate.status} label={meta(gate.status).label} hex={meta(gate.status).hex} />
                        ) : (
                          <span class="unreviewed">Not reviewed</span>
                        )}
                        <span class="board__meta">{gateWhen(gate)}</span>
                      </button>
                    ))
                  }
                </div>
              </section>

              <div class="drawer__more">
                <EsaCollapsible title="Buffer conflicts (1)" flush icon="alert-triangle" iconPaths={ALERT}>
                  <ul class="rows">
                    <li class="conflict">
                      <span class="conflict__main">
                        {swha.species}
                        <span class="conflict__sub">{swha.id} · {swha.bufferFt.toLocaleString()} ft buffer</span>
                      </span>
                      <span class="conflict__meta">
                        {swhaDist.toLocaleString()} ft away
                        <span class="conflict__sub">est. end {formatDate(swha.estEndDate)}</span>
                      </span>
                    </li>
                  </ul>
                </EsaCollapsible>
                <EsaCollapsible title="Notes (1)" flush icon="quote" iconPaths={QUOTE}>
                  <blockquote class="note">{wa184.biologistNote}</blockquote>
                </EsaCollapsible>
                <EsaCollapsible title="Activity" flush icon="history" iconPaths={HISTORY}>
                  <p class="empty">No changes this session.</p>
                </EsaCollapsible>
              </div>
            </div>
            <footer class="drawer__foot">
              <EsaButton color="ghost" appearance="outline" size="md">Edit site details</EsaButton>
            </footer>
          </article>
        </figure>

        <!-- v2 · Case B: DCRAI-DH-014 -->
        <figure class="mockup">
          <figcaption class="mockup__case">
            DCRAI-DH-014 · multi-discipline — the empty dates are as informative as the filled ones.
          </figcaption>
          <article class="drawer">
            <header class="drawer__head">
              <div class="drawer__headrow">
                <h3 class="drawer__title">{wa014.id}</h3>
                <BcnStatusChip status={st014} label={meta(st014).label} hex={meta(st014).hex} />
              </div>
              <p class="drawer__sub">{wa014.segment} · {wa014.constructionPackage}</p>
            </header>
            <div class="band">
              <BcnKeyValue label="Notification" value={formatDate(wa014.notificationDate)} />
              <BcnKeyValue label="Clearance visit" value={formatDate(wa014.clearanceVisitDate)} />
              <BcnKeyValue label="Planned start" value={formatDate(wa014.plannedStartDate)} />
            </div>
            <div class="drawer__body">
              <div class="decide">
                <p class="decide__line">
                  Awaiting geology review — {formatDate(g014geo.reviewDate)} (in {daysUntil(g014geo.reviewDate!)} days)
                </p>
                <div class="decide__row decide__row--warn">
                  <EsaIcon name="alert-triangle" size="sm" paths={ALERT} />
                  <span class="decide__warntext">
                    Start {formatDate(wa014.plannedStartDate)} precedes the geology and noise reviews
                  </span>
                </div>
                <div class="decide__actions">
                  <EsaButton color="ghost" appearance="outline" size="sm">Edit start</EsaButton>
                </div>
              </div>

              <section>
                <h4 class="drawer__section">
                  <EsaIcon name="shield-check" size="sm" paths={SHIELD} />
                  Disciplines
                </h4>
                <div class="board">
                  {
                    cells(wa014).map(({ label, gate }) => (
                      <button type="button" class="board__cell board__cell--btn">
                        <span class="board__cellhead">
                          <span class="board__dim">{label}</span>
                          <span class="board__chev"><EsaIcon name="chevron-right" size="sm" paths={CHEVRON} /></span>
                        </span>
                        {gate ? (
                          <BcnStatusChip status={gate.status} label={meta(gate.status).label} hex={meta(gate.status).hex} />
                        ) : (
                          <span class="unreviewed">Not reviewed</span>
                        )}
                        <span class="board__meta">{gateWhen(gate)}</span>
                      </button>
                    ))
                  }
                </div>
              </section>

              <div class="drawer__more">
                <EsaCollapsible title="Notes (1)" flush icon="quote" iconPaths={QUOTE}>
                  <blockquote class="note">{wa014.biologistNote}</blockquote>
                </EsaCollapsible>
                <EsaCollapsible title="Activity" flush icon="history" iconPaths={HISTORY}>
                  <p class="empty">No changes this session.</p>
                </EsaCollapsible>
              </div>
            </div>
            <footer class="drawer__foot">
              <EsaButton color="ghost" appearance="outline" size="md">Edit site details</EsaButton>
            </footer>
          </article>
        </figure>
      </div>

      <h3 class="v2__sub">The discipline child drawer — stacked over the parent</h3>
      <figure class="mockup mockup--stack">
        <figcaption class="mockup__case">
          DCTR2-DH-010 · clicking the Biological cell (count "2") opens its review history as a child drawer
          stacked over the parent — the parent slides aside and dims behind it, exactly as the permit
          workspace stacks its permit editor over the segment drawer.
        </figcaption>
        <div class="stack">
          <!-- Parent drawer (under card — dimmed, peeking out at the left) -->
          <article class="drawer stack__parent">
            <header class="drawer__head">
              <div class="drawer__headrow">
                <h4 class="drawer__title">{wa010.id}</h4>
                <BcnStatusChip status={st010} label={meta(st010).label} hex={meta(st010).hex} />
              </div>
              <p class="drawer__sub">{wa010.segment} · {wa010.constructionPackage}</p>
            </header>
            <div class="band band--4">
              <BcnKeyValue label="Notification" value={formatDate(wa010.notificationDate)} />
              <BcnKeyValue label="Clearance visit" value={formatDate(wa010.clearanceVisitDate)} />
              <BcnKeyValue label="Planned start" value={formatDate(wa010.plannedStartDate)} />
              <BcnKeyValue label="Blocked until">
                <span class="band__alert">{formatDate(until010)}</span>
              </BcnKeyValue>
            </div>
            <div class="drawer__body">
              <div class="decide decide--blocked">
                <p class="decide__line">
                  Blocked through {formatDate(until010)} — est. {daysUntil(until010)} more days · re-survey
                  {formatDate(RESURVEY)}
                </p>
              </div>

              <section>
                <h4 class="drawer__section">
                  <EsaIcon name="shield-check" size="sm" paths={SHIELD} />
                  Disciplines
                </h4>
                <div class="board">
                  {
                    cells(wa010).map(({ dim, label, gate }) => (
                      <button type="button" class="board__cell board__cell--btn" data-active={dim === 'biological' ? 'true' : undefined}>
                        <span class="board__cellhead">
                          <span class="board__dim">{label}</span>
                          {(counts010[dim] ?? 1) > 1 && <EsaBadge value={counts010[dim]} variant="secondary" size="sm" />}
                          <span class="board__chev"><EsaIcon name="chevron-right" size="sm" paths={CHEVRON} /></span>
                        </span>
                        {gate ? (
                          <BcnStatusChip status={gate.status} label={meta(gate.status).label} hex={meta(gate.status).hex} />
                        ) : (
                          <span class="unreviewed">Not reviewed</span>
                        )}
                        <span class="board__meta">{gateWhen(gate)}</span>
                      </button>
                    ))
                  }
                </div>
              </section>

              <div class="drawer__more">
                <EsaCollapsible title="Buffer conflicts (1)" flush icon="alert-triangle" iconPaths={ALERT}>
                  <ul class="rows">
                    <li class="conflict">
                      <span class="conflict__main">
                        {swha.species}
                        <span class="conflict__sub">{swha.id} · {swha.bufferFt.toLocaleString()} ft buffer</span>
                      </span>
                      <span class="conflict__meta">
                        {swha010Dist.toLocaleString()} ft away
                        <span class="conflict__sub">est. end {formatDate(swha.estEndDate)}</span>
                      </span>
                    </li>
                  </ul>
                </EsaCollapsible>
                <EsaCollapsible title="Notes (1)" flush icon="quote" iconPaths={QUOTE}>
                  <blockquote class="note">{wa010.biologistNote}</blockquote>
                </EsaCollapsible>
                <EsaCollapsible title="Activity" flush icon="history" iconPaths={HISTORY}>
                  <p class="empty">No changes this session.</p>
                </EsaCollapsible>
              </div>
            </div>
            <footer class="drawer__foot">
              <EsaButton color="ghost" appearance="outline" size="md">Edit site details</EsaButton>
            </footer>
          </article>

          <!-- Child drawer (top card — the discipline's review history) -->
          <article class="drawer stack__child">
            <header class="drawer__head">
              <div class="drawer__headrow">
                <h4 class="drawer__title">Biological review</h4>
                <BcnStatusChip status={g010bio.status} label={meta(g010bio.status).label} hex={meta(g010bio.status).hex} />
                <span class="drawer__close"><EsaIconButton icon="x" label="Close review history" size="sm" /></span>
              </div>
              <p class="drawer__sub">{wa010.id} · the latest completed review sets this status</p>
            </header>
            <div class="drawer__body">
              <div class="child__bar">
                <span class="child__count">2 reviews</span>
                <EsaButton color="ghost" appearance="outline" size="sm">Add review</EsaButton>
              </div>
              <ol class="revs">
                <li class="rev" data-kind="scheduled">
                  <span class="rev__dot"></span>
                  <div class="rev__main">
                    <p class="rev__head">
                      Re-survey <span class="rev__when">scheduled {formatDate(RESURVEY)}</span>
                    </p>
                    <div class="rev__chiprow">
                      <BcnStatusChip
                        status="survey-scheduled"
                        label={meta('survey-scheduled').label}
                        hex={meta('survey-scheduled').hex}
                      />
                    </div>
                    <p class="rev__note">
                      Post-fledge confirmation visit — SWHA est. fledge {formatDate(until010)}. Reviewer not
                      yet assigned.
                    </p>
                  </div>
                </li>
                <li class="rev" data-kind="blocked">
                  <span class="rev__dot"></span>
                  <div class="rev__main">
                    <p class="rev__head">
                      Clearance survey
                      <span class="rev__when">{formatDate(g010bio.reviewDate)} · {g010bio.reviewer}</span>
                    </p>
                    <div class="rev__chiprow">
                      <BcnStatusChip status={g010bio.status} label={meta(g010bio.status).label} hex={meta(g010bio.status).hex} />
                      <span class="rev__until">until {formatDate(g010bio.blockedUntil)}</span>
                      <span class="rev__current">Sets current status</span>
                    </div>
                    <p class="rev__note">{g010bio.note}</p>
                  </div>
                </li>
              </ol>
            </div>
            <footer class="drawer__foot">
              <EsaButton color="ghost" appearance="outline" size="md">Close</EsaButton>
            </footer>
          </article>
        </div>
      </figure>

      <aside class="model-note">
        <p class="model-note__title">Data-model note (for productionizing)</p>
        <p class="model-note__text">
          Today's <code>ClearanceGate</code> holds one status per discipline — it cannot say "Blocked now,
          re-survey scheduled Sep 2." Productionizing v2 turns each discipline's gate into a per-discipline
          <strong>review list</strong> (date, kind — Clearance survey / Re-survey / Management determination —
          reviewer, outcome, notes/stipulations): the latest completed review derives the discipline's current
          status, and future reviews ride the history as scheduled. The fixture keeps its single-gate shape for
          now; the June → September story above is mocked statically in this specimen.
        </p>
      </aside>
    </section>

    <!-- ═══ How to evaluate (v2) ═══ -->
    <section class="evaluate" aria-labelledby="eval-title">
      <h2 class="evaluate__title" id="eval-title">How to evaluate v2</h2>
      <ol class="evaluate__list">
        <li>From a cold open, how fast do you know whether work can start — and what the single next action is?</li>
        <li>Are the dates you decide with — notification, visit, planned start, blocked-until — visible without
          opening anything?</li>
        <li>Does the stacked discipline drawer keep you oriented to the parent site?</li>
