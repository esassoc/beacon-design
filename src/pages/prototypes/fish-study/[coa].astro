---
// Fish Study — the detail / sketch page (one ITP Condition of Approval).
//
// The NARRATIVE projection of a single study record: the 9-field science-plan
// sketch in the main column, the CDFW review-comment cycle beneath it, and the
// structured facts (details, dependencies, deliverables, RACI roles, planning
// metrics) in the rail — all the SAME record the crosswalk grid and the gantt
// render elsewhere. Studies without a drafted sketch show an empty-state prompting
// authoring (most studies are tabular stubs awaiting their sketch — the plan-
// CREATION workflow).
//
// Static dynamic route: one page per COA via getStaticPaths over STUDIES.
import AppShell from '../../../layouts/AppShell.astro';
import PageLayout from '../../../layouts/PageLayout.astro';
import EsaButton from '@esa/ecology/esa-button.astro';
import EsaPill from '@esa/ecology/esa-pill.astro';
import EsaBadge from '@esa/ecology/esa-badge.astro';
import EsaEmptyState from '@esa/ecology/esa-empty-state.astro';
import EsaCollapsible from '@esa/ecology/esa-collapsible.astro';
import BcnStudySketch from '../../../components/bcn/BcnStudySketch.astro';
import BcnReviewThread from '../../../components/bcn/BcnReviewThread.astro';
import BcnKeyValue from '../../../components/bcn/BcnKeyValue.astro';
import BcnStatusChip from '../../../components/bcn/BcnStatusChip.astro';
import { STUDIES } from '../../../data/fish-studies';
import {
  CATEGORY_META,
  PLAN_STATUS_META,
  EXEC_STATUS_META,
  DELIVERABLE_STATUS_META,
  WORKSTREAM_META,
  type Study,
} from '../../../data/fish-model';
import { PHASE_META } from '../../../data/fish-schedule';
import { withBase } from '../../../lib/base';

export async function getStaticPaths() {
  return STUDIES.map((s) => ({ params: { coa: s.coaNumber }, props: { study: s } }));
}
interface Props {
  study: Study;
}
const { study } = Astro.props;
const s = study;

const plan = PLAN_STATUS_META[s.planStatus];
const exec = EXEC_STATUS_META[s.execStatus];
const indexHref = withBase('/prototypes/fish-studies');
const coaHref = (coa: string) => withBase(`/prototypes/fish-study/${coa}`);
const byCoa = new Map(STUDIES.map((x) => [x.coaNumber, x]));
const ICONS = {
  info: "<circle cx='12' cy='12' r='10'/><path d='M12 16v-4'/><path d='M12 8h.01'/>",
  link: "<path d='M9 17H7A5 5 0 0 1 7 7h2'/><path d='M15 7h2a5 5 0 1 1 0 10h-2'/><line x1='8' x2='16' y1='12' y2='12'/>",
  file: "<path d='M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z'/><path d='M14 2v5h5'/>",
  users: "<path d='M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2'/><circle cx='9' cy='7' r='4'/><path d='M22 21v-2a4 4 0 0 0-3-3.87'/>",
  gauge: "<path d='m12 14 4-4'/><path d='M3.34 19a10 10 0 1 1 17.32 0'/>",
};

// flask-conical isn't in esa-icon's registry — pass the Lucide paths to the nav.
const FLASK =
  '<path d="M14 2v6a2 2 0 0 0 .245.96l5.51 10.08A2 2 0 0 1 18 22H6a2 2 0 0 1-1.755-2.96l5.51-10.08A2 2 0 0 0 10 8V2"/><path d="M6.453 15h11.094"/><path d="M8.5 2h7"/>';

// Sidebar nav — Science Plan active (detail is under it).
const fishNav = [
  { id: 'project', title: 'Project', icon: 'layout-dashboard', expanded: false, items: [{ id: 'dashboard', label: 'Dashboard' }] },
  {
    id: 'studies', title: 'Studies', icon: 'flask-conical', iconPaths: FLASK, expanded: true, active: true, dividerAfter: true,
    items: [{ id: 'science-plan', label: 'Science Plan', active: true }],
  },
  { id: 'tracking', title: 'Tracking', icon: 'radar', expanded: false, items: [{ id: 'project-tracking', label: 'Project Tracking' }] },
];
---

<!-- manifest:
  layout: stack
  sections:
    - identity header  -> esa-pill           # COA / name / plan + exec status chips (in PageLayout title)
    - sketch body      -> bcn-study-sketch    # the 9-field science-plan sketch (or esa-empty-state stub)
    - agency review    -> bcn-review-thread   # the CDFW comment cycle, pinned per field
    - details rail     -> esa-collapsible     # BcnKeyValue rows: category / type / lead / agencies / phases
    - dependencies     -> esa-collapsible     # informs / informed-by COA links + regulatory refs
    - deliverables     -> esa-collapsible     # deliverable lifecycle with BcnStatusChip
    - roles (RACI)     -> esa-collapsible     # work-stream → org / person assignments
-->

<AppShell title={`COA ${s.coaNumber} — ${s.name}`} tenantName="DWR" projectName="Delta Conveyance" navSections={fishNav}>
  <PageLayout
    title={s.name}
    icon="flask-conical"
    breadcrumbs={[
      { label: 'Delta Conveyance', href: '#project' },
      { label: 'Science Plan', href: indexHref },
      { label: `COA ${s.coaNumber}` },
    ]}
  >
    <span slot="title-badge" class="bcn-study__badges">
      <span class="bcn-study__coa">COA {s.coaNumber}</span>
      <BcnStatusChip status={s.planStatus} label={plan.label} hex={plan.hex} />
      <BcnStatusChip status={s.execStatus} label={exec.label} hex={exec.hex} />
    </span>
    <div slot="utilities" class="bcn-study__utils">
      <EsaButton color="ghost" appearance="outline" size="sm" icon="file-text">Generate sketch (.docx)</EsaButton>
      <EsaButton color="primary" size="sm" icon="upload">Submit for CDFW review</EsaButton>
    </div>

    <div class="bcn-study">
      <!-- ── Main column: sketch + agency review ── -->
      <main class="bcn-study__main">
        {s.sketch ? (
          <BcnStudySketch sketch={s.sketch} species={s.focalSpecies} />
        ) : (
          <EsaEmptyState
            title="Sketch not yet drafted"
            description="This study is tracked in the crosswalk and schedule, but its 9-field science-plan sketch hasn't been authored yet. Draft it to include the study in the next plan export to CDFW."
          >
            <EsaButton slot="action" color="primary" icon="plus">Draft study sketch</EsaButton>
          </EsaEmptyState>
        )}

        {(s.reviewComments?.length ?? 0) > 0 && <BcnReviewThread comments={s.reviewComments!} />}
      </main>

      <!-- ── Rail: structured facts (the crosswalk + roles + planning, per study) ── -->
      <aside class="bcn-study__rail">
        <EsaCollapsible icon="info" iconPaths={ICONS.info} title="Details" open>
          <BcnKeyValue label="Category" value={CATEGORY_META[s.category].label} />
          <BcnKeyValue label="Study type" value={s.method ? `${s.studyProgram} — ${s.method}` : s.studyProgram} />
          <BcnKeyValue label="DCP lead" value={s.dcpLead} />
          <BcnKeyValue label="Agency participants" value={s.agencies.join(', ')} />
          <BcnKeyValue label="Timeframe" value={s.timeframe} />
          <div class="bcn-study__kv">
            <span class="bcn-study__kv-label">DCP phases</span>
            <span class="bcn-study__chips">
              {s.phases.map((p) => <EsaPill label={PHASE_META[p].short} removable={false} size="sm" />)}
            </span>
          </div>
        </EsaCollapsible>

        <EsaCollapsible icon="link" iconPaths={ICONS.link} title="Dependencies & references" open>
          <div class="bcn-study__kv">
            <span class="bcn-study__kv-label">Informed by</span>
            {s.informedBy.length ? (
              <span class="bcn-study__chips">
                {s.informedBy.map((c) => (byCoa.has(c)
                  ? <a class="bcn-study__coa-link" href={coaHref(c)}>{c}</a>
                  : <span class="bcn-study__coa-ref">{c}</span>))}
              </span>
            ) : <span class="bcn-study__empty">None</span>}
          </div>
          <div class="bcn-study__kv">
            <span class="bcn-study__kv-label">Informs</span>
            {s.informs.length ? (
              <span class="bcn-study__chips">
                {s.informs.map((c) => (byCoa.has(c)
                  ? <a class="bcn-study__coa-link" href={coaHref(c)}>{c}</a>
                  : <span class="bcn-study__coa-ref">{c}</span>))}
              </span>
            ) : <span class="bcn-study__empty">None</span>}
          </div>
          {s.regulatoryRefs.length > 0 && (
            <div class="bcn-study__kv">
              <span class="bcn-study__kv-label">ITP cross-references</span>
              <span class="bcn-study__chips">
                {s.regulatoryRefs.map((r) => <span class="bcn-study__coa-ref">{r}</span>)}
              </span>
            </div>
          )}
        </EsaCollapsible>

        <EsaCollapsible icon="file-text" iconPaths={ICONS.file} title={`Deliverables (${s.deliverables.length})`} open>
          {s.deliverables.length ? (
            <ul class="bcn-study__deliv">
              {s.deliverables.map((d) => {
                const m = DELIVERABLE_STATUS_META[d.status];
                return (
                  <li class="bcn-study__deliv-row">
                    <span class="bcn-study__deliv-name">{d.type}</span>
                    <BcnStatusChip status={d.status} label={m.label} hex={m.hex} />
                  </li>
                );
              })}
            </ul>
          ) : <span class="bcn-study__empty">No deliverables listed.</span>}
        </EsaCollapsible>

        {s.roles.length > 0 && (
          <EsaCollapsible icon="users" iconPaths={ICONS.users} title="Roles & responsibilities">
            <ul class="bcn-study__roles">
              {s.roles.map((r) => (
                <li class="bcn-study__role-row">
                  <span class="bcn-study__role-stream">{WORKSTREAM_META[r.workstream].label}</span>
                  <span class="bcn-study__role-org">
                    {r.org}{r.person && <span class="bcn-study__role-person"> · {r.person}</span>}
                    {r.tentative && <EsaBadge variant="secondary" size="sm" value="tentative" />}
                  </span>
                </li>
              ))}
            </ul>
          </EsaCollapsible>
        )}

        <EsaCollapsible icon="gauge" iconPaths={ICONS.gauge} title="Planning">
          {(s.planning.studyPlanDue || s.planning.complexity || s.planning.peakFte || s.planning.budgetMagnitude) ? (
            <>
              {s.planning.studyPlanDue && <BcnKeyValue label="Study plan due" value={s.planning.studyPlanDue} />}
              {s.planning.complexity != null && <BcnKeyValue label="Complexity (1–10)" value={String(s.planning.complexity)} />}
              {s.planning.peakFte != null && <BcnKeyValue label="Peak staff (FTE)" value={String(s.planning.peakFte)} />}
              {s.planning.budgetMagnitude && <BcnKeyValue label="Budget magnitude" value={s.planning.budgetMagnitude} />}
            </>
          ) : <span class="bcn-study__empty">Not yet sized.</span>}
        </EsaCollapsible>
      </aside>
    </div>
  </PageLayout>
</AppShell>

<style>
  /* bcn-lego-checked: PAGE-COMPOSITION GLUE ONLY — the two-column main+rail layout,
     the title badge cluster, and the rail's small key/value + chip rows. Every
     section body is a component (BcnStudySketch / BcnReviewThread / esa-collapsible
     holding BcnKeyValue / BcnStatusChip / esa-pill). Checked esa-* (no study-detail
     layout lego) and Beacon. No reinvented primitive. */

  .bcn-study__badges { display: inline-flex; align-items: center; gap: var(--spacing-200); flex-wrap: wrap; }
  .bcn-study__coa { font-family: var(--font-mono); font-size: var(--type-size-100); font-weight: var(--font-weight-semibold); color: var(--color-text-tertiary); }
  .bcn-study__utils { display: inline-flex; align-items: center; gap: var(--spacing-200); }

  .bcn-study { display: grid; grid-template-columns: minmax(0, 1fr) 360px; gap: var(--spacing-600); align-items: start; }
  .bcn-study__main { display: flex; flex-direction: column; gap: var(--spacing-700); min-width: 0; }
  .bcn-study__rail { display: flex; flex-direction: column; gap: var(--spacing-300); min-width: 0; }

  /* rail key/value + chips (small, matches BcnKeyValue) */
  .bcn-study__kv { display: flex; flex-direction: column; gap: var(--spacing-150); }
  .bcn-study__kv-label { font-size: var(--form-font-size-md); font-weight: var(--font-weight-medium); color: var(--form-label-color); }
  .bcn-study__chips { display: flex; flex-wrap: wrap; gap: var(--spacing-150); }
  .bcn-study__empty { font-size: var(--type-size-100); color: var(--color-text-tertiary); font-style: italic; }

  .bcn-study__coa-link, .bcn-study__coa-ref {
    display: inline-flex; align-items: center;
    font-family: var(--font-mono); font-size: 0.75rem; font-weight: var(--font-weight-semibold);
    padding: 1px var(--spacing-200); border-radius: var(--radius-100);
    background: var(--color-surface-sunken); border: 1px solid var(--color-border);
  }
  .bcn-study__coa-link { color: var(--color-primary); text-decoration: none; }
  .bcn-study__coa-link:hover { background: var(--color-primary-subtle); border-color: var(--color-primary-border); }
  .bcn-study__coa-ref { color: var(--color-text-tertiary); }

  .bcn-study__deliv, .bcn-study__roles { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--spacing-200); }
  .bcn-study__deliv-row { display: flex; align-items: center; justify-content: space-between; gap: var(--spacing-200); }
  .bcn-study__deliv-name { font-size: var(--type-size-100); color: var(--color-text-primary); }
  .bcn-study__role-row { display: flex; flex-direction: column; gap: 1px; padding-bottom: var(--spacing-150); border-bottom: 1px solid var(--color-border-light); }
  .bcn-study__role-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .bcn-study__role-stream { font-size: var(--type-size-100); font-weight: var(--font-weight-semibold); color: var(--color-text-secondary); }
  .bcn-study__role-org { display: inline-flex; align-items: center; gap: var(--spacing-150); font-size: var(--type-size-100); color: var(--color-text-primary); }
  .bcn-study__role-person { color: var(--color-text-tertiary); }

  @media (max-width: 900px) {
    .bcn-study { grid-template-columns: 1fr; }
  }
</style>
