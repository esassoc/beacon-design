---
// Fish Studies — the MULTI-LEVEL TASKING GANTT (second fish-study prototype).
//
// The 7/8 data-model decision gave fish-study compliance its own module built on a
// recursive hierarchy. This page socializes that model (for Gardner + Chris Geech)
// as a four-tier WORK BREAKDOWN — Program → Study → Sub-study → Task — where:
//   • the TASK is the schedulable month-by-month unit (a status-colored bar on the
//     water-year axis), and status / funding / span roll UP to the parents;
//   • every node is editable (add / rename / reparent / delete at all four tiers);
//   • stable type-prefixed IDs (PRG/STY/SUB/TSK) are identity, the COA dot-number a
//     secondary reference; there is NO dependency dimension in this view;
//   • clicking a row opens its EDIT drawer — Date range, Budget, Status (tasks)
//     plus Add-child / Delete — the slim write surface. Name + ID editing and the
//     full record (COA reference, parent, owner, water years, roll-up meter,
//     constraints/notes) live on the node DETAILS page (/prototypes/fish-node?id=…)
//     behind the drawer's "View full details" link.
// The same fish-schedule.ts calendar rules (water-year deadlines, half-year field
// seasons) drive the axis. Dollar/status content is illustrative fixture data.
import AppShell from '../../layouts/AppShell.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import EsaButton from '@esa/ecology/esa-button.astro';
import BcnWorkBreakdown from '../../components/bcn/BcnWorkBreakdown.astro';
import BcnNodeEdit from '../../components/bcn/BcnNodeEdit.astro';
import { PROGRAMS } from '../../data/fish-hierarchy';
import { computeRollUp, flattenForest, TIER_META, PROJECT_NAME, type HierNode } from '../../data/fish-model';
import { withBase } from '../../lib/base';

const TODAY = '2029-06-15';

const flat = flattenForest(PROGRAMS);

// One SSR edit panel per node — toggled into the drawer on wb-node-select.
const nodePanels = flat.map(({ node }) => ({
  node,
  rollup: computeRollUp(node),
}));

// Blank panel templates cloned client-side for nodes ADDED after load (the CRUD
// layer). The branch template carries one pseudo-child so the funding table's
// Own/Rolled-up split renders; the sync script re-derives every value (labels,
// fields, details link) once the panel is bound.
const TPL_TASK: HierNode = { id: '', tier: 'task', name: '', status: 'not-started', funding: [], children: [] };
const TPL_BRANCH: HierNode = { id: '', tier: 'study', name: '', funding: [], children: [TPL_TASK] };

const FLASK =
  '<path d="M14 2v6a2 2 0 0 0 .245.96l5.51 10.08A2 2 0 0 1 18 22H6a2 2 0 0 1-1.755-2.96l5.51-10.08A2 2 0 0 0 10 8V2"/><path d="M6.453 15h11.094"/><path d="M8.5 2h7"/>';

const fishNav = [
  { id: 'project', title: 'Project', icon: 'layout-dashboard', iconPaths: '<rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/>', expanded: false, items: [{ id: 'dashboard', label: 'Dashboard' }] },
  {
    id: 'studies', title: 'Studies', icon: 'flask-conical', iconPaths: FLASK, expanded: true, active: true, dividerAfter: true,
    items: [
      { id: 'science-plan', label: 'Science Plan', href: withBase('/prototypes/fish-studies') },
      { id: 'tasking-gantt', label: 'Study Planning', active: true },
    ],
  },
  { id: 'tracking', title: 'Tracking', icon: 'radar', expanded: false, items: [{ id: 'project-tracking', label: 'Project Tracking' }] },
];
---

<!-- manifest:
  layout: stack
  sections:
    - header utilities       -> esa-button            # Science Plan crosswalk link in the PageLayout utilities slot
    - work-breakdown gantt    -> bcn-work-breakdown    # recursive 4-tier tree + month timeline + roll-up bars + CRUD
    - node edit drawer        -> esa-side-dialog        # row side-panel container
    - node edit body          -> bcn-node-edit          # date range / budget / status (tasks) + add-child / delete / details link
-->

<AppShell title={`${PROJECT_NAME} — Study Planning`} tenantName="DWR" projectName="Delta Conveyance" navSections={fishNav}>
  <PageLayout
    title="Study Planning"
    icon="flask-conical"
    breadcrumbs={[{ label: 'Delta Conveyance', href: '#project' }, { label: 'Studies', href: '#studies' }, { label: 'Study Planning' }]}
  >
    <div slot="utilities" class="bcn-gantt-utils">
      <EsaButton href={withBase('/prototypes/fish-studies')} color="ghost" appearance="outline" size="md" icon="table">Science Plan crosswalk</EsaButton>
    </div>

    <!-- ═══ The four-tier tasking gantt ═══
         bcn-lego-checked: PAGE-COMPOSITION GLUE ONLY. The tree is bcn-work-breakdown;
         the drawer body is bcn-node-edit. Every section resolves to a component (see
         manifest). Checked esa-* (no 4-tier gantt lego, no node-panel lego) and Beacon.
         Page CSS is drawer-chrome glue. -->
    <BcnWorkBreakdown programs={PROGRAMS} today={TODAY} />
  </PageLayout>

  <!-- ═══ Node-edit drawer — Date range / Budget / Status (tasks) + actions ═══ -->
  <esa-side-dialog id="node-drawer" size="md" style="--z-modal: 1300; --z-modal-backdrop: 1250;">
    <div slot="header" class="bcn-node-head">
      <span class="bcn-node-head__id" id="node-id">—</span>
      <span class="bcn-node-head__title" id="node-title">Select a node</span>
    </div>

    <div class="bcn-node-body">
      {
        nodePanels.map(({ node, rollup }) => (
          <section data-node-panel={node.id} data-node-name={node.name} data-node-tier={TIER_META[node.tier].label} hidden>
            <BcnNodeEdit node={node} rollup={rollup} />
          </section>
        ))
      }
      <template id="bcn-panel-tpl-task">
        <section data-node-panel="" data-node-name="" hidden>
          <BcnNodeEdit node={TPL_TASK} rollup={computeRollUp(TPL_TASK)} />
        </section>
      </template>
      <template id="bcn-panel-tpl-branch">
        <section data-node-panel="" data-node-name="" hidden>
          <BcnNodeEdit node={TPL_BRANCH} rollup={computeRollUp(TPL_BRANCH)} />
        </section>
      </template>
    </div>

    <span slot="footer" class="bcn-node-foot">
      <span id="node-close"><EsaButton color="primary">Close</EsaButton></span>
    </span>
  </esa-side-dialog>
</AppShell>

<script>
  import '@esa/ecology/esa-side-dialog';
  import type { HierNode, NodeRollUp } from '../../data/fish-model';

  type WbApi = {
    getNode(id: string): HierNode | undefined;
    allNodes(): HierNode[];
    planRollup(): NodeRollUp;
    tierCounts(): { programs: number; studies: number };
  };
  const getApi = (): WbApi | undefined =>
    (document.querySelector('.bcn-wb') as (HTMLElement & { wbApi?: WbApi }) | null)?.wbApi;

  const drawer = document.getElementById('node-drawer') as HTMLElement & { show(): void; close(): void };
  const idEl = document.getElementById('node-id')!;
  const titleEl = document.getElementById('node-title')!;
  const panelHost = document.querySelector<HTMLElement>('.bcn-node-body')!;
  const panels = () => [...panelHost.querySelectorAll<HTMLElement>('[data-node-panel]')];

  document.addEventListener('wb-node-select', (e) => {
    const id = (e as CustomEvent).detail?.id as string;
    const panel = panels().find((p) => p.dataset.nodePanel === id);
    if (!panel) return;
    panels().forEach((p) => (p.hidden = p !== panel));
    idEl.textContent = id;
    titleEl.textContent = panel.dataset.nodeName ?? id;
    drawer.show();
  });

  // wbApi.setId re-keys the model (ID editing now lives on the details page;
  // the machinery stays for any caller) — move the node's panel to the new
  // key BEFORE the recompute broadcast so reconciliation keeps (not replaces) it.
  document.addEventListener('wb-node-id-change', (e) => {
    const { oldId, newId } = ((e as CustomEvent).detail ?? {}) as { oldId?: string; newId?: string };
    if (!oldId || !newId) return;
    const panel = panels().find((p) => p.dataset.nodePanel === oldId);
    if (!panel) return;
    panel.dataset.nodePanel = newId;
    if (!panel.hidden) idEl.textContent = newId;
  });

  document.getElementById('node-close')!.addEventListener('click', () => drawer.close());
  // The lego's own Esc handler only hears keydown when focus is inside the dialog;
  // close from anywhere so an open drawer never traps the page.
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') drawer.close();
  });

  // ── Panel reconciliation: nodes added by the CRUD layer get a cloned blank
  //    panel; panels for deleted nodes are removed (closing the drawer if open).
  const tplTask = document.getElementById('bcn-panel-tpl-task') as HTMLTemplateElement;
  const tplBranch = document.getElementById('bcn-panel-tpl-branch') as HTMLTemplateElement;
  function reconcilePanels() {
    const api = getApi();
    if (!api) return;
    const nodes = api.allNodes();
    const ids = new Set(nodes.map((n) => n.id));
    for (const p of panels()) {
      if (!ids.has(p.dataset.nodePanel ?? '')) {
        if (!p.hidden) drawer.close();
        p.remove();
      }
    }
    for (const n of nodes) {
      let panel = panelHost.querySelector<HTMLElement>(`[data-node-panel="${n.id}"]`);
      if (!panel) {
        const tpl = n.tier === 'task' ? tplTask : tplBranch;
        panel = (tpl.content.firstElementChild as HTMLElement).cloneNode(true) as HTMLElement;
        panel.dataset.nodePanel = n.id;
        panel.hidden = true;
        panelHost.appendChild(panel);
      }
      panel.dataset.nodeName = n.name;
    }
    // Refresh the drawer chrome if the open node was renamed.
    const open = panels().find((p) => !p.hidden);
    if (open) {
      idEl.textContent = open.dataset.nodePanel ?? '';
      titleEl.textContent = open.dataset.nodeName ?? '';
    }
  }

  document.addEventListener('wb-model-change', () => {
    reconcilePanels();
  });
</script>

<style>
  /* bcn-lego-checked: PAGE-COMPOSITION GLUE ONLY. The stat row wraps esa-stat legos;
     the tree is bcn-work-breakdown; the drawer body is bcn-node-edit. Every section
     resolves to a component (see manifest). Checked esa-* (no 4-tier gantt lego, no
     node-panel lego) and Beacon. No reinvented primitive; no raw form control. */



  .bcn-node-head { display: flex; align-items: center; gap: var(--spacing-200); flex-wrap: wrap; min-width: 0; }
  .bcn-node-head__id { flex-shrink: 0; font-family: var(--font-mono); font-size: var(--type-size-100); font-weight: var(--font-weight-semibold); color: var(--color-commitment); background: color-mix(in srgb, var(--color-commitment) 12%, white); padding: 1px var(--spacing-200); border-radius: var(--radius-100); }
  .bcn-node-head__title { font-family: var(--font-decorative); font-size: 1.125rem; font-weight: var(--font-weight-semibold); color: var(--color-text-primary); line-height: 1.25; min-width: 0; }

  /* The edit form fills the drawer body so the actions row sits at the bottom. */
  .bcn-node-body { display: flex; flex-direction: column; min-height: 100%; }
  .bcn-node-body [data-node-panel][hidden] { display: none; }
  .bcn-node-body [data-node-panel]:not([hidden]) { display: flex; flex-direction: column; flex: 1; }

  .bcn-node-foot { display: flex; align-items: center; justify-content: flex-end; width: 100%; }
  .bcn-node-foot a { text-decoration: none; }
</style>
