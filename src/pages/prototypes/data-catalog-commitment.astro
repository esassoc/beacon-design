---
// Data Catalog — Commitment detail (standard workflow). The PARENT entity page.
//
// Recomposes the prod Commitment detail (Overview + Requirements + Revision History
// tabs) into the Data Catalog family, matched to the canonical Source Document detail:
// identity header (ID badge · serif title · type badge · version chip), main + rail,
// a single lineage spine at the TOP of the rail, PDF drawer, single-pane upsert.
//
// The MAIN events:
//   · Full Commitment Text — the document-review serif treatment, bulleted as parsed;
//     each bullet ≈ one carved-out requirement.
//   · Requirements — ONE flat list (no phase grouping), with a keyword search + Phase +
//     Type filters and a single Add affordance. Each row prefixes the title with the
//     purple commitment-ID badge and carries a type badge + a neutral phase badge.
// The rail leads with Lineage (full Project → Source Document → Commitment → Requirements
// → Actions spine; current node = filled primary dot, child rollups = counted links),
// then Details, Related Data (rolled up from the child requirements), Associated
// Components, and Revisions (the prod Revision History version chain as a spine module
// with Add New Version + per-version Edit, both faithful to prod — no delete/revert/diff).
// A bottom danger zone deletes the commitment.
//
// COMPONENT MANIFEST: AppShell + PageLayout chrome; BcnKeyValue + BcnDangerZone + esa-*
// legos (EsaButton/Icon/Badge/Pill/Collapsible/IconLink/EmptyState, esa-file-list,
// esa-filter-container/dropdown/clear-button); the edit + revision modals are
// single-column esa-dialogs (esa-select / esa-text-field / esa-textarea / esa-input-tag /
// esa-date-picker / esa-file-upload); the source viewer is esa-side-dialog; delete
// confirms via esa-confirm-dialog (danger variant).
import AppShell from '../../layouts/AppShell.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import EsaButton from '@esa/ecology/esa-button.astro';
import EsaIcon from '@esa/ecology/esa-icon.astro';
import EsaBadge from '@esa/ecology/esa-badge.astro';
import EsaPill from '@esa/ecology/esa-pill.astro';
import EsaCollapsible from '@esa/ecology/esa-collapsible.astro';
import EsaIconLink from '@esa/ecology/esa-icon-link.astro';
import EsaEmptyState from '@esa/ecology/esa-empty-state.astro';
import FilterContainer from '@esa/ecology/esa-filter-container.astro';
import FilterClearButton from '@esa/ecology/esa-filter-clear-button.astro';
import BcnKeyValue from '../../components/bcn/BcnKeyValue.astro';
import BcnDangerZone from '../../components/bcn/BcnDangerZone.astro';
import { actions, PROJECT_NAME, SOURCE_DOCUMENT } from '../../data/tracker-fixture';
import { ICON_PATHS } from '../../components/bcn/requirement-reference';
import { withBase } from '../../lib/base';

const CHEVRON_RIGHT = "<path d='m9 18 6-6-6-6'/>";
const FOLDER = "<path d='M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z'/>";
const SCROLL_TEXT = "<path d='M15 12h-5'/><path d='M15 8h-5'/><path d='M19 17V5a2 2 0 0 0-2-2H4'/><path d='M8 21h12a2 2 0 0 0 2-2v-1a1 1 0 0 0-1-1H11a1 1 0 0 0-1 1v1a2 2 0 1 1-4 0V5a2 2 0 1 0-4 0v2a1 1 0 0 0 1 1h3'/>";
const LIST_TODO = "<rect x='3' y='5' width='6' height='6' rx='1'/><path d='m3 17 2 2 4-4'/><path d='M13 6h8'/><path d='M13 12h8'/><path d='M13 18h8'/>";
const RADAR = "<path d='M19.07 4.93A10 10 0 0 0 6.99 3.34'/><path d='M4 6h.01'/><path d='M2.29 9.62A10 10 0 1 0 21.31 8.35'/><path d='M16.24 7.76A6 6 0 1 0 8.23 16.67'/><path d='M12 18h.01'/><path d='M17.99 11.66A6 6 0 0 1 15.77 16.67'/><circle cx='12' cy='12' r='2'/><path d='m13.41 10.59 5.66-5.66'/>";
const GIT_BRANCH = "<line x1='6' x2='6' y1='3' y2='15'/><circle cx='18' cy='6' r='3'/><circle cx='6' cy='18' r='3'/><path d='M18 9a9 9 0 0 1-9 9'/>";
const HISTORY = "<path d='M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8'/><path d='M3 3v5h5'/><path d='M12 7v5l4 2'/>";
const COMPONENTS = "<rect width='7' height='7' x='3' y='3' rx='1'/><rect width='7' height='7' x='14' y='3' rx='1'/><rect width='7' height='7' x='14' y='14' rx='1'/><rect width='7' height='7' x='3' y='14' rx='1'/>";

const dataCatalogNav = [
  {
    id: 'data-catalog',
    title: 'Data Catalog',
    icon: 'database',
    expanded: true,
    active: true,
    items: [
      { id: 'dc-projects', label: 'Projects' },
      { id: 'dc-source-documents', label: 'Source Documents' },
      { id: 'dc-commitments', label: 'Commitments', active: true },
      { id: 'dc-requirements', label: 'Requirements' },
      { id: 'dc-actions', label: 'Actions' },
      { id: 'dc-components', label: 'Components' },
      { id: 'dc-evidence', label: 'Evidence of Compliance' },
    ],
  },
];

// ── The Commitment: MM-BIO-2 — parent of the Requirement detail prototype's record. ──
const commitmentId = 'MM-BIO-2';
const commitmentTitle = 'Nesting Birds and Raptors';
const commitmentType = 'Mitigation Measure';
const version = 'v.2';
const resourceCategory = 'Biological Resources';
const tags = ['CDFW', 'Wildlife'];
const generalGuidance =
  'Include the nesting-season survey and buffer requirements in contractor bid documents. Coordinate any buffer-zone reduction with CDFW before work proceeds inside an established buffer.';
const createdMeta = 'Created Jan 8, 2026 · Updated Jun 3, 2026';

// Full commitment text, bulleted as parsed — each bullet ≈ one carved-out requirement.
const commitmentSections = [
  {
    label: 'Pre-Construction Survey',
    text: 'If construction, ground-disturbing, or vegetation-removal activities would occur during the nesting season (February 1 – August 31), a qualified biologist shall conduct a pre-construction survey for nesting raptors and other migratory birds within 14 days prior to the start of those activities.',
  },
  {
    label: 'No-Disturbance Buffers',
    text: 'If active nests are found, the biologist shall establish appropriate no-disturbance buffer zones around each nest, to remain in place until young have fledged.',
  },
  {
    label: 'Work Within Buffer Zones',
    text: 'If work must occur within an established buffer zone, it shall proceed only under biological monitoring by the qualified biologist.',
  },
  {
    label: 'Reporting',
    text: 'A report of findings documenting any construction conducted within a no-disturbance buffer zone shall be submitted to the City.',
  },
];

// ── Requirements — ONE flat list (no phase grouping). The survey deep-links to the
//    Requirement detail prototype; siblings are catalog stubs. Each row carries its
//    phase + type so the filter bar can facet it client-side. ──
const requirementHref = withBase('/prototypes/data-catalog-requirement');
const requirements = [
  { name: 'Pre-construction survey for nesting raptors and other migratory birds during nesting season', type: 'Survey', phase: 'Pre-Construction', href: requirementHref },
  { name: 'If bird nests are found, establish no-disturbance buffer zones', type: 'Other', phase: 'Construction', href: '#data-catalog/requirements/mm-bio-2-buffers' },
  { name: 'If work must occur within established no-disturbance buffer zones', type: 'Other', phase: 'Construction', href: '#data-catalog/requirements/mm-bio-2-work-within' },
  { name: 'Report of findings for construction within any no-disturbance buffer zone', type: 'Reporting', phase: 'Post-Construction', href: '#data-catalog/requirements/mm-bio-2-report' },
];
const requirementsTotal = requirements.length;

// Actions rolled up under this commitment (fixture-computed) — the lineage tail count.
const actionsTotal = new Set(
  actions.filter((a) => a.commitment === commitmentId).map((a) => a.action).filter(Boolean),
).size;

// Related Data — rolled up from the child requirements (prod commitment roll-up).
const species = ['Nesting raptors', 'Migratory birds'];
const seasons = ['Nesting Bird Season (Feb 1 – Aug 31)'];
const constructionActivities = ['Ground disturbance', 'Vegetation removal'];

const files = ['feir-ch3.4_biological-resources.pdf', 'mmrp_mm-bio-2_excerpt.pdf'];
const associatedComponents = ['North Grading Area', 'South Grading Area'];

// Revisions — the prod Revision History version chain as a rail spine module (newest
// first). Each version carries the prod change-metadata (Originator / Effective Date /
// Summary) + author + create date. Capabilities mirror prod: Add New Version (create
// only) + Edit on the current version's metadata — NO delete, revert, or diff.
const revisions = [
  { label: 'Version 2', current: true, summary: 'DWR OGC review of Vol. 1, Submittal 1', originator: 'DWR Office of General Counsel', effectiveDate: 'Jun 1, 2026', effectiveISO: '2026-06-01', author: 'Leah McNearney', createdDate: 'Jun 1, 2026' },
  { label: 'Version 1', current: false, summary: 'Original FEIR language', originator: 'Original FEIR adoption', effectiveDate: 'Mar 6, 2026', effectiveISO: '2026-03-06', author: 'Mikey Knowles', createdDate: 'Mar 6, 2026' },
];

const sourceDocHref = withBase('/prototypes/data-catalog-source-document');
const actionsListHref = withBase('/prototypes/data-catalog-actions');

// Lineage — the full spine: ancestry (Project → Source Document → this Commitment, the
// current/filled node) then the commitment's child rollups (Requirements → Actions),
// each a counted link. All share the lineage line + icon treatment.
const lineage = [
  { kind: 'Project', kindHref: '#data-catalog/projects', name: PROJECT_NAME, href: '#data-catalog/projects/3600-alameda', icon: 'folder', paths: FOLDER, current: false },
  { kind: 'Source Document', kindHref: '#data-catalog/source-documents', name: SOURCE_DOCUMENT, href: sourceDocHref, icon: 'file-text', paths: undefined, current: false },
  { kind: 'Commitment', kindHref: '#data-catalog/commitments', name: `${commitmentId} — ${commitmentTitle}`, href: undefined, icon: 'scroll-text', paths: SCROLL_TEXT, current: true },
];
const lineageChildren = [
  { label: 'Requirements', count: requirementsTotal, href: requirementHref, icon: 'list-todo', paths: LIST_TODO },
  { label: 'Actions', count: actionsTotal, href: actionsListHref, icon: 'radar', paths: RADAR },
];

const sourcePdf = withBase('/source-docs/feir-sample.pdf');
const editPayload = {
  commitmentTitle,
  commitmentId,
  sourceDoc: SOURCE_DOCUMENT,
  commitmentType,
  resourceCategory,
  generalGuidance,
  tags,
  fullText: commitmentSections.map((s) => `${s.label}: ${s.text}`).join('\n\n'),
};
---

<!-- manifest:
  layout: stack(2xl)                          # page spine; identity header + commitment-text card are composition glue
  sections:
    - requirements          -> esa-filter-dropdown   # ONE flat list; keyword (esa-text-field) + Phase/Type filters + single Add (esa-icon-link); rows are glue; esa-empty-state on no match
    - files                 -> esa-file-list         # removable rows; each links to the source PDF (opens the viewer drawer)
    - lineage rail          -> esa-collapsible        # one spine: project -> source document -> commitment (current, filled dot) -> requirements/actions (counted links)
    - details rail          -> bcn-key-value          # type / resource category / general guidance / tags
    - related data rail     -> bcn-key-value          # species / seasons / construction activities (child roll-up)
    - components rail        -> esa-collapsible         # associated components list
    - revisions rail         -> esa-collapsible          # prod version chain; Add New Version (esa-button) + per-version Edit
    - edit commitment        -> esa-dialog               # single-column upsert (prod Edit Commitment field set)
    - add new version         -> esa-dialog               # prod create-version (originator/effective/summary + file upload)
    - edit version metadata   -> esa-dialog               # prod edit-metadata (no file upload)
    - source viewer           -> esa-side-dialog           # the source PDF in the family side drawer
    - delete                  -> bcn-danger-zone           # GitHub-layout danger zone
    - delete confirm          -> esa-confirm-dialog        # simple yes/no danger confirm (faithful to Beacon)
-->

<AppShell title={`${commitmentId} — Data Catalog`} projectName="Select a Project" navSections={dataCatalogNav}>
  <PageLayout
    title={commitmentTitle}
    breadcrumbs={[{ label: 'Data Catalog', href: '#data-catalog' }, { label: 'Commitments', href: '#data-catalog/commitments' }, { label: commitmentId }]}
  >
    <div class="bcn-cmt">
      <!-- Identity header — ID badge on top, serif title, type badge + version chip. -->
      <header class="bcn-cmt__head">
        <div class="bcn-cmt__identity">
          <span class="bcn-cmt__badge bcn-cmt__badge--commitment">{commitmentId}</span>
          <div class="bcn-cmt__title-row">
            <h1 class="bcn-cmt__title">{commitmentTitle}</h1>
            <span class="bcn-cmt__badge bcn-cmt__badge--type">{commitmentType}</span>
            <span class="bcn-cmt__badge bcn-cmt__badge--type">{version}</span>
          </div>
        </div>
        <div class="bcn-cmt__head-actions">
          <span id="edit-cmt"><EsaButton color="primary" size="sm"><span class="bcn-btn-ico"><EsaIcon name="pencil" size="xs" />Edit commitment</span></EsaButton></span>
        </div>
      </header>

      <div class="bcn-cmt__body">
        <div class="bcn-cmt__main">
          <!-- Full commitment text — serif regulatory voice, bulleted as parsed. -->
          <section class="bcn-cmt__section">
            <h2 class="bcn-section-title">Full Commitment Text</h2>
            <article class="bcn-cmttext">
              <ul class="bcn-cmttext__list">
                {commitmentSections.map((s) => (
                  <li class="bcn-cmttext__item"><strong>{s.label}:</strong> {s.text}</li>
                ))}
              </ul>
              <footer class="bcn-cmttext__footer">
                <span data-bcn-source><EsaButton color="ghost" size="sm" icon="file-text">View in Source Document</EsaButton></span>
              </footer>
            </article>
          </section>

          <!-- Requirements — one flat list, single Add, keyword + Phase + Type filters. -->
          <section class="bcn-cmt__section">
            <header class="bcn-cmt__section-head">
              <h2 class="bcn-section-title">Requirements <span class="bcn-count-neutral"><EsaBadge size="sm" value={requirementsTotal} /></span></h2>
              <EsaIconLink href="#add-requirement" icon="plus" size="sm" weight="medium">Add requirement</EsaIconLink>
            </header>

            <div class="bcn-reqfilters">
              <esa-text-field id="req-search" placeholder="Search requirements…" size="md"></esa-text-field>
              <div class="bcn-reqfilters__row">
                <FilterContainer>
                  <esa-filter-dropdown id="flt-phase" label="Phase" size="sm"></esa-filter-dropdown>
                  <esa-filter-dropdown id="flt-type" label="Type" size="sm"></esa-filter-dropdown>
                </FilterContainer>
                <span id="req-clear-filters"><FilterClearButton /></span>
              </div>
            </div>

            <ul class="bcn-row-list" id="req-list">
              {requirements.map((r) => (
                <li class="bcn-row-li" data-name={r.name.toLowerCase()} data-phase={r.phase} data-type={r.type}>
                  <a class="bcn-row" href={r.href}>
                    <span class="bcn-cmt__badge bcn-cmt__badge--commitment">{commitmentId}</span>
                    <span class="bcn-row__name">{r.name}</span>
                    <span class="bcn-cmt__badge bcn-cmt__badge--type">{r.type}</span>
                    <span class="bcn-cmt__badge bcn-cmt__badge--phase">{r.phase}</span>
                    <EsaIcon name="chevron-right" size="sm" paths={CHEVRON_RIGHT} />
                  </a>
                </li>
              ))}
            </ul>
            <div class="bcn-reqs__empty" id="req-empty" hidden>
              <EsaEmptyState title="No requirements match your filters" size="sm" />
            </div>
          </section>

          <section class="bcn-cmt__section">
            <h2 class="bcn-section-title">Files <span id="cmt-files-count" class="bcn-count-neutral"><EsaBadge size="sm" value={files.length} /></span></h2>
            <esa-file-list id="cmt-files" removable data-src={sourcePdf}></esa-file-list>
          </section>
        </div>

        <aside class="bcn-cmt__rail">
          <!-- Lineage leads the rail — one spine: ancestry (Project → Source Document →
               this Commitment, the current filled node) then child rollups. -->
          <EsaCollapsible icon="git-branch" iconPaths={GIT_BRANCH} title="Lineage" open>
            <ol class="bcn-lineage">
              {lineage.map((n) => (
                <li class={`bcn-lineage__node${n.current ? ' bcn-lineage__node--current' : ''}`}>
                  <span class="bcn-lineage__icon"><EsaIcon name={n.icon} size="sm" paths={n.paths} /></span>
                  <span class="bcn-lineage__body">
                    <a class="bcn-lineage__kind" href={n.kindHref}>{n.kind}</a>
                    {n.href ? <a class="bcn-lineage__name" href={n.href}>{n.name}</a> : <span class="bcn-lineage__name bcn-lineage__name--current">{n.name}</span>}
                  </span>
                </li>
              ))}
              {lineageChildren.map((c) => (
                <li class="bcn-lineage__node bcn-lineage__node--child">
                  <span class="bcn-lineage__icon"><EsaIcon name={c.icon} size="sm" paths={c.paths} /></span>
                  <span class="bcn-lineage__body">
                    <a class="bcn-lineage__name" href={c.href}>{c.label}</a>
                  </span>
                  <span class="bcn-count-neutral"><EsaBadge size="sm" value={c.count} /></span>
                </li>
              ))}
            </ol>
          </EsaCollapsible>

          <EsaCollapsible icon="info" title="Details" open>
            <BcnKeyValue label="Type" value={commitmentType} />
            <BcnKeyValue label="Resource Category" value={resourceCategory} />
            <BcnKeyValue label="General Guidance" value={generalGuidance} />
            <BcnKeyValue label="Tags">
              <span class="bcn-tagrow">
                {tags.map((t) => <EsaPill label={t} size="sm" removable={false} />)}
              </span>
            </BcnKeyValue>
            <p class="bcn-rail-meta">{createdMeta}</p>
          </EsaCollapsible>

          <EsaCollapsible icon="layers" iconPaths={ICON_PATHS.layers} title="Related Data" open>
            <BcnKeyValue label="Species" value={species.join(', ')} />
            <BcnKeyValue label="Seasons" value={seasons.join(', ')} />
            <BcnKeyValue label="Construction Activities" value={constructionActivities.join(', ')} />
          </EsaCollapsible>

          <EsaCollapsible icon="grid" iconPaths={COMPONENTS} title="Associated Components" open>
            <ul class="bcn-lists">
              {associatedComponents.map((c) => <li><a class="bcn-list-link" href="#data-catalog/components">{c}</a></li>)}
            </ul>
          </EsaCollapsible>

          <!-- Revisions — the prod Revision History version chain. Add New Version +
               per-version Edit (current only); no delete/revert/diff (faithful to prod). -->
          <EsaCollapsible icon="history" iconPaths={HISTORY} title="Revisions" open>
            <ol class="bcn-lineage bcn-revs">
              {revisions.map((r) => (
                <li class={`bcn-lineage__node${r.current ? ' bcn-lineage__node--current' : ''}`}>
                  <span class="bcn-lineage__icon"><EsaIcon name="history" size="sm" paths={HISTORY} /></span>
                  <span class="bcn-lineage__body">
                    <span class="bcn-revs__head">
                      <span class="bcn-lineage__kind">{r.label}{r.current ? ' · Current' : ''}</span>
                      {r.current && (
                        <button
                          type="button"
                          class="bcn-revs__edit"
                          data-edit-rev
                          data-originator={r.originator}
                          data-effective={r.effectiveISO}
                          data-summary={r.summary}
                        >Edit</button>
                      )}
                    </span>
                    <span class="bcn-revs__summary">{r.summary}</span>
                    <span class="bcn-revs__meta">Originator: {r.originator}</span>
                    <span class="bcn-revs__meta">Effective {r.effectiveDate}</span>
                    <span class="bcn-revs__by">Created by {r.author} on {r.createdDate}</span>
                  </span>
                </li>
              ))}
            </ol>
            <div class="bcn-revs__add">
              <span id="add-rev"><EsaButton color="ghost" appearance="outline"><span class="bcn-btn-ico"><EsaIcon name="plus" size="xs" />Add New Version</span></EsaButton></span>
            </div>
          </EsaCollapsible>
        </aside>
      </div>

      <!-- Danger zone — GitHub layout; opens a simple confirm, matching prod. -->
      <BcnDangerZone title="Delete this commitment" description="Deleting this commitment also deletes all requirements and actions defined under it. This action cannot be undone.">
        <span id="delete-cmt"><EsaButton color="danger" appearance="soft">Delete commitment</EsaButton></span>
      </BcnDangerZone>
    </div>
  </PageLayout>

  <!-- ═══ Edit Commitment MODAL — single-column form (prod field set). ═══ -->
  <esa-dialog id="edit-dialog" heading="Edit Commitment" style="--_dialog-width: 760px; --_dialog-max-height: 92vh; --_dialog-bg: var(--color-surface, #fff); --z-modal-backdrop: 1150; --z-modal: 1200;">
    <div class="bcn-form bcn-form--dialog">
      <esa-text-field id="c-title" label="Title" required></esa-text-field>
      <div class="bcn-grid-2">
        <esa-text-field id="c-id" label="Commitment ID" required></esa-text-field>
        <esa-select id="c-doc" label="Source Document" required></esa-select>
      </div>
      <div class="bcn-grid-2">
        <esa-select id="c-type" label="Commitment Type" required></esa-select>
        <esa-select id="c-cat" label="Resource Category"></esa-select>
      </div>
      <esa-textarea id="c-guidance" label="General Guidance" rows="3"></esa-textarea>
      <esa-input-tag id="c-tags" label="Tags"></esa-input-tag>
      <esa-textarea id="c-text" label="Full Commitment Text" rows="10"></esa-textarea>
    </div>
    <div slot="footer" class="bcn-editor__foot">
      <span id="ec-cancel"><EsaButton color="ghost" appearance="outline">Cancel</EsaButton></span>
      <span id="ec-save"><EsaButton color="primary">Save</EsaButton></span>
    </div>
  </esa-dialog>

  <!-- ═══ Add New Version MODAL — prod create-version field set (with file upload). ═══ -->
  <esa-dialog id="rev-add-dialog" heading="Add New Version" style="--_dialog-width: 640px; --_dialog-max-height: 92vh; --_dialog-bg: var(--color-surface, #fff); --z-modal-backdrop: 1150; --z-modal: 1200;">
    <div class="bcn-form bcn-form--dialog">
      <esa-text-field id="rv-originator" label="Originator of Change" required></esa-text-field>
      <esa-date-picker id="rv-effective" label="Effective Date"></esa-date-picker>
      <esa-textarea id="rv-summary" label="Summary of Change" rows="4" required></esa-textarea>
      <div class="bcn-field">
        <span class="bcn-field__label">Files</span>
        <esa-file-upload label="Drag &amp; drop files, or browse" multiple accept=".pdf,.csv,.xlsx"></esa-file-upload>
      </div>
    </div>
    <div slot="footer" class="bcn-editor__foot">
      <span id="rv-cancel"><EsaButton color="ghost" appearance="outline">Cancel</EsaButton></span>
      <span id="rv-save"><EsaButton color="primary">Add version</EsaButton></span>
    </div>
  </esa-dialog>

  <!-- ═══ Edit Version Metadata MODAL — prod edit-metadata field set (no upload). ═══ -->
  <esa-dialog id="rev-edit-dialog" heading="Edit Version Metadata" style="--_dialog-width: 640px; --_dialog-max-height: 92vh; --_dialog-bg: var(--color-surface, #fff); --z-modal-backdrop: 1150; --z-modal: 1200;">
    <div class="bcn-form bcn-form--dialog">
      <esa-text-field id="re-originator" label="Originator of Change" required></esa-text-field>
      <esa-date-picker id="re-effective" label="Effective Date"></esa-date-picker>
      <esa-textarea id="re-summary" label="Summary of Change" rows="4" required></esa-textarea>
    </div>
    <div slot="footer" class="bcn-editor__foot">
      <span id="re-cancel"><EsaButton color="ghost" appearance="outline">Cancel</EsaButton></span>
      <span id="re-save"><EsaButton color="primary">Save</EsaButton></span>
    </div>
  </esa-dialog>

  <!-- Source-document viewer. -->
  <esa-side-dialog id="source-drawer" heading={SOURCE_DOCUMENT} size="lg" style="--_width: 66vw; --z-modal: 1300; --z-modal-backdrop: 1250; --backdrop-filter: blur(4px);">
    <div class="bcn-source-pdf">
      <iframe class="bcn-source-pdf__frame" src={`${sourcePdf}#view=FitH&navpanes=0&pagemode=none`} title={`Source document — ${SOURCE_DOCUMENT} (sample)`}></iframe>
    </div>
    <span slot="footer" class="bcn-source-foot">
      <EsaIconLink href={sourceDocHref} trailing="arrow-right" size="sm" weight="medium">Open Source Document</EsaIconLink>
    </span>
  </esa-side-dialog>

  <!-- Delete confirmation — simple yes/no (faithful to Beacon; no type-to-confirm). -->
  <esa-confirm-dialog
    id="delete-confirm"
    variant="danger"
    heading="Delete Commitment"
    message="Are you sure you want to delete this commitment? Doing so will also delete all requirements and actions defined under it. This action cannot be undone."
    confirm-label="Delete"
    cancel-label="Cancel"
    style="--z-modal: 1400; --z-modal-backdrop: 1350;"
  ></esa-confirm-dialog>

  <script type="application/json" id="edit-meta" set:html={JSON.stringify(editPayload)}></script>
  <script type="application/json" id="cmt-files-data" set:html={JSON.stringify(files)}></script>
</AppShell>

<script>
  import '@esa/ecology/esa-dialog';
  import '@esa/ecology/esa-side-dialog';
  import '@esa/ecology/esa-select';
  import '@esa/ecology/esa-text-field';
  import '@esa/ecology/esa-textarea';
  import '@esa/ecology/esa-input-tag';
  import '@esa/ecology/esa-date-picker';
  import '@esa/ecology/esa-file-list';
  import '@esa/ecology/esa-file-upload';
  import '@esa/ecology/esa-filter-dropdown';
  import '@esa/ecology/esa-confirm-dialog';

  const editMeta = JSON.parse(document.getElementById('edit-meta')!.textContent || '{}');
  const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
  const setValue = (id: string, value: string) => {
    const el = document.getElementById(id) as (HTMLElement & { value: string }) | null;
    if (el) el.value = value;
  };
  const setOptions = (id: string, opts: string[], value?: string) => {
    const el = document.getElementById(id) as (HTMLElement & { options: { value: string; label: string }[]; value: string }) | null;
    if (!el) return;
    el.options = opts.map((o) => ({ value: o, label: o }));
    if (value !== undefined) el.value = value;
  };
  const setTags = (id: string, values: string[]) => {
    const el = document.getElementById(id) as (HTMLElement & { value: string[] }) | null;
    if (el) el.value = values;
  };

  // ── Source drawer (shared by the commitment-text footer + file rows) ──────────
  const drawer = $('source-drawer') as HTMLElement & { open: boolean };
  document.querySelectorAll<HTMLElement>('[data-bcn-source]').forEach((el) =>
    el.addEventListener('click', () => (drawer.open = true)),
  );

  // Trigger a browser download for an href under a given filename (prototype helper).
  const downloadFile = (href: string, name: string) => {
    const a = document.createElement('a');
    a.href = href;
    a.download = name;
    document.body.appendChild(a);
    a.click();
    a.remove();
  };

  // ── Files — each row links to the source PDF (opens the viewer), with per-row
  //    download and remove. The lego self-manages the row removal; we just keep the
  //    Files count badge in sync. ──
  const cmtFiles = JSON.parse(document.getElementById('cmt-files-data')!.textContent || '[]') as string[];
  const fileList = $('cmt-files') as HTMLElement & { files: { name: string; href: string }[] };
  const sourceHref = fileList.dataset.src ?? '#';
  fileList.files = cmtFiles.map((name) => ({ name, href: sourceHref }));
  const filesCount = document.querySelector<HTMLElement>('#cmt-files-count .esa-badge__text');
  fileList.addEventListener('click', (e) => {
    // The file name is an <a> inside the lego's shadow DOM; open the viewer instead
    // of following the link. The download/remove <button>s fall through.
    if (!e.composedPath().some((el) => el instanceof HTMLAnchorElement)) return;
    e.preventDefault();
    drawer.open = true;
  });
  fileList.addEventListener('download', (e) => {
    const { file } = (e as CustomEvent<{ file: { name: string } }>).detail;
    downloadFile(sourceHref, file?.name ?? '');
  });
  fileList.addEventListener('remove', () => {
    if (filesCount) filesCount.textContent = String(fileList.files.length);
  });

  // ── Requirements filter bar — keyword search + Phase + Type, all client-side. ──
  const reqRows = Array.from(document.querySelectorAll<HTMLElement>('#req-list .bcn-row-li'));
  const reqEmpty = $('req-empty');
  const uniq = (xs: string[]) => [...new Set(xs.filter(Boolean))].sort();
  const toOpts = (xs: string[]) => xs.map((v) => ({ label: v, value: v }));
  let q = '', phase = '', type = '';
  const applyReqFilters = () => {
    let visible = 0;
    reqRows.forEach((li) => {
      const show =
        (!q || (li.dataset.name ?? '').includes(q)) &&
        (!phase || li.dataset.phase === phase) &&
        (!type || li.dataset.type === type);
      li.hidden = !show;
      if (show) visible++;
    });
    reqEmpty.hidden = visible !== 0;
  };

  const reqSearch = $('req-search') as HTMLElement & { value: string };
  reqSearch.addEventListener('change', (e) => {
    q = ((e as CustomEvent).detail?.value ?? reqSearch.value ?? '').toLowerCase();
    applyReqFilters();
  });

  type FilterDropdownEl = HTMLElement & { options: { label: string; value: string }[]; _selected: string[] };
  const fltPhase = $('flt-phase') as FilterDropdownEl;
  const fltType = $('flt-type') as FilterDropdownEl;
  fltPhase.options = toOpts(uniq(reqRows.map((li) => li.dataset.phase ?? '')));
  fltType.options = toOpts(uniq(reqRows.map((li) => li.dataset.type ?? '')));
  fltPhase.addEventListener('selection-change', (e) => {
    phase = ((e as CustomEvent).detail?.value as string) ?? '';
    applyReqFilters();
  });
  fltType.addEventListener('selection-change', (e) => {
    type = ((e as CustomEvent).detail?.value as string) ?? '';
    applyReqFilters();
  });
  $('req-clear-filters').addEventListener('esa-filter-clear', () => {
    reqSearch.value = ''; q = ''; phase = ''; type = '';
    fltPhase._selected = []; fltType._selected = [];
    applyReqFilters();
  });

  // ── Edit Commitment modal — prod Edit Commitment field set. ──
  const dialog = $('edit-dialog') as HTMLElement & { open: boolean };
  setValue('c-title', editMeta.commitmentTitle ?? '');
  setValue('c-id', editMeta.commitmentId ?? '');
  setOptions('c-doc', [editMeta.sourceDoc, 'Conditions of Approval — Planning Permit', 'SWPPP'], editMeta.sourceDoc);
  setOptions('c-type', ['Mitigation Measure', 'Standard Condition of Approval', 'Permit Condition', 'Commitment'], editMeta.commitmentType);
  setOptions(
    'c-cat',
    ['Aesthetics', 'Air Quality', 'Biological Resources', 'Cultural Resources', 'Geology, Soils, and Paleontological Resources', 'Greenhouse Gas Emissions', 'Noise', 'Utilities and Service Systems'],
    editMeta.resourceCategory,
  );
  setValue('c-guidance', editMeta.generalGuidance ?? '');
  setTags('c-tags', editMeta.tags ?? []);
  setValue('c-text', editMeta.fullText ?? '');
  $('edit-cmt').addEventListener('click', () => (dialog.open = true));
  $('ec-cancel').addEventListener('click', () => (dialog.open = false));
  $('ec-save').addEventListener('click', () => (dialog.open = false));

  // ── Revisions — Add New Version (create) + Edit Version Metadata (current only). ──
  const revAdd = $('rev-add-dialog') as HTMLElement & { open: boolean };
  $('add-rev').addEventListener('click', () => {
    setValue('rv-originator', ''); setValue('rv-effective', ''); setValue('rv-summary', '');
    revAdd.open = true;
  });
  $('rv-cancel').addEventListener('click', () => (revAdd.open = false));
  $('rv-save').addEventListener('click', () => (revAdd.open = false));

  const revEdit = $('rev-edit-dialog') as HTMLElement & { open: boolean };
  document.querySelectorAll<HTMLElement>('[data-edit-rev]').forEach((btn) =>
    btn.addEventListener('click', () => {
      setValue('re-originator', btn.dataset.originator ?? '');
      setValue('re-effective', btn.dataset.effective ?? '');
      setValue('re-summary', btn.dataset.summary ?? '');
      revEdit.open = true;
    }),
  );
  $('re-cancel').addEventListener('click', () => (revEdit.open = false));
  $('re-save').addEventListener('click', () => (revEdit.open = false));

  // ── Danger zone → confirm → route to the commitments list (prod navigates there). ──
  const deleteConfirm = $('delete-confirm') as HTMLElement & { open: boolean };
  $('delete-cmt').addEventListener('click', () => (deleteConfirm.open = true));
  deleteConfirm.addEventListener('confirm', () => {
    window.location.hash = '#data-catalog/commitments';
  });
</script>

<style>
  /* bcn-lego-checked: page-composition glue only — the family detail layout (identity
     header, main+rail), the serif commitment-text card, the flat requirement rows +
     filter bar, the lineage/revisions spine modules, and the single-column dialog forms.
     No esa-* lego models an entity detail PAGE; checked Ecology (every control is a lego
     — buttons/badges/pills/collapsibles/empty-state/icon-link/dialog/side-dialog/
     selects/text-fields/textareas/input-tag/date-picker/file-list/file-upload/
     filter-container/filter-dropdown/filter-clear/confirm-dialog; delete uses
     BcnDangerZone for the GitHub layout) and Beacon (recomposes the prod Commitment
     Overview + Requirements + Revision History tabs, the Edit Commitment modal, and the
     prod version-chain create/edit-metadata dialogs). Matched to data-catalog-source-document.astro. */

  .bcn-cmt { display: flex; flex-direction: column; gap: var(--spacing-600); }

  .bcn-cmt__head { display: flex; align-items: flex-start; justify-content: space-between; gap: var(--spacing-400); padding-bottom: var(--spacing-400); border-bottom: 1px solid var(--color-border); }
  .bcn-cmt__head-actions { display: inline-flex; align-items: center; gap: var(--spacing-200); flex-shrink: 0; }
  .bcn-cmt__identity { display: flex; flex-direction: column; align-items: flex-start; gap: var(--spacing-100); min-width: 0; }
  .bcn-cmt__title-row { display: flex; align-items: center; flex-wrap: wrap; gap: var(--spacing-200); min-width: 0; }
  .bcn-cmt__title { margin: 0; font-family: var(--font-decorative); font-size: 1.5rem; font-weight: var(--font-weight-semibold); line-height: 1.2; color: var(--color-text-primary); }
  .bcn-cmt__badge { flex-shrink: 0; padding: 0.125rem 0.375rem; border-radius: var(--radius-100); font-size: var(--type-size-100); font-weight: var(--font-weight-semibold); line-height: 1.4; white-space: nowrap; }
  .bcn-cmt__badge--commitment { color: var(--color-commitment); background: color-mix(in srgb, var(--color-commitment) 12%, white); }
  .bcn-cmt__badge--type { color: var(--color-text-secondary); background: var(--color-surface-sunken); transform: translateY(2px); }
  .bcn-cmt__badge--phase { color: var(--color-text-secondary); background: transparent; border: 1px solid var(--color-border); }

  .bcn-cmt__body { display: grid; grid-template-columns: minmax(0, 1fr) 360px; gap: var(--spacing-600); align-items: start; }
  .bcn-cmt__main { min-width: 0; display: flex; flex-direction: column; gap: var(--spacing-600); }
  .bcn-cmt__rail { min-width: 0; display: flex; flex-direction: column; gap: var(--spacing-500); }
  .bcn-cmt__rail :global(.esa-collapsible__title) { font-size: var(--type-size-250); font-weight: var(--font-weight-semibold); }

  .bcn-cmt__section { display: flex; flex-direction: column; gap: var(--spacing-300); }
  .bcn-cmt__section-head { display: flex; align-items: center; justify-content: space-between; gap: var(--spacing-300); }
  .bcn-section-title { display: flex; align-items: center; gap: var(--spacing-200); margin: 0; font-size: var(--type-size-300); font-weight: var(--font-weight-semibold); color: var(--color-text-primary); }
  .bcn-btn-ico { display: inline-flex; align-items: center; gap: var(--spacing-150); }

  /* Neutral count badge — re-point esa-badge to the house neutral pair. */
  .bcn-count-neutral { display: inline-flex; align-items: center; --badge-bg: var(--color-surface-sunken); --badge-text-color: var(--color-text-secondary); }

  /* Commitment-text card — serif regulatory voice, parsed bullets with bold lead-ins. */
  .bcn-cmttext { display: flex; flex-direction: column; gap: var(--spacing-300); padding: var(--spacing-500); background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-300); }
  .bcn-cmttext__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--spacing-400); }
  .bcn-cmttext__item { font-family: var(--font-decorative); font-size: 1.0625rem; line-height: 1.65; color: var(--color-text-primary); }
  .bcn-cmttext__footer { display: flex; justify-content: flex-end; gap: var(--spacing-100); padding-top: var(--spacing-200); border-top: 1px solid var(--color-border-light); }
  .bcn-cmttext__footer :global(.esa-button--color-ghost .esa-button__native) { color: var(--color-primary); }
  .bcn-cmttext__footer :global(.esa-button--color-ghost .esa-button__native:hover:not(:disabled)) { color: var(--color-primary-hover); background: color-mix(in srgb, var(--color-primary) 8%, transparent); }

  /* Requirements filter bar (canonical: search + filter-dropdowns + clear). */
  .bcn-reqfilters { display: flex; flex-direction: column; gap: var(--spacing-250); }
  .bcn-reqfilters :global(esa-text-field) { max-width: 360px; }
  .bcn-reqfilters__row { display: flex; align-items: center; flex-wrap: wrap; gap: var(--spacing-300); }

  /* Requirement rows — family hover whisper. */
  .bcn-row-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--spacing-200); }
  .bcn-row-li[hidden] { display: none; }
  .bcn-row {
    display: flex; align-items: center; gap: var(--spacing-300);
    padding: var(--spacing-300) var(--spacing-400);
    border: 1px solid var(--color-border); border-radius: var(--radius-200); background: var(--color-surface);
    text-decoration: none;
    transition: background-color 120ms ease;
  }
  .bcn-row:hover { background: color-mix(in srgb, var(--color-primary) 4%, var(--color-surface)); }
  .bcn-row__name { flex: 1; min-width: 0; font-size: var(--form-font-size-md); font-weight: var(--font-weight-semibold); color: var(--color-text-primary); }
  .bcn-row .bcn-cmt__badge--type,
  .bcn-row .bcn-cmt__badge--phase { transform: none; }
  .bcn-row > :global(.esa-icon:last-child) { color: var(--color-text-tertiary); flex-shrink: 0; transition: transform 120ms ease, color 120ms ease; }
  .bcn-row:hover > :global(.esa-icon:last-child) { transform: translateX(2px); color: var(--color-text-secondary); }

  .bcn-reqs__empty { border: 1px dashed var(--color-border); border-radius: var(--radius-200); padding: var(--spacing-400); }
  .bcn-reqs__empty :global(.esa-empty-state__title) { color: var(--color-text-tertiary); font-weight: var(--font-weight-regular); }

  /* Roomier file rows; the lego's density knob inherits into its shadow DOM. */
  #cmt-files { --file-list-row-padding-y: var(--spacing-200); }

  /* Rail extras */
  .bcn-tagrow { display: flex; flex-wrap: wrap; gap: var(--spacing-150); margin-top: var(--spacing-100); }
  .bcn-tagrow :global(.esa-pill) { border-radius: var(--radius-100); background: var(--color-surface-sunken); border: 1px solid var(--color-border); color: var(--color-text-secondary); }
  .bcn-lists { display: flex; flex-direction: column; align-items: flex-start; gap: var(--spacing-150); margin: 0; padding: 0; list-style: none; }
  .bcn-list-link { font-size: var(--form-font-size-md); font-weight: var(--font-weight-medium); color: var(--color-primary); text-decoration: none; }
  .bcn-list-link:hover { text-decoration: underline; }
  .bcn-rail-meta { margin: var(--spacing-300) 0 0; padding-top: var(--spacing-300); border-top: 1px solid var(--color-border-light); font-size: 0.75rem; color: var(--color-text-secondary); }

  /* Lineage / Revisions spine modules (family treatment). */
  .bcn-lineage { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; }
  .bcn-lineage__node { position: relative; display: flex; align-items: flex-start; gap: var(--spacing-300); padding-bottom: var(--spacing-400); }
  .bcn-lineage__node::before { content: ''; position: absolute; left: 13px; top: 30px; bottom: 2px; width: 2px; background: var(--color-border); }
  .bcn-lineage__node:last-child { padding-bottom: 0; }
  .bcn-lineage__node:last-child::before { display: none; }
  .bcn-lineage__icon { display: inline-flex; align-items: center; justify-content: center; width: 28px; height: 28px; flex-shrink: 0; border-radius: 50%; background: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text-secondary); }
  .bcn-lineage__icon :global(.esa-icon) { --_icon-size: 14px; }
  .bcn-lineage__node--current .bcn-lineage__icon { border-color: var(--color-primary); background: var(--color-primary); color: var(--color-text-inverse); }
  .bcn-lineage__body { display: flex; flex-direction: column; gap: 1px; min-width: 0; padding-top: 2px; }
  .bcn-lineage__kind { font-size: 0.75rem; color: var(--color-primary); text-decoration: none; width: fit-content; }
  a.bcn-lineage__kind:hover { text-decoration: underline; }
  .bcn-lineage__name { font-size: var(--form-font-size-md); font-weight: var(--font-weight-medium); line-height: 1.35; color: var(--color-primary); text-decoration: none; }
  a.bcn-lineage__name:hover { text-decoration: underline; }
  .bcn-lineage__name--current { color: var(--color-text-primary); font-weight: var(--font-weight-semibold); }

  /* Child rollup nodes (Requirements / Actions) — single-line link + neutral count. */
  .bcn-lineage__node.bcn-lineage__node--child { align-items: center; }
  .bcn-lineage__node--child .bcn-lineage__body { flex: 1; padding-top: 0; }
  .bcn-lineage__node--child .bcn-lineage__name { font-size: 0.75rem; }
  .bcn-lineage__node--child .bcn-count-neutral { flex-shrink: 0; }

  /* Revisions spine — caption-style kind, change metadata, inline edit, add action. */
  .bcn-revs .bcn-lineage__body { gap: 2px; }
  .bcn-revs__head { display: flex; align-items: baseline; justify-content: space-between; gap: var(--spacing-200); }
  .bcn-revs .bcn-lineage__kind { color: var(--color-text-tertiary); }
  .bcn-revs__edit { border: 0; background: none; padding: 0; cursor: pointer; font-size: 0.75rem; font-weight: var(--font-weight-medium); color: var(--color-primary); }
  .bcn-revs__edit:hover { text-decoration: underline; }
  .bcn-revs__summary { font-size: var(--form-font-size-md); font-weight: var(--font-weight-medium); line-height: 1.35; color: var(--color-text-primary); }
  .bcn-revs__meta { font-size: 0.75rem; color: var(--color-text-secondary); }
  .bcn-revs__by { font-size: 0.75rem; color: var(--color-text-tertiary); margin-top: 1px; }
  .bcn-revs__add { padding-top: var(--spacing-300); }
  #add-rev { display: block; }
  #add-rev :global(.esa-button) { width: 100%; justify-content: center; }

  @media (max-width: 1024px) {
    .bcn-cmt__body { grid-template-columns: 1fr; }
  }

  /* Single-column dialog form; neutral squared chips in the Tags input-tag. */
  .bcn-form { display: flex; flex-direction: column; gap: var(--spacing-400); }
  .bcn-form--dialog { padding: var(--spacing-100) 0; }
  .bcn-form :global(esa-input-tag) {
    --_chip-bg: var(--color-surface-sunken);
    --_chip-color: var(--color-text-primary);
    --_chip-radius: var(--radius-100);
  }
  .bcn-field { display: flex; flex-direction: column; gap: var(--spacing-150); }
  .bcn-field__label { font-size: var(--form-font-size-md); font-weight: var(--font-weight-medium); color: var(--color-text-primary); }
  .bcn-grid-2 { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--spacing-300); }
  .bcn-editor__foot { display: flex; gap: var(--spacing-300); justify-content: flex-end; width: 100%; }

  .bcn-source-pdf { height: 100%; min-height: 60vh; }
  .bcn-source-pdf__frame { width: 100%; height: 100%; min-height: 60vh; border: 0; border-radius: var(--radius-200); background: var(--color-surface-sunken); }
  .bcn-source-foot { display: flex; justify-content: flex-end; width: 100%; }
</style>

<!-- Page renders its own identity header; hide PageLayout's default title row. -->
<style is:global>
  .page-layout__title { display: none !important; }
</style>
