---
// Site Clearance — map-first go/no-go decision support for geotechnical
// drill-hole work areas (the Beacon WorkArea entity). Scoped to a single
// COMPONENT via the inline picker beside the page title (the selection
// persists in browser storage); all 231 sites live under 2024-2029
// Geotechnical Activities — the other components render the empty state.
//
//   Map  (default) — the component's work areas (client KMZ) as circle markers
//                    colored by DERIVED clearance status (latest review ×
//                    live observation buffers), zoom-adaptive marker sizing
//                    (program extent → street zoom), the View segmented bar
//                    (All + one pill per display status, live counts) driving
//                    the Status facets, a Status dropdown filter, "Go to work
//                    area" / "Go to observation" combobox jumps in the View
//                    row (type-ahead → pan + pulse; the same machinery backs
//                    the drawers' "Show on map"), a reset-view backout under
//                    the zoom control, a Map/Satellite base-layer control, the
//                    optional COMPONENT BUFFER overlay (a user-defined
//                    distance ring around every work area — feet + label,
//                    edited in a minimal dialog), and a readiness strip.
//   Data           — Work Areas × Observations AG Grids (beacon-grid kit)
//                    behind the requirement-tracker filter bar; rows open the
//                    same drawers as the map. No forecasting columns.
//   Activity       — date-grouped card feed of CLEARANCE changes (recorded
//                    reviews, monitor notes, live drawer saves), scoped by a
//                    Type filter; entries open the work-area drawer. History
//                    only — there is no Upcoming rail and no Timeline tab:
//                    Beacon records what happened, it never forecasts.
//
// Status is never stored — deriveStatus(workArea, observations) is PURE, so
// every save re-derives everything (marker fills, readiness strip, both
// grids, the open drawers) from the in-memory store. A work area with NO
// recorded review that an active observation buffer covers renders a
// PROVISIONAL BLOCK (hollow red — the system detects, humans decide); ANY
// recorded review status overrules the provisional display.
//
// The work-area drawer: header → clearance-visit band (the one date the
// clearance carries; the Work Area custom fields live on the Data grid, not
// in the drawer) → INLINE review history (dated determinations —
// Kind from the tenant's configurable list, Date, required Outcome, Reviewer,
// Note — newest first; the latest review sets the status and adding one
// updates the clearance-visit date) → Comments (a per-work-area collaboration
// thread with @-mention, ported from permit tracking) → Notes / Activity
// collapsibles. Notes are append-only monitor records (date, author, verbatim
// text — create + delete, never edit; Beacon as the system of record for what
// the field biologists send by email). "Edit site details" is site-level only
// (the clearance-visit date + the add-note flow).
import AppShell from '../../layouts/AppShell.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import '../../styles/beacon-map.css'; // shared Leaflet chrome (.leaflet-tooltip restyle for all map pages)
import EsaButton from '@esa/ecology/esa-button.astro';
import EsaIconButton from '@esa/ecology/esa-icon-button.astro';
import EsaIcon from '@esa/ecology/esa-icon.astro';
import EsaBadge from '@esa/ecology/esa-badge.astro';
import EsaCollapsible from '@esa/ecology/esa-collapsible.astro';
import EsaEmptyState from '@esa/ecology/esa-empty-state.astro';
import FilterContainer from '@esa/ecology/esa-filter-container.astro';
import FilterClearButton from '@esa/ecology/esa-filter-clear-button.astro';
import BcnKeyValue from '../../components/bcn/BcnKeyValue.astro';
import BcnStatusChip from '../../components/bcn/BcnStatusChip.astro';
import {
  workAreas,
  observations,
  STATUS_ORDER,
  STATUS_META,
  statusCounts,
  GEOTECH_COMPONENT,
} from '../../data/geotech-fixture-bio';

// ── Precompute (build-time mirror of what the client re-derives after edits;
//    the SSR default component is the geotech program — all 231 sites) ────────
const initialCounts = statusCounts(observations);
const countFor = (s: string) => initialCounts.find((c) => c.status === s)?.count ?? 0;
const totalWas = workAreas.length;
const readyCount = countFor('cleared');

// SSR :root defaults — STATUS_META's hexes ARE the committed field-map palette
// (the fixture's single source), plus the page's inks: --st-neutral for the
// observation-drawer chip, the observation violet (--obs-color /
// --obs-color-strong) for buffers + dots, and the component-buffer blue
// (--cbuf-color) for the analysis overlay — page glue, deliberately NOT status
// colors so facts can never be confused with judgments.
const rootVars =
  `:root{` +
  Object.values(STATUS_META)
    .map((m) => `${m.colorVar}:${m.hex};`)
    .join('') +
  `--st-neutral:#8a9099;--obs-color:#7b5ea7;--obs-color-strong:#5b3f87;--cbuf-color:#4575b4;}`;

// Shared Lucide paths for the drawer chrome (the same glyphs the approved
// drawer specimen uses).
const ICON_SHIELD =
  "<path d='M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1 1 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z'/><path d='m9 12 2 2 4-4'/>";
const ICON_QUOTE =
  "<path d='M16 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z'/><path d='M5 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z'/>";
const ICON_HISTORY =
  "<path d='M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8'/><path d='M3 3v5h5'/><path d='M12 7v5l4 2'/>";
const ICON_MSG =
  "<path d='M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z'/>";
const ICON_CHEVRON_DOWN = "<path d='m6 9 6 6 6-6'/>";
---

<!-- manifest:
  layout: stack(lg)
  sections:
    - component picker (inline beside the page title) -> esa-dropdown-menu
    - clearance tabs (Map / Data / Activity) -> esa-tab-layout
    - work-area drawer (site-details band, inline review history + add/edit, notes, comments) -> esa-side-dialog
    - observation drawer -> esa-side-dialog
    - component-buffer edit dialog -> esa-dialog
-->

<!-- The BCN-1337 build spec: the BIOLOGICAL clearance surface (geotech-fixture-bio).
     One clearance per work area, carried through dated reviews with REQUIRED
     outcomes; the review history + add/edit form are INLINED directly in the
     work-area drawer (the dd-* machinery). No Timeline tab, no forecasting
     dates, no stipulations — see the fixture header for the model contract. -->
<!-- bcn-lego-checked: composed from esa-tab-layout, esa-side-dialog ×2 (work-area
     parent + the observation drawer; the review history lives inline in the parent),
     esa-dropdown-menu (the inline component picker beside the H1 — slotted text+chevron
     trigger, menu-action selection; checked esa-select/esa-combobox, both render as
     form fields, wrong chrome for a title-adjacent switcher), esa-dialog (the minimal
     component-buffer edit form), esa-switch-toggle (the Component Buffer layer on/off),
     esa-filter-dropdown ×3 in esa-filter-container ×3 + esa-filter-clear-button ×3
     (map Status, Data Status, Activity Type; the Status dropdowns use the lego's
     per-option `color` dot, fed var(--st-*) so they stay in lockstep with the
     map/legend/chips), esa-combobox ×2 (the View-row "Go to work area"/"Go to
     observation" jumps — autocomplete mode type-aheads over the component's work-area
     IDs client-side; checked esa-entity-search, but it is an async search-service
     shell and these options are static in-page lists), esa-select ×2 (the review
     form's kind + outcome — checked BcnStatusSelect, typed/baked to the three
     tracking statuses, wrong shape for the clearance ladder), esa-date-picker,
     esa-textarea, esa-text-field, esa-button-toggle ×2 (grid pivot + the map's View
     segmented bar, both size="md"; counts ride the option labels as plain text — the
     lego renders label strings only), esa-collapsible ×2 (flush — the drawer's Notes /
     Activity summary rows; JS updates the SSR title span for live counts), esa-button
     (both drawers' "Show on map" — its map-pin EsaIcon rides the label slot; the
     registry has no map glyph), esa-icon-button (search clear, the review-history
     pencil edit affordance, the note delete, the buffer edit pencil), esa-icon,
     esa-badge (observation impact count), esa-empty-state (filtered-empty Activity
     feed + the empty-component map state) + BcnStatusChip, BcnKeyValue (the
     site-details band is a BcnKeyValue grid) + the shared beacon-grid AG Grid kit
     (src/lib/beacon-grid.ts). The review history IS the record.
     Remaining CSS is composition glue: Leaflet map chrome (status legend overlay,
     observation-buffer + component-buffer ring styling, the status-flip pulse, and
     the reset-view control — a custom L.Control styled to match Leaflet's own zoom
     buttons, injected into Leaflet's control corner where no esa- lego can reach;
     the shared .leaflet-tooltip restyle lives in src/styles/beacon-map.css; checked
     Beacon, prod has no map UI), the readiness strip (no esa- lego models a
     proportional census bar), the go-to comboboxes' form-token re-point so they sit
     on the filter legos' 32px control line, the component-picker trigger (a
     borderless text+chevron button slotted into the dropdown-menu lego — trigger
     chrome is the consumer's by design), the drawer structures from the approved
     specimen — the site-details band (full-bleed against the lego body padding) and
     the review-history node rail (checked Ecology + Beacon: no timeline/history lego
     exists) — the provisional-block hollow treatment (white-fill/red-stroke markers +
     the outlined BcnStatusChip/.bcn-grid-chip variant), the Activity-tab feed
     (date-grouped rows JS-injected from the fixture + the in-session change log),
     the deterministic .entry row system (ONE renderer for every event/reference row
     on the Activity tab and in the drawers — leading work-area/observation ID badge
     mirroring the Data Catalog commitment-ID badge idiom (observation IDs in the
     page's --obs-color violet, work-area IDs in a primary-teal tint), a fixed
     enumerated event-type label, structured primary, quoted verbatim secondary,
     right-aligned meta; chips clone the BcnStatusChip template; JS-injected →
     :global), the print stylesheet, the filter-bar card shell + grid footer
     (faithful copies of requirement-tracker's page glue), and the global
     .bcn-grid-chip / entry / rev classes that JS injects outside Astro's scope. -->
<AppShell
  title="Site Clearance"
  activeNavId="site-clearance"
  expandedSections={['monitoring']}
  tenantName="Delta Conveyance"
  projectName="Delta Conveyance Project"
>
  <!-- SSR :root status colors — exact fixture values (the field-map palette), so
       the legend/readiness strip are correct before any JS runs. Inside the body
       on purpose: rendering it before <AppShell> would precede the doctype. -->
  <style is:inline set:html={rootVars}></style>
  <PageLayout
    title="Site Clearance"
    icon="map"
    breadcrumbs={[
      { label: 'Monitoring', href: '#monitoring' },
      { label: 'Monitoring Portal', href: '#monitoring-portal' },
      { label: 'Site Clearance' },
    ]}
  >
    <!-- Component picker — inline beside the H1 (the title-badge slot), a
         quiet text+chevron trigger on the esa-dropdown-menu lego. The picker
         scopes EVERYTHING below it (map, grids, activity); the selection
         persists in browser storage so returning reopens the last component. -->
    <span slot="title-badge" class="comp-picker">
      <!-- The lego takes its trigger via the DEFAULT slot. -->
      <esa-dropdown-menu id="comp-menu" position="below-start">
        <button type="button" class="comp-picker__trigger" aria-label="Switch component">
          <span class="comp-picker__label" id="comp-label">{GEOTECH_COMPONENT}</span>
          <EsaIcon name="chevron-down" size="sm" paths={ICON_CHEVRON_DOWN} />
        </button>
      </esa-dropdown-menu>
    </span>
    <esa-tab-layout id="gc-tabs" appearance="underline">
      <!-- ═══ TAB 1 — MAP (the hero: can we start work at this site on its date?) ═══ -->
      <section slot="panel-0" class="map-panel" aria-label="Clearance status map">
        <!-- Print-only header (filled on beforeprint) -->
        <div class="print-header" aria-hidden="true">
          <span class="print-header__title">Site Clearance</span>
          <span class="print-header__meta" id="print-meta"></span>
        </div>

        <!-- View segmented bar + map filters. The View bar is the primary status
             scoping (All + one pill per display status, live counts) over the
             SAME facet state the Status dropdown edits (one source of truth):
             pressing a pill sets the facets; a pill reads as selected only
             while the facets exactly equal its set, so hand-editing the
             dropdown drops back to no-pill. Counts ride the labels as plain
             text (the lego renders label strings — an esa-badge inside a segment
             would fight it). Both scope markers AND the readiness strip. The
             go-to comboboxes on the View row's right are jumps, not filters:
             type-ahead or pick any of the component's work-area IDs / any
             observation → pan/zoom + pulse (no drawer), then reset to the
             placeholder. The Filters row also hosts the WORK AREA BUFFER layer
             control (BCN-1454's Component Buffer): an on/off switch + a pencil
             opening the minimal edit dialog (label + distance live there). -->
        <div class="map-filterbar">
          <div class="map-filterbar__row">
            <span class="map-filterbar__label">View</span>
            <!-- size="md": the View pills one type-size step up (sm 12px/28px →
                 md 14px/36px) — the lego's own size prop, no override; matches
                 the Data tab's pivot toggle. -->
            <esa-button-toggle id="view-presets" value="all" size="md"></esa-button-toggle>
            <!-- mode="select" (not autocomplete): the button trigger carries the
                 standard chevron, and type-ahead survives via the panel's own
                 search input. -->
            <div class="map-filterbar__goto">
              <esa-combobox id="goto-wa" mode="select" size="sm" placeholder="Go to work area…"></esa-combobox>
              <esa-combobox id="goto-obs" mode="select" size="sm" placeholder="Go to observation…"></esa-combobox>
            </div>
          </div>
          <div class="map-filterbar__row">
            <span class="map-filterbar__label">Filters</span>
            <FilterContainer>
              <esa-filter-dropdown id="map-flt-status" label="Status" multiple size="sm"></esa-filter-dropdown>
            </FilterContainer>
            <span id="map-clear-filters"><FilterClearButton /></span>
            <div class="map-filterbar__buffer">
              <esa-switch-toggle id="buffer-toggle" label="Work Area Buffer" size="sm"></esa-switch-toggle>
              <span id="buffer-edit"><EsaIconButton icon="pencil" label="Edit work area buffer" size="sm" /></span>
            </div>
          </div>
        </div>

        <div class="map-wrap">
          <div id="gc-map" class="map"></div>

          <!-- Empty-component state — shown when the selected component has no
               geo-located work areas (every component but the geotech program). -->
          <div class="map-empty" id="map-empty" hidden>
            <EsaEmptyState
              title="No geo-located work areas"
              description="This component has no work areas with geometry. Work areas load through the Work Area shapefile import."
              size="sm"
            />
          </div>

          <div class="map-legend" aria-label="Clearance status legend">
            <span class="map-legend__title">Work area status</span>
            {
              // Provisional Block is the hollow swatch — white fill, red stroke:
              // "blocked, but not solidified" (the map markers render the same way).
              STATUS_ORDER.map((status) => (
                <span class="map-legend__row">
                  <span
                    class="map-legend__dot"
                    style={
                      status === 'provisional-block'
                        ? `background:var(--color-surface); border: 2px solid var(${STATUS_META[status].colorVar}); box-sizing: border-box;`
                        : `background:var(${STATUS_META[status].colorVar});`
                    }
                  />
                  {STATUS_META[status].label}
                </span>
              ))
            }
            <span class="map-legend__row">
              <span class="map-legend__ring"></span>
              Observation buffer
            </span>
            <span class="map-legend__row">
              <span class="map-legend__hollow"></span>
              Tracking-only sighting
            </span>
          </div>
        </div>

        <!-- Readiness strip — the census figure below the map -->
        <section class="readiness" aria-label="Work areas by clearance status">
          <div class="readiness__head">
            <span class="readiness__title">Work areas by clearance status</span>
            <span class="readiness__summary">
              Ready to work <strong id="rs-ready">{readyCount}</strong>
              <span id="rs-total">of {totalWas} work areas</span>
            </span>
          </div>
          <div class="readiness__bar" id="rs-bar" role="img" aria-label={`${readyCount} of ${totalWas} work areas ready`}>
            {
              // Provisional Block gets a red/white stripe — "not solidified", same
              // story as the hollow markers (a solid segment would read as Blocked).
              STATUS_ORDER.filter((s) => countFor(s) > 0).map((s) => (
                <div
                  style={`height:100%; flex: 0 0 ${(countFor(s) / totalWas) * 100}%; background:${
                    s === 'provisional-block'
                      ? `repeating-linear-gradient(135deg, var(--st-provisional-block) 0 4px, var(--color-surface) 4px 7px)`
                      : `var(${STATUS_META[s].colorVar})`
                  };`}
                  title={`${STATUS_META[s].label}: ${countFor(s)}`}
                />
              ))
            }
          </div>
          <ul class="readiness__legend">
            {
              STATUS_ORDER.map((status) => (
                <li class="readiness__legend-item" data-rs-item={status} data-empty={countFor(status) === 0 ? 'true' : 'false'}>
                  <span
                    class="readiness__swatch"
                    style={
                      status === 'provisional-block'
                        ? `background:var(--color-surface); border: 2px solid var(${STATUS_META[status].colorVar}); box-sizing: border-box;`
                        : `background:var(${STATUS_META[status].colorVar});`
                    }
                  />
                  <span class="readiness__legend-label">{STATUS_META[status].label}</span>
                  <span class="readiness__legend-count" data-rs-count={status}>{countFor(status)}</span>
                </li>
              ))
            }
          </ul>
        </section>
      </section>

      <!-- ═══ TAB 2 — DATA (requirement-tracker filter bar + beacon AG Grids) ═══ -->
      <section slot="panel-1" class="data-panel" aria-label="Clearance data workspace">
        <div class="bcn-filterbar">
          <div class="bcn-filterbar__top">
            <div class="bcn-filterbar__group">
              <span class="bcn-filterbar__label">View</span>
              <esa-button-toggle id="pivot-toggle" value="workareas" size="md"></esa-button-toggle>
            </div>
            <div class="bcn-filterbar__search">
              <esa-text-field id="gc-search" placeholder="Search work areas…" size="md"></esa-text-field>
              <span id="gc-search-clear" hidden><EsaIconButton icon="x" label="Clear search" size="sm" /></span>
            </div>
          </div>
          <div class="bcn-filterbar__bottom">
            <span class="bcn-filterbar__label">Filters</span>
            <FilterContainer>
              <esa-filter-dropdown id="flt-status" label="Status" multiple size="sm"></esa-filter-dropdown>
            </FilterContainer>
            <span id="gc-clear-filters" class="bcn-filterbar__clear"><FilterClearButton /></span>
          </div>
        </div>

        <div class="bcn-view-pane" id="pane-was">
          <div id="grid-was" class="gc-grid"></div>
        </div>
        <div class="bcn-view-pane" id="pane-obs" hidden>
          <div id="grid-obs" class="gc-grid"></div>
        </div>

        <div class="table-footer">
          <span id="gc-download"><EsaButton color="ghost" appearance="outline" size="sm" icon="download">Download as CSV</EsaButton></span>
          <div class="row-count-data">
            Total Records: <span id="gc-total">0</span>
            <span id="gc-filtered" class="filtered-rows-count" hidden></span>
          </div>
        </div>
      </section>

      <!-- ═══ TAB 3 — ACTIVITY (what changed): a date-grouped card feed of the
           component's CLEARANCE history — recorded reviews, monitor notes, and
           the live in-session change log (one drawer save lands in BOTH the
           drawer's Activity list and this feed). History only — no Upcoming
           rail, no forecasting. Entries jump to the work-area drawer. ═══ -->
      <section slot="panel-2" class="feed-panel" aria-label="Activity feed">
        <div class="feed">
          <div class="feed-main">
            <!-- Filter row — the same filter legos as the map/Data bars. Type
                 has no dots on purpose (colors belong to status, not event
                 type); the page's Component picker already scopes the feed. -->
            <div class="map-filterbar feed-filterbar">
              <div class="map-filterbar__row">
                <span class="map-filterbar__label">Filters</span>
                <FilterContainer>
                  <esa-filter-dropdown id="act-flt-type" label="Type" multiple size="sm"></esa-filter-dropdown>
                </FilterContainer>
                <span id="act-clear-filters"><FilterClearButton /></span>
              </div>
            </div>
            <div id="feed-groups"></div>
            <div id="feed-empty" hidden>
              <EsaEmptyState
                title="No activity matches the filters"
                description="Clear the Type filter to see the full feed."
                size="sm"
              />
            </div>
          </div>
        </div>
      </section>
    </esa-tab-layout>
  </PageLayout>

  <!-- ═══ Work-area drawer — header → clearance-visit band → inline review
       history (add/edit) → Comments → Notes / Activity collapsibles → footer
       "Edit site details" (site-level only) + Show on map. esa-side-dialog
       lego, from BOTH tabs. ═══ -->
  <esa-side-dialog id="wa-dialog" size="md" style="--_width: 640px; --z-modal: 1300; --z-modal-backdrop: 1250;">
    <div slot="header" class="wa__header">
      <div class="wa__headmain">
        <h2 class="wa__title" id="wa-title">Work area</h2>
        <span id="wa-chip"><BcnStatusChip status="cleared" label="—" hex={STATUS_META.cleared.hex} /></span>
      </div>
      <p class="wa__subtitle" id="wa-sub">—</p>
    </div>

    <!-- READ mode (default) -->
    <div class="wa" id="wa-read">
      <!-- Clearance-visit band — the one date the clearance carries, directly
           under the header (full-bleed against the lego's body padding). The
           Work Area custom fields live on the Data grid, not here — the drawer
           stays a decision surface, not a record dump. -->
      <div class="band" id="wa-band">
        <BcnKeyValue label="Clearance visit"><span class="wa__kv-val" id="wa-d-visit">—</span></BcnKeyValue>
      </div>

      <!-- Biological clearance — the full review history (newest first; the
           latest review sets the status) + the inline Add/Edit review form. -->
      <section class="bioclear">
        <h3 class="wa__section">
          <EsaIcon name="shield-check" size="sm" paths={ICON_SHIELD} />
          Biological clearance
          <span class="bioclear__add">
            <span class="dd__count" id="dd-count">0 reviews</span>
            <span id="dd-add"><EsaButton color="ghost" appearance="outline" size="sm">Add review</EsaButton></span>
          </span>
        </h3>

        <!-- Add/Edit review form — inline above the history when adding; swapped
             into a history node when editing (the pencil affordance). Outcome is
             REQUIRED — a review IS a determination; any stipulation language
             belongs in the note (the epic cut the stipulations field). -->
        <div class="dd__form" id="dd-form" hidden>
          <esa-select id="dd-kind" label="Kind" size="sm"></esa-select>
          <div class="we__row">
            <esa-date-picker id="dd-date" label="Date" size="sm"></esa-date-picker>
            <esa-select id="dd-outcome" label="Outcome" size="sm"></esa-select>
          </div>
          <esa-text-field id="dd-reviewer" label="Reviewer" placeholder="Name (org)" size="sm"></esa-text-field>
          <esa-textarea id="dd-note" label="Note" rows="2" auto-resize size="sm"></esa-textarea>
          <div class="dd__formactions">
            <span id="dd-cancel"><EsaButton color="ghost" appearance="outline" size="sm">Cancel</EsaButton></span>
            <span id="dd-save"><EsaButton color="primary" size="sm">Save review</EsaButton></span>
          </div>
        </div>

        <!-- Review history — reverse-chron node rail (JS-injected) -->
        <ol class="revs" id="dd-history"></ol>
      </section>

      <!-- Comments — a per-work-area collaboration thread (ported from permit
           tracking, BCN-1364), DISTINCT from the read-only Activity log below.
           @-mention project users (would feed notifications). -->
      <section class="wa-comments">
        <h3 class="wa__section">
          <EsaIcon name="message-square" size="sm" paths={ICON_MSG} />
          Comments <span id="wa-comment-count"></span>
        </h3>
        <ul class="wa__comments" id="wa-comments"></ul>
        <div class="wa__compose">
          <div class="wa__compose-field">
            <esa-textarea id="wa-comment-input" rows="2" placeholder="Write a comment…  type @ to mention a teammate"></esa-textarea>
            <ul class="wa__mention-menu" id="wa-mention-menu" hidden></ul>
          </div>
          <div class="wa__compose-foot">
            <span class="wa__compose-hint">Posting as Andy Lovseth</span>
            <span id="wa-comment-post"><EsaButton color="primary" size="sm">Post comment</EsaButton></span>
          </div>
        </div>
      </section>

      <!-- Collapsible summary rows — ambient detail folds until asked for.
           Titles carry live counts (JS updates the lego's title span). -->
      <div class="wa__more">
        <span class="wa__more-item" id="wa-notes-col" hidden>
          <EsaCollapsible title="Notes" flush icon="quote" iconPaths={ICON_QUOTE}>
            <!-- Append-only monitor notes (date · author · verbatim text) — a
                 note can be DELETED but never edited. -->
            <ul class="wa__notes-added" id="wa-notes-added"></ul>
          </EsaCollapsible>
        </span>
        <span class="wa__more-item">
          <EsaCollapsible title="Activity" flush icon="history" iconPaths={ICON_HISTORY}>
            <ul class="wa__activity" id="wa-activity"></ul>
          </EsaCollapsible>
        </span>
      </div>
    </div>

    <!-- EDIT mode — SITE-LEVEL only: the clearance-visit date + the append-only
         note (Leah's paste-the-email flow). Reviews are edited inline in the
         read mode's review section, never here. -->
    <div class="wa" id="wa-edit" hidden>
      <section>
        <h3 class="wa__section">
          <EsaIcon name="clock" size="sm" paths="<circle cx='12' cy='12' r='10'/><polyline points='12 6 12 12 16 14'/>" />
          Dates
        </h3>
        <div class="we__dates">
          <esa-date-picker id="we-visit" label="Clearance visit" size="sm"></esa-date-picker>
        </div>
      </section>

      <section>
        <h3 class="wa__section">
          <EsaIcon name="quote" size="sm" paths={ICON_QUOTE} />
          Notes
        </h3>
        <!-- Append-only: existing notes are read-only even here (delete lives
             on the read-mode list); "Add note" is the paste-the-biologist-email
             affordance. -->
        <ul class="wa__notes-added" id="we-notes-added"></ul>
        <div class="we__addnote">
          <span class="we__addnote-title">Add note</span>
          <div class="we__row">
            <esa-date-picker id="we-note-date" label="Date" size="sm"></esa-date-picker>
            <esa-text-field id="we-note-author" label="Author" placeholder="Who sent it" size="sm"></esa-text-field>
          </div>
          <esa-textarea
            id="we-note-text"
            label="Note"
            rows="3"
            auto-resize
            placeholder="Paste the biologist's email note…"
            size="sm"></esa-textarea>
        </div>
      </section>
    </div>

    <div slot="footer" class="wa__footer">
      <!-- "Show on map" (round-5 ch5) — closes the drawer, switches to the Map
           tab, pans/zooms + pulses the marker (the ch2 go-to machinery). Hidden
           while editing — a mid-edit jump would discard the form. -->
      <span id="wa-showmap" class="wa__footer-start">
        <EsaButton color="ghost" appearance="outline" size="md">
          <EsaIcon
            name="map-pin"
            size="sm"
            paths="<path d='M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0'/><circle cx='12' cy='10' r='3'/>"
          />
          Show on map
        </EsaButton>
      </span>
      <span id="wa-edit-btn"><EsaButton color="ghost" appearance="outline" size="md">Edit site details</EsaButton></span>
      <span id="wa-cancel" hidden><EsaButton color="ghost" appearance="outline" size="md">Cancel</EsaButton></span>
      <span id="wa-save" hidden><EsaButton color="primary" size="md">Save</EsaButton></span>
    </div>
  </esa-side-dialog>

  <!-- ═══ Observation drawer (read-only, compact) — esa-side-dialog lego ═══ -->
  <esa-side-dialog id="obs-dialog" size="md" style="--_width: 520px; --z-modal: 1300; --z-modal-backdrop: 1250;">
    <div slot="header" class="wa__header">
      <div class="wa__headmain">
        <h2 class="wa__title" id="obs-title">Observation</h2>
        <span id="obs-chip"><BcnStatusChip status="neutral" label="—" hex="#3b4754" /></span>
      </div>
      <p class="wa__subtitle" id="obs-sub">—</p>
    </div>
    <div class="wa">
      <div class="od__meta">
        <BcnKeyValue label="Species code"><span class="wa__kv-val" id="obs-code">—</span></BcnKeyValue>
        <BcnKeyValue label="Kind"><span class="wa__kv-val" id="obs-kind">—</span></BcnKeyValue>
        <BcnKeyValue label="Buffer"><span class="wa__kv-val" id="obs-buffer">—</span></BcnKeyValue>
        <BcnKeyValue label="First observed"><span class="wa__kv-val" id="obs-first">—</span></BcnKeyValue>
      </div>

      <section id="obs-log-wrap" hidden>
        <h3 class="wa__section">
          <EsaIcon
            name="notebook-pen"
            size="sm"
            paths="<path d='M13.4 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7.4'/><path d='M2 6h4'/><path d='M2 10h4'/><path d='M2 14h4'/><path d='M2 18h4'/><path d='M21.378 5.626a1 1 0 1 0-3.004-3.004l-5.01 5.012a2 2 0 0 0-.506.854l-.837 2.87a.5.5 0 0 0 .62.62l2.87-.837a2 2 0 0 0 .854-.506z'/>"
          />
          Latest log
        </h3>
        <blockquote class="wa__note wa__note--log" id="obs-log"></blockquote>
      </section>

      <section>
        <h3 class="wa__section">
          <EsaIcon
            name="crosshair"
            size="sm"
            paths="<circle cx='12' cy='12' r='10'/><line x1='22' x2='18' y1='12' y2='12'/><line x1='6' x2='2' y1='12' y2='12'/><line x1='12' x2='12' y1='6' y2='2'/><line x1='12' x2='12' y1='22' y2='18'/>"
          />
          Work areas within buffer
          <span id="obs-impact-count"><EsaBadge value="0" size="sm" /></span>
        </h3>
        <ul class="od__impact" id="obs-impact"></ul>
      </section>
    </div>
    <div slot="footer" class="wa__footer">
      <!-- "Show on map" (round-5 ch5) — same jump as the work-area drawer's. -->
      <span id="obs-showmap" class="wa__footer-start">
        <EsaButton color="ghost" appearance="outline" size="md">
          <EsaIcon
            name="map-pin"
            size="sm"
            paths="<path d='M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0'/><circle cx='12' cy='10' r='3'/>"
          />
          Show on map
        </EsaButton>
      </span>
    </div>
  </esa-side-dialog>

  <!-- ═══ Component Buffer edit dialog (BCN-1454) — a minimal esa-dialog:
       distance (feet) + label. The overlay itself is a toggleable map layer
       drawing the ring around EVERY work-area geometry. ═══ -->
  <esa-dialog id="buffer-dialog" heading="Work Area Buffer" size="sm">
    <div class="bufform">
      <p class="bufform__hint">
        Draws a ring at the given distance around every work area — a satellite-mode analysis overlay
        (e.g. a Noise buffer near residences). One buffer per component.
      </p>
      <div class="we__row">
        <esa-text-field id="buf-label" label="Label" placeholder="e.g. Noise" size="sm"></esa-text-field>
        <esa-text-field id="buf-distance" label="Distance (ft)" type="number" size="sm"></esa-text-field>
      </div>
    </div>
    <div slot="footer" class="wa__footer">
      <span id="buf-cancel"><EsaButton color="ghost" appearance="outline" size="md">Cancel</EsaButton></span>
      <span id="buf-save"><EsaButton color="primary" size="md">Save</EsaButton></span>
    </div>
  </esa-dialog>

  <!-- Cloneable legos for JS-rendered rows: cloning SSR nodes (not innerHTML
       strings) keeps the components' scoped styles + markup as the single source. -->
  <template id="gc-chip-tpl">
    <span class="gate__chipwrap"><BcnStatusChip status="cleared" label="—" hex={STATUS_META.cleared.hex} /></span>
  </template>
  <template id="dd-edit-tpl">
    <span class="rev__edit"><EsaIconButton icon="pencil" label="Edit review" size="sm" /></span>
  </template>
  <template id="note-del-tpl">
    <span class="wnote__del"><EsaIconButton icon="trash-2" label="Delete note" size="sm" /></span>
  </template>
</AppShell>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';
  import { createGrid, ModuleRegistry, AllCommunityModule } from 'ag-grid-community';
  import type { GridApi, GridOptions, ColDef, IRowNode, ICellRendererParams } from 'ag-grid-community';
  import { beaconTheme, makeStatusRenderer } from '../../lib/beacon-grid';
  import '@esa/ecology/esa-tab-layout';
  import '@esa/ecology/esa-side-dialog';
  import '@esa/ecology/esa-dialog';
  import '@esa/ecology/esa-dropdown-menu';
  import '@esa/ecology/esa-switch-toggle';
  import '@esa/ecology/esa-select';
  import '@esa/ecology/esa-combobox';
  import '@esa/ecology/esa-text-field';
  import '@esa/ecology/esa-textarea';
  import '@esa/ecology/esa-date-picker';
  import '@esa/ecology/esa-button-toggle';
  import '@esa/ecology/esa-filter-dropdown';
  import {
    workAreas,
    observations,
    TODAY,
    STATUS_ORDER,
    STATUS_META,
    COMPONENTS,
    GEOTECH_COMPONENT,
    REVIEW_KINDS,
    REVIEW_KIND_LABEL,
    OUTCOMES,
    distanceFt,
    clearanceReviews,
    currentReview,
    bufferConflicts,
    deriveStatus,
    statusCounts,
    formatDate,
  } from '../../data/geotech-fixture-bio';
  import type {
    WorkArea,
    Observation,
    ClearanceStatus,
    ClearanceReview,
    ClearanceNote,
    ReviewKind,
  } from '../../data/geotech-fixture-bio';

  ModuleRegistry.registerModules([AllCommunityModule]);

  const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
  const waById = new Map(workAreas.map((w) => [w.id, w]));

  // ── THE client store — deriveStatus/bufferConflicts are pure and take this
  //    list, so every drawer save re-derives everything from it. ────────────────
  const activeObservations: Observation[] = [...observations];

  const statusOf = (wa: WorkArea): ClearanceStatus => deriveStatus(wa, activeObservations);
  const stLabel = (s: ClearanceStatus | string) => STATUS_META[s as ClearanceStatus]?.label ?? s;
  const fmtDistance = (ft: number) =>
    ft >= 5280 ? `${(ft / 5280).toFixed(1)} mi` : `${Math.round(ft).toLocaleString()} ft`;
  const KIND_LABEL: Record<string, string> = { 'nesting-bird': 'Nesting bird', resource: 'Resource' };
  const OBS_STATUS_LABEL: Record<string, string> = { active: 'Active', tracking: 'Tracking' };

  // Lego element shapes (esa-* form controls expose plain value/options props)
  type Field = HTMLElement & { value: string; options?: { value: string; label: string }[] };
  type SelectEl = HTMLElement & { value: string | string[] | null; options: { value: string; label: string }[] };
  type FilterDropdownEl = HTMLElement & {
    options: { label: string; value: string; color?: string }[];
    _selected: string[];
  };
  type ToggleEl = HTMLElement & { options: { value: string; label: string }[]; value: string };
  type SideDialog = HTMLElement & { open: boolean; heading: string; show(): void; close(): void };
  type DialogEl = HTMLElement & { open: boolean; heading: string };
  type SwitchEl = HTMLElement & { checked: boolean };
  type MenuEl = HTMLElement & {
    items: { label: string; action?: string; icon?: string }[];
    close(): void;
  };

  // ── Component scope — the picker beside the H1 drives EVERYTHING below it;
  //    the selection persists in browser storage. All fixture work areas (and
  //    the observations tied to them) belong to the geotech program component;
  //    the other components render the empty state. ────────────────────────────
  const COMPONENT_KEY = 'site-clearance-bio.component';
  let activeComponent: string = (() => {
    try {
      const saved = localStorage.getItem(COMPONENT_KEY);
      if (saved && (COMPONENTS as readonly string[]).includes(saved)) return saved;
    } catch {
      /* storage unavailable (private mode) — fall through to the default */
    }
    return GEOTECH_COMPONENT;
  })();
  const componentWas = () => workAreas.filter((w) => w.component === activeComponent);

  // ── Component Buffer (BCN-1454) — one user-defined ring per component
  //    (label + distance in feet), drawn around EVERY work-area geometry as a
  //    toggleable satellite-analysis layer. Off by default. ─────────────────────
  interface ComponentBuffer {
    label: string;
    distanceFt: number;
  }
  const bufferByComponent = new Map<string, ComponentBuffer>([
    [GEOTECH_COMPONENT, { label: 'Noise', distanceFt: 500 }],
  ]);
  const activeBuffer = () => bufferByComponent.get(activeComponent) ?? { label: 'Buffer', distanceFt: 500 };
  let bufferOn = false;

  /** In-session change entries are STRUCTURED at the source: a fixed event
      kind + one structured primary value (+ optional verbatim secondary /
      status chip) — never an assembled sentence. Both renderers (the drawer
      Activity list and the feed) pass these straight to entryRow. */
  type ChangeKind = 'note' | 'edit';
  interface ChangeEntry {
    ts: string; // full ISO datetime (live edits only — no seeds)
    waId: string;
    kind: ChangeKind;
    primary: string;
    secondary?: string;
    chip?: ClearanceStatus;
    user: string;
  }
  const changeLog: ChangeEntry[] = [];
  const logChange = (
    waId: string,
    kind: ChangeKind,
    primary: string,
    extra: { secondary?: string; chip?: ClearanceStatus } = {}
  ) => changeLog.push({ ts: new Date().toISOString(), waId, kind, primary, ...extra, user: 'Andy Lovseth' });
  const fmtTime = (ts: string) => new Date(ts).toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' });
  const fmtTs = (ts: string) => `Today · ${fmtTime(ts)}`;
  const entriesFor = (waId: string) =>
    changeLog.filter((c) => c.waId === waId).sort((a, b) => b.ts.localeCompare(a.ts));

  // ── Filter state (multi-select; empty = all) — scopes markers + the
  //    readiness strip, always inside the active component. ─────────────────────
  let statusFilters: string[] = [];

  const waShown = (wa: WorkArea) =>
    wa.component === activeComponent && (!statusFilters.length || statusFilters.includes(statusOf(wa)));
  const visibleWas = () => workAreas.filter(waShown);

  // ── Runtime colors — markers resolve the static :root vars (set SSR-side from
  //    the fixture's field-map palette); CSS surfaces read them directly. ───────
  const cssVar = (name: string, fallback: string) =>
    getComputedStyle(document.documentElement).getPropertyValue(name).trim() || fallback;
  const colorFor = (status: string) =>
    cssVar(`--st-${status}`, STATUS_META[status as ClearanceStatus]?.hex ?? '#8a9099');
  const obsColor = () => cssVar('--obs-color', '#7b5ea7');
  const obsStroke = () => cssVar('--obs-color-strong', '#5b3f87');

  // ── Chip cloning (BcnStatusChip SSR template) ───────────────────────────────
  const chipTpl = $('gc-chip-tpl') as unknown as HTMLTemplateElement;

  function applyChip(wrapper: Element, statusKey: string, label: string) {
    const chip = wrapper.querySelector<HTMLElement>('.bcn-status-chip');
    if (!chip) return;
    chip.style.setProperty('--_chip', `var(--st-${statusKey})`);
    chip.dataset.status = statusKey;
    const text = chip.querySelector('.bcn-status-chip__label');
    if (text) text.textContent = label;
  }
  function cloneChip(statusKey: string, label: string): HTMLElement {
    const wrap = (chipTpl.content.firstElementChild as HTMLElement).cloneNode(true) as HTMLElement;
    applyChip(wrap, statusKey, label);
    return wrap;
  }

  // ── Deterministic entry rows (round-5 ch3) — ONE renderer for every event /
  //    reference row on the Activity tab and in both drawers. The anatomy is
  //    slots, never assembled sentences, so prose can't creep back in:
  //      [ID badge] EventType · primary (+ status chip) — meta (right)
  //                 "secondary" (verbatim field text, quoted)
  //    Badge idiom mirrors the Data Catalog commitment-ID badge (compact mono/
  //    semibold tinted token): observation IDs in the page's --obs-color violet,
  //    work-area IDs in a primary-teal tint (two violets read as one entity —
  //    teal keeps the WA/observation distinction the whole page draws). ──────
  type EntryKind = 'review' | 'note' | 'edit' | 'work-area';

  // The fixed event-type vocabulary — normal case, rendered semibold ≥14px.
  const ENTRY_TYPE_LABEL: Record<EntryKind, string> = {
    review: 'Review',
    note: 'Note',
    edit: 'Edit',
    'work-area': 'Work area',
  };

  interface EntrySpec {
    badgeId: string;
    badgeKind: 'wa' | 'obs';
    eventType: EntryKind;
    /** Structured value(s) only — species / discipline / distance / date,
        '·'-joined. Never a sentence. */
    primary?: string;
    /** Verbatim field text (log excerpt, note text) — rendered quoted. */
    secondary?: string;
    chip?: ClearanceStatus;
    meta?: string; // right-aligned: date/time · actor · distance
  }

  function entryRow(spec: EntrySpec): HTMLLIElement {
    const li = document.createElement('li');
    li.className = 'entry';

    const badge = document.createElement('span');
    badge.className = `entry__badge entry__badge--${spec.badgeKind}`;
    badge.textContent = spec.badgeId;

    const body = document.createElement('div');
    body.className = 'entry__body';
    const line = document.createElement('p');
    line.className = 'entry__line';
    const type = document.createElement('span');
    type.className = 'entry__type';
    type.textContent = ENTRY_TYPE_LABEL[spec.eventType];
    line.appendChild(type);
    if (spec.primary) {
      // Plain-text separators keep the line in natural inline flow, so narrow
      // containers wrap between values — never a dangling flex item.
      const sep = document.createElement('span');
      sep.className = 'entry__sep';
      sep.textContent = ' · ';
      const primary = document.createElement('span');
      primary.className = 'entry__primary';
      primary.textContent = spec.primary;
      line.append(sep, primary);
    }
    if (spec.chip) {
      line.append(' ');
      line.appendChild(cloneChip(spec.chip, stLabel(spec.chip)));
    }
    body.appendChild(line);
    if (spec.secondary) {
      const secondary = document.createElement('p');
      secondary.className = 'entry__secondary';
      secondary.textContent = `“${spec.secondary}”`;
      body.appendChild(secondary);
    }
    li.append(badge, body);

    if (spec.meta) {
      const meta = document.createElement('span');
      meta.className = 'entry__meta';
      meta.textContent = spec.meta;
      li.appendChild(meta);
    }
    return li;
  }

  /** Card-dressed, clickable entry row that jumps to a drawer (the feed /
      conflict / impact treatment). */
  function entryCard(spec: EntrySpec, jump: { wa?: string; obs?: string }): HTMLLIElement {
    const li = entryRow(spec);
    li.classList.add('entry--card');
    if (jump.wa) li.dataset.wa = jump.wa;
    else if (jump.obs) li.dataset.obs = jump.obs;
    li.tabIndex = 0;
    li.setAttribute('role', 'button');
    return li;
  }

  // ── Map (Leaflet, lazy-built so a #data deep link doesn't init at 0×0) ──────
  let map: L.Map | null = null;
  const waMarkers = new Map<string, L.CircleMarker>();
  const obsDots = new Map<string, L.CircleMarker>(); // center/tracking dots, for the go-to highlight
  const obsLayers: L.Layer[] = []; // every observation layer (rings + dots) — hidden with the component
  const lastStatus = new Map<string, ClearanceStatus>();
  let bufferRings: L.Circle[] = []; // the Component Buffer overlay (rebuilt on toggle/edit/component)
  let initialBounds: L.LatLngBounds | null = null; // the boot fit — what the reset-view control restores
  let activeWaId: string | null = null;
  let activeObsId: string | null = null;

  // ── Zoom-adaptive marker sizing (ch2): at the program-wide boot extent
  //    (zoom ~10) 231 radius-9 markers smear into a blob — radii follow the
  //    zoom so dots resolve individually along the alignment. ≥13 keeps the
  //    original street-zoom sizes (and the legend keeps the ≥13 sizes).
  //    Observation buffers are geographic circles (L.circle) — they scale with
  //    the map on their own and are deliberately untouched. ──────────────────
  function waRadiusForZoom(z: number): number {
    if (z <= 10) return 4;
    if (z <= 11) return 4 + (z - 10) * 1.5; // 10→11: 4→5.5
    if (z <= 12) return 5.5 + (z - 11) * 1.5; // 11→12: 5.5→7
    if (z <= 13) return 7 + (z - 12) * 2; // 12→13: 7→9
    return 9;
  }
  let waR = 9; // current base work-area radius — set from zoom on build + zoomend
  const zoomScale = () => waR / 9;
  /** Observation dots ride ~55% of the WA radius (the round-1 5-vs-9 hierarchy). */
  const obsRadius = () => Math.max(2.5, waR * 0.55);
  const obsWeight = (o: Observation) => Math.max(0.75, (o.bufferFt > 0 ? 1.25 : 1.5) * zoomScale());

  /** Full marker style: solid status fill with white stroke — except
      provisional-block, which renders HOLLOW (white fill, bold red stroke):
      the system flagged it, no manager has solidified it. Radius and stroke
      follow the current zoom; the active (open-drawer) marker is enlarged —
      hover uses the same +2 via the mouseover handlers. */
  function markerStyle(st: ClearanceStatus, active = false): L.CircleMarkerOptions {
    const radius = active ? waR + 2 : waR;
    if (st === 'provisional-block') {
      const w = Math.max(1.5, 2.5 * zoomScale());
      return { radius, color: colorFor(st), weight: active ? w + 1 : w, opacity: 1, fillColor: '#ffffff', fillOpacity: 0.92 };
    }
    const w = Math.max(1, 2 * zoomScale());
    return { radius, color: '#ffffff', weight: active ? w + 1 : w, opacity: 1, fillColor: colorFor(st), fillOpacity: 0.95 };
  }

  /** Brief white-halo pulse so a save-induced status flip is unmissable. */
  function pulseMarker(m: L.CircleMarker) {
    const el = m.getElement() as SVGElement | null;
    if (!el) return;
    el.classList.remove('gc-pulse');
    void (el as unknown as HTMLElement).getBoundingClientRect();
    el.classList.add('gc-pulse');
    window.setTimeout(() => el.classList.remove('gc-pulse'), 2800);
  }

  /** Buffer circle (bufferFt > 0) + center dot, or a hollow dot for tracking-only
      sightings. All in the observation violet — a hue deliberately outside the
      status palette, because buffers are FACTS; the status colors are reserved
      for judgments. Dots run HALF the work-area radius (5 vs 9–11): work areas
      are the subject, observations are context — a violet dot must never read
      as a site. */
  function addObsLayers(o: Observation): L.Layer[] {
    if (!map) return [];
    const violet = obsColor();
    const layers: L.Layer[] = [];
    if (o.bufferFt > 0) {
      const circle = L.circle([o.lat, o.lng], {
        radius: o.bufferFt * 0.3048,
        color: violet,
        weight: 1.5,
        dashArray: '6 4',
        fillColor: violet,
        fillOpacity: 0.11,
      });
      circle.on('click', () => openObservation(o.id));
      circle.bindTooltip(`${o.species} · ${(o.bufferFt / 5280).toFixed(2).replace(/\.?0+$/, '')}-mi buffer`, {
        sticky: true,
        direction: 'top',
      });
      circle.addTo(map);
      layers.push(circle);
      const dot = L.circleMarker([o.lat, o.lng], {
        radius: obsRadius(),
        color: obsStroke(),
        weight: obsWeight(o),
        fillColor: violet,
        fillOpacity: 1,
      });
      dot.on('click', () => openObservation(o.id));
      dot.addTo(map);
      obsDots.set(o.id, dot);
      layers.push(dot);
    } else {
      const dot = L.circleMarker([o.lat, o.lng], {
        radius: obsRadius(),
        color: violet,
        weight: obsWeight(o),
        fillColor: '#ffffff',
        fillOpacity: 0.9,
      });
      dot.on('click', () => openObservation(o.id));
      dot.bindTooltip(`${o.species} · tracking only`, { sticky: true, direction: 'top' });
      dot.addTo(map);
      obsDots.set(o.id, dot);
      layers.push(dot);
    }
    return layers;
  }

  function buildMap() {
    map = L.map('gc-map', { zoomControl: true, attributionControl: true, zoomSnap: 0.25 });
    // Map/Satellite base layers — the Component Buffer overlay is a
    // satellite-mode analysis tool (BCN-1454), so the imagery base ships too.
    const baseMap = L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; OpenStreetMap &copy; CARTO',
      subdomains: 'abcd',
      maxZoom: 20,
    }).addTo(map);
    const baseSat = L.tileLayer(
      'https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',
      { attribution: '&copy; Esri', maxZoom: 19 }
    );
    L.control.layers({ Map: baseMap, Satellite: baseSat }, undefined, { position: 'topright' }).addTo(map);

    // Fit FIRST so every marker is born at the right zoom-adaptive size — the
    // boot view IS the full program extent (all sites carry geometry today;
    // an empty component keeps the program extent behind its empty state).
    initialBounds = L.latLngBounds(workAreas.map((w) => [w.lat, w.lng] as L.LatLngTuple));
    map.fitBounds(initialBounds, { padding: [40, 40] });
    waR = waRadiusForZoom(map.getZoom());

    // Buffers under the work-area markers: facts first, judgments on top.
    for (const o of activeObservations) obsLayers.push(...addObsLayers(o));
    syncObsVisibility();
    rebuildBufferRings();

    for (const wa of workAreas) {
      const st = statusOf(wa);
      const m = L.circleMarker([wa.lat, wa.lng], markerStyle(st));
      m.on('click', () => openWorkArea(wa.id));
      // Hover-enlarge adapts to the CURRENT zoom-adaptive base (+2).
      m.on('mouseover', () => m.setStyle({ radius: waR + 2 }));
      m.on('mouseout', () => m.setStyle({ radius: activeWaId === wa.id ? waR + 2 : waR }));
      m.bindTooltip(`${wa.id} · ${stLabel(st)}`, { sticky: true, direction: 'top', offset: [0, -8] });
      waMarkers.set(wa.id, m);
      lastStatus.set(wa.id, st);
      if (waShown(wa)) m.addTo(map);
    }

    // Zoom changed → recompute the base radius, restyle markers + observation
    // dots (buffers are geographic and scale on their own).
    map.on('zoomend', () => {
      if (!map) return;
      waR = waRadiusForZoom(map.getZoom());
      refreshMarkers();
      for (const [oid, dot] of obsDots) {
        const o = activeObservations.find((x) => x.id === oid);
        if (o) dot.setStyle({ radius: obsRadius(), weight: obsWeight(o) });
      }
    });

    // Reset-view backout — a custom L.Control directly under the zoom control,
    // dressed in Leaflet's own .leaflet-bar chrome (composition glue: this lives
    // inside Leaflet's control corner, out of reach of any esa- lego). Restores
    // the boot fit-bounds of all work areas after go-to jumps / manual panning.
    const ResetViewControl = L.Control.extend({
      options: { position: 'topleft' },
      onAdd() {
        const bar = L.DomUtil.create('div', 'leaflet-bar gc-reset');
        const btn = L.DomUtil.create('a', 'gc-reset__btn', bar) as HTMLAnchorElement;
        btn.href = '#';
        btn.title = 'Reset view to all work areas';
        btn.setAttribute('role', 'button');
        btn.setAttribute('aria-label', 'Reset view to all work areas');
        btn.innerHTML = ICON(
          '<path d="M8 3H5a2 2 0 0 0-2 2v3"/><path d="M21 8V5a2 2 0 0 0-2-2h-3"/><path d="M3 16v3a2 2 0 0 0 2 2h3"/><path d="M16 21h3a2 2 0 0 0 2-2v-3"/>'
        );
        L.DomEvent.on(btn, 'click', (e) => {
          L.DomEvent.preventDefault(e);
          L.DomEvent.stopPropagation(e);
          if (map && initialBounds) map.fitBounds(initialBounds, { padding: [40, 40] });
        });
        return bar;
      },
    });
    map.addControl(new ResetViewControl());
  }
  const ensureMap = () => (map ? map.invalidateSize() : buildMap());

  function refreshMarkers(pulseChanged = false) {
    if (!map) return;
    for (const wa of workAreas) {
      const st = statusOf(wa);
      const m = waMarkers.get(wa.id);
      if (!m) continue;
      // Full restyle, not just fill: a status flip can swap solid ↔ hollow
      // (provisional-block), and the radius/stroke follow the current zoom.
      m.setStyle(markerStyle(st, activeWaId === wa.id));
      m.setTooltipContent(`${wa.id} · ${stLabel(st)}`);
      if (pulseChanged && lastStatus.get(wa.id) !== st) pulseMarker(m);
      lastStatus.set(wa.id, st);
    }
  }

  /** Status is DERIVED, so a save can move a work area in/out of an active
      status filter — re-sync marker visibility (without refitting). The
      component scope rides waShown, so a component switch re-syncs here too. */
  function syncMarkerVisibility() {
    if (!map) return;
    for (const wa of workAreas) {
      const m = waMarkers.get(wa.id);
      if (!m) continue;
      if (waShown(wa)) m.addTo(map);
      else m.removeFrom(map);
    }
  }

  /** Observation layers (rings + dots) belong to the geotech program's sites —
      they hide with the component like the markers do. */
  function syncObsVisibility() {
    if (!map) return;
    const show = activeComponent === GEOTECH_COMPONENT;
    for (const layer of obsLayers) {
      if (show) layer.addTo(map);
      else layer.remove();
    }
  }

  /** The Component Buffer overlay (BCN-1454): one ring per work-area geometry
      at the buffer's distance, in the dedicated non-status blue. Rebuilt whole
      on toggle / edit / component switch — geometry never changes mid-session. */
  function rebuildBufferRings() {
    for (const ring of bufferRings) ring.remove();
    bufferRings = [];
    if (!map || !bufferOn) return;
    const buf = activeBuffer();
    const blue = cssVar('--cbuf-color', '#4575b4');
    for (const wa of componentWas()) {
      const ring = L.circle([wa.lat, wa.lng], {
        radius: buf.distanceFt * 0.3048,
        color: blue,
        weight: 1.25,
        dashArray: '2 4',
        fill: false,
        interactive: false,
      });
      ring.addTo(map);
      bufferRings.push(ring);
    }
  }

  /** The empty-component surfaces: the map's empty state replaces the marker
      story, and the readiness strip hides (a census of nothing reads wrong). */
  function syncComponentSurfaces() {
    const has = componentWas().length > 0;
    $('map-empty').hidden = has;
    const strip = document.querySelector<HTMLElement>('.readiness');
    if (strip) strip.hidden = !has;
  }

  /** Every interactive surface recomputes here: marker fills, readiness strip,
      both grids, the Activity feed, the View-bar counts, and any open drawer
      (including the inline review history). */
  function refreshAll(pulse = false) {
    refreshMarkers(pulse);
    syncMarkerVisibility();
    syncComponentSurfaces();
    refreshReadiness();
    refreshGrids();
    renderFeed();
    presets.options = presetOptions(); // label counts follow the derived statuses
    if (activeWaId) fillWaDialog(activeWaId); // repaints the inline review section too
    if (activeObsId) fillObsDialog(activeObsId);
  }

  // ── Readiness strip (census of the VISIBLE work areas) ──────────────────────
  function refreshReadiness() {
    const scoped = visibleWas();
    const counts = statusCounts(activeObservations, scoped);
    const countOf = (s: string) => counts.find((c) => c.status === s)?.count ?? 0;
    const total = scoped.length;
    const ready = countOf('cleared');
    $('rs-ready').textContent = String(ready);
    $('rs-total').textContent = `of ${total} work area${total === 1 ? '' : 's'}`;

    const bar = $('rs-bar');
    bar.innerHTML = '';
    for (const status of STATUS_ORDER) {
      const n = countOf(status);
      if (!n || !total) continue;
      const div = document.createElement('div');
      // Provisional Block stripes red/white — "not solidified", matching the
      // hollow markers (a solid segment would read as Blocked).
      const fill =
        status === 'provisional-block'
          ? 'repeating-linear-gradient(135deg, var(--st-provisional-block) 0 4px, var(--color-surface) 4px 7px)'
          : `var(--st-${status})`;
      div.style.cssText = `height:100%; flex: 0 0 ${(n / total) * 100}%; background:${fill};`;
      div.title = `${stLabel(status)}: ${n}`;
      bar.appendChild(div);
    }
    for (const status of STATUS_ORDER) {
      const n = countOf(status);
      const countEl = document.querySelector(`[data-rs-count="${status}"]`);
      if (countEl) countEl.textContent = String(n);
      const item = document.querySelector<HTMLElement>(`[data-rs-item="${status}"]`);
      if (item) item.dataset.empty = n ? 'false' : 'true';
    }
  }

  // ── AG Grids (beacon-grid kit; lazy-built when the Data tab first shows) ────
  const affectedWas = (o: Observation) =>
    o.bufferFt > 0 ? workAreas.filter((wa) => distanceFt(wa.lat, wa.lng, o.lat, o.lng) <= o.bufferFt) : [];

  // Work Areas view: identifier, derived status, clearance-visit date, and the
  // Work Area CUSTOM FIELDS as columns (the custom-fields-as-columns pattern) —
  // no forecasting columns (notification / planned-start / blocked-until are
  // out of scope for the epic).
  interface WaRow {
    id: string;
    status: ClearanceStatus;
    visitDate: string;
    method: string;
    depthFt: number | null;
    parcel: string;
    county: string;
    entryAgreement: string;
  }
  interface ObsRow {
    id: string;
    species: string;
    kind: string;
    statusKey: string;
    status: string;
    buffer: string;
    firstObserved: string;
    affected: number;
  }

  const buildWaRows = (): WaRow[] =>
    componentWas().map((wa) => ({
      id: wa.id,
      status: statusOf(wa),
      visitDate: formatDate(wa.clearanceVisitDate),
      method: wa.method ?? '—',
      depthFt: wa.depthFt ?? null,
      parcel: [wa.parcelApn, wa.dcpn].filter(Boolean).join(' · ') || '—',
      county: wa.county ?? '—',
      entryAgreement: wa.entryAgreement ?? '—',
    }));

  const buildObsRows = (): ObsRow[] =>
    (activeComponent === GEOTECH_COMPONENT ? activeObservations : []).map((o) => ({
      id: o.id,
      species: o.species,
      kind: KIND_LABEL[o.kind] ?? o.kind,
      statusKey: o.status,
      status: OBS_STATUS_LABEL[o.status] ?? o.status,
      buffer: o.bufferFt > 0 ? o.bufferFt.toLocaleString() : '—',
      firstObserved: formatDate(o.firstObserved),
      affected: affectedWas(o).length,
    }));

  // Chip renderer reads the runtime --st-* vars (the committed field-map palette).
  // Wrapped to tag the status on the element: the shared kit renderer only sets
  // the color var, and provisional-block needs the page's outlined-chip CSS hook.
  const waChipBase = makeStatusRenderer(
    Object.fromEntries(STATUS_ORDER.map((s) => [s, { label: stLabel(s), hex: `var(--st-${s})` }]))
  );
  const waChip = (p: ICellRendererParams) => {
    const el = waChipBase(p);
    if (el instanceof HTMLElement) el.dataset.status = String(p.value);
    return el;
  };

  let statusFacet: string[] = [];
  let wasApi: GridApi<WaRow> | null = null;
  let obsApi: GridApi<ObsRow> | null = null;
  let pivotValue = 'workareas';
  const activeApi = (): GridApi<WaRow> | GridApi<ObsRow> | null => (pivotValue === 'workareas' ? wasApi : obsApi);

  function updateCounts() {
    const api = activeApi();
    if (!api) return;
    const total =
      pivotValue === 'workareas'
        ? componentWas().length
        : activeComponent === GEOTECH_COMPONENT
          ? activeObservations.length
          : 0;
    const displayed = api.getDisplayedRowCount();
    $('gc-total').textContent = String(total);
    const filteredEl = $('gc-filtered');
    if (displayed < total) {
      filteredEl.hidden = false;
      filteredEl.textContent = `Filtered Records: ${displayed}`;
    } else {
      filteredEl.hidden = true;
    }
  }

  function ensureGrids() {
    if (wasApi) return;

    // Every column flex-sized (no fixed widths) so they fill the grid
    // edge-to-edge at any viewport. minWidth only guards squish.
    const waCols: ColDef<WaRow>[] = [
      { field: 'id', headerName: 'ID', flex: 1, minWidth: 130 },
      {
        field: 'status',
        headerName: 'Status',
        flex: 1.3,
        minWidth: 170,
        cellRenderer: waChip,
        cellClass: 'bcn-grid-status-cell',
        filterValueGetter: (p) => stLabel(p.data!.status),
      },
      { field: 'visitDate', headerName: 'Visit Date', flex: 1, minWidth: 120 },
      { field: 'method', headerName: 'Method', flex: 0.8, minWidth: 100 },
      { field: 'depthFt', headerName: 'Depth (ft)', flex: 0.8, minWidth: 100, type: 'numericColumn' },
      { field: 'parcel', headerName: 'Parcel / DCPN', flex: 1.4, minWidth: 180 },
      { field: 'county', headerName: 'County', flex: 0.9, minWidth: 110 },
      { field: 'entryAgreement', headerName: 'Entry Agreement', flex: 1, minWidth: 140 },
    ];

    const obsCols: ColDef<ObsRow>[] = [
      { field: 'id', headerName: 'ID', flex: 0.8, minWidth: 110 },
      { field: 'species', headerName: 'Species', flex: 1.6, minWidth: 180 },
      { field: 'kind', headerName: 'Kind', flex: 1, minWidth: 120 },
      { field: 'status', headerName: 'Status', flex: 0.9, minWidth: 110 },
      { field: 'buffer', headerName: 'Buffer (ft)', flex: 0.9, minWidth: 110, type: 'numericColumn' },
      { field: 'firstObserved', headerName: 'First Observed', flex: 1, minWidth: 140 },
      { field: 'affected', headerName: 'Work Areas Affected', flex: 1.1, minWidth: 170, type: 'numericColumn' },
    ];

    const shared = {
      theme: beaconTheme,
      defaultColDef: {
        sortable: true,
        resizable: true,
        filter: true,
        floatingFilter: false,
        suppressHeaderMenuButton: true,
      },
      onFilterChanged: updateCounts,
      onFirstDataRendered: updateCounts,
    };

    const waOptions: GridOptions<WaRow> = {
      ...shared,
      rowData: buildWaRows(),
      columnDefs: waCols,
      isExternalFilterPresent: () => statusFacet.length > 0,
      doesExternalFilterPass: (node: IRowNode<WaRow>) =>
        !node.data || !statusFacet.length || statusFacet.includes(node.data.status),
      onRowClicked: (e) => e.data && openWorkArea(e.data.id),
    };

    const obsOptions: GridOptions<ObsRow> = {
      ...shared,
      rowData: buildObsRows(),
      columnDefs: obsCols,
      isExternalFilterPresent: () => statusFacet.length > 0,
      doesExternalFilterPass: (node: IRowNode<ObsRow>) =>
        !node.data || !statusFacet.length || statusFacet.includes(node.data.statusKey),
      onRowClicked: (e) => e.data && openObservation(e.data.id),
    };

    wasApi = createGrid($('grid-was'), waOptions);
    obsApi = createGrid($('grid-obs'), obsOptions);
  }

  function refreshGrids() {
    wasApi?.setGridOption('rowData', buildWaRows());
    obsApi?.setGridOption('rowData', buildObsRows());
    updateCounts();
  }

  // ── Filter bar wiring (Data tab) ─────────────────────────────────────────────
  // Clearance-status options carry the lego's per-option color dot, fed the SAME
  // runtime --st-* vars the markers/legend/chips read — always in lockstep. The
  // observation pivot's active/tracking values are not clearance statuses and
  // have no --st-* color, so they stay dotless.
  const statusFilterOptions = () =>
    STATUS_ORDER.map((s) => ({ value: s, label: stLabel(s), color: `var(--st-${s})` }));
  const fltStatus = $('flt-status') as FilterDropdownEl;
  const statusOptionsFor = (pivot: string) =>
    pivot === 'workareas'
      ? statusFilterOptions()
      : Object.entries(OBS_STATUS_LABEL).map(([value, label]) => ({ value, label }));
  fltStatus.options = statusOptionsFor('workareas');

  fltStatus.addEventListener('selection-change', (e) => {
    statusFacet = ((e as CustomEvent).detail?.value as string[]) ?? [];
    activeApi()?.onFilterChanged();
  });

  $('gc-clear-filters').addEventListener('esa-filter-clear', () => {
    statusFacet = [];
    fltStatus._selected = [];
    wasApi?.setFilterModel(null);
    obsApi?.setFilterModel(null);
    wasApi?.onFilterChanged();
    obsApi?.onFilterChanged();
  });

  // Keyword search → quick filter on both grids.
  const search = $('gc-search') as HTMLElement & { value: string; placeholder: string };
  const searchClear = $('gc-search-clear');
  search.addEventListener('change', (e) => {
    const v = (e as CustomEvent).detail?.value ?? search.value ?? '';
    wasApi?.setGridOption('quickFilterText', v);
    obsApi?.setGridOption('quickFilterText', v);
    searchClear.hidden = !v;
  });
  searchClear.addEventListener('click', () => {
    search.value = '';
    wasApi?.setGridOption('quickFilterText', '');
    obsApi?.setGridOption('quickFilterText', '');
    searchClear.hidden = true;
  });

  // Pivot toggle (esa-button-toggle lego)
  const pivot = $('pivot-toggle') as ToggleEl;
  pivot.options = [
    { value: 'workareas', label: 'Work Areas' },
    { value: 'observations', label: 'Observations' },
  ];
  pivot.addEventListener('change', (e) => {
    pivotValue = ((e as CustomEvent).detail?.value as string) ?? pivot.value;
    const isWas = pivotValue === 'workareas';
    $('pane-was').hidden = !isWas;
    $('pane-obs').hidden = isWas;
    search.placeholder = isWas ? 'Search work areas…' : 'Search observations…';
    // Status values differ per pivot (clearance ladder vs active/tracking) — swap + reset.
    statusFacet = [];
    fltStatus._selected = [];
    fltStatus.options = statusOptionsFor(pivotValue);
    wasApi?.onFilterChanged();
    obsApi?.onFilterChanged();
    updateCounts();
  });

  $('gc-download').addEventListener('click', () =>
    activeApi()?.exportDataAsCsv({ fileName: `site-clearance-${pivotValue}.csv` })
  );

  // ── Work-area drawer (read mode) ────────────────────────────────────────────
  const waDialog = $('wa-dialog') as SideDialog;
  const obsDialog = $('obs-dialog') as SideDialog;

  /** Update an EsaCollapsible's SSR title text (live counts on the summary rows). */
  function setCollapsibleTitle(wrapId: string, title: string) {
    const el = document.querySelector(`#${wrapId} .esa-collapsible__title`);
    if (el) el.textContent = title;
  }

  /** The work area's notes, newest first (append-only monitor records). */
  const sortedNotes = (wa: WorkArea): ClearanceNote[] =>
    [...wa.notes].sort((a, b) => b.date.localeCompare(a.date));

  /** The append-only notes list — date · author meta over the verbatim text.
      `deletable` adds the trash affordance (a note can be deleted but never
      edited); delete is read-mode only, so the edit form stays an add surface. */
  function renderNotes(list: HTMLElement, wa: WorkArea, deletable: boolean) {
    list.innerHTML = '';
    for (const n of sortedNotes(wa)) {
      const li = document.createElement('li');
      li.className = 'wnote';
      const head = document.createElement('div');
      head.className = 'wnote__head';
      const meta = document.createElement('span');
      meta.className = 'wnote__meta';
      meta.textContent = `${formatDate(n.date)} · ${n.author}`;
      head.appendChild(meta);
      if (deletable) {
        const del = (
          document.querySelector<HTMLTemplateElement>('#note-del-tpl')!.content.firstElementChild as HTMLElement
        ).cloneNode(true) as HTMLElement;
        del.addEventListener('click', () => {
          const idx = wa.notes.indexOf(n);
          if (idx >= 0) wa.notes.splice(idx, 1);
          logChange(wa.id, 'note', `Deleted · ${formatDate(n.date)} · ${n.author}`);
          refreshAll();
        });
        head.appendChild(del);
      }
      const text = document.createElement('p');
      text.className = 'wnote__text';
      text.textContent = n.text;
      li.append(head, text);
      list.appendChild(li);
    }
  }

  function renderActivity(waId: string) {
    const act = $('wa-activity');
    act.innerHTML = '';
    const entries = entriesFor(waId).slice(0, 10);
    if (!entries.length) {
      const li = document.createElement('li');
      li.className = 'entry entry--empty';
      li.textContent = 'No changes yet — edits made here are logged.';
      act.appendChild(li);
      return;
    }
    // Same deterministic anatomy as the feed (one renderer — ch3): the badge is
    // this work area's own ID, so the rows read identically everywhere.
    for (const c of entries) {
      act.appendChild(
        entryRow({
          badgeId: waId,
          badgeKind: 'wa',
          eventType: c.kind,
          primary: c.primary,
          secondary: c.secondary,
          chip: c.chip,
          meta: `${fmtTs(c.ts)} · ${c.user}`,
        })
      );
    }
  }

  function fillWaDialog(id: string) {
    const wa = waById.get(id);
    if (!wa) return;
    const st = statusOf(wa);
    waDialog.heading = wa.id; // aria-label; the visible header is the slot
    $('wa-title').textContent = wa.id;
    $('wa-sub').textContent = wa.component;
    applyChip($('wa-chip'), st, stLabel(st));

    // Clearance-visit band — the one date the clearance carries.
    $('wa-d-visit').textContent = formatDate(wa.clearanceVisitDate);

    // The inline review history
    fillReviews(wa);

    // Notes collapsible — append-only monitor records; hidden when empty.
    $('wa-notes-col').hidden = wa.notes.length === 0;
    setCollapsibleTitle('wa-notes-col', `Notes (${wa.notes.length})`);
    renderNotes($('wa-notes-added'), wa, true);

    // Change feed
    renderActivity(wa.id);

    // Comments thread (per work area)
    renderComments(wa.id);
  }

  function openWorkArea(id: string) {
    if (obsDialog.open) obsDialog.close();
    activeWaId = id;
    editing = false;
    hideReviewForm(); // reset the inline review form on a fresh open
    syncMode();
    fillWaDialog(id);
    waDialog.show();
    refreshMarkers(); // re-applies full styles — the active marker enlarges at the current zoom base
  }
  waDialog.addEventListener('close', () => {
    activeWaId = null;
    editing = false;
    syncMode();
    refreshMarkers();
  });

  // ── Work-area comments + @-mention (ported from permit tracking, BCN-1364) ──
  //    A per-work-area collaboration thread, distinct from the read-only
  //    Activity log. @-mentions of project users render highlighted (and would
  //    feed email notifications). Rendered live (per-work-area, postable), so it
  //    can't be the static BcnDiscussion SSR component.
  const CURRENT_USER = 'Andy Lovseth';
  const PROJECT_USERS = ['Leah McNearney', 'C. Anderson', 'H. Barbare', 'Andy Lovseth', 'Marco Reyes'];
  const AVATAR_TOKENS = ['--color-source', '--color-commitment', '--color-requirement', '--color-action'];
  interface WaComment {
    author: string;
    ts: string;
    text: string;
  }
  // Seed the two SWHA-adjacent work areas so the thread reads populated.
  const commentsByWa: Record<string, WaComment[]> = {
    'DCTR2-DH-010': [
      { author: 'C. Anderson', ts: '2026-05-18T15:10:00', text: 'Active SWHA nest confirmed within the 0.5-mi buffer on the clearance visit. @Leah McNearney flagging — this blocks the DH until the est. fledge date.' },
      { author: 'Leah McNearney', ts: '2026-05-19T08:42:00', text: 'Thanks. Holding work here until the post-fledge re-survey clears it. @Andy Lovseth keep this one on the watch list.' },
    ],
    'DCTR2-DH-012': [
      { author: 'H. Barbare', ts: '2026-05-27T11:20:00', text: 'Closest DH to the nest after DH-010 — 30-day notification went out 5/15 for a 6/16 clearance visit. @Leah McNearney heads up on the buffer overlap.' },
    ],
  };

  const cInitials = (name: string): string =>
    name.split(/\s+/).map((w) => w[0]).slice(0, 2).join('').toUpperCase();
  const cToken = (name: string): string => {
    const i = PROJECT_USERS.indexOf(name);
    return `var(${AVATAR_TOKENS[(i < 0 ? 0 : i) % AVATAR_TOKENS.length]})`;
  };
  const cEscape = (s: string): string =>
    s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  const cTime = (ts: string): string =>
    new Date(ts).toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' });
  // Wrap "@Name" tokens (known users) in a highlight; the current user stands out.
  function cMentions(text: string): string {
    let html = cEscape(text);
    for (const u of [...PROJECT_USERS].sort((a, b) => b.length - a.length)) {
      const cls = u === CURRENT_USER ? 'wc-mention wc-mention--me' : 'wc-mention';
      html = html.split('@' + u).join(`<span class="${cls}">@${u}</span>`);
    }
    return html;
  }

  function renderComments(waId: string) {
    const list = $('wa-comments');
    const arr = commentsByWa[waId] ?? [];
    $('wa-comment-count').innerHTML = arr.length ? `<span class="wc-badge">${arr.length}</span>` : '';
    list.innerHTML = '';
    if (!arr.length) {
      list.innerHTML = `<li class="wc-comment wc-comment--empty">No comments yet. Start the discussion.</li>`;
    }
    for (const c of arr) {
      const li = document.createElement('li');
      li.className = 'wc-comment';
      li.innerHTML = `
        <span class="wc-comment__avatar" style="--_c:${cToken(c.author)}">${cInitials(c.author)}</span>
        <div class="wc-comment__body">
          <div class="wc-comment__meta"><span class="wc-comment__author">${cEscape(c.author)}</span><span class="wc-comment__time">${cTime(c.ts)}</span></div>
          <p class="wc-comment__text">${cMentions(c.text)}</p>
        </div>`;
      list.appendChild(li);
    }
    // Clear via the esa-textarea HOST property (it re-syncs its own value onto
    // the inner <textarea>, so clearing only the inner node doesn't stick).
    const host = $('wa-comment-input') as HTMLElement & { value?: string };
    host.value = '';
    const ta = getCommentTA();
    if (ta) ta.value = '';
    hideMentionMenu();
  }

  // The esa-textarea wraps a native <textarea> in shadow DOM; operating on that
  // inner element gives reliable value + caret access for the @-mention typeahead.
  let _commentTA: HTMLTextAreaElement | null = null;
  function getCommentTA(): HTMLTextAreaElement | null {
    if (_commentTA && _commentTA.isConnected) return _commentTA;
    const host = $('wa-comment-input');
    _commentTA = (host.shadowRoot?.querySelector('textarea') ?? host.querySelector('textarea')) as HTMLTextAreaElement | null;
    return _commentTA;
  }

  const mentionMenu = $('wa-mention-menu');
  let mentionAt = -1; // index of the '@' that opened the menu
  const hideMentionMenu = () => {
    mentionMenu.hidden = true;
    mentionAt = -1;
  };
  function updateMentionMenu() {
    const ta = getCommentTA();
    if (!ta) return;
    const upto = ta.value.slice(0, ta.selectionStart ?? ta.value.length);
    const m = upto.match(/@([A-Za-z]*)$/);
    if (!m) return hideMentionMenu();
    const partial = m[1].toLowerCase();
    const matches = PROJECT_USERS.filter((u) => u !== CURRENT_USER && u.toLowerCase().startsWith(partial));
    if (!matches.length) return hideMentionMenu();
    mentionAt = m.index ?? 0;
    mentionMenu.innerHTML = matches
      .map(
        (u) =>
          `<li class="wc-mention-opt" role="option" data-user="${u}"><span class="wc-comment__avatar wc-comment__avatar--xs" style="--_c:${cToken(u)}">${cInitials(u)}</span>${u}</li>`
      )
      .join('');
    mentionMenu.hidden = false;
  }
  function insertMention(user: string) {
    const ta = getCommentTA();
    if (!ta || mentionAt < 0) return;
    const caret = ta.selectionStart ?? ta.value.length;
    ta.value = ta.value.slice(0, mentionAt) + '@' + user + ' ' + ta.value.slice(caret);
    const pos = mentionAt + user.length + 2;
    ta.focus();
    ta.setSelectionRange(pos, pos);
    hideMentionMenu();
  }
  function bindCommentEvents() {
    const ta = getCommentTA();
    if (!ta || ta.dataset.bound) return;
    ta.dataset.bound = '1';
    ta.addEventListener('input', updateMentionMenu);
    ta.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Escape' && !mentionMenu.hidden) {
        e.stopPropagation();
        hideMentionMenu();
      }
    });
    ta.addEventListener('blur', () => setTimeout(hideMentionMenu, 150));
  }
  $('wa-comment-input').addEventListener('focusin', bindCommentEvents);
  mentionMenu.addEventListener('mousedown', (e) => {
    const opt = (e.target as HTMLElement).closest<HTMLElement>('[data-user]');
    if (opt) {
      e.preventDefault();
      insertMention(opt.dataset.user!);
    }
  });
  $('wa-comment-post').addEventListener('click', () => {
    const ta = getCommentTA();
    if (!ta || !activeWaId) return;
    const text = ta.value.trim();
    if (!text) return;
    (commentsByWa[activeWaId] ??= []).push({ author: CURRENT_USER, ts: new Date().toISOString(), text });
    renderComments(activeWaId);
  });

  // ── Inline review history + write surface (#dd-* ids). The review is the
  //    write path: a dated determination with a REQUIRED outcome — there is no
  //    scheduled review, no stipulations field, no blocked-until horizon. ───────
  let editingReview: ClearanceReview | null = null; // null = the form is adding

  /** Paint the inline review section — the review count + the reverse-chron
      history rail (the latest review sets the status, shown on the drawer
      header chip). */
  function fillReviews(wa: WorkArea) {
    const revs = clearanceReviews(wa);
    $('dd-count').textContent = `${revs.length} review${revs.length === 1 ? '' : 's'}`;
    renderHistory(wa);
  }

  /** One review-history node: kind + when + pencil, outcome chip, the teal
      "Sets current status" tag on the latest, note. */
  function reviewNode(r: ClearanceReview, isCurrent: boolean): HTMLLIElement {
    const li = document.createElement('li');
    li.className = 'rev';
    const dot = document.createElement('span');
    dot.className = 'rev__dot';
    dot.style.background = `var(--st-${r.outcome})`;
    dot.style.borderColor = `var(--st-${r.outcome})`;

    const main = document.createElement('div');
    main.className = 'rev__main';

    const head = document.createElement('p');
    head.className = 'rev__head';
    head.append(REVIEW_KIND_LABEL[r.kind]);
    const when = document.createElement('span');
    when.className = 'rev__when';
    when.textContent = `${formatDate(r.date)}${r.reviewer ? ` · ${r.reviewer}` : ''}`;
    head.appendChild(when);
    const edit = (
      document.querySelector<HTMLTemplateElement>('#dd-edit-tpl')!.content.firstElementChild as HTMLElement
    ).cloneNode(true) as HTMLElement;
    head.appendChild(edit);
    main.appendChild(head);

    const chiprow = document.createElement('div');
    chiprow.className = 'rev__chiprow';
    chiprow.appendChild(cloneChip(r.outcome, stLabel(r.outcome)));
    if (isCurrent) {
      const cur = document.createElement('span');
      cur.className = 'rev__current';
      cur.textContent = 'Sets current status';
      chiprow.appendChild(cur);
    }
    main.appendChild(chiprow);

    if (r.note) {
      const note = document.createElement('p');
      note.className = 'rev__note';
      note.textContent = r.note;
      main.appendChild(note);
    }

    li.append(dot, main);
    return li;
  }

  function renderHistory(wa: WorkArea) {
    const listEl = $('dd-history');
    listEl.innerHTML = '';
    const revs = clearanceReviews(wa);
    const cur = currentReview(wa);
    if (!revs.length) {
      const li = document.createElement('li');
      li.className = 'entry entry--empty';
      li.textContent = 'No reviews on record — add the first one.';
      listEl.appendChild(li);
    }
    for (const r of revs) {
      const li = reviewNode(r, r === cur);
      li.querySelector('.rev__edit')!.addEventListener('click', () => beginEditReview(r, li));
      listEl.appendChild(li);
    }
  }

  // ── The Add/Edit review form ────────────────────────────────────────────────
  const ddForm = $('dd-form');
  // Kind reads the tenant's configurable clearance-review-kind list (DCP seed:
  // 14-day clearance, 72-hour clearance, Management determination).
  const ddKind = $('dd-kind') as SelectEl;
  ddKind.options = REVIEW_KINDS.map((k) => ({ value: k, label: REVIEW_KIND_LABEL[k] }));
  // Outcome is the FIXED recordable set — Cleared, Inaccessible, Blocked.
  // Not-surveyed is the absence of reviews and provisional-block stays
  // derived-only; neither is recordable.
  const ddOutcome = $('dd-outcome') as SelectEl;
  ddOutcome.options = OUTCOMES.map((s) => ({ value: s, label: stLabel(s) }));

  function setReviewForm(r: Partial<ClearanceReview>) {
    ddKind.value = r.kind ?? '14-day-clearance';
    ($('dd-date') as Field).value = r.date ?? TODAY;
    ddOutcome.value = r.outcome ?? 'cleared';
    ($('dd-reviewer') as Field).value = r.reviewer ?? '';
    ($('dd-note') as Field).value = r.note ?? '';
  }

  /** The form lives in ONE place at a time: its home above the history (add),
      or swapped into the node being edited (the pencil affordance). */
  function showFormAtTop() {
    $('dd-history').before(ddForm);
    ddForm.hidden = false;
  }
  function hideReviewForm() {
    $('dd-history').before(ddForm); // return to the home slot
    ddForm.hidden = true;
    editingReview = null;
  }

  $('dd-add').addEventListener('click', () => {
    const wa = activeWaId ? waById.get(activeWaId) : null;
    if (!wa) return;
    editingReview = null;
    // Sensible default: the first visit is the 14-day clearance; later visits
    // are usually the 72-hour pre-work check.
    setReviewForm({ kind: clearanceReviews(wa).length ? '72-hour-clearance' : '14-day-clearance' });
    renderHistory(wa); // restore any node the form was swapped into
    showFormAtTop();
  });

  function beginEditReview(r: ClearanceReview, node: HTMLLIElement) {
    const wa = activeWaId ? waById.get(activeWaId) : null;
    if (!wa) return;
    renderHistory(wa); // collapse any other open edit first
    const freshNode = [...$('dd-history').children][[...clearanceReviews(wa)].indexOf(r)] ?? node;
    editingReview = r;
    setReviewForm(r);
    // Swap the node's content for the form — the history line literally
    // becomes the editor (the moved element keeps its lego state/listeners).
    (freshNode as HTMLElement).replaceChildren(ddForm);
    (freshNode as HTMLElement).classList.add('rev--editing');
    ddForm.hidden = false;
  }

  $('dd-cancel').addEventListener('click', () => {
    const wa = activeWaId ? waById.get(activeWaId) : null;
    hideReviewForm();
    if (wa) renderHistory(wa);
  });

  function collectReview(): ClearanceReview {
    const kind = ((ddKind.value as string) || '14-day-clearance') as ReviewKind;
    const outcome = ((ddOutcome.value as string) || 'cleared') as ClearanceReview['outcome'];
    const r: ClearanceReview = { kind, date: ($('dd-date') as Field).value || TODAY, outcome };
    const reviewer = (($('dd-reviewer') as Field).value ?? '').trim();
    if (reviewer) r.reviewer = reviewer;
    const note = (($('dd-note') as Field).value ?? '').trim();
    if (note) r.note = note;
    return r;
  }

  $('dd-save').addEventListener('click', () => {
    const wa = activeWaId ? waById.get(activeWaId) : null;
    if (!wa) return;
    const next = collectReview();
    if (editingReview) {
      const idx = wa.reviews.indexOf(editingReview);
      if (idx >= 0) wa.reviews[idx] = next;
      else wa.reviews.push(next);
      logChange(wa.id, 'edit', `${REVIEW_KIND_LABEL[next.kind]} updated`, { chip: next.outcome });
    } else {
      wa.reviews.push(next);
      // Adding a review auto-updates the clearance-visit date (the epic's rule).
      if (wa.clearanceVisitDate !== next.date) {
        wa.clearanceVisitDate = next.date;
      }
      logChange(wa.id, 'edit', `${REVIEW_KIND_LABEL[next.kind]} added`, { chip: next.outcome });
    }
    hideReviewForm();
    refreshAll(true); // re-derives + repaints everything incl. this drawer
  });

  // ── Work-area drawer (EDIT mode — SITE-LEVEL only: the clearance-visit date
  //    + the append-only note). Same esa-side-dialog, two stacked bodies:
  //    #wa-read ↔ #wa-edit, footer swaps "Edit site details" for Cancel/Save
  //    (permit-tracking's affordance placement). Reviews are edited inline in
  //    read mode, never here. ──────────────────────────────────────────────────
  let editing = false;
  function syncMode() {
    $('wa-read').hidden = editing;
    $('wa-edit').hidden = !editing;
    $('wa-edit-btn').hidden = editing;
    $('wa-showmap').hidden = editing; // a mid-edit map jump would discard the form
    $('wa-cancel').hidden = !editing;
    $('wa-save').hidden = !editing;
  }

  function enterEdit() {
    const wa = activeWaId ? waById.get(activeWaId) : null;
    if (!wa) return;
    editing = true;
    ($('we-visit') as Field).value = wa.clearanceVisitDate ?? '';
    // Notes — existing notes stay read-only here (delete lives on the read
    // list); the add-note form starts fresh, dated TODAY.
    renderNotes($('we-notes-added'), wa, false);
    ($('we-note-date') as Field).value = TODAY;
    ($('we-note-author') as Field).value = '';
    ($('we-note-text') as Field).value = '';
    syncMode();
  }
  $('wa-edit-btn').addEventListener('click', enterEdit);
  $('wa-cancel').addEventListener('click', () => {
    editing = false;
    syncMode();
  });

  function saveWa() {
    const wa = activeWaId ? waById.get(activeWaId) : null;
    if (!wa) return;

    // The clearance-visit date — directly editable; empty picker = no date.
    const nextVisit = ($('we-visit') as Field).value || undefined;
    if (wa.clearanceVisitDate !== nextVisit) {
      logChange(wa.id, 'edit', `Clearance visit · ${formatDate(wa.clearanceVisitDate)} → ${formatDate(nextVisit)}`);
      wa.clearanceVisitDate = nextVisit;
    }

    // Append-only note (the paste-from-email affordance).
    const text = (($('we-note-text') as Field).value ?? '').trim();
    if (text) {
      const date = ($('we-note-date') as Field).value || TODAY;
      const author = (($('we-note-author') as Field).value ?? '').trim() || 'Unknown';
      wa.notes.push({ date, author, text });
      logChange(wa.id, 'note', `${formatDate(date)} · ${author}`, { secondary: text });
    }

    editing = false;
    refreshAll(true); // re-derive + repaint: marker fills (pulse on flips), strip, grids, drawer read mode
    syncMode();
  }
  $('wa-save').addEventListener('click', saveWa);

  // ── Observation drawer (read-only, compact) ─────────────────────────────────
  function fillObsDialog(id: string) {
    const o = activeObservations.find((x) => x.id === id);
    if (!o) return;
    obsDialog.heading = o.species;
    $('obs-title').textContent = o.species;
    $('obs-sub').textContent = o.id;
    applyChip($('obs-chip'), 'neutral', o.status === 'active' ? 'Active' : 'Tracking only');
    $('obs-code').textContent = o.speciesCode;
    $('obs-kind').textContent = KIND_LABEL[o.kind] ?? o.kind;
    $('obs-buffer').textContent = o.bufferFt > 0 ? `${o.bufferFt.toLocaleString()} ft` : 'None (tracking only)';
    $('obs-first').textContent = formatDate(o.firstObserved);

    const logWrap = $('obs-log-wrap');
    logWrap.hidden = !o.latestLog;
    $('obs-log').textContent = o.latestLog ?? '';

    // Work areas within buffer — the cross-site impact view
    const within = affectedWas(o)
      .map((wa) => ({ wa, d: distanceFt(wa.lat, wa.lng, o.lat, o.lng) }))
      .sort((a, b) => a.d - b.d);
    const badge = $('obs-impact-count').querySelector('.esa-badge__text');
    if (badge) badge.textContent = String(within.length);
    const list = $('obs-impact');
    list.innerHTML = '';
    if (!within.length) {
      const li = document.createElement('li');
      li.className = 'entry entry--empty';
      li.textContent = o.bufferFt > 0 ? 'No work areas inside this buffer.' : 'Tracking-only sighting — no buffer.';
      list.appendChild(li);
    }
    for (const { wa, d } of within) {
      list.appendChild(
        entryCard(
          {
            badgeId: wa.id,
            badgeKind: 'wa',
            eventType: 'work-area',
            primary: wa.method ?? '',
            chip: statusOf(wa),
            meta: fmtDistance(d),
          },
          { wa: wa.id }
        )
      );
    }
  }

  function openObservation(id: string) {
    if (waDialog.open) waDialog.close();
    activeObsId = id;
    fillObsDialog(id);
    obsDialog.show();
  }
  obsDialog.addEventListener('close', () => {
    activeObsId = null;
  });

  // Impact rows jump from the observation drawer to the work-area drawer.
  $('obs-impact').addEventListener('click', (e) => {
    const li = (e.target as HTMLElement).closest<HTMLElement>('[data-wa]');
    if (li) openWorkArea(li.dataset.wa!);
  });

  // ── Map Status filter (above the map) — the SAME filter lego as the Data
  //    tab, multi-select; empty = all. Scopes markers + the readiness strip. ────
  const mapFltStatus = $('map-flt-status') as FilterDropdownEl;
  mapFltStatus.options = statusFilterOptions();
  mapFltStatus.addEventListener('selection-change', (e) => {
    statusFilters = ((e as CustomEvent).detail?.value as string[]) ?? [];
    syncPresetSelection(); // hand-edited facets deselect to no-pill unless they match a set
    applyMapFilters();
  });

  $('map-clear-filters').addEventListener('esa-filter-clear', () => {
    statusFilters = [];
    mapFltStatus._selected = [];
    syncPresetSelection(); // empty facets = the All pill
    applyMapFilters();
  });

  // ── View segmented bar — All + one pill per display status (live counts),
  //    over the SAME facet state the Status dropdown edits (one source of
  //    truth: statusFilters). Pressing a pill SETS the facets; the toggle reads
  //    as selected only while the facets EXACTLY equal a pill's set. Counts
  //    ride the labels as plain text (refreshed by refreshAll as statuses
  //    re-derive). Provisional blocks count under Blocked — on a go/no-go
  //    surface "Blocked" means everything red, solid or hollow. ────────────────
  const PRESET_SETS: Record<string, ClearanceStatus[]> = {
    all: [],
    cleared: ['cleared'],
    blocked: ['blocked', 'provisional-block'],
    inaccessible: ['inaccessible'],
    'not-surveyed': ['not-surveyed'],
  };
  const PRESET_LABELS: Record<string, string> = {
    all: 'All',
    cleared: 'Cleared',
    blocked: 'Blocked',
    inaccessible: 'Inaccessible',
    'not-surveyed': 'Not Surveyed',
  };
  const presets = $('view-presets') as ToggleEl;
  function presetOptions(): { value: string; label: string }[] {
    const scoped = componentWas();
    const counts = statusCounts(activeObservations, scoped);
    const countOf = (s: ClearanceStatus) => counts.find((c) => c.status === s)?.count ?? 0;
    return Object.keys(PRESET_SETS).map((key) => {
      const set = PRESET_SETS[key];
      const n = set.length ? set.reduce((sum, s) => sum + countOf(s), 0) : scoped.length;
      return { value: key, label: `${PRESET_LABELS[key]} (${n})` };
    });
  }
  /** Selected pill = the one whose set EXACTLY equals the current facets
      (order-insensitive); anything else deselects the whole group. */
  function syncPresetSelection() {
    const cur = [...statusFilters].sort().join('|');
    const match = Object.keys(PRESET_SETS).find((key) =>
      key === 'all' ? statusFilters.length === 0 : [...PRESET_SETS[key]].sort().join('|') === cur
    );
    presets.value = match ?? '';
  }
  presets.options = presetOptions();
  presets.addEventListener('change', (e) => {
    const key = ((e as CustomEvent).detail?.value as string) ?? presets.value;
    statusFilters = [...(PRESET_SETS[key] ?? [])];
    mapFltStatus._selected = [...statusFilters]; // drive the dropdown — one source of truth
    applyMapFilters();
  });

  function applyMapFilters() {
    syncMarkerVisibility();
    refreshReadiness();
  }

  // ── Component picker (beside the H1) — esa-dropdown-menu over the real DCP
  //    component register, rendered as a plain option list (the standard
  //    select-panel look; the trigger label already names the active one).
  //    Selecting re-scopes every surface; the choice persists in browser
  //    storage. ────────────────────────────────────────────────────────────
  const compMenu = $('comp-menu') as MenuEl;
  const compMenuItems = () => COMPONENTS.map((c) => ({ label: c, action: c }));
  compMenu.items = compMenuItems();
  $('comp-label').textContent = activeComponent;

  function setComponent(next: string) {
    if (next === activeComponent) return;
    activeComponent = next;
    try {
      localStorage.setItem(COMPONENT_KEY, next);
    } catch {
      /* storage unavailable — selection just won't persist */
    }
    $('comp-label').textContent = next;
    compMenu.items = compMenuItems();
    // Close any open drawer — it belongs to the previous component's scope.
    if (waDialog.open) waDialog.close();
    if (obsDialog.open) obsDialog.close();
    statusFilters = [];
    mapFltStatus._selected = [];
    syncPresetSelection();
    refreshGotoOptions();
    syncObsVisibility();
    rebuildBufferRings();
    refreshAll();
    // Refit the map to the component's sites (the full program extent stays
    // behind the empty state when there are none).
    if (map && componentWas().length) {
      map.fitBounds(L.latLngBounds(componentWas().map((w) => [w.lat, w.lng] as L.LatLngTuple)), {
        padding: [40, 40],
      });
    }
  }
  compMenu.addEventListener('menu-action', (e) => {
    const action = (e as CustomEvent).detail?.action as string | undefined;
    if (action) setComponent(action);
  });

  // ── Component Buffer wiring (BCN-1454): the layer switch, the label·distance
  //    readout, and the minimal edit dialog. ──────────────────────────────────
  const bufferToggle = $('buffer-toggle') as SwitchEl;
  const bufferDialog = $('buffer-dialog') as DialogEl;
  bufferToggle.addEventListener('change', (e) => {
    bufferOn = !!(e as CustomEvent).detail?.checked;
    ensureMap();
    rebuildBufferRings();
  });
  $('buffer-edit').addEventListener('click', () => {
    const buf = activeBuffer();
    ($('buf-label') as Field).value = buf.label;
    ($('buf-distance') as Field).value = String(buf.distanceFt);
    bufferDialog.open = true;
  });
  $('buf-cancel').addEventListener('click', () => {
    bufferDialog.open = false;
  });
  $('buf-save').addEventListener('click', () => {
    const label = (($('buf-label') as Field).value ?? '').trim() || 'Buffer';
    const distanceFt = Math.max(0, Number(($('buf-distance') as Field).value) || 0);
    bufferByComponent.set(activeComponent, { label, distanceFt });
    bufferDialog.open = false;
    rebuildBufferRings();
  });

  // ── "Go to …" jumps (round-5 ch2) + "Show on map" (ch5) — ONE machinery:
  //    switch to the Map tab if needed, pan/zoom to the point (~street zoom),
  //    pulse the marker/dot (the same status-flip pulse). Never opens a drawer
  //    — click the marker for that. The marker is resolved INSIDE the deferred
  //    frame: a Data-tab deep link means the map (and its markers) may not
  //    exist until ensureMap() builds them. ────────────────────────────────────
  function showOnMap(kind: 'wa' | 'obs', id: string) {
    const pt = kind === 'wa' ? waById.get(id) : activeObservations.find((o) => o.id === id);
    if (!pt) return;
    if (tabs.activeIndex !== 0) {
      tabs.activeIndex = 0; // programmatic — the lego fires tabchange only on user input
      history.replaceState(null, '', '#map');
    }
    requestAnimationFrame(() => {
      ensureMap();
      map?.setView([pt.lat, pt.lng], 15);
      const m = kind === 'wa' ? waMarkers.get(id) : obsDots.get(id);
      if (m) pulseMarker(m);
    });
  }

  // The two go-to comboboxes (esa-combobox, autocomplete mode — its dropdown
  // filters the full option list client-side, so all 231 work-area IDs ride
  // one type-ahead control). Both reset to the placeholder after the jump:
  // a "go to" is an action, not a state.
  type ComboboxEl = HTMLElement & {
    value: string | string[] | null;
    options: { value: string; label: string }[];
  };
  const gotoWa = $('goto-wa') as ComboboxEl;
  const gotoObs = $('goto-obs') as ComboboxEl;
  /** Both jump lists follow the active component. Observation options run
      newest-first by firstObserved, date first (the sort key). */
  function refreshGotoOptions() {
    gotoWa.options = componentWas()
      .sort((a, b) => a.id.localeCompare(b.id))
      .map((w) => ({ value: w.id, label: w.id }));
    gotoObs.options = (activeComponent === GEOTECH_COMPONENT ? [...activeObservations] : [])
      .sort((a, b) => b.firstObserved.localeCompare(a.firstObserved))
      .map((o) => ({ value: o.id, label: `${formatDate(o.firstObserved)} · ${o.species} · ${o.id}` }));
  }
  refreshGotoOptions();
  gotoWa.addEventListener('change', (e) => {
    const id = ((e as CustomEvent).detail?.value as string) ?? '';
    if (!id) return;
    showOnMap('wa', id);
    gotoWa.value = null;
  });
  gotoObs.addEventListener('change', (e) => {
    const id = ((e as CustomEvent).detail?.value as string) ?? '';
    if (!id) return;
    showOnMap('obs', id);
    gotoObs.value = null;
  });

  // "Show on map" from the drawers (ch5): capture the id, close the drawer
  // (its close handler nulls the active id), then run the shared jump.
  $('wa-showmap').addEventListener('click', () => {
    const id = activeWaId;
    if (!id) return;
    waDialog.close();
    showOnMap('wa', id);
  });
  $('obs-showmap').addEventListener('click', () => {
    const id = activeObsId;
    if (!id) return;
    obsDialog.close();
    showOnMap('obs', id);
  });

  // ── Activity feed (Tab 3) — the component's CLEARANCE history: recorded
  //    reviews and monitor notes from the fixture + the live in-session change
  //    log (the same entries the drawer's Activity list shows: one save → one
  //    set of entries in both places). Grouped per calendar date against the
  //    fixture's frozen TODAY — never Date.now(). Every event IS an EntrySpec:
  //    builders fill slots, the renderer is the only thing that touches the
  //    DOM — no event ever carries an assembled sentence. History only. ────────
  interface FeedEvent {
    date: string; // ISO day — drives the date group (the group heading carries the date)
    sort: string; // descending sort key within a group
    entry: EntrySpec; // the deterministic row — meta is attribution (time/actor), never the date
    waId?: string;
    obsId?: string;
  }

  function buildFeedEvents(): FeedEvent[] {
    const events: FeedEvent[] = [];
    for (const wa of componentWas()) {
      // Recorded reviews — the review's KIND rides the primary slot, the
      // outcome rides the chip, the reviewer rides the meta.
      for (const r of wa.reviews) {
        if (r.date > TODAY) continue;
        events.push({
          date: r.date,
          sort: `${r.date}T10`,
          entry: {
            badgeId: wa.id,
            badgeKind: 'wa',
            eventType: 'review',
            primary: REVIEW_KIND_LABEL[r.kind],
            chip: r.outcome,
            meta: r.reviewer ?? '',
          },
          waId: wa.id,
        });
      }
      // Monitor notes — author as the structured primary, the verbatim text
      // as the quoted secondary.
      for (const n of wa.notes) {
        if (n.date > TODAY) continue;
        events.push({
          date: n.date,
          sort: `${n.date}T08`,
          entry: { badgeId: wa.id, badgeKind: 'wa', eventType: 'note', primary: n.author, secondary: n.text },
          waId: wa.id,
        });
      }
    }
    // Live in-session edits → the TODAY date group, sorted above the fixture's
    // dated events (the ChangeEntry already IS structured — pass it through)
    for (const c of changeLog) {
      if (waById.get(c.waId)?.component !== activeComponent) continue;
      events.push({
        date: TODAY,
        sort: `${TODAY}T99-${c.ts}`,
        entry: {
          badgeId: c.waId,
          badgeKind: 'wa',
          eventType: c.kind,
          primary: c.primary,
          secondary: c.secondary,
          chip: c.chip,
          meta: `${fmtTime(c.ts)} · ${c.user}`,
        },
        waId: c.waId,
      });
    }
    return events.sort((a, b) => b.sort.localeCompare(a.sort));
  }

  // ── Feed Type filter — esa-filter-dropdown lego; multi-select, empty = all.
  //    No color dots on purpose: colors belong to status, not event type. The
  //    page's Component picker already scopes the feed. ───────────────────────
  const FEED_TYPE_OF: Partial<Record<EntryKind, string>> = {
    review: 'reviews',
    note: 'notes',
    edit: 'edits',
  };
  let feedTypeFilters: string[] = [];
  const feedShown = (ev: FeedEvent) =>
    !feedTypeFilters.length || feedTypeFilters.includes(FEED_TYPE_OF[ev.entry.eventType] ?? '');

  const actFltType = $('act-flt-type') as FilterDropdownEl;
  actFltType.options = [
    { value: 'reviews', label: 'Clearance reviews' },
    { value: 'notes', label: 'Notes' },
    { value: 'edits', label: 'Edits' },
  ];
  actFltType.addEventListener('selection-change', (e) => {
    feedTypeFilters = ((e as CustomEvent).detail?.value as string[]) ?? [];
    renderFeed();
  });

  $('act-clear-filters').addEventListener('esa-filter-clear', () => {
    feedTypeFilters = [];
    actFltType._selected = [];
    renderFeed();
  });

  function renderFeed() {
    // Feed — one group per calendar date, newest first. buildFeedEvents() sorts
    // descending, so Map insertion order IS the date order; live edits land in
    // the fixture-TODAY group ("… · Today"). Every row is an entry card.
    const groupsEl = $('feed-groups');
    groupsEl.innerHTML = '';
    const groups = new Map<string, FeedEvent[]>();
    for (const ev of buildFeedEvents()) {
      if (!feedShown(ev)) continue;
      if (!groups.has(ev.date)) groups.set(ev.date, []);
      groups.get(ev.date)!.push(ev);
    }
    $('feed-empty').hidden = groups.size > 0;
    for (const [iso, evs] of groups) {
      const sec = document.createElement('section');
      sec.className = 'feed-day';
      const h = document.createElement('h3');
      h.className = 'feed-heading';
      h.textContent = iso === TODAY ? `${formatDate(iso)} · Today` : formatDate(iso);
      const ul = document.createElement('ul');
      ul.className = 'feed-day__list';
      for (const ev of evs) ul.appendChild(entryCard(ev.entry, { wa: ev.waId, obs: ev.obsId }));
      sec.append(h, ul);
      groupsEl.appendChild(sec);
    }
  }

  // Feed rows jump to the relevant drawer, opened OVER the Activity tab — the
  // drawers are viewport-fixed side dialogs, so no tab switch is needed (the
  // most natural fit for the existing openWorkArea/openObservation wiring).
  document.querySelector('.feed-panel')!.addEventListener('click', (e) => {
    const li = (e.target as HTMLElement).closest<HTMLElement>('[data-wa], [data-obs]');
    if (!li) return;
    if (li.dataset.wa) openWorkArea(li.dataset.wa);
    else if (li.dataset.obs) openObservation(li.dataset.obs);
  });

  // ── Tabs (Map default; #data / #activity deep-link) ─────────────────────────
  const tabs = $('gc-tabs') as HTMLElement & { tabs: { label: string; icon?: string }[]; activeIndex: number };
  const ICON = (paths: string) =>
    `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${paths}</svg>`;
  tabs.tabs = [
    {
      label: 'Map',
      icon: ICON(
        '<path d="M14.106 5.553a2 2 0 0 0 1.788 0l3.659-1.83A1 1 0 0 1 21 4.619v12.764a1 1 0 0 1-.553.894l-4.553 2.277a2 2 0 0 1-1.788 0l-4.212-2.106a2 2 0 0 0-1.788 0l-3.659 1.83A1 1 0 0 1 3 19.381V6.618a1 1 0 0 1 .553-.894l4.553-2.277a2 2 0 0 1 1.788 0z"/><path d="M15 5.764v15"/><path d="M9 3.236v15"/>'
      ),
    },
    {
      label: 'Data',
      icon: ICON('<path d="M12 3v18"/><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M3 15h18"/>'),
    },
    {
      label: 'Activity',
      icon: ICON('<path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M12 7v5l4 2"/>'),
    },
  ];
  const TAB_HASHES = ['#map', '#data', '#activity'];
  const deepLinkIdx = TAB_HASHES.indexOf(location.hash);
  if (deepLinkIdx > 0) tabs.activeIndex = deepLinkIdx;
  tabs.addEventListener('tabchange', (e) => {
    const idx = (e as CustomEvent).detail.index;
    history.replaceState(null, '', TAB_HASHES[idx] ?? '#map');
    if (idx === 0) requestAnimationFrame(ensureMap);
    else if (idx === 1) requestAnimationFrame(ensureGrids);
    else renderFeed();
  });

  // ── Print — pin the map's on-screen size so Leaflet's loaded tiles are reused ─
  window.addEventListener('beforeprint', () => {
    $('print-meta').textContent =
      `Printed ${new Date().toLocaleDateString([], { month: 'short', day: 'numeric', year: 'numeric' })}` +
      ` · ${activeComponent}` +
      ` · Status: ${statusFilters.length ? statusFilters.map((s) => stLabel(s)).join(', ') : 'All'}` +
      ` · ${visibleWas().length} work areas`;
    const wrap = document.querySelector<HTMLElement>('.map-wrap')!;
    wrap.style.width = `${wrap.offsetWidth}px`;
    wrap.style.height = `${wrap.offsetHeight}px`;
  });
  window.addEventListener('afterprint', () => {
    const wrap = document.querySelector<HTMLElement>('.map-wrap')!;
    wrap.style.width = '';
    wrap.style.height = '';
    map?.invalidateSize();
  });

  // ── Boot ─────────────────────────────────────────────────────────────────────
  syncComponentSurfaces();
  refreshReadiness();
  renderFeed();
  presets.options = presetOptions(); // SSR counts assume the geotech component — re-derive for the persisted one
  if (tabs.activeIndex === 0) requestAnimationFrame(ensureMap);
  else if (tabs.activeIndex === 1) requestAnimationFrame(ensureGrids);
</script>

<style>
  /* Runtime status colors live on :root via the SSR-inlined style above — the
     exact fixture hexes (the committed field-map palette). Markers, chips,
     readiness bar, legend and grid chips all read them. */

  /* Pre-upgrade FOUC guard: only the default (Map) panel shows until the lego defines */
  esa-tab-layout:not(:defined) [slot='panel-1'],
  esa-tab-layout:not(:defined) [slot='panel-2'] {
    display: none;
  }

  /* ═══ Map + overlays (the hero) ═══ */
  .map-wrap {
    position: relative;
    width: 100%;
    height: 70vh;
    min-height: 480px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-300);
    overflow: hidden;
  }
  .map {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }
  /* Leaflet panes stay below the topbar (z 1100) and the side-dialogs */
  :global(.leaflet-pane),
  :global(.leaflet-top),
  :global(.leaflet-bottom) {
    z-index: 400;
  }
  :global(#gc-map .leaflet-interactive) {
    cursor: pointer;
  }

  /* Status-flip pulse — white-halo stroke pulse on markers whose derived status
     changed after a drawer save. (Astro leaves @keyframes unscoped; the class
     lands on Leaflet SVG paths.) */
  :global(.gc-pulse) {
    animation: gc-pulse 0.9s ease-out 3;
  }
  @keyframes gc-pulse {
    0% {
      stroke-width: 2;
      stroke-opacity: 1;
    }
    50% {
      stroke-width: 14;
      stroke-opacity: 0.25;
    }
    100% {
      stroke-width: 2;
      stroke-opacity: 1;
    }
  }

  /* Reset-view control — rides Leaflet's own .leaflet-bar chrome (border, radius,
     hover) so it reads as a sibling of the zoom buttons; this only centers the
     glyph inside the anchor. JS-injected into Leaflet's corner → :global. */
  :global(.gc-reset__btn) {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  :global(.gc-reset__btn svg) {
    width: 16px;
    height: 16px;
    display: block;
  }

  /* Map filter bar — two bands: View presets on top, filters + go-to below
     (the requirement-tracker two-band idiom). The feed reuses it one-banded. */
  .map-filterbar {
