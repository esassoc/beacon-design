    font-weight: var(--font-weight-semibold);
    color: var(--color-text-tertiary);
    white-space: nowrap;
  }
  /* Go-to jumps (ch2) — right-aligned in the View row, beside the presets.
     The size="md" presets run a taller 36px line (the round-5 step up); the
     comboboxes deliberately stay on the page's quiet 32px control line (same
     as the filter dropdowns below), vertically centered against the toggle —
     subordinate jumps, not peers of the presets. Widths sized so the row
     holds one line beside the md toggle at desktop widths. */
  .map-filterbar__goto {
    margin-left: auto;
    display: flex;
    gap: var(--spacing-200);
  }
  .map-filterbar__goto :global(esa-combobox) {
    /* esa-combobox sm reads the Beacon form tokens (28px / 12px) — re-point
       them to the filter legos' 32px / --type-size-150 line, scoped here. */
    --form-height-sm: 32px;
    --form-font-size-sm: var(--type-size-150);
  }
  #goto-wa {
    width: 200px;
  }
  #goto-obs {
    width: 260px;
  }

  /* Work Area Buffer control — right-aligned in the Filters row: the layer
     switch and the edit pencil (the label/distance live in the edit dialog). */
  .map-filterbar__buffer {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: var(--spacing-200);
  }
  /* The Filters row's clear button sits mid-row once the buffer group takes
     the right edge — keep a breath between it and the dropdowns. */
  #map-clear-filters {
    margin-left: var(--spacing-100);
  }

  /* Empty-component state — centered over the map, above the Leaflet panes,
     on the page's surface so the basemap reads as background. */
  .map-empty {
    position: absolute;
    inset: 0;
    z-index: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--color-surface) 78%, transparent);
    backdrop-filter: blur(2px);
  }
