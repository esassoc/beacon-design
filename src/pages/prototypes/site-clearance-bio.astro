  }

  /* ═══ Component picker — the quiet text+chevron trigger beside the H1
     (slotted into the esa-dropdown-menu lego; trigger chrome is the
     consumer's by design). Flex-centered against the H1's cap height. ═══ */
  .comp-picker {
