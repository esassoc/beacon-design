---
// Fish Detail — the unified per-node detail page (Program / Study / Sub-study /
// Task), one static route per HierNode id.
//
// ARCHITECTURE (Andy, 2026-07-21): the gantt/roles/readiness tabs are light
// PROJECTIONS; THIS page carries the comprehensive record and the heavy editing —
// identity, dates, money, status, owner/lead, RACI roles — plus tree traversal
// (ancestor breadcrumbs, children records, sibling navigation). Study-tier pages
// additionally carry the authored science-plan narrative (sketch, CDFW review
// cycle, crosswalk facts rail).
//
// READ-ONLY LANDING (Andy, 2026-07-21): "All editing should be done in a modal or
// side drawer. The detail page should be read only as you land on it." Field
// editing lives in the EDIT-RECORD drawer (name / ID / COA ref / notes; task:
// schedule + status + owner; study: deadline + driven-by milestone + constraints;
// own funding per water year) and the ASSIGNMENTS drawer (lead + RACI repeater).
// Tree-STRUCTURE operations (add / reparent / delete nodes) stay on the gantt —
// the CRUD split: structure on the tree surface, record fields here.
//
// DATA SOURCES: everything comes through ./data/fish-plan.ts (the source of
// truth). The work-breakdown node owns identity, schedule, money, status, lead,
// owner, and roles; the authored science-plan satellite arrives as the
// fish-plan STUDY_PROFILES record for this COA (sketch, review comments,
// category/agencies/timeframe/phases, dependencies, deliverables, planning
// sizing). Execution facts never render from the satellite — the work-breakdown
// wins by construction (the profile type carries no execution fields).
//
// EDITING is session-local (in-page model + live recompute of derived displays),
// the same contract as the gantt's wbApi — no cross-page persistence.
import AppShell from '../../../layouts/AppShell.astro';
import PageLayout from '../../../layouts/PageLayout.astro';
import EsaButton from '@esa/ecology/esa-button.astro';
import EsaPill from '@esa/ecology/esa-pill.astro';
import EsaCollapsible from '@esa/ecology/esa-collapsible.astro';
import BcnNodeDetail from '../../../components/bcn/BcnNodeDetail.astro';
import BcnDetailLineage from '../../../components/bcn/BcnDetailLineage.astro';
import BcnDetailChildren from '../../../components/bcn/BcnDetailChildren.astro';
import BcnDetailAssignments from '../../../components/bcn/BcnDetailAssignments.astro';
import BcnRolesRepeater from '../../../components/bcn/BcnRolesRepeater.astro';
import BcnStudySketch from '../../../components/bcn/BcnStudySketch.astro';
import BcnReviewThread from '../../../components/bcn/BcnReviewThread.astro';
import BcnKeyValue from '../../../components/bcn/BcnKeyValue.astro';
import BcnStatusChip from '../../../components/bcn/BcnStatusChip.astro';
import BcnStatusSelect from '../../../components/bcn/BcnStatusSelect.astro';
import { PROGRAMS, STUDY_PROFILES, COA_NAMES, PLAN_SECTIONS, MILESTONES } from '../../../data/fish-plan';
import {
  computeRollUp,
  flattenForest,
  formatUSD,
  monthLabel,
  waterYearOf,
  TIER_META,
  TASK_STATUS_META,
  CATEGORY_META,
  DELIVERABLE_STATUS_META,
  WORKSTREAM_META,
  LEAD_ORGS,
  PROJECT_NAME,
  type HierNode,
  type WorkstreamKey,
} from '../../../data/fish-model';
import { PHASE_META, SCHEDULE_START_YEAR, SCHEDULE_END_YEAR } from '../../../data/fish-schedule';
import { withBase } from '../../../lib/base';

export async function getStaticPaths() {
  return flattenForest(PROGRAMS).map(({ node, ancestors }) => ({
    params: { id: node.id },
    props: { node, ancestors },
  }));
}

interface Props {
  node: HierNode;
  ancestors: HierNode[];
}
const { node, ancestors } = Astro.props;

const tier = TIER_META[node.tier];
const isTask = node.tier === 'task';
const isStudy = node.tier === 'study';
const rollup = computeRollUp(node);
const parent = ancestors.at(-1);

const detailHref = (id: string) => withBase(`/prototypes/fish-detail/${id}`);
const ganttHref = withBase('/prototypes/fish-gantt');

// ── Tree traversal projections ──
const pluralize = (w: string) => (w.endsWith('y') ? `${w.slice(0, -1)}ies` : `${w}s`);
const childTier = node.children[0]?.tier;
const childrenHeading = childTier ? pluralize(TIER_META[childTier].label) : '';
const childRows = node.children.map((c) => {
  const r = computeRollUp(c);
  return {
    id: c.id,
    name: c.name,
    href: detailHref(c.id),
    span: r.startMonth ? `${monthLabel(r.startMonth)} – ${monthLabel(r.endMonth)}` : '—',
    funding: formatUSD(r.totalFunding),
    statusTone: r.aggregate,
    statusLabel: TASK_STATUS_META[r.aggregate].label,
  };
});
const siblingsOf = parent?.children ?? [];
const idx = siblingsOf.findIndex((s) => s.id === node.id);
const prev = idx > 0 ? siblingsOf[idx - 1] : undefined;
const next = idx >= 0 && idx < siblingsOf.length - 1 ? siblingsOf[idx + 1] : undefined;
const siblings = {
  prevHref: prev ? detailHref(prev.id) : undefined,
  prevId: prev?.id,
  prevName: prev?.name,
  nextHref: next ? detailHref(next.id) : undefined,
  nextId: next?.id,
  nextName: next?.name,
};

// ── Assignments projections ──
const WORKSTREAMS = Object.keys(WORKSTREAM_META) as WorkstreamKey[];
const roleRows = WORKSTREAMS.map((w) => {
  const a = node.roles?.find((r) => r.workstream === w);
  return { workstream: w, label: WORKSTREAM_META[w].label, org: a?.org ?? '', person: a?.person ?? '', tentative: a?.tentative ?? false };
});
// Repeater vocabularies: work-streams from the contract; orgs = the distinct org
// values across all study assignments + the lead-org list (a derivation of the
// fixture, recomputed here — never stored).
const wsOptsJson = JSON.stringify(WORKSTREAMS.map((w) => ({ value: w, label: WORKSTREAM_META[w].label })));
const ORGS = [
  ...new Set([...LEAD_ORGS, ...PROGRAMS.flatMap((p) => p.children).flatMap((s) => (s.roles ?? []).map((r) => r.org))]),
].sort();
const orgOptsJson = JSON.stringify(ORGS.map((o) => ({ value: o, label: o })));
const leadOptsJson = JSON.stringify(LEAD_ORGS.map((l) => ({ value: l, label: l })));
const statusOptions = (Object.entries(TASK_STATUS_META) as [string, { label: string; hex: string }][]).map(
  ([value, m]) => ({ value, label: m.label, color: m.hex }),
);

// ── Study tier: the authored science-plan satellite, joined read-only by COA ──
// The authored science-plan satellite for this COA (fish-plan.STUDY_PROFILES).
const profile = isStudy && node.coaRef ? STUDY_PROFILES[node.coaRef] : undefined;
// COA → work-breakdown study id, so dependency references link to LIVE detail pages.
const coaToNodeId = new Map(
  PROGRAMS.flatMap((p) => p.children)
    .filter((s) => s.coaRef)
    .map((s) => [s.coaRef as string, s.id]),
);

// ── Edit-record drawer vocabularies + funding rows ──
const MONTH_NAMES = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const monthOptsJson = JSON.stringify(MONTH_NAMES.map((label, i) => ({ value: String(i + 1).padStart(2, '0'), label })));
const yearOpts = [];
for (let y = SCHEDULE_START_YEAR; y < SCHEDULE_END_YEAR; y++) yearOpts.push({ value: String(y), label: String(y) });
const yearOptsJson = JSON.stringify(yearOpts);
// Deadline is clearable — a leading blank option empties it.
const dlMonthOptsJson = JSON.stringify([{ value: '', label: '—' }, ...JSON.parse(monthOptsJson)]);
const dlYearOptsJson = JSON.stringify([{ value: '', label: '—' }, ...yearOpts]);
const msOptsJson = JSON.stringify([{ value: '', label: '—' }, ...MILESTONES.map((m) => ({ value: m.id, label: m.name }))]);
// Own-funding rows offered in the drawer: union of entered years, rolled-up
// years, and the node's own scheduled span (same union the funding table shows).
const fundingYears = [
  ...new Set([
    ...node.funding.map((f) => f.waterYear),
    ...rollup.fundingByYear.map((f) => f.waterYear),
    ...(node.startMonth && node.endMonth
      ? Array.from(
          { length: Math.max(waterYearOf(node.endMonth) - waterYearOf(node.startMonth), 0) + 1 },
          (_, i) => waterYearOf(node.startMonth!) + i,
        )
      : []),
  ]),
].sort((a, b) => a - b);

// ── Science-plan document references: sections citing this COA + the § chip map
//    for the review thread — both link into the reader. ──
const readerHref = (id: string) => withBase(`/prototypes/fish-science-plan#${id}`);
const planSections =
  isStudy && node.coaRef
    ? PLAN_SECTIONS.filter((s) => s.coaRefs.includes(node.coaRef!)).map((s) => ({
        number: s.number,
        title: s.title,
        href: readerHref(s.id),
      }))
    : [];
const sectionRefs = Object.fromEntries(PLAN_SECTIONS.map((s) => [s.id, { number: s.number, href: readerHref(s.id) }]));

const ICONS = {
  info: "<circle cx='12' cy='12' r='10'/><path d='M12 16v-4'/><path d='M12 8h.01'/>",
  link: "<path d='M9 17H7A5 5 0 0 1 7 7h2'/><path d='M15 7h2a5 5 0 1 1 0 10h-2'/><line x1='8' x2='16' y1='12' y2='12'/>",
  file: "<path d='M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z'/><path d='M14 2v5h5'/>",
  users: "<path d='M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2'/><circle cx='9' cy='7' r='4'/><path d='M22 21v-2a4 4 0 0 0-3-3.87'/>",
  gauge: "<path d='m12 14 4-4'/><path d='M3.34 19a10 10 0 1 1 17.32 0'/>",
  tree: "<path d='M8 3H5a2 2 0 0 0-2 2v3'/><path d='M21 8V5a2 2 0 0 0-2-2h-3'/><path d='M3 16v3a2 2 0 0 0 2 2h3'/><path d='M16 21h3a2 2 0 0 0 2-2v-3'/>",
};

const FLASK =
  '<path d="M14 2v6a2 2 0 0 0 .245.96l5.51 10.08A2 2 0 0 1 18 22H6a2 2 0 0 1-1.755-2.96l5.51-10.08A2 2 0 0 0 10 8V2"/><path d="M6.453 15h11.094"/><path d="M8.5 2h7"/>';
const FOLDER =
  '<path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/>';
const GIT_BRANCH =
  '<line x1="6" x2="6" y1="3" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/>';
const SQUARE_CHECK =
  '<rect width="18" height="18" x="3" y="3" rx="2"/><path d="m9 12 2 2 4-4"/>';

// ── Lineage spine: Program → … → this node, each ancestor linking to its page. ──
const TIER_ICON: Record<string, { icon: string; paths: string }> = {
  program: { icon: 'folder', paths: FOLDER },
  study: { icon: 'flask-conical', paths: FLASK },
  substudy: { icon: 'git-branch', paths: GIT_BRANCH },
  task: { icon: 'square-check', paths: SQUARE_CHECK },
};
const lineageNodes = [...ancestors, node].map((n) => ({
  kind: TIER_META[n.tier].label,
  name: n.name,
  href: n.id === node.id ? undefined : detailHref(n.id),
  current: n.id === node.id,
  icon: TIER_ICON[n.tier].icon,
  paths: TIER_ICON[n.tier].paths,
}));

const fishNav = [
  { id: 'project', title: 'Project', icon: 'layout-dashboard', iconPaths: '<rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/>', expanded: false, items: [{ id: 'dashboard', label: 'Dashboard' }] },
  {
    id: 'studies', title: 'Studies', icon: 'flask-conical', iconPaths: FLASK, expanded: true, active: true, dividerAfter: true,
    items: [
      { id: 'science-plan', label: 'Science Plan', href: withBase('/prototypes/fish-science-plan') },
      { id: 'tasking-gantt', label: 'Study Planning', href: ganttHref, active: true },
      { id: 'data-model', label: 'Data Model', href: withBase('/prototypes/fish-model-map') },
    ],
  },
  { id: 'tracking', title: 'Tracking', icon: 'radar', expanded: false, items: [{ id: 'project-tracking', label: 'Project Tracking' }] },
];

// Breadcrumbs stay shallow — the full chain lives in the rail's Lineage module.
const breadcrumbs = [
  { label: 'Delta Conveyance', href: '#project' },
  { label: 'Study Planning', href: ganttHref },
  { label: node.name },
];

// Serialized subtree for the session-local edit model (see the script).
const detailJson = JSON.stringify({ node });
---

<!-- manifest:
  layout: stack
  sections:
    - identity badge      -> esa-pill              # the id chip beside the H1 (the only header badge)
    - lineage rail         -> bcn-detail-lineage    # one spine: Program → Study → Sub-study → Task (current = secondary ring); leads the rail
    - node record          -> bcn-node-detail       # READ-ONLY: Identity / Timing / Funding (readonly) / Roll-up / notes
    - edit-record drawer    -> esa-side-dialog       # ALL field editing: name/id/coa/notes + tier fields + own funding per WY
    - assignments drawer    -> esa-side-dialog       # study lead + RACI repeater (bcn-roles-repeater)
    - study sketch         -> bcn-study-sketch      # study tier: the authored 9-field science-plan sketch (fish-plan STUDY_PROFILES by coaRef)
    - agency review        -> bcn-review-thread     # study tier: the CDFW comment cycle
    - children module      -> bcn-detail-children   # child records as linked rows
    - related records      -> bcn-detail-children   # previous/next siblings as a plain linked list
    - assignments          -> bcn-detail-assignments # READ-ONLY WHO block; edits via the drawers
    - crosswalk rail       -> esa-collapsible       # study tier: profile satellite facts (details / dependencies / deliverables / planning)
-->

<AppShell title={`${node.id} — ${node.name} — ${PROJECT_NAME}`} tenantName="DWR" projectName="Delta Conveyance" navSections={fishNav}>
  <PageLayout title={node.name} icon="flask-conical" breadcrumbs={breadcrumbs}>
    <span slot="title-badge" class="bcn-fdetail__badges">
      <span class="bcn-fdetail__chip" data-chip="id">{node.id}</span>
    </span>
    <div slot="utilities" class="bcn-fdetail__utils">
      <span data-rec-edit><EsaButton color="ghost" appearance="outline" size="sm" icon="pencil">Edit record</EsaButton></span>
      {isStudy && profile?.sketch && (
        <EsaButton color="ghost" appearance="outline" size="sm" icon="file-text">Generate sketch (.docx)</EsaButton>
      )}
      {isStudy && <EsaButton color="primary" size="sm" icon="upload">Submit for CDFW review</EsaButton>}
    </div>

    <!-- bcn-lego-checked: PAGE-COMPOSITION GLUE ONLY — the KPI strip wraps esa-stat
         legos, the two-column main+rail grid, badge chips, and the rail's key/value
         + chip rows ported from the fish-study page. Every section body is a
         component (see manifest). No reinvented primitive. -->

    <div class="bcn-fdetail">
      <main class="bcn-fdetail__main">
        <BcnNodeDetail node={node} rollup={rollup} parentName={parent?.name} />

        {isStudy && profile?.sketch && <BcnStudySketch sketch={profile.sketch} species={profile.focalSpecies} />}
        {isStudy && (profile?.reviewComments?.length ?? 0) > 0 && (
          <BcnReviewThread comments={profile!.reviewComments!} sectionRefs={sectionRefs} />
        )}
      </main>

      <aside class="bcn-fdetail__rail">
        <EsaCollapsible icon="git-branch" iconPaths={GIT_BRANCH} title="Lineage" open>
          <BcnDetailLineage nodes={lineageNodes} />
        </EsaCollapsible>

        {childRows.length > 0 && (
          <EsaCollapsible icon="tree" iconPaths={ICONS.tree} title={childrenHeading} open>
            <BcnDetailChildren heading="" rows={childRows} />
          </EsaCollapsible>
        )}

        {(siblings.prevHref || siblings.nextHref) && (
          <EsaCollapsible icon="info" iconPaths={ICONS.info} title="Related records" open>
            <BcnDetailChildren heading="" rows={[]} siblings={siblings} />
          </EsaCollapsible>
        )}

        {(isStudy || isTask) && (
          <EsaCollapsible icon="users" iconPaths={ICONS.users} title="Assignments" open>
            <BcnDetailAssignments
              tier={isStudy ? 'study' : 'task'}
              lead={node.lead}
              roles={roleRows}
              owner={node.owner}
              statusValue={node.status ?? 'not-started'}
              statusOptions={statusOptions}
            />
          </EsaCollapsible>
        )}

        {isStudy && profile && (
          <>
            <EsaCollapsible icon="info" iconPaths={ICONS.info} title="Details" open>
              <BcnKeyValue label="Category" value={CATEGORY_META[profile.category].label} />
              <BcnKeyValue label="Study type" value={profile.method ? `${profile.studyProgram} — ${profile.method}` : profile.studyProgram} />
              <BcnKeyValue label="Agency participants" value={profile.agencies.join(', ')} />
              <BcnKeyValue label="Timeframe" value={profile.timeframe} />
              <div class="bcn-fdetail__kv">
                <span class="bcn-fdetail__kv-label">DCP phases</span>
                <span class="bcn-fdetail__chips">
                  {profile.phases.map((p) => <EsaPill label={PHASE_META[p].short} removable={false} size="sm" />)}
                </span>
              </div>
            </EsaCollapsible>

            {planSections.length > 0 && (
              <EsaCollapsible icon="file" iconPaths={ICONS.file} title="Plan sections" open>
                <ul class="fd-plansec">
                  {planSections.map((s) => (
                    <li>
                      <a href={s.href}>
                        <span class="fd-plansec__num">{s.number}</span> {s.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </EsaCollapsible>
            )}
            <EsaCollapsible icon="link" iconPaths={ICONS.link} title="Dependencies & references" open>
              <div class="bcn-fdetail__kv">
                <span class="bcn-fdetail__kv-label">Informed by</span>
                {profile.informedBy.length ? (
                  <span class="bcn-fdetail__chips">
                    {profile.informedBy.map((c) => (coaToNodeId.has(c)
                      ? <a class="bcn-fdetail__coa-link" href={detailHref(coaToNodeId.get(c)!)} title={COA_NAMES[c]}>{c}</a>
                      : <span class="bcn-fdetail__coa-ref" title={COA_NAMES[c]}>{c}</span>))}
                  </span>
                ) : <span class="bcn-fdetail__empty">None</span>}
              </div>
              <div class="bcn-fdetail__kv">
                <span class="bcn-fdetail__kv-label">Informs</span>
                {profile.informs.length ? (
                  <span class="bcn-fdetail__chips">
                    {profile.informs.map((c) => (coaToNodeId.has(c)
                      ? <a class="bcn-fdetail__coa-link" href={detailHref(coaToNodeId.get(c)!)} title={COA_NAMES[c]}>{c}</a>
                      : <span class="bcn-fdetail__coa-ref" title={COA_NAMES[c]}>{c}</span>))}
                  </span>
                ) : <span class="bcn-fdetail__empty">None</span>}
              </div>
              {profile.regulatoryRefs.length > 0 && (
                <div class="bcn-fdetail__kv">
                  <span class="bcn-fdetail__kv-label">ITP cross-references</span>
                  <span class="bcn-fdetail__chips">
                    {profile.regulatoryRefs.map((r) => <span class="bcn-fdetail__coa-ref">{r}</span>)}
                  </span>
                </div>
              )}
            </EsaCollapsible>

            <EsaCollapsible icon="file-text" iconPaths={ICONS.file} title={`Deliverables (${profile.deliverables.length})`}>
              {profile.deliverables.length ? (
                <ul class="bcn-fdetail__deliv">
                  {profile.deliverables.map((d) => {
                    const m = DELIVERABLE_STATUS_META[d.status];
                    return (
                      <li class="bcn-fdetail__deliv-row">
                        <span class="bcn-fdetail__deliv-name">{d.type}</span>
                        <BcnStatusChip status={d.status} label={m.label} hex={m.hex} />
                      </li>
                    );
                  })}
                </ul>
              ) : <span class="bcn-fdetail__empty">No deliverables listed.</span>}
            </EsaCollapsible>

            <EsaCollapsible icon="gauge" iconPaths={ICONS.gauge} title="Planning">
              {(profile.planning.studyPlanDue || profile.planning.complexity || profile.planning.peakFte || profile.planning.budgetMagnitude) ? (
                <>
                  {profile.planning.studyPlanDue && <BcnKeyValue label="Study plan due" value={profile.planning.studyPlanDue} />}
                  {profile.planning.complexity != null && <BcnKeyValue label="Complexity (1–10)" value={String(profile.planning.complexity)} />}
                  {profile.planning.peakFte != null && <BcnKeyValue label="Peak staff (FTE)" value={String(profile.planning.peakFte)} />}
                  {profile.planning.budgetMagnitude && <BcnKeyValue label="Budget magnitude" value={profile.planning.budgetMagnitude} />}
                </>
              ) : <span class="bcn-fdetail__empty">Not yet sized.</span>}
            </EsaCollapsible>
          </>
        )}
      </aside>
    </div>
  </PageLayout>
  <esa-side-dialog id="record-drawer" size="md" style="--z-modal: 1300; --z-modal-backdrop: 1250;">
    <div slot="header" class="bcn-adr-head">
      <span class="bcn-adr-head__id" data-rd-chip>{node.id}</span>
      <span class="bcn-adr-head__title">Edit record</span>
    </div>
    <div class="bcn-adr-body">
      <esa-text-field data-rd-name label="Name" size="sm"></esa-text-field>
      <esa-text-field data-rd-id label="ID" size="sm"></esa-text-field>
      <esa-text-field data-rd-coa label="COA reference" size="sm"></esa-text-field>

      {isTask && (
        <>
          <div class="bcn-rd-grid" role="group" aria-label="Schedule">
            <esa-select data-rd-sched="start-month" label="Start month" size="sm" placeholder="Month" options={monthOptsJson}></esa-select>
            <esa-select data-rd-sched="start-year" label="Start year" size="sm" placeholder="Year" options={yearOptsJson}></esa-select>
            <esa-select data-rd-sched="end-month" label="End month" size="sm" placeholder="Month" options={monthOptsJson}></esa-select>
            <esa-select data-rd-sched="end-year" label="End year" size="sm" placeholder="Year" options={yearOptsJson}></esa-select>
          </div>
          <BcnStatusSelect id="rd-status" label="Status" value={node.status ?? 'not-started'} options={statusOptions} />
          <esa-text-field data-rd-owner label="Owner" size="sm" placeholder="Org or org — person"></esa-text-field>
        </>
      )}

      {isStudy && (
        <>
          <div class="bcn-rd-grid" role="group" aria-label="Deadline">
            <esa-select data-rd-dl="month" label="Deadline month" size="sm" placeholder="Month" options={dlMonthOptsJson}></esa-select>
            <esa-select data-rd-dl="year" label="Deadline year" size="sm" placeholder="Year" options={dlYearOptsJson}></esa-select>
          </div>
          <esa-select data-rd-drivenby label="Driven by" size="sm" placeholder="Milestone" options={msOptsJson}></esa-select>
          <esa-textarea data-rd-constraints label="Constraints" size="sm" rows="3" help-text="One per line"></esa-textarea>
        </>
      )}

      <esa-textarea data-rd-notes label="Notes" size="sm" rows="3"></esa-textarea>

      {fundingYears.length > 0 && (
        <div class="bcn-rd-funding" role="group" aria-label="Funding — own entries per water year">
          <span class="bcn-rd-funding__label">Funding — own entries</span>
          {fundingYears.map((wy) => (
            <div class="bcn-rd-funding__row">
              <span class="bcn-rd-funding__wy">WY{wy}</span>
              <esa-text-field data-rd-funding data-wy={wy} size="sm" type="text" prefix="$" placeholder="0"></esa-text-field>
            </div>
          ))}
        </div>
      )}
    </div>
    <span slot="footer" class="bcn-adr-foot">
      <span data-rd-cancel><EsaButton color="ghost" appearance="outline">Cancel</EsaButton></span>
      <span data-rd-save><EsaButton color="primary">Save record</EsaButton></span>
    </span>
  </esa-side-dialog>

  {isStudy && (
    <esa-side-dialog
      id="assign-drawer"
      size="md"
      style="--z-modal: 1300; --z-modal-backdrop: 1250;"
      data-ws-options={wsOptsJson}
      data-org-options={orgOptsJson}
      data-lead-options={leadOptsJson}
    >
      <div slot="header" class="bcn-adr-head">
        <span class="bcn-adr-head__id">{node.id}</span>
        <span class="bcn-adr-head__title">Edit assignments</span>
      </div>
      <div class="bcn-adr-body">
        <esa-select data-adr-lead label="Lead org" size="sm" placeholder="Select lead org"></esa-select>
        <BcnRolesRepeater />
      </div>
      <span slot="footer" class="bcn-adr-foot">
        <span data-adr-cancel><EsaButton color="ghost" appearance="outline">Cancel</EsaButton></span>
        <span data-adr-save><EsaButton color="primary">Save assignments</EsaButton></span>
      </span>
    </esa-side-dialog>
  )}
</AppShell>

<script type="application/json" data-detail-json is:inline set:html={detailJson} />

<script>
  import '@esa/ecology/esa-select';
  import '@esa/ecology/esa-text-field';
  import '@esa/ecology/esa-switch-toggle';
  import {
    computeRollUp,
    monthLabel,
    formatUSD,
    waterYearOf,
    fieldSeasonOf,
    FIELD_SEASON_META,
    TASK_STATUS_META,
    type HierNode,
    type RoleAssignment,
    type TaskStatus,
    type WorkstreamKey,
  } from '../../../data/fish-model';
  import { setupStatusSelect } from '../../../components/bcn/status-select';
  import { setupRolesRepeater } from '../../../components/bcn/roles-repeater';
  import '@esa/ecology/esa-side-dialog';
  import '@esa/ecology/esa-textarea';

  // ── Session-local model: this page's subtree, mutated in place; every edit
  //    recomputes the roll-up and repatches the derived displays. Same contract
  //    as the gantt's wbApi — no cross-page persistence. ──
  const island = document.querySelector('[data-detail-json]');
  const { node } = JSON.parse(island?.textContent ?? '{}') as { node: HierNode };
  const isTask = node.tier === 'task';

  type Field = HTMLElement & { value: string };
  const $ = <T extends HTMLElement>(sel: string) => document.querySelector<T>(sel);

  const setText = (sel: string, text: string) => {
    const el = document.querySelector<HTMLElement>(sel);
    if (el) el.textContent = text;
  };

  const wyLabelOf = (start?: string, end?: string): string => {
    if (!start) return '—';
    const a = waterYearOf(start);
    const b = end ? waterYearOf(end) : a;
    return a === b ? `WY${a}` : `WY${a}–${b}`;
  };

  function patchDerived() {
    const r = computeRollUp(node);
    const start = isTask ? node.startMonth : r.startMonth;
    const end = isTask ? node.endMonth : r.endMonth;
    const span = start ? `${monthLabel(start)} – ${monthLabel(end)}` : '—';

    // Node record (BcnNodeDetail data-live hooks)
    if (isTask) {
      setText('[data-live="sched"] .bcn-key-value__val', span);
      const ss = start ? FIELD_SEASON_META[fieldSeasonOf(start)] : undefined;
      const es = end ? FIELD_SEASON_META[fieldSeasonOf(end)] : undefined;
      setText(
        '[data-live="season"] .bcn-key-value__val',
        ss && es ? (ss === es ? ss.label : `${ss.label} → ${es.label}`) : '—',
      );
    } else {
      setText('[data-live="span"] .bcn-key-value__val', span);
    }
    setText('[data-live="wy"] .bcn-key-value__val', wyLabelOf(start, end));

    // Funding plan: the Planned key/value + the table footer.
    const fy = r.fundingByYear.map((f) => f.waterYear);
    setText(
      '[data-live="funding"] .bcn-key-value__val',
      `${formatUSD(r.totalFunding)}${fy.length ? ` · WY${Math.min(...fy)}–${Math.max(...fy)}` : ''}`,
    );
    setText('[data-cell="foot-own"]', formatUSD(r.ownFunding));
    setText('[data-cell="foot-sub"]', formatUSD(r.totalFunding - r.ownFunding));
    setText('[data-cell="foot-total"]', formatUSD(r.totalFunding));
  }

  // ── Page chrome repaint (title / h1 / chips) after an Edit-record save. ──
  const h1 = document.querySelector<HTMLElement>('.page-layout__title h1');
  const baseTitle = document.title;
  const paintHeader = () => {
    document.title = `${node.id} — ${node.name} — ${baseTitle.split(' — ').slice(2).join(' — ') || baseTitle}`;
    if (h1?.lastChild) h1.lastChild.textContent = ` ${node.name}`;
    setText('[data-chip="id"]', node.id);
    setText('[data-rd-chip]', node.id);
  };

  // ── Read-only record repaint: the authored fields BcnNodeDetail displays. ──
  const escHtml = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  const repaintRecord = () => {
    paintHeader();
    setText('[data-live="name"] .bcn-key-value__val', node.name);
    setText('[data-live="idrow"] .bcn-key-value__val', node.id);
    setText('[data-live="coa"] .bcn-key-value__val', node.coaRef ?? '—');
    if (isTask) {
      // Owner + Status live ONLY in the Assignments rail (the WHO module).
      setText('[data-da-owner-ro]', node.owner ?? '—');
      const chip = document.querySelector<HTMLElement>('[data-da-status-ro] .bcn-status-chip');
      const meta = TASK_STATUS_META[node.status ?? 'not-started'];
      if (chip) {
        chip.dataset.status = node.status ?? 'not-started';
        chip.style.setProperty('--_chip', meta.hex);
        const lbl = chip.querySelector<HTMLElement>('.bcn-status-chip__label');
        if (lbl) lbl.textContent = meta.label;
      }
    }
    // Notes & constraints (bcn-detail__ notes classes are global for this rebuild).
    const notes = document.querySelector<HTMLElement>('[data-live="notes"]');
    if (notes) {
      const cs = (node.constraints ?? []).filter(Boolean);
      const parts: string[] = [];
      if (cs.length) parts.push(`<ul class="bcn-detail__constraints">${cs.map((c) => `<li>${escHtml(c)}</li>`).join('')}</ul>`);
      if (node.notes) parts.push(`<p class="bcn-detail__note">${escHtml(node.notes)}</p>`);
      notes.innerHTML = parts.length ? parts.join('') : '<p class="bcn-detail__note bcn-detail__note--empty">None recorded.</p>';
    }
    // Funding: own cells (derived cells are patchDerived's job).
    document.querySelectorAll<HTMLElement>('.bcn-funding tr[data-wy] [data-cell="own"]').forEach((cell) => {
      const wy = Number(cell.closest('tr')?.dataset.wy);
      const own = node.funding.find((f) => f.waterYear === wy)?.amount ?? 0;
      cell.textContent = own ? formatUSD(own) : '—';
    });
  };

  // ── Edit-record drawer: ALL field editing lives here — the page lands
  //    read-only (Andy, 2026-07-21). Seeded from the node on open; Save applies
  //    every field, recomputes, and repaints the read-only record. ──
  const recordDrawer = document.getElementById('record-drawer') as
    | (HTMLElement & { show(): void; close(): void })
    | null;
  if (recordDrawer) {
    const rd = <T extends HTMLElement>(sel: string) => recordDrawer.querySelector<T>(sel);
    const rdField = (sel: string) => rd<Field>(sel);
    const schedSel = (part: string) => rd<Field>(`esa-select[data-rd-sched="${part}"]`);
    const rdStatusRoot = rd<HTMLElement>('#rd-status');
    const rdStatusCtl = rdStatusRoot ? setupStatusSelect(rdStatusRoot) : null;

    document.querySelector('[data-rec-edit]')?.addEventListener('click', () => {
      customElements.whenDefined('esa-text-field').then(() => {
        rdField('[data-rd-name]')!.value = node.name;
        rdField('[data-rd-id]')!.value = node.id;
        rdField('[data-rd-coa]')!.value = node.coaRef ?? '';
        const notesTa = rdField('[data-rd-notes]');
        if (notesTa) notesTa.value = node.notes ?? '';
        const consTa = rdField('[data-rd-constraints]');
        if (consTa) consTa.value = (node.constraints ?? []).join('\n');
        const ownerTa = rdField('[data-rd-owner]');
        if (ownerTa) ownerTa.value = node.owner ?? '';
        recordDrawer.querySelectorAll<Field & { dataset: DOMStringMap }>('[data-rd-funding]').forEach((f) => {
          const own = node.funding.find((x) => x.waterYear === Number(f.dataset.wy))?.amount ?? 0;
          f.value = own ? String(own) : '';
        });
      });
      customElements.whenDefined('esa-select').then(() => {
        if (isTask) {
          schedSel('start-month')!.value = node.startMonth ? node.startMonth.slice(5) : '';
          schedSel('start-year')!.value = node.startMonth ? node.startMonth.slice(0, 4) : '';
          schedSel('end-month')!.value = node.endMonth ? node.endMonth.slice(5) : '';
          schedSel('end-year')!.value = node.endMonth ? node.endMonth.slice(0, 4) : '';
        }
        if (node.tier === 'study') {
          const dlm = rd<Field>('esa-select[data-rd-dl="month"]');
          const dly = rd<Field>('esa-select[data-rd-dl="year"]');
          if (dlm) dlm.value = node.deadline ? node.deadline.slice(5) : '';
          if (dly) dly.value = node.deadline ? node.deadline.slice(0, 4) : '';
          const drv = rd<Field>('esa-select[data-rd-drivenby]');
          if (drv) drv.value = node.drivenBy ?? '';
        }
      });
      rdStatusCtl?.setValue(node.status ?? 'not-started');
      recordDrawer.show();
    });

    rd('[data-rd-save]')?.addEventListener('click', () => {
      const name = String(rdField('[data-rd-name]')?.value ?? '').trim();
      if (name) node.name = name;
      const nextId = String(rdField('[data-rd-id]')?.value ?? '').trim();
      if (nextId) node.id = nextId;
      node.coaRef = String(rdField('[data-rd-coa]')?.value ?? '').trim() || undefined;
      node.notes = String(rdField('[data-rd-notes]')?.value ?? '').trim() || undefined;

      if (isTask) {
        const iso = (m: string, y: string) => (m && y ? `${y}-${m}` : undefined);
        let s = iso(String(schedSel('start-month')?.value ?? ''), String(schedSel('start-year')?.value ?? ''));
        let e = iso(String(schedSel('end-month')?.value ?? ''), String(schedSel('end-year')?.value ?? ''));
        if (s && !e) e = s;
        if (e && !s) s = e;
        if (s && e && s > e) e = s;
        node.startMonth = s;
        node.endMonth = e;
        node.status = ((rdStatusRoot?.dataset.value as TaskStatus | undefined) ?? node.status) as TaskStatus;
        node.owner = String(rdField('[data-rd-owner]')?.value ?? '').trim() || undefined;
      }

      if (node.tier === 'study') {
        const m = String(rd<Field>('esa-select[data-rd-dl="month"]')?.value ?? '');
        const y = String(rd<Field>('esa-select[data-rd-dl="year"]')?.value ?? '');
        node.deadline = m && y ? `${y}-${m}` : undefined;
        node.drivenBy = String(rd<Field>('esa-select[data-rd-drivenby]')?.value ?? '') || undefined;
        const lines = String(rdField('[data-rd-constraints]')?.value ?? '')
          .split('\n')
          .map((l) => l.trim())
          .filter(Boolean);
        node.constraints = lines.length ? lines : undefined;
      }

      const entries: { waterYear: number; amount: number }[] = [];
      recordDrawer.querySelectorAll<Field & { dataset: DOMStringMap }>('[data-rd-funding]').forEach((f) => {
        const amount = Math.max(0, Math.round(Number(String(f.value ?? '').replace(/[^0-9.]/g, '')) || 0));
        if (amount > 0) entries.push({ waterYear: Number(f.dataset.wy), amount });
      });
      node.funding = entries;

      patchDerived();
      repaintRecord();
      recordDrawer.close();
    });
    rd('[data-rd-cancel]')?.addEventListener('click', () => recordDrawer.close());
  }

  // ── Assignments drawer (study tier): read-only WHO block + Edit → side panel
  //    with the lead select and the roles repeater. Save writes node.lead /
  //    node.roles and repaints the read-only rows from the SSR template. ──
  const assignDrawer = document.getElementById('assign-drawer') as
    | (HTMLElement & { show(): void; close(): void })
    | null;
  if (assignDrawer) {
    const vocab = {
      workstreams: JSON.parse(assignDrawer.dataset.wsOptions ?? '[]') as { value: string; label: string }[],
      orgs: JSON.parse(assignDrawer.dataset.orgOptions ?? '[]') as { value: string; label: string }[],
    };
    const wsLabel = new Map(vocab.workstreams.map((w) => [w.value, w.label]));
    const leadOptions = JSON.parse(assignDrawer.dataset.leadOptions ?? '[]') as { value: string; label: string }[];
    const adrLead = assignDrawer.querySelector('esa-select[data-adr-lead]') as
      | (Field & { options: { value: string; label: string }[] })
      | null;
    const repeaterRoot = assignDrawer.querySelector<HTMLElement>('[data-roles-repeater]');
    const repCtl = repeaterRoot ? setupRolesRepeater(repeaterRoot, vocab) : null;

    document.querySelector('[data-da-edit]')?.addEventListener('click', () => {
      customElements.whenDefined('esa-select').then(() => {
        if (adrLead) {
          adrLead.options = leadOptions;
          adrLead.value = node.lead ?? '';
        }
      });
      repCtl?.setRows(node.roles ?? []);
      assignDrawer.show();
    });

    // Repaint the read-only WHO block from the current node after a save.
    const repaintAssignments = () => {
      const leadRo = document.querySelector<HTMLElement>('[data-da-lead-ro]');
      if (leadRo) leadRo.textContent = node.lead ?? '—';
      const list = document.querySelector<HTMLElement>('[data-da-ro-list]');
      const tpl = document.querySelector<HTMLTemplateElement>('template[data-da-ro-row]');
      if (!list || !tpl) return;
      list.innerHTML = '';
      (node.roles ?? []).forEach((r) => {
        const row = (tpl.content.firstElementChild as HTMLElement).cloneNode(true) as HTMLElement;
        row.querySelector('[data-ro-ws]')!.textContent = wsLabel.get(r.workstream) ?? r.workstream;
        row.querySelector('[data-ro-org]')!.textContent = r.org;
        const person = row.querySelector<HTMLElement>('[data-ro-person]')!;
        if (r.person) person.textContent = r.person;
        else person.remove();
        if (!r.tentative) row.querySelector('[data-ro-tent]')?.remove();
        list.appendChild(row);
      });
    };

    assignDrawer.querySelector('[data-adr-save]')?.addEventListener('click', () => {
      node.lead = ((adrLead?.value ?? '') || undefined) as HierNode['lead'];
      node.roles = repCtl?.getRows() ?? node.roles;
      repaintAssignments();
      assignDrawer.close();
    });
    assignDrawer.querySelector('[data-adr-cancel]')?.addEventListener('click', () => assignDrawer.close());
  }
</script>

