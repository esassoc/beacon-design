---
// <BcnPlanReader> — the draft science plan as a navigable document with its
// review layer: numbered section outline, per-section COA references (linking to
// the study/program detail pages), and the CDFW comment threads anchored to each
// section. The document corpus is FIXED; the live datum is comment status.
//
// Like the other projection components, it takes fully-projected plain data —
// the PAGE joins PLAN_SECTIONS + PLAN_COMMENTS + STUDY_PROFILES review threads
// and the coaRef→node-id map; this component renders and filters.
//
// bcn-lego-checked: composed legos — esa-text-field/esa-select (filter bar),
// esa-avatar/esa-badge/esa-pill (comment meta), BcnStatusSelect (status filter),
// BcnStatusChip (comment status). Bespoke: the two-column outline/document
// layout and the section blocks — no esa-* lego renders a sectioned document
// with anchored threads (esa-tab-layout/esa-card checked; Beacon has no
// document-reader surface). The per-section thread reuses BcnReviewThread's
// visual language but NOT the component — that groups by sketch field, wrong
// grouping for a document. Tokens: semantic layer only.
import EsaAvatar from '@esa/ecology/esa-avatar.astro';
import EsaBadge from '@esa/ecology/esa-badge.astro';
import EsaPill from '@esa/ecology/esa-pill.astro';
import EsaFilterClearButton from '@esa/ecology/esa-filter-clear-button.astro';
import BcnStatusSelect from './BcnStatusSelect.astro';
import BcnStatusChip from './BcnStatusChip.astro';

export interface ReaderCoaChip {
  ref: string;
  /** COA display name (hover title). */
  name?: string;
  /** Detail-page href when the ref resolves to a work-breakdown node. */
  href?: string;
}

export interface ReaderReply {
  author: string;
  date: string;
  text: string;
}

export interface ReaderComment {
  id: string;
  author: string;
  agency: boolean;
  date: string;
  intentKey: string;
  intentLabel: string;
  statusKey: string;
  statusLabel: string;
  statusHex: string;
  text: string;
  replies: ReaderReply[];
}

export interface ReaderSection {
  id: string;
  number: string;
  title: string;
  level: 1 | 2 | 3;
  excerpt?: string;
  coaChips: ReaderCoaChip[];
  comments: ReaderComment[];
}

export interface ReaderOutlineItem {
  id: string;
  number: string;
  title: string;
  level: 1 | 2 | 3;
  commentCount: number;
}

interface Props {
  sections: ReaderSection[];
  outline: ReaderOutlineItem[];
  counts: { open: number; addressed: number; resolved: number };
  intents: { value: string; label: string }[];
  statusOptions: { value: string; label: string; color?: string }[];
  coas: { value: string; label: string }[];
}

const { sections, outline, counts, intents, statusOptions, coas } = Astro.props;
---

<div class="bcn-planr">
  <div class="bcn-planr__filterbar" data-intents={JSON.stringify(intents)} data-coas={JSON.stringify(coas)}>
    <div class="bcn-planr__fb-top">
      <div class="bcn-planr__fb-group">
        <span class="bcn-planr__fb-label">Search</span>
        <esa-text-field id="bcn-planr-search" placeholder="Search sections or comments" size="sm"></esa-text-field>
      </div>
      <span class="bcn-planr__fb-divider"></span>
      <div class="bcn-planr__fb-group">
        <span class="bcn-planr__fb-label">Status</span>
        <BcnStatusSelect id="bcn-planr-status" label="" value="all" options={statusOptions} />
      </div>
      <div class="bcn-planr__fb-group">
        <span class="bcn-planr__fb-label">Intent</span>
        <esa-select id="bcn-planr-intent" size="sm"></esa-select>
      </div>
      <div class="bcn-planr__fb-group">
        <span class="bcn-planr__fb-label">COA</span>
        <esa-select id="bcn-planr-coa" size="sm"></esa-select>
      </div>
      <span class="bcn-planr__fb-right">
        <span class="bcn-planr__counts">
          <span class="bcn-planr__count" data-s="open">{counts.open} open</span>
          <span class="bcn-planr__count" data-s="addressed">{counts.addressed} addressed</span>
          <span class="bcn-planr__count" data-s="resolved">{counts.resolved} resolved</span>
        </span>
        <EsaFilterClearButton label="Clear" />
      </span>
    </div>
  </div>

  <div class="bcn-planr__grid">
    <!-- ── Section outline ── -->
    <nav class="bcn-planr__outline" aria-label="Plan sections">
      <ul class="bcn-planr__toc">
        {outline.map((o) => (
          <li class="bcn-planr__toc-item" data-level={o.level} data-for={o.id}>
            <a class="bcn-planr__toc-link" href={`#${o.id}`}>
              <span class="bcn-planr__toc-num">{o.number}</span>
              <span class="bcn-planr__toc-title">{o.title}</span>
              {o.commentCount > 0 && <span class="bcn-planr__toc-count">{o.commentCount}</span>}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- ── Document sections ── -->
    <div class="bcn-planr__doc">
      {sections.map((s) => (
        <section
          class="bcn-planr__section"
          id={s.id}
          data-level={s.level}
          data-search={`${s.number} ${s.title} ${s.excerpt ?? ''}`.toLowerCase()}
          data-coas={s.coaChips.map((c) => c.ref).join(' ')}
          data-has-comments={s.comments.length > 0 ? '' : undefined}
        >
          <header class="bcn-planr__sec-head">
            {s.level === 1 ? (
              <h2 class="bcn-planr__h1"><span class="bcn-planr__num">{s.number}</span>{s.title}</h2>
            ) : s.level === 2 ? (
              <h3 class="bcn-planr__h2"><span class="bcn-planr__num">{s.number}</span>{s.title}</h3>
            ) : (
              <h4 class="bcn-planr__h3"><span class="bcn-planr__num">{s.number}</span>{s.title}</h4>
            )}
            {s.coaChips.length > 0 && (
              <span class="bcn-planr__coas">
                {s.coaChips.map((c) =>
                  c.href ? (
                    <a class="bcn-planr__coa" href={c.href} title={c.name ?? c.ref}>{c.ref}</a>
                  ) : (
                    <span class="bcn-planr__coa" title={c.name ?? c.ref}>{c.ref}</span>
                  ),
                )}
              </span>
            )}
          </header>

          {s.excerpt && <p class="bcn-planr__excerpt">{s.excerpt}</p>}

          {s.comments.length > 0 && (
            <ul class="bcn-planr__thread">
              {s.comments.map((c) => (
                <li
                  class="bcn-planr__comment"
                  data-status={c.statusKey}
                  data-intent={c.intentKey}
                  data-search={`${c.text} ${c.author} ${c.replies.map((r) => r.text).join(' ')}`.toLowerCase()}
                >
                  <span class="bcn-planr__avatar"><EsaAvatar name={c.author} size="sm" /></span>
                  <div class="bcn-planr__c-body">
                    <div class="bcn-planr__c-meta">
                      <span class="bcn-planr__c-author">{c.author}</span>
                      {c.agency && <EsaBadge variant="warning" size="sm" value="CDFW" />}
                      <span class="bcn-planr__c-time">{c.date}</span>
                      <span class="bcn-planr__c-tags">
                        <EsaPill label={c.intentLabel} removable={false} size="sm" />
                        <BcnStatusChip status={c.statusKey} label={c.statusLabel} hex={c.statusHex} />
                      </span>
                    </div>
                    <p class="bcn-planr__c-text">{c.text}</p>
                    {c.replies.length > 0 && (
                      <ul class="bcn-planr__replies">
                        {c.replies.map((r) => (
                          <li class="bcn-planr__reply">
                            <span class="bcn-planr__avatar"><EsaAvatar name={r.author} size="sm" /></span>
                            <div class="bcn-planr__c-body">
                              <div class="bcn-planr__c-meta">
                                <span class="bcn-planr__c-author">{r.author}</span>
                                <span class="bcn-planr__c-time">{r.date}</span>
                              </div>
                              <p class="bcn-planr__c-text">{r.text}</p>
                            </div>
                          </li>
                        ))}
                      </ul>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          )}
        </section>
      ))}
      <p class="bcn-planr__noresults" hidden>No sections match the filters.</p>
    </div>
  </div>
</div>

<script>
  import { setupStatusSelect } from './status-select';

  document.querySelectorAll<HTMLElement>('.bcn-planr').forEach((root) => {
    const sections = [...root.querySelectorAll<HTMLElement>('.bcn-planr__section')];
    const tocItems = [...root.querySelectorAll<HTMLElement>('.bcn-planr__toc-item')];
    const noResults = root.querySelector<HTMLElement>('.bcn-planr__noresults');
    const search = root.querySelector('#bcn-planr-search') as HTMLElement & { value: string };
    const statusRoot = root.querySelector<HTMLElement>('#bcn-planr-status');
    const statusCtl = statusRoot ? setupStatusSelect(statusRoot) : null;
    const intentSel = root.querySelector('#bcn-planr-intent') as HTMLElement & { options: { value: string; label: string }[]; value: string };
    const coaSel = root.querySelector('#bcn-planr-coa') as HTMLElement & { options: { value: string; label: string }[]; value: string };

    // Option lists arrive as JSON on the host (SSR'd data attributes).
    const host = root.querySelector<HTMLElement>('.bcn-planr__filterbar');
    const intents = JSON.parse(host?.dataset.intents ?? '[]');
    const coas = JSON.parse(host?.dataset.coas ?? '[]');
    if (intentSel) {
      intentSel.options = [{ value: 'all', label: 'All intents' }, ...intents];
      intentSel.value = 'all';
    }
    if (coaSel) {
      coaSel.options = [{ value: 'all', label: 'All COAs' }, ...coas];
      coaSel.value = 'all';
    }

    let q = '';
    let status = 'all';
    let intent = 'all';
    let coa = 'all';

    function apply() {
      const anyCommentFilter = status !== 'all' || intent !== 'all';
      let shown = 0;
      sections.forEach((sec) => {
        const comments = [...sec.querySelectorAll<HTMLElement>('.bcn-planr__comment')];
        // Comment-level visibility (status/intent/search hit inside the thread).
        let visibleComments = 0;
        comments.forEach((c) => {
          const match =
            (status === 'all' || c.dataset.status === status) &&
            (intent === 'all' || c.dataset.intent === intent) &&
            (!q || (c.dataset.search ?? '').includes(q) || (sec.dataset.search ?? '').includes(q));
          c.hidden = !match;
          if (match) visibleComments++;
        });
        // Section-level visibility.
        const coaMatch = coa === 'all' || (sec.dataset.coas ?? '').split(' ').includes(coa);
        const searchMatch = !q || (sec.dataset.search ?? '').includes(q) || visibleComments > 0;
        const commentMatch = !anyCommentFilter || visibleComments > 0;
        const show = coaMatch && searchMatch && commentMatch;
        sec.hidden = !show;
        if (show) shown++;
        const toc = tocItems.find((t) => t.dataset.for === sec.id);
        if (toc) toc.hidden = !show;
      });
      if (noResults) noResults.hidden = shown > 0;
    }

    search?.addEventListener('change', (e) => {
      q = (((e as CustomEvent).detail?.value as string) ?? search.value ?? '').trim().toLowerCase();
      apply();
    });
    statusRoot?.addEventListener('change', (e) => {
      status = (((e as CustomEvent).detail?.value as string) ?? 'all');
      apply();
    });
    intentSel?.addEventListener('change', (e) => {
      intent = (((e as CustomEvent).detail?.value as string) ?? intentSel.value ?? 'all');
      apply();
    });
    coaSel?.addEventListener('change', (e) => {
      coa = (((e as CustomEvent).detail?.value as string) ?? coaSel.value ?? 'all');
      apply();
    });
    root.addEventListener('esa-filter-clear', () => {
      q = '';
      status = 'all';
      intent = 'all';
      coa = 'all';
      if (search) search.value = '';
      statusCtl?.setValue('all');
      if (intentSel) intentSel.value = 'all';
      if (coaSel) coaSel.value = 'all';
      apply();
    });
  });
</script>

<style>
  /* bcn-lego-checked: document-reader layout glue only (see frontmatter note). */

  .bcn-planr {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-400);
    font-size: var(--type-size-200);
    color: var(--color-text-primary);
  }

  /* ── Filter bar (house pattern) ── */
  .bcn-planr__filterbar {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-200);
    background: var(--color-surface);
  }
  .bcn-planr__fb-top {
    display: flex;
    align-items: center;
    gap: var(--spacing-300);
    flex-wrap: wrap;
    padding: var(--spacing-250) var(--spacing-400);
  }
  .bcn-planr__fb-group {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-300);
  }
  .bcn-planr__fb-label {
    font-size: var(--type-size-150);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-tertiary);
    white-space: nowrap;
  }
  .bcn-planr__fb-divider {
    width: 1px;
    align-self: stretch;
    background: var(--color-border);
    margin: 0 var(--spacing-100);
  }
  .bcn-planr__fb-right {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-400);
  }
  .bcn-planr__fb-group :global(esa-text-field) {
    width: 240px;
  }
  .bcn-planr__fb-group :global(esa-select) {
    display: inline-block;
    width: 12em;
  }
  .bcn-planr__fb-group :global(.bcn-status-select__trigger) {
    height: 32px;
    padding: 0 var(--spacing-200);
    font-size: var(--form-font-size-sm, 12px);
    font-weight: var(--font-weight-regular);
  }
  .bcn-planr__counts {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-300);
    font-size: var(--type-size-100);
  }
  .bcn-planr__count {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-100);
    color: var(--color-text-secondary);
    white-space: nowrap;
  }
  .bcn-planr__count::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
  }
  .bcn-planr__count[data-s='open']::before { background: var(--color-warning); }
  .bcn-planr__count[data-s='addressed']::before { background: var(--color-info); }
  .bcn-planr__count[data-s='resolved']::before { background: var(--color-success); }

  /* ── Two-column: outline + document ── */
  .bcn-planr__grid {
    display: grid;
    grid-template-columns: 300px minmax(0, 1fr);
    gap: var(--spacing-600);
    align-items: start;
  }
  .bcn-planr__outline {
    position: sticky;
    top: var(--spacing-400);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-200);
    background: var(--color-surface);
    padding: var(--spacing-300);
    max-height: calc(100vh - 140px);
    overflow-y: auto;
  }
  .bcn-planr__toc {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .bcn-planr__toc-link {
    display: flex;
    align-items: baseline;
    gap: var(--spacing-200);
    padding: var(--spacing-150) var(--spacing-200);
    border-radius: var(--radius-100);
    text-decoration: none;
    color: var(--color-text-secondary);
    font-size: var(--type-size-150);
    line-height: 1.35;
  }
  .bcn-planr__toc-link:hover {
    background: var(--color-surface-sunken);
    color: var(--color-text-primary);
  }
  .bcn-planr__toc-item[data-level='1'] .bcn-planr__toc-link {
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
    margin-top: var(--spacing-150);
  }
  .bcn-planr__toc-item[data-level='3'] .bcn-planr__toc-link {
    padding-left: var(--spacing-500);
  }
  .bcn-planr__toc-num {
    flex: none;
    font-family: var(--font-mono);
    font-size: var(--type-size-100);
    color: var(--color-text-tertiary);
    min-width: 34px;
  }
  .bcn-planr__toc-title {
    min-width: 0;
  }
  .bcn-planr__toc-count {
    margin-left: auto;
    flex: none;
    font-size: var(--type-size-100);
    font-weight: var(--font-weight-semibold);
    color: var(--color-commitment);
    background: color-mix(in srgb, var(--color-commitment) 12%, white);
    padding: 0 6px;
    border-radius: var(--radius-full);
    line-height: 1.6;
  }

  /* ── Document ── */
  .bcn-planr__doc {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-500);
    min-width: 0;
    max-width: 84ch;
  }
  .bcn-planr__section {
    scroll-margin-top: var(--spacing-400);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-250);
  }
  .bcn-planr__sec-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--spacing-200) var(--spacing-400);
  }
  .bcn-planr__h1 {
    margin: var(--spacing-400) 0 0;
    padding-bottom: var(--spacing-200);
    border-bottom: 2px solid var(--color-border-strong);
    font-size: var(--type-size-400);
    font-weight: var(--font-weight-semibold);
    line-height: 1.3;
    flex: 1 1 100%;
  }
  .bcn-planr__h2 {
    margin: 0;
    font-size: var(--type-size-300);
    font-weight: var(--font-weight-semibold);
    line-height: 1.3;
  }
  .bcn-planr__h3 {
    margin: 0;
    font-size: var(--type-size-200);
    font-weight: var(--font-weight-semibold);
    line-height: 1.35;
  }
  .bcn-planr__num {
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: var(--color-text-tertiary);
    margin-right: var(--spacing-250);
  }
  .bcn-planr__coas {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--spacing-150);
  }
  .bcn-planr__coa {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6875rem; /* adherence-allow: font-too-small — matches the sanctioned 11px reference chips */
    font-weight: var(--font-weight-semibold);
    color: var(--color-commitment);
    background: color-mix(in srgb, var(--color-commitment) 12%, white);
    padding: 1px 5px;
    border-radius: var(--radius-100);
    line-height: 1.5;
    text-decoration: none;
    white-space: nowrap;
  }
  a.bcn-planr__coa:hover {
    background: color-mix(in srgb, var(--color-commitment) 20%, white);
  }
  .bcn-planr__excerpt {
    margin: 0;
    font-size: var(--type-size-200);
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 72ch;
  }

  /* ── Per-section thread (review-thread visual language) ── */
  .bcn-planr__thread {
    list-style: none;
    margin: var(--spacing-100) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-300);
  }
  .bcn-planr__comment,
  .bcn-planr__reply {
    display: flex;
    gap: var(--spacing-250);
  }
  .bcn-planr__comment {
    padding: var(--spacing-300);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-200);
    background: var(--color-surface);
  }
  .bcn-planr__avatar {
    flex: none;
  }
  .bcn-planr__c-body {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-150);
    min-width: 0;
    flex: 1;
  }
  .bcn-planr__c-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--spacing-200);
    font-size: var(--type-size-150);
  }
  .bcn-planr__c-author {
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
  }
  .bcn-planr__c-time {
    color: var(--color-text-tertiary);
    font-size: var(--type-size-100);
  }
  .bcn-planr__c-tags {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-150);
    margin-left: auto;
  }
  .bcn-planr__c-text {
    margin: 0;
    font-size: var(--type-size-150);
    color: var(--color-text-secondary);
    line-height: 1.55;
  }
  .bcn-planr__replies {
    list-style: none;
    margin: var(--spacing-100) 0 0;
    padding: var(--spacing-250) 0 0 var(--spacing-400);
    border-top: 1px solid var(--color-border-light);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-250);
  }
  .bcn-planr__noresults {
    margin: 0;
    font-size: var(--type-size-150);
    color: var(--color-text-tertiary);
  }

  @media (max-width: 1000px) {
    .bcn-planr__grid {
      grid-template-columns: 1fr;
    }
    .bcn-planr__outline {
      position: static;
      max-height: none;
    }
  }
</style>
