---
// <BcnWorkBreakdown> — the four-tier tasking gantt / work breakdown.
//
// bcn-lego-checked: no esa-* lego renders a recursive, collapsible work-breakdown
// gantt with month-scale bars and roll-up spans — esa-progress-bar is a single bar,
// esa-stat/esa-card are static, and the flat BcnScheduleTimeline is single-level with
// no tree nesting or roll-up brackets. Checked Beacon prod (no gantt component;
// scheduling lives in exported spreadsheets). The disclosure caret + inline row bar are
// gantt affordances (esa-icon-button is too heavy for a 12px twisty). Everything that
// HAS a lego uses it: the row-action menu is esa-dropdown-menu, delete is esa-confirm-
// dialog, reparent is esa-dialog + esa-select, add-child is esa-icon-button.
// bcn-work-breakdown is the reusable home.
//
// vs. the prior prototype (Andy's five locked decisions):
//   1. FOUR named tiers (Program → Study → Sub-study → Task), CRUD at every tier.
//   2. NO dependency arrows — that dimension is dropped from this view.
//   3. Stable type-prefixed IDS are identity; the COA dot-number rides as a muted
//      secondary reference label next to the id.
//   4. The TASK is the schedulable month unit (status-colored bar); parents draw a
//      neutral roll-up bracket spanning their tasks' min-start → max-end.
//   5. Clicking a row opens its side panel (host wires the drawer via wb-node-select).
// Water-year axis, phase bands, and milestones are honored exactly as fish-schedule.ts.
//
// FUNCTIONAL CRUD LAYER (client model): the SSR fixture is serialized into the page
// and hydrated into a mutable tree. Task bars drag (edge hotzones resize by month,
// body drag moves the whole bar); the node-edit drawer's Name/ID/date/budget legos
// write through `wbApi` on this element (setName / setId / setSchedule / setFunding
// / addChildTo / requestDelete); every mutation funnels into ONE recompute() that
// patches bars, roll-up brackets, badges, data-start/data-end, and emits
// `wb-model-change` for the page (header KPIs) and panel components. Re-keying an
// id additionally emits `wb-node-id-change` so panels can follow. In-memory only —
// reload resets.
import type { HierNode } from '../../data/fish-model';
import { computeRollUp, flattenForest, TASK_STATUS_META, TIER_META } from '../../data/fish-model';
import EsaButton from '@esa/ecology/esa-button.astro';
import EsaIconButton from '@esa/ecology/esa-icon-button.astro';
import {
  DCP_PHASES,
  MILESTONES,
  PHASE_META,
  axisFraction,
  axisYears,
  SCHEDULE_START_YEAR,
  SCHEDULE_END_YEAR,
} from '../../data/fish-schedule';

interface Props {
  programs: HierNode[];
  /** ISO date for the TODAY marker; omit to hide it. */
  today?: string;
}
const { programs, today } = Astro.props;

const flat = flattenForest(programs);
const rollups = new Map(flat.map((f) => [f.node.id, computeRollUp(f.node)]));

// The client-side model: the same fixture the SSR rendered, hydrated mutable.
const modelJson = JSON.stringify(programs).replace(/</g, '\\u003c');

const years = axisYears();
const span = SCHEDULE_END_YEAR - SCHEDULE_START_YEAR;
const pct = (n: number) => `${(n * 100).toFixed(2)}%`;
const yearFrac = (y: number) => (y - SCHEDULE_START_YEAR) / span;

// Bar geometry: a node WITH children uses its DERIVED roll-up span; a node with
// none (a Task, or a childless parent) uses its own months.
function barGeo(node: HierNode): { left: string; width: string } | null {
  const r = rollups.get(node.id)!;
  const startISO = node.children.length ? r.startMonth : (node.startMonth ?? r.startMonth);
  const endISO = node.children.length ? r.endMonth : (node.endMonth ?? r.endMonth);
  if (!startISO || !endISO) return null;
  const left = axisFraction(`${startISO}-01`);
  const right = axisFraction(`${endISO}-28`);
  return { left: pct(left), width: pct(Math.max(right - left, 0.005)) };
}

// Legend statuses (leaf-task health ramp) + the roll-up bracket swatch.
const LEGEND_STATUSES = ['complete', 'on-track', 'at-risk', 'blocked', 'not-started'] as const;
const TIER_CLASS: Record<HierNode['tier'], string> = {
  program: 'is-program',
  study: 'is-study',
  substudy: 'is-substudy',
  task: 'is-task',
};
---

<div class="bcn-wb">
  <script is:inline type="application/json" data-wb-model set:html={modelJson}></script>
  <!-- ── Filter bar (permit-tracking pattern): controls on top, legend below.
       Every lego rides the sm size variant; Add program lives at the BOTTOM of
       the tree body (the ghost add-row), so the bar starts with Search. ── -->
  <div class="bcn-wb__filterbar">
    <div class="bcn-wb__fb-top">
      <div class="bcn-wb__fb-group">
        <span class="bcn-wb__fb-label">Search</span>
        <esa-text-field id="bcn-wb-search" placeholder="Search name or ID" size="sm"></esa-text-field>
      </div>
      <span class="bcn-wb__fb-divider"></span>
      <div class="bcn-wb__fb-group">
        <span class="bcn-wb__fb-label">Tier</span>
        <esa-button-toggle id="bcn-wb-tier-filter" value="all" size="sm"></esa-button-toggle>
      </div>
      <span class="bcn-wb__fb-divider"></span>
      <div class="bcn-wb__fb-group">
        <span class="bcn-wb__fb-label">Years</span>
        <esa-select id="bcn-wb-year-from" class="bcn-wb__fb-year" size="sm"></esa-select>
        <span class="bcn-wb__fb-to">to</span>
        <esa-select id="bcn-wb-year-to" class="bcn-wb__fb-year" size="sm"></esa-select>
      </div>
      <span class="bcn-wb__filter-count" id="bcn-wb-filter-count" hidden></span>
    </div>
    <div class="bcn-wb__legend">
      {
        LEGEND_STATUSES.map((s) => (
          <span class="bcn-wb__legend-item">
            <span class="bcn-wb__legend-dot" style={`--_c: ${TASK_STATUS_META[s].hex};`} />
            {TASK_STATUS_META[s].label}
          </span>
        ))
      }
      <span class="bcn-wb__legend-item">
        <span class="bcn-wb__legend-summary" />
        Roll-up span
      </span>
    </div>
  </div>

  <div class="bcn-wb__scroll">
    <div class="bcn-wb__canvas">
      <!-- ── Axis header: phases / years / milestones (water-year aware) ── -->
      <header class="bcn-wb__axis">
        <div class="bcn-wb__corner">Program / study / sub-study / task</div>
        <div class="bcn-wb__head-plot">
          <div class="bcn-wb__head-bands">
            {
              DCP_PHASES.map((p) => (
                <span class="bcn-wb__band" data-phase={p.id} style={`left: ${pct(yearFrac(p.startYear))}; width: ${pct(yearFrac(p.endYear) - yearFrac(p.startYear))};`} />
              ))
            }
          </div>
          <div class="bcn-wb__head-phases">
            {
              DCP_PHASES.map((p) => (
                <span class="bcn-wb__phase-tag" style={`left: ${pct(yearFrac(p.startYear))}; width: ${pct(yearFrac(p.endYear) - yearFrac(p.startYear))};`}>
                  {PHASE_META[p.id].short}
                </span>
              ))
            }
          </div>
          <div class="bcn-wb__head-years">
            {
              years.slice(0, -1).map((y) => (
                <span class="bcn-wb__yr" class:list={[{ 'is-five': y % 5 === 0 }]} style={`left: ${pct(yearFrac(y))}; width: ${pct(1 / span)};`}>
                  <span class="bcn-wb__yr-label">{`’${String(y).slice(2)}`}</span>
                </span>
              ))
            }
          </div>
          <div class="bcn-wb__head-ms">
            {
              MILESTONES.map((m, i) => (
                <span class="bcn-wb__ms-tag" class:list={[{ 'is-alt': i % 2 === 1 }]} style={`left: ${pct(axisFraction(m.date))};`} title={`${m.label} (WY${m.waterYear})`}>
                  {m.tag}
                </span>
              ))
            }
          </div>
        </div>
      </header>

      <!-- ── Body: recursive rows (no dependency overlay) ── -->
      <div class="bcn-wb__body">
        {
          flat.map(({ node, depth, parentId }) => {
            const r = rollups.get(node.id)!;
            const geo = barGeo(node);
            const hasChildren = node.children.length > 0;
            const st = node.status ? TASK_STATUS_META[node.status] : undefined;
            return (
              <div
                class:list={['bcn-wb__row', TIER_CLASS[node.tier], { 'is-leaf': !hasChildren }]}
                data-id={node.id}
                data-start={(node.children.length ? r.startMonth : (node.startMonth ?? r.startMonth)) ?? ''}
                data-end={(node.children.length ? r.endMonth : (node.endMonth ?? r.endMonth)) ?? ''}
                data-tier={node.tier}
                data-depth={depth}
                data-parent={parentId ?? ''}
                data-has-children={hasChildren ? '1' : '0'}
              >
                <div class="bcn-wb__label" style={`--_indent: ${depth};`}>
                  {hasChildren ? (
                    <button type="button" class="bcn-wb__caret" aria-expanded="true" aria-label={`Collapse ${node.name}`}>
                      <svg viewBox="0 0 24 24" width="12" height="12" aria-hidden="true"><path d="m6 9 6 6 6-6" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
                    </button>
                  ) : (
                    <span class="bcn-wb__caret-spacer" />
                  )}
                  <button type="button" class="bcn-wb__name-btn" title={`${node.id} — ${node.name}`} aria-label={`Open ${node.id} ${node.name}`}>
                    <span class="bcn-wb__id">{node.id}</span>
                    <span class="bcn-wb__name">{node.name}</span>
                  </button>
                  {node.tier !== 'task' && (
                    <span class="bcn-wb__add">
                      <EsaIconButton icon="plus" size="xs" label={`Add ${TIER_META[node.tier].childLabel.toLowerCase()}`} />
                    </span>
                  )}
                  <esa-dropdown-menu class="bcn-wb__menu" position="below-end" width="auto">
                    <button type="button" class="bcn-wb__kebab" aria-label={`Actions for ${node.name}`}>⋯</button>
                  </esa-dropdown-menu>
                </div>

                <div class="bcn-wb__plot">
                  {DCP_PHASES.map((p) => (
                    <span class="bcn-wb__band" data-phase={p.id} style={`left: ${pct(yearFrac(p.startYear))}; width: ${pct(yearFrac(p.endYear) - yearFrac(p.startYear))};`} />
                  ))}
                  {years.slice(1, -1).map((y) => (
                    <span class="bcn-wb__grid" class:list={[{ 'is-five': y % 5 === 0 }]} style={`left: ${pct(yearFrac(y))};`} />
                  ))}
                  {MILESTONES.map((m) => (
                    <span class="bcn-wb__ms-line" style={`left: ${pct(axisFraction(m.date))};`} />
                  ))}
                  {today && <span class="bcn-wb__today" style={`left: ${pct(axisFraction(today))};`} />}
                  {geo && node.tier === 'task' && (
                    <button
                      type="button"
                      class="bcn-wb__bar"
                      style={`left: ${geo.left}; width: ${geo.width}; --_c: ${st!.hex};`}
                      title={`${node.id} — ${node.name} · ${st!.label}`}
                      aria-label={`Open ${node.id} ${node.name}`}
                    />
                  )}
                  {geo && node.tier !== 'task' && (
                    <span class="bcn-wb__summary" style={`left: ${geo.left}; width: ${geo.width};`} aria-hidden="true" />
                  )}
                </div>
              </div>
            );
          })
        }
      </div>

      <!-- ── Ghost add-row: Add program lives at the bottom of the tree body.
           The button rides the sticky label column so it stays visible while
           the plot scrolls. Same #bcn-wb-add-program hook as before. ── -->
      <div class="bcn-wb__addrow">
        <span id="bcn-wb-add-program"><EsaButton color="ghost" appearance="dashed" size="sm" icon="plus">Add program</EsaButton></span>
      </div>
    </div>
  </div>

  <!-- Row template cloned by the CRUD script for newly added nodes (unscheduled). -->
  <template id="bcn-wb-row-tpl">
    <div class="bcn-wb__row is-leaf" data-id="" data-tier="" data-depth="0" data-parent="" data-has-children="0">
      <div class="bcn-wb__label" style="--_indent: 0;">
        <span class="bcn-wb__caret-spacer"></span>
        <button type="button" class="bcn-wb__name-btn">
          <span class="bcn-wb__id"></span>
          <span class="bcn-wb__name"></span>
        </button>
        <span class="bcn-wb__add">
          <EsaIconButton icon="plus" size="xs" label="Add child" />
        </span>
        <esa-dropdown-menu class="bcn-wb__menu" position="below-end" width="auto">
          <button type="button" class="bcn-wb__kebab" aria-label="Row actions">⋯</button>
        </esa-dropdown-menu>
      </div>
      <div class="bcn-wb__plot">
        {DCP_PHASES.map((p) => (
          <span class="bcn-wb__band" data-phase={p.id} style={`left: ${pct(yearFrac(p.startYear))}; width: ${pct(yearFrac(p.endYear) - yearFrac(p.startYear))};`} />
        ))}
        {years.slice(1, -1).map((y) => (
          <span class="bcn-wb__grid" class:list={[{ 'is-five': y % 5 === 0 }]} style={`left: ${pct(yearFrac(y))};`} />
        ))}
        {MILESTONES.map((m) => (
          <span class="bcn-wb__ms-line" style={`left: ${pct(axisFraction(m.date))};`} />
        ))}
        <span class="bcn-wb__unscheduled">Unscheduled — open the panel to set a start &amp; end month</span>
      </div>
    </div>
  </template>

  <!-- Delete confirmation (esa-confirm-dialog lego). Delete is reachable from the
       node-edit drawer too, so this must stack ABOVE the drawer's --z-modal:1300. -->
  <esa-confirm-dialog id="bcn-wb-confirm" heading="Delete node" variant="danger" confirm-label="Delete" cancel-label="Keep" style="--z-modal: 1400; --z-modal-backdrop: 1350;"></esa-confirm-dialog>

  <!-- Reparent chooser (esa-dialog + esa-select legos). -->
  <esa-dialog id="bcn-wb-reparent" heading="Move to a different parent" size="sm">
    <esa-select id="bcn-wb-reparent-select" label="New parent" placeholder="Choose a parent…"></esa-select>
    <span slot="footer" class="bcn-wb__dialog-foot">
      <button type="button" class="bcn-wb__dialog-cancel" id="bcn-wb-reparent-cancel">Cancel</button>
      <button type="button" class="bcn-wb__dialog-move" id="bcn-wb-reparent-move">Move</button>
    </span>
  </esa-dialog>
</div>

<script>
  import '@esa/ecology/esa-dropdown-menu';
  import '@esa/ecology/esa-confirm-dialog';
  import '@esa/ecology/esa-dialog';
  import '@esa/ecology/esa-select';
  import '@esa/ecology/esa-text-field';
  import '@esa/ecology/esa-button-toggle';
  import { computeRollUp, TASK_STATUS_META } from '../../data/fish-model';
  import type { HierNode, NodeRollUp, TaskStatus } from '../../data/fish-model';
  import { axisFraction, SCHEDULE_START_YEAR, SCHEDULE_END_YEAR } from '../../data/fish-schedule';

  type Tier = 'program' | 'study' | 'substudy' | 'task';
  const CHILD_TIER: Partial<Record<Tier, Tier>> = { program: 'study', study: 'substudy', substudy: 'task' };
  const PARENT_TIER: Partial<Record<Tier, Tier>> = { study: 'program', substudy: 'study', task: 'substudy' };
  const TIER_LABEL: Record<Tier, string> = { program: 'Program', study: 'Study', substudy: 'Sub-study', task: 'Task' };
  const TIER_PREFIX: Record<Tier, string> = { program: 'PRG', study: 'STY', substudy: 'SUB', task: 'TSK' };
  const TIER_CLASS: Record<Tier, string> = { program: 'is-program', study: 'is-study', substudy: 'is-substudy', task: 'is-task' };

  // ── Month math. Mirrors the SSR axis EXACTLY (axisFraction is Date-based, so
  //    month widths are uneven) — BOUNDS[i] is the axis fraction of month i's start.
  const TOTAL_MONTHS = (SCHEDULE_END_YEAR - SCHEDULE_START_YEAR) * 12;
  const monthISO = (idx: number) => `${SCHEDULE_START_YEAR + Math.floor(idx / 12)}-${String((idx % 12) + 1).padStart(2, '0')}`;
  const monthIdxOf = (iso: string) => {
    const [y, m] = iso.split('-').map(Number);
    return Math.max(0, Math.min(TOTAL_MONTHS - 1, (y - SCHEDULE_START_YEAR) * 12 + (m - 1)));
  };
  const BOUNDS: number[] = [];
  for (let i = 0; i <= TOTAL_MONTHS; i++) BOUNDS.push(i === TOTAL_MONTHS ? 1 : axisFraction(`${monthISO(i)}-01`));
  const nearestBoundary = (f: number) => {
    let i = Math.max(0, Math.min(TOTAL_MONTHS, Math.round(f * TOTAL_MONTHS)));
    while (i > 0 && Math.abs(BOUNDS[i - 1] - f) < Math.abs(BOUNDS[i] - f)) i--;
    while (i < TOTAL_MONTHS && Math.abs(BOUNDS[i + 1] - f) < Math.abs(BOUNDS[i] - f)) i++;
    return i;
  };
  const pct = (n: number) => `${(n * 100).toFixed(2)}%`;

  document.querySelectorAll<HTMLElement>('.bcn-wb').forEach((wb) => {
    const body = wb.querySelector<HTMLElement>('.bcn-wb__body')!;
    const tpl = wb.querySelector<HTMLTemplateElement>('#bcn-wb-row-tpl')!;
    const confirm = wb.querySelector('#bcn-wb-confirm') as HTMLElement & { open: boolean; heading: string; message: string };
    const reparentDialog = wb.querySelector('#bcn-wb-reparent') as HTMLElement & { show(): void; close(): void };
    const reparentSelect = wb.querySelector('#bcn-wb-reparent-select') as HTMLElement & { options: { label: string; value: string }[]; value: string };
    const collapsed = new Set<string>();

    // ── The client model: SSR fixture hydrated into a mutable tree + indexes. ──
    const model: HierNode[] = JSON.parse(wb.querySelector('[data-wb-model]')?.textContent ?? '[]');
    const byId = new Map<string, HierNode>();
    const parentNode = new Map<string, HierNode | null>();
    function reindex() {
      byId.clear();
      parentNode.clear();
      const walk = (n: HierNode, p: HierNode | null) => {
        byId.set(n.id, n);
        parentNode.set(n.id, p);
        n.children.forEach((c) => walk(c, n));
      };
      model.forEach((n) => walk(n, null));
    }
    reindex();
    let rollups = new Map<string, NodeRollUp>();

    const rows = () => [...body.querySelectorAll<HTMLElement>('.bcn-wb__row')];
    const rowById = (id: string) => body.querySelector<HTMLElement>(`.bcn-wb__row[data-id="${id}"]`);
    const depthOf = (row: HTMLElement) => Number(row.dataset.depth ?? '0');
    const tierOf = (row: HTMLElement) => (row.dataset.tier ?? 'task') as Tier;

    // The contiguous block of a row = the row + following rows deeper than it.
    function blockOf(row: HTMLElement): HTMLElement[] {
      const all = rows();
      const i = all.indexOf(row);
      const d = depthOf(row);
      const block = [row];
      for (let j = i + 1; j < all.length; j++) {
        if (depthOf(all[j]) > d) block.push(all[j]);
        else break;
      }
      return block;
    }

    // A row is visible iff no ancestor (by data-parent chain) is collapsed.
    function isVisible(row: HTMLElement): boolean {
      let p = row.dataset.parent ?? '';
      while (p) {
        if (collapsed.has(p)) return false;
        p = rowById(p)?.dataset.parent ?? '';
      }
      return true;
    }

    // ── recompute(): THE single entry point after any model mutation. Rebuilds
    //    every roll-up, patches every row (data attrs + bar/bracket geometry +
    //    status color + unscheduled note), then notifies the page + panels.
    function barGeoOf(node: HierNode): { left: number; width: number } | null {
      const r = rollups.get(node.id);
      // Derived span for parents WITH children; own dates when the node has none.
      const startISO = node.children.length ? r?.startMonth : (node.startMonth ?? r?.startMonth);
      const endISO = node.children.length ? r?.endMonth : (node.endMonth ?? r?.endMonth);
      if (!startISO || !endISO) return null;
      const left = axisFraction(`${startISO}-01`);
      const right = axisFraction(`${endISO}-28`);
      return { left, width: Math.max(right - left, 0.005) };
    }

    function patchRow(row: HTMLElement) {
      const node = byId.get(row.dataset.id ?? '');
      if (!node) return;
      const r = rollups.get(node.id);
      // Span semantics: a node WITH children shows the DERIVED roll-up span; a
      // node with none (task, or a childless parent) uses its own dates. The
      // roll-up of a childless node already returns its own months.
      const start = node.children.length ? r?.startMonth : (node.startMonth ?? r?.startMonth);
      const end = node.children.length ? r?.endMonth : (node.endMonth ?? r?.endMonth);
      row.dataset.start = start ?? '';
      row.dataset.end = end ?? '';
      // Keep the label cell in sync with drawer edits (name + ID write-through).
      const badge = row.querySelector<HTMLElement>('.bcn-wb__id');
      if (badge && badge.textContent !== node.id) badge.textContent = node.id;
      const nameEl = row.querySelector<HTMLElement>('.bcn-wb__name');
      if (nameEl && !nameEl.isContentEditable && nameEl.textContent !== node.name) nameEl.textContent = node.name;
      const plot = row.querySelector<HTMLElement>('.bcn-wb__plot')!;
      let mark = plot.querySelector<HTMLElement>('.bcn-wb__bar, .bcn-wb__summary');
      const geo = barGeoOf(node);
      if (!geo) {
        mark?.remove();
        if (!plot.querySelector('.bcn-wb__unscheduled')) {
          const note = document.createElement('span');
          note.className = 'bcn-wb__unscheduled';
          note.textContent = 'Unscheduled — open the panel to set a start & end month';
          plot.append(note);
        }
        return;
      }
      plot.querySelector('.bcn-wb__unscheduled')?.remove();
      const isTask = node.tier === 'task';
      if (mark && mark.classList.contains('bcn-wb__bar') !== isTask) {
        mark.remove();
        mark = null;
      }
      if (!mark) {
        if (isTask) {
          const b = document.createElement('button');
          b.type = 'button';
          b.className = 'bcn-wb__bar';
          mark = b;
        } else {
          const s = document.createElement('span');
          s.className = 'bcn-wb__summary';
          s.setAttribute('aria-hidden', 'true');
          mark = s;
        }
        plot.append(mark);
      }
      mark.style.left = pct(geo.left);
      mark.style.width = pct(geo.width);
      if (isTask) {
        const st = TASK_STATUS_META[(node.status ?? 'not-started') as TaskStatus];
        mark.style.setProperty('--_c', st.hex);
        mark.title = `${node.id} — ${node.name} · ${st.label}`;
        mark.setAttribute('aria-label', `Open ${node.id} ${node.name}`);
      }
    }

    function recompute(reason: string) {
      rollups = new Map();
      const walk = (n: HierNode) => {
        rollups.set(n.id, computeRollUp(n));
        n.children.forEach(walk);
      };
      model.forEach(walk);
      rows().forEach(patchRow);
      wb.dispatchEvent(new CustomEvent('wb-model-change', { detail: { reason }, bubbles: true }));
    }

    // ── Public write-through API for the drawer panels + page header KPIs. ──
    (wb as HTMLElement & { wbApi?: unknown }).wbApi = {
      getNode: (id: string) => byId.get(id),
      parentOf: (id: string) => parentNode.get(id) ?? null,
      rollupOf: (id: string) => rollups.get(id),
      allNodes: () => [...byId.values()],
      planRollup: () => computeRollUp({ id: 'PLAN', tier: 'program', name: 'plan', funding: [], children: model } as HierNode),
      tierCounts: () => ({ programs: model.length, studies: [...byId.values()].filter((n) => n.tier === 'study').length }),
      // ANY tier may carry its own start/end months (drawer edit surface). Parents
      // with children keep showing the derived roll-up span on the gantt.
      setSchedule(id: string, startMonth: string, endMonth: string) {
        const n = byId.get(id);
        if (!n) return;
        n.startMonth = startMonth;
        n.endMonth = endMonth;
        recompute('schedule');
      },
      setTaskSchedule(id: string, startMonth: string, endMonth: string) {
        const n = byId.get(id);
        if (!n || n.tier !== 'task') return;
        n.startMonth = startMonth;
        n.endMonth = endMonth;
        recompute('schedule');
      },
      setName(id: string, name: string) {
        const n = byId.get(id);
        if (!n) return;
        const clean = name.trim() || 'Untitled';
        if (n.name === clean) return;
        n.name = clean;
        recompute('rename');
      },
      // Re-key a node: the id IS the client-model key, so this updates the model
      // node, the row's data-id + badge, children's data-parent references, and
      // the collapse set — then announces the re-key (wb-node-id-change) so the
      // page can move its panel before the recompute broadcast syncs everything.
      setId(oldId: string, newId: string): boolean {
        const n = byId.get(oldId);
        const clean = newId.trim();
        if (!n || !clean || clean === oldId || byId.has(clean)) return false;
        n.id = clean;
        const row = rowById(oldId);
        if (row) row.dataset.id = clean;
        rows().forEach((r) => {
          if (r.dataset.parent === oldId) r.dataset.parent = clean;
        });
        if (collapsed.has(oldId)) {
          collapsed.delete(oldId);
          collapsed.add(clean);
        }
        reindex();
        wb.dispatchEvent(new CustomEvent('wb-node-id-change', { detail: { oldId, newId: clean }, bubbles: true }));
        recompute('id');
        return true;
      },
      // Drawer-reachable structure ops: add a child of the node's child tier
      // (selecting it so the drawer follows), and delete via the confirm dialog.
      addChildTo(id: string) {
        const row = rowById(id);
        if (row) addChild(row, { select: true });
      },
      requestDelete(id: string) {
        const row = rowById(id);
        if (row) askDelete(row);
      },
      setFunding(id: string, waterYear: number, amount: number) {
        const n = byId.get(id);
        if (!n || !Number.isFinite(waterYear)) return;
        const entry = n.funding.find((f) => f.waterYear === waterYear);
        if (amount > 0) {
          if (entry) entry.amount = amount;
          else {
            n.funding.push({ waterYear, amount });
            n.funding.sort((a, b) => a.waterYear - b.waterYear);
          }
        } else if (entry) {
          n.funding.splice(n.funding.indexOf(entry), 1);
        }
        recompute('funding');
      },
    };

    // ── Tier filter + search. Matches keep their children (whole block) and
    //    their ancestors for context; an active filter overrides collapse state.
    const searchInput = wb.querySelector('#bcn-wb-search') as HTMLElement & { value: string };
    const tierToggle = wb.querySelector('#bcn-wb-tier-filter') as HTMLElement & {
      options: { value: string; label: string }[];
      value: string;
    };
    const filterCount = wb.querySelector<HTMLElement>('#bcn-wb-filter-count');
    let filterTier = 'all';
    let filterQuery = '';
    if (tierToggle) {
      tierToggle.options = [
        { value: 'all', label: 'All' },
        { value: 'program', label: 'Programs' },
        { value: 'study', label: 'Studies' },
        { value: 'substudy', label: 'Sub-studies' },
        { value: 'task', label: 'Tasks' },
      ];
    }

    // Year-range filter: bounds derived from the rows' actual spans.
    const yearFrom = wb.querySelector('#bcn-wb-year-from') as HTMLElement & { options: { value: string; label: string }[]; value: string };
    const yearTo = wb.querySelector('#bcn-wb-year-to') as HTMLElement & { options: { value: string; label: string }[]; value: string };
    // Options cover the full schedule horizon (matches the axis), not just current data.
    const minYear = SCHEDULE_START_YEAR;
    const maxYear = SCHEDULE_END_YEAR - 1;
    let filterYearFrom = minYear;
    let filterYearTo = maxYear;
    const yearOpts = [];
    for (let y = minYear; y <= maxYear; y++) yearOpts.push({ value: String(y), label: String(y) });
    if (yearFrom) { yearFrom.options = yearOpts; yearFrom.value = String(minYear); }
    if (yearTo) { yearTo.options = yearOpts; yearTo.value = String(maxYear); }

    function filterSet(): Set<HTMLElement> | null {
      const yearNarrowed = filterYearFrom > minYear || filterYearTo < maxYear;
      if (filterTier === 'all' && !filterQuery && !yearNarrowed) return null;
      const q = filterQuery.toLowerCase();
      const matches = rows().filter((r) => {
        if (filterTier !== 'all' && r.dataset.tier !== filterTier) return false;
        if (yearNarrowed) {
          const ds = r.dataset.start;
          const de = r.dataset.end;
          if (!ds || !de) return false; // unscheduled rows drop out of a narrowed range
          if (Number(ds.slice(0, 4)) > filterYearTo || Number(de.slice(0, 4)) < filterYearFrom) return false;
        }
        if (!q) return true;
        const name = r.querySelector('.bcn-wb__name')?.textContent?.toLowerCase() ?? '';
        return name.includes(q) || (r.dataset.id ?? '').toLowerCase().includes(q);
      });
      // Search keeps the matches' children; a bare tier filter acts as an
      // outline level (that grain and above), else it would show everything.
      const visible = new Set<HTMLElement>();
      for (const m of matches) {
        if (q) blockOf(m).forEach((r) => visible.add(r));
        else visible.add(m);
        let p = m.dataset.parent ?? '';
        while (p) {
          const pr = rowById(p);
          if (!pr) break;
          visible.add(pr);
          p = pr.dataset.parent ?? '';
        }
      }
      if (filterCount) {
        filterCount.hidden = false;
        filterCount.textContent = `${matches.length} ${matches.length === 1 ? 'match' : 'matches'}`;
      }
      return visible;
    }

    function applyVisibility() {
      const set = filterSet();
      if (set) {
        rows().forEach((r) => (r.hidden = !set.has(r)));
      } else {
        if (filterCount) filterCount.hidden = true;
        rows().forEach((r) => (r.hidden = !isVisible(r)));
      }
    }

    searchInput?.addEventListener('change', (e) => {
      filterQuery = (((e as CustomEvent).detail?.value as string) ?? searchInput.value ?? '').trim();
      applyVisibility();
    });
    tierToggle?.addEventListener('change', (e) => {
      filterTier = ((e as CustomEvent).detail?.value as string) ?? tierToggle.value ?? 'all';
      applyVisibility();
    });
    yearFrom?.addEventListener('change', (e) => {
      filterYearFrom = Number(((e as CustomEvent).detail?.value as string) ?? yearFrom.value ?? minYear);
      if (filterYearFrom > filterYearTo) {
        filterYearTo = filterYearFrom;
        if (yearTo) yearTo.value = String(filterYearTo);
      }
      applyVisibility();
    });
    yearTo?.addEventListener('change', (e) => {
      filterYearTo = Number(((e as CustomEvent).detail?.value as string) ?? yearTo.value ?? maxYear);
      if (filterYearTo < filterYearFrom) {
        filterYearFrom = filterYearTo;
        if (yearFrom) yearFrom.value = String(filterYearFrom);
      }
      applyVisibility();
    });

    function nextId(tier: Tier): string {
      const prefix = TIER_PREFIX[tier];
      let max = 0;
      rows().forEach((r) => {
        const m = (r.dataset.id ?? '').match(new RegExp(`^${prefix}-(\\d+)$`));
        if (m) max = Math.max(max, Number(m[1]));
      });
      return `${prefix}-${String(max + 1).padStart(3, '0')}`;
    }

    function refreshCaret(row: HTMLElement) {
      const has = blockOf(row).length > 1;
      row.dataset.hasChildren = has ? '1' : '0';
      row.classList.toggle('is-leaf', !has);
      const label = row.querySelector<HTMLElement>('.bcn-wb__label')!;
      const existing = label.querySelector<HTMLElement>('.bcn-wb__caret, .bcn-wb__caret-spacer')!;
      if (has && existing.classList.contains('bcn-wb__caret-spacer')) {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'bcn-wb__caret';
        btn.setAttribute('aria-expanded', 'true');
        btn.innerHTML = '<svg viewBox="0 0 24 24" width="12" height="12" aria-hidden="true"><path d="m6 9 6 6 6-6" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
        existing.replaceWith(btn);
      } else if (!has && existing.classList.contains('bcn-wb__caret')) {
        const spacer = document.createElement('span');
        spacer.className = 'bcn-wb__caret-spacer';
        existing.replaceWith(spacer);
      }
    }

    function setMenu(row: HTMLElement) {
      const menu = row.querySelector('.bcn-wb__menu') as HTMLElement & { items: unknown[] };
      if (!menu) return;
      const tier = tierOf(row);
      const items: Record<string, unknown>[] = [{ label: 'Rename', action: 'rename' }];
      const child = CHILD_TIER[tier];
      if (child) items.push({ label: `Add ${TIER_LABEL[child].toLowerCase()}`, action: 'add-child' });
      if (PARENT_TIER[tier]) items.push({ label: 'Reparent…', action: 'reparent' });
      items.push({ divider: true }, { label: `Delete ${TIER_LABEL[tier].toLowerCase()}`, action: 'delete', variant: 'danger' });
      menu.items = items;
    }
    rows().forEach(setMenu);

    // ── Rename (inline contenteditable) — writes through to the model. ──
    function startRename(row: HTMLElement) {
      const name = row.querySelector<HTMLElement>('.bcn-wb__name')!;
      name.contentEditable = 'true';
      name.classList.add('is-editing');
      name.focus();
      const range = document.createRange();
      range.selectNodeContents(name);
      const sel = window.getSelection();
      sel?.removeAllRanges();
      sel?.addRange(range);
      const finish = () => {
        name.contentEditable = 'false';
        name.classList.remove('is-editing');
        name.textContent = (name.textContent ?? '').trim() || 'Untitled';
        name.removeEventListener('blur', finish);
        name.removeEventListener('keydown', onKey);
        const node = byId.get(row.dataset.id ?? '');
        if (node && node.name !== name.textContent) {
          node.name = name.textContent ?? node.name;
          recompute('rename');
        }
      };
      const onKey = (e: KeyboardEvent) => {
        if (e.key === 'Enter') { e.preventDefault(); name.blur(); }
        if (e.key === 'Escape') { name.blur(); }
      };
      name.addEventListener('blur', finish);
      name.addEventListener('keydown', onKey);
    }

    // Cloned rows: fix the "+" affordance for the new row's tier (tasks are
    // leaves — no add) and keep its accessible name specific.
    function fixAddButton(row: HTMLElement, tier: Tier) {
      const child = CHILD_TIER[tier];
      if (!child) {
        row.querySelector('.bcn-wb__add')?.remove();
        return;
      }
      const btn = row.querySelector('.bcn-wb__add .esa-icon-button');
      const lbl = `Add ${TIER_LABEL[child].toLowerCase()}`;
      btn?.setAttribute('aria-label', lbl);
      btn?.setAttribute('title', lbl);
    }

    // ── Add a child (unscheduled row cloned from the template + model node).
    //    Row-affordance adds start the inline rename; drawer adds (opts.select)
    //    select the new node instead so the open drawer follows it. ──
    function addChild(parentRow: HTMLElement, opts: { select?: boolean } = {}) {
      const parentTier = tierOf(parentRow);
      const tier = CHILD_TIER[parentTier];
      const parent = byId.get(parentRow.dataset.id ?? '');
      if (!tier || !parent) return;
      const row = tpl.content.firstElementChild!.cloneNode(true) as HTMLElement;
      const id = nextId(tier);
      const depth = depthOf(parentRow) + 1;
      const name = `New ${TIER_LABEL[tier].toLowerCase()}`;
      row.className = `bcn-wb__row ${TIER_CLASS[tier]} is-leaf`;
      row.dataset.id = id;
      row.dataset.tier = tier;
      row.dataset.depth = String(depth);
      row.dataset.parent = parentRow.dataset.id ?? '';
      row.dataset.hasChildren = '0';
      row.querySelector<HTMLElement>('.bcn-wb__label')!.style.setProperty('--_indent', String(depth));
      row.querySelector<HTMLElement>('.bcn-wb__id')!.textContent = id;
      row.querySelector<HTMLElement>('.bcn-wb__name')!.textContent = name;
      fixAddButton(row, tier);
      // Insert at the end of the parent's existing subtree.
      const block = blockOf(parentRow);
      block[block.length - 1].after(row);
      setMenu(row);
      refreshCaret(parentRow);
      // Expand the parent so the new child shows.
      collapsed.delete(parentRow.dataset.id ?? '');
      parentRow.querySelector('.bcn-wb__caret')?.setAttribute('aria-expanded', 'true');
      parentRow.querySelector('.bcn-wb__caret')?.classList.remove('is-collapsed');
      applyVisibility();
      // Model: a new leaf under the parent (tasks start unscheduled).
      const node: HierNode = { id, tier, name, funding: [], children: [] };
      if (tier === 'task') node.status = 'not-started';
      parent.children.push(node);
      reindex();
      recompute('structure');
      if (opts.select) {
        rows().forEach((r) => r.classList.toggle('is-selected', r === row));
        wb.dispatchEvent(new CustomEvent('wb-node-select', { detail: { id }, bubbles: true }));
      } else {
        startRename(row);
      }
    }

    function addProgram() {
      const row = tpl.content.firstElementChild!.cloneNode(true) as HTMLElement;
      const id = nextId('program');
      const name = 'New program';
      row.className = 'bcn-wb__row is-program is-leaf';
      row.dataset.id = id;
      row.dataset.tier = 'program';
      row.dataset.depth = '0';
      row.dataset.parent = '';
      row.querySelector<HTMLElement>('.bcn-wb__label')!.style.setProperty('--_indent', '0');
      row.querySelector<HTMLElement>('.bcn-wb__id')!.textContent = id;
      row.querySelector<HTMLElement>('.bcn-wb__name')!.textContent = name;
      fixAddButton(row, 'program');
      body.appendChild(row);
      setMenu(row);
      const node: HierNode = { id, tier: 'program', name, funding: [], children: [] };
      model.push(node);
      reindex();
      recompute('structure');
      startRename(row);
    }

    // ── Delete (esa-confirm-dialog) — removes the subtree from DOM AND model ──
    let pendingDelete: HTMLElement | null = null;
    function askDelete(row: HTMLElement) {
      const tier = tierOf(row);
      const kids = blockOf(row).length - 1;
      pendingDelete = row;
      confirm.heading = `Delete ${TIER_LABEL[tier].toLowerCase()}?`;
      confirm.message = kids > 0
        ? `“${row.querySelector('.bcn-wb__name')?.textContent}” and its ${kids} descendant ${kids === 1 ? 'node' : 'nodes'} will be removed.`
        : `“${row.querySelector('.bcn-wb__name')?.textContent}” will be removed.`;
      confirm.open = true;
    }
    confirm.addEventListener('confirm', () => {
      if (pendingDelete) {
        const id = pendingDelete.dataset.id ?? '';
        const parentId = pendingDelete.dataset.parent ?? '';
        blockOf(pendingDelete).forEach((r) => r.remove());
        if (parentId) { const p = rowById(parentId); if (p) refreshCaret(p); }
        const node = byId.get(id);
        if (node) {
          const parent = parentNode.get(id);
          const list = parent ? parent.children : model;
          const i = list.indexOf(node);
          if (i >= 0) list.splice(i, 1);
          reindex();
          recompute('structure');
        }
        pendingDelete = null;
        applyVisibility();
      }
      confirm.open = false;
    });
    confirm.addEventListener('cancel', () => { pendingDelete = null; confirm.open = false; });

    // ── Reparent (esa-dialog + esa-select), same-tier move ──
    let pendingReparent: HTMLElement | null = null;
    function askReparent(row: HTMLElement) {
      const tier = tierOf(row);
      const parentTier = PARENT_TIER[tier];
      if (!parentTier) return;
      const currentParent = row.dataset.parent ?? '';
      const options = rows()
        .filter((r) => tierOf(r) === parentTier && r.dataset.id !== currentParent)
        .map((r) => ({ label: `${r.dataset.id} — ${r.querySelector('.bcn-wb__name')?.textContent ?? ''}`, value: r.dataset.id ?? '' }));
      if (options.length === 0) return;
      pendingReparent = row;
      reparentSelect.options = options;
      reparentSelect.value = '';
      reparentDialog.show();
    }
    function doReparent() {
      const targetId = reparentSelect.value;
      if (pendingReparent && targetId) {
        const target = rowById(targetId);
        if (target && tierOf(target) === PARENT_TIER[tierOf(pendingReparent)]) {
          const moving = blockOf(pendingReparent);
          const targetBlock = blockOf(target);
          const anchor = targetBlock[targetBlock.length - 1];
          let after = anchor;
          moving.forEach((r) => { after.after(r); after = r; });
          pendingReparent.dataset.parent = targetId;
          refreshCaret(target);
          applyVisibility();
          // Model: move the node between parents' children arrays.
          const node = byId.get(pendingReparent.dataset.id ?? '');
          const newParent = byId.get(targetId);
          if (node && newParent) {
            const oldParent = parentNode.get(node.id);
            const list = oldParent ? oldParent.children : model;
            const i = list.indexOf(node);
            if (i >= 0) list.splice(i, 1);
            newParent.children.push(node);
            reindex();
            recompute('structure');
          }
        }
      }
      pendingReparent = null;
      reparentDialog.close();
    }
    wb.querySelector('#bcn-wb-reparent-move')?.addEventListener('click', doReparent);
    wb.querySelector('#bcn-wb-reparent-cancel')?.addEventListener('click', () => { pendingReparent = null; reparentDialog.close(); });

    // ── Menu action routing ──
    body.addEventListener('menu-action', (e) => {
      const action = (e as CustomEvent).detail as string;
      const row = (e.target as HTMLElement).closest('.bcn-wb__row') as HTMLElement | null;
      if (!row) return;
      if (action === 'rename') startRename(row);
      else if (action === 'add-child') addChild(row);
      else if (action === 'reparent') askReparent(row);
      else if (action === 'delete') askDelete(row);
    });

    // ── Bar drag: ~7px edge hotzones resize by month, body drag moves the bar.
    //    Snaps to the SAME month boundaries the SSR geometry uses. recompute()
    //    runs rAF-throttled during the drag so parent brackets re-derive live.
    const EDGE = 7;
    let drag: {
      node: HierNode;
      mode: 'left' | 'right' | 'move';
      rect: DOMRect;
      f0: number;
      startIdx0: number;
      endIdx0: number;
      moved: boolean;
    } | null = null;
    let dragEndAt = 0;
    let dragRaf = 0;

    const zoneAt = (bar: HTMLElement, clientX: number): 'left' | 'right' | 'move' => {
      const r = bar.getBoundingClientRect();
      const x = clientX - r.left;
      return x <= EDGE ? 'left' : x >= r.width - EDGE ? 'right' : 'move';
    };

    body.addEventListener('pointerdown', (e) => {
      if (e.button !== 0) return;
      const bar = (e.target as HTMLElement).closest?.('.bcn-wb__bar') as HTMLElement | null;
      if (!bar) return;
      const row = bar.closest('.bcn-wb__row') as HTMLElement;
      const node = byId.get(row.dataset.id ?? '');
      if (!node?.startMonth || !node.endMonth) return;
      const plot = bar.parentElement as HTMLElement;
      const rect = plot.getBoundingClientRect();
      drag = {
        node,
        mode: zoneAt(bar, e.clientX),
        rect,
        f0: (e.clientX - rect.left) / rect.width,
        startIdx0: monthIdxOf(node.startMonth),
        endIdx0: monthIdxOf(node.endMonth),
        moved: false,
      };
      bar.setPointerCapture(e.pointerId);
      wb.classList.add('is-dragging');
      e.preventDefault();
    });

    body.addEventListener('pointermove', (e) => {
      if (!drag) {
        // Hover affordance: resize cursor on the edge hotzones, grab on the body.
        const bar = (e.target as HTMLElement).closest?.('.bcn-wb__bar') as HTMLElement | null;
        if (bar) bar.style.cursor = zoneAt(bar, e.clientX) === 'move' ? 'grab' : 'ew-resize';
        return;
      }
      const f = Math.max(0, Math.min(1, (e.clientX - drag.rect.left) / drag.rect.width));
      const n = drag.node;
      let start = monthIdxOf(n.startMonth!);
      let end = monthIdxOf(n.endMonth!);
      if (drag.mode === 'left') {
        start = Math.min(nearestBoundary(f), end);
      } else if (drag.mode === 'right') {
        end = Math.min(Math.max(nearestBoundary(f) - 1, start), TOTAL_MONTHS - 1);
      } else {
        const delta = Math.round((f - drag.f0) * TOTAL_MONTHS);
        const dur = drag.endIdx0 - drag.startIdx0;
        start = Math.max(0, Math.min(TOTAL_MONTHS - 1 - dur, drag.startIdx0 + delta));
        end = start + dur;
      }
      const s = monthISO(start);
      const en = monthISO(end);
      if (s !== n.startMonth || en !== n.endMonth) {
        n.startMonth = s;
        n.endMonth = en;
        drag.moved = true;
        if (!dragRaf) {
          dragRaf = requestAnimationFrame(() => {
            dragRaf = 0;
            recompute('drag');
          });
        }
      }
    });

    const endDrag = () => {
      if (!drag) return;
      if (drag.moved) {
        dragEndAt = performance.now();
        recompute('schedule');
      }
      drag = null;
      wb.classList.remove('is-dragging');
    };
    body.addEventListener('pointerup', endDrag);
    body.addEventListener('pointercancel', endDrag);

    // ── Collapse / expand + row select + visible add-child ──
    wb.querySelector('#bcn-wb-add-program')?.addEventListener('click', addProgram);
    body.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const add = target.closest('.bcn-wb__add') as HTMLElement | null;
      if (add) {
        const row = add.closest('.bcn-wb__row') as HTMLElement;
        addChild(row);
        return;
      }
      const caret = target.closest('.bcn-wb__caret') as HTMLElement | null;
      if (caret) {
        const row = caret.closest('.bcn-wb__row') as HTMLElement;
        const id = row.dataset.id ?? '';
        const nowCollapsed = !collapsed.has(id);
        if (nowCollapsed) collapsed.add(id); else collapsed.delete(id);
        caret.setAttribute('aria-expanded', String(!nowCollapsed));
        caret.classList.toggle('is-collapsed', nowCollapsed);
        applyVisibility();
        return;
      }
      const trigger = target.closest('.bcn-wb__name-btn, .bcn-wb__bar') as HTMLElement | null;
      if (trigger) {
        // A completed bar drag ends with a click on the bar — don't open the panel.
        if (trigger.classList.contains('bcn-wb__bar') && performance.now() - dragEndAt < 350) return;
        const name = trigger.querySelector<HTMLElement>('.bcn-wb__name');
        if (name?.isContentEditable) return; // don't select while renaming
        const row = trigger.closest('.bcn-wb__row') as HTMLElement;
        rows().forEach((r) => r.classList.toggle('is-selected', r === row));
        wb.dispatchEvent(new CustomEvent('wb-node-select', { detail: { id: row.dataset.id }, bubbles: true }));
      }
    });

    // Initial pass: builds the roll-up cache the API serves (SSR geometry is
    // already correct, so this is a no-op visually).
    recompute('init');
  });
</script>

<style is:global>
  /* Global (not Astro-scoped) ON PURPOSE: the CRUD layer creates rows, bars,
     brackets, and carets AFTER hydration — scoped attribute selectors would miss
     those client-built elements. Every class is bcn-wb__-namespaced. */
  .bcn-wb {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-300);
    --_label-w: 420px;
    --_plot-w: 1900px;
    --_row-h: 28px;
  }
