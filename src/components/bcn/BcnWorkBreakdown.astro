  .bcn-wb__label { display: flex; align-items: center; gap: var(--spacing-150); min-height: var(--_row-h); padding: 0 var(--spacing-200) 0 calc(var(--spacing-200) + var(--_indent) * 18px); border-right: 1px solid var(--color-border); background: var(--color-surface); position: sticky; left: 0; z-index: 3; }
