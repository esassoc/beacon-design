---
// <BcnFundingPlan> — CDFW's dollars-per-water-year funding plan for one node.
// Funding is enterable at ANY tier; a Task's dollars sum upward, so a parent's
// plan splits what was entered AT this node ("Own") from what rolled UP from its
// descendants ("Rolled up"), with the per-water-year total. Two variants: 'full'
// (details page — $ summary + split sentence + table) and 'slim' (drawer — the
// table only, reading as an addition equation with a bold live Total).
//
// EDITABLE only in drawer hosts: the per-water-year "Own"/"Amount" cells are
// esa-text-field legos that write through the gantt's wbApi (see BcnWorkBreakdown).
// With `readonly` (detail pages — they land read-only; edits go through the host's
// Edit-record drawer) the Own cells render as plain numbers with data-cell="own"
// patch hooks. The client script below owns re-rendering this block after any
// model change — it rebuilds the same markup the SSR emits (respecting the
// block's data-readonly attribute), and PATCHES derived cells only while an
// amount field has focus so typing never loses the caret.
//
// bcn-lego-checked: no esa-* lego renders a multi-column money-by-period plan
// table (esa-stat is a single metric; there is no data-table lego — AG Grid is the
// page-level table kit, overkill for a ≤8-row funding schedule in a detail panel).
// Checked Beacon (funding lives in exported spreadsheets, no component). The dollar
// inputs are esa-text-field legos; only the money table is bespoke. bcn-funding-plan
// is the reusable home.
import { formatUSD, type FundingEntry, type NodeRollUp } from '../../data/fish-model';

interface Props {
  rollup: NodeRollUp;
  /** Funding entered AT this node (the "Own" column — the editable one). */
  ownFunding: FundingEntry[];
  /** Extra water years to offer empty rows for (a task's scheduled span). */
  spanYears?: number[];
  /**
   * 'slim' (the drawer) drops the big $ summary line and the own/rolled-up split
   * sentence — the table alone reads as an addition equation: water-year rows with
   * right-aligned $ inputs, a sum rule (border-top), and a bold live Total. Parent
   * nodes keep the Own/Rolled-up/Total columns. 'full' (details page) keeps both.
   */
  variant?: 'full' | 'slim';
  /** Read-only: Own renders as plain numbers (detail pages land read-only —
   *  editing happens in the host's Edit-record drawer). */
  readonly?: boolean;
}
const { rollup, ownFunding, spanYears = [], variant = 'full', readonly = false } = Astro.props;
const slim = variant === 'slim';

const ownByYear = new Map(ownFunding.map((f) => [f.waterYear, f.amount]));
const totalByYear = new Map(rollup.fundingByYear.map((f) => [f.waterYear, f.amount]));
const years = [...new Set([...ownByYear.keys(), ...totalByYear.keys(), ...spanYears])].sort((a, b) => a - b);
const rows = years.map((wy) => {
  const own = ownByYear.get(wy) ?? 0;
  const total = totalByYear.get(wy) ?? 0;
  return { wy, own, sub: total - own, total };
});
const hasSub = rollup.totalFunding !== rollup.ownFunding;
---

<div class:list={['bcn-funding', { 'bcn-funding--slim': slim }]} data-readonly={readonly ? '' : undefined}>
  {rows.length > 0 ? (
    <table class="bcn-funding__table">
      <thead>
        <tr>
          <th scope="col">Water year</th>
          <th scope="col" class="bcn-funding__num">{hasSub ? 'Own' : 'Amount'}</th>
          {hasSub && <th scope="col" class="bcn-funding__num">Rolled up</th>}
          {hasSub && <th scope="col" class="bcn-funding__num">Total</th>}
        </tr>
      </thead>
      <tbody>
        {rows.map((r) => (
          <tr data-wy={r.wy}>
            <th scope="row" class="bcn-funding__year">WY{r.wy}</th>
            {readonly ? (
              <td class="bcn-funding__num" data-cell="own">{r.own ? formatUSD(r.own) : '—'}</td>
            ) : (
              <td class="bcn-funding__num bcn-funding__edit">
                <esa-text-field class="bcn-funding__field" size="sm" type="text" prefix="$" placeholder="0" value={r.own ? String(r.own) : ''} data-wb-funding data-wy={r.wy}></esa-text-field>
              </td>
            )}
            {hasSub && <td class="bcn-funding__num bcn-funding__muted" data-cell="sub">{r.sub ? formatUSD(r.sub) : '—'}</td>}
            {hasSub && <td class="bcn-funding__num bcn-funding__strong" data-cell="total">{r.total ? formatUSD(r.total) : '—'}</td>}
          </tr>
        ))}
      </tbody>
      <tfoot>
        <tr>
          <th scope="row">Total</th>
          <td class="bcn-funding__num bcn-funding__muted" data-cell="foot-own">{formatUSD(rollup.ownFunding)}</td>
          {hasSub && <td class="bcn-funding__num bcn-funding__muted" data-cell="foot-sub">{formatUSD(rollup.totalFunding - rollup.ownFunding)}</td>}
          {hasSub && <td class="bcn-funding__num bcn-funding__strong" data-cell="foot-total">{formatUSD(rollup.totalFunding)}</td>}
        </tr>
      </tfoot>
    </table>
  ) : (
    <p class="bcn-funding__empty">None planned.</p>
  )}
</div>

<script>
  import '@esa/ecology/esa-text-field';
  import { formatUSD, waterYearOf } from '../../data/fish-model';
  import type { FundingEntry, HierNode, NodeRollUp } from '../../data/fish-model';

  type WbApi = {
    getNode(id: string): HierNode | undefined;
    rollupOf(id: string): NodeRollUp | undefined;
    setFunding(id: string, waterYear: number, amount: number): void;
  };
  const getApi = (): WbApi | undefined =>
    (document.querySelector('.bcn-wb') as (HTMLElement & { wbApi?: WbApi }) | null)?.wbApi;

  interface FundingRow {
    wy: number;
    own: number;
    sub: number;
    total: number;
  }

  // Rows = union of entered years, rolled-up years, and the water years the
  // node's OWN schedule spans (any tier may carry dates now) — so a freshly
  // scheduled node gets empty dollar rows to fill in.
  function rowsFor(node: HierNode, r: NodeRollUp): FundingRow[] {
    const ownBy = new Map(node.funding.map((f: FundingEntry) => [f.waterYear, f.amount]));
    const totalBy = new Map(r.fundingByYear.map((f) => [f.waterYear, f.amount]));
    const years = new Set<number>([...ownBy.keys(), ...totalBy.keys()]);
    if (node.startMonth && node.endMonth) {
      const a = waterYearOf(node.startMonth);
      const b = Math.max(a, waterYearOf(node.endMonth));
      for (let wy = a; wy <= b; wy++) years.add(wy);
    }
    return [...years]
      .sort((a, b) => a - b)
      .map((wy) => {
        const own = ownBy.get(wy) ?? 0;
        const total = totalBy.get(wy) ?? 0;
        return { wy, own, sub: total - own, total };
      });
  }

  const money = (n: number) => (n ? formatUSD(n) : '—');

  // Full re-render: rebuilds the same markup the SSR emits (classes must match).
  // The slim (drawer) variant is read off the block's own class — no summary line,
  // no own/rolled-up split sentence; the table alone is the addition equation.
  function render(block: HTMLElement, node: HierNode, r: NodeRollUp) {
    const rows = rowsFor(node, r);
    const hasSub = r.totalFunding !== r.ownFunding;
    const slim = block.classList.contains('bcn-funding--slim');
    const readonly = block.hasAttribute('data-readonly');
    const field = (row: FundingRow) =>
      readonly
        ? money(row.own)
        : `<esa-text-field class="bcn-funding__field" size="sm" type="text" prefix="$" placeholder="0" value="${row.own || ''}" data-wb-funding data-wy="${row.wy}"></esa-text-field>`;
    block.innerHTML = `
      ${
        rows.length
          ? `<table class="bcn-funding__table">
              <thead><tr>
                <th scope="col">Water year</th>
                <th scope="col" class="bcn-funding__num">${hasSub ? 'Own' : 'Amount'}</th>
                ${hasSub ? '<th scope="col" class="bcn-funding__num">Rolled up</th><th scope="col" class="bcn-funding__num">Total</th>' : ''}
              </tr></thead>
              <tbody>
                ${rows
                  .map(
                    (row) => `<tr data-wy="${row.wy}">
                      <th scope="row" class="bcn-funding__year">WY${row.wy}</th>
                      <td class="bcn-funding__num${readonly ? '' : ' bcn-funding__edit'}"${readonly ? ' data-cell="own"' : ''}>${field(row)}</td>
                      ${
                        hasSub
                          ? `<td class="bcn-funding__num bcn-funding__muted" data-cell="sub">${money(row.sub)}</td>
                             <td class="bcn-funding__num bcn-funding__strong" data-cell="total">${money(row.total)}</td>`
                          : ''
                      }
                    </tr>`,
                  )
                  .join('')}
              </tbody>
              <tfoot><tr>
                <th scope="row">Total</th>
                <td class="bcn-funding__num bcn-funding__muted" data-cell="foot-own">${formatUSD(r.ownFunding)}</td>
                ${
                  hasSub
                    ? `<td class="bcn-funding__num bcn-funding__muted" data-cell="foot-sub">${formatUSD(r.totalFunding - r.ownFunding)}</td>
                       <td class="bcn-funding__num bcn-funding__strong" data-cell="foot-total">${formatUSD(r.totalFunding)}</td>`
                    : ''
                }
              </tr></tfoot>
            </table>`
          : '<p class="bcn-funding__empty">None planned.</p>'
      }
    `;
  }

  // Caret-preserving patch: only derived cells change while an amount field has
  // focus (typing fires a change per keystroke — a rebuild would eat the caret).
  function patchDerived(block: HTMLElement, node: HierNode, r: NodeRollUp) {
    const rows = rowsFor(node, r);
    const setCell = (sel: string, text: string) => {
      const el = block.querySelector<HTMLElement>(sel);
      if (el) el.textContent = text;
    };
    for (const row of rows) {
      setCell(`tr[data-wy="${row.wy}"] [data-cell="sub"]`, money(row.sub));
      setCell(`tr[data-wy="${row.wy}"] [data-cell="total"]`, money(row.total));
    }
    setCell('[data-cell="foot-own"]', formatUSD(r.ownFunding));
    setCell('[data-cell="foot-sub"]', formatUSD(r.totalFunding - r.ownFunding));
    setCell('[data-cell="foot-total"]', formatUSD(r.totalFunding));
  }

  function syncBlock(panel: HTMLElement) {
    const api = getApi();
    if (!api) return;
    const block = panel.querySelector<HTMLElement>('.bcn-funding');
    if (!block) return;
    const id = panel.dataset.nodePanel ?? '';
    const node = api.getNode(id);
    const r = api.rollupOf(id);
    if (!node || !r) return;
    const active = document.activeElement;
    const editing = active instanceof HTMLElement && active.tagName === 'ESA-TEXT-FIELD' && block.contains(active);
    if (editing) patchDerived(block, node, r);
    else render(block, node, r);
  }

  // ONE delegated listener: any dollar field (SSR'd or client-rendered) writes
  // through wbApi; the resulting wb-model-change re-syncs this block.
  document.addEventListener('change', (e) => {
    const t = e.target as HTMLElement & { value?: string };
    if (!(t instanceof HTMLElement) || t.tagName !== 'ESA-TEXT-FIELD' || !('wbFunding' in t.dataset)) return;
    const panel = t.closest('[data-node-panel]') as HTMLElement | null;
    const api = getApi();
    if (!panel || !api) return;
    const wy = Number(t.dataset.wy);
    const digits = String((e as CustomEvent).detail?.value ?? t.value ?? '').replace(/[^0-9]/g, '');
    api.setFunding(panel.dataset.nodePanel ?? '', wy, digits ? Number(digits) : 0);
  });

  document.addEventListener('wb-model-change', () => {
    const panel = document.querySelector<HTMLElement>('[data-node-panel]:not([hidden])');
    if (panel) syncBlock(panel);
  });
  document.addEventListener('wb-node-select', (e) => {
    const id = (e as CustomEvent).detail?.id as string;
    const panel = document.querySelector<HTMLElement>(`[data-node-panel="${id}"]`);
    if (panel) syncBlock(panel);
  });
</script>

<style is:global>
  /* Global (not Astro-scoped) ON PURPOSE: the client script re-renders this block
     after model changes — scoped attribute selectors would miss the rebuilt rows.
     Every class is bcn-funding__-namespaced. */
  .bcn-funding { display: flex; flex-direction: column; gap: var(--spacing-300); }

  .bcn-funding__table { width: 100%; border-collapse: collapse; font-variant-numeric: tabular-nums; }
  .bcn-funding__table th, .bcn-funding__table td { padding: var(--spacing-150) var(--spacing-200); font-size: var(--type-size-200); text-align: left; border-bottom: 1px solid var(--color-border-light); }
  .bcn-funding__table thead th { font-weight: var(--font-weight-semibold); color: var(--color-text-tertiary); border-bottom: 1px solid var(--color-border); }
  /* Drawer (slim): one label scale with the esa field labels — same tokens the
     legos' .field__label uses (form-label-*, sm field-size fallback). */
  .bcn-funding--slim .bcn-funding__table thead th {
    font-size: var(--form-label-font-size, var(--form-font-size-sm, 12px));
    font-weight: var(--form-label-font-weight, var(--font-weight-medium));
    color: var(--form-label-color);
  }
  /* The amount input fills its column (two-column task tables only — parents
     keep Own/Rolled-up/Total widths). */
  .bcn-funding--slim .bcn-funding__table:not(:has([data-cell='sub'])) .bcn-funding__edit { width: 60%; }
  .bcn-funding--slim .bcn-funding__field { width: 100%; }
  .bcn-funding__num { text-align: right; }
  .bcn-funding__year { font-weight: var(--font-weight-regular); color: var(--color-text-primary); }
  .bcn-funding__muted { color: var(--color-text-secondary); }
  .bcn-funding__strong { font-weight: var(--font-weight-semibold); color: var(--color-text-primary); }
  .bcn-funding__table tfoot th, .bcn-funding__table tfoot td { border-top: 1px solid var(--color-border-strong); border-bottom: 0; font-weight: var(--font-weight-semibold); color: var(--color-text-primary); }
  .bcn-funding__empty { margin: 0; font-size: var(--type-size-100); color: var(--color-text-tertiary); font-style: italic; }

  .bcn-funding__edit { padding-top: var(--spacing-100); padding-bottom: var(--spacing-100); }
  .bcn-funding__field { width: 130px; margin-left: auto; }
</style>
