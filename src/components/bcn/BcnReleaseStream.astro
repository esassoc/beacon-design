---
// <BcnReleaseStream> — the body of the Release Notes prototype (/prototypes/
// release-notes): one reverse-chronological stream of product releases, the
// changelog pattern (Notion / Claude Code / Sketch) adapted to Beacon's chrome.
// Each release is an anchored <article>: a quiet date + "Latest" meta line, the
// serif version number, the headline stories (serif titles — the richest tier),
// area-grouped entries with optional feature-flag / applies notes, and a
// collapsed "Fixes & small improvements" list. Every release and every entry is a
// hash target so the sidebar / release index and cross-release headline links
// resolve to it (scroll-margin adds landing room — the app's scroll container
// already starts below the fixed topbar).
//
// Presentational — the whole stream comes from RELEASES (../../data/release-notes);
// no props, no client JS (the fixes disclosure is native <details>). Blocks
// (p / bullets / callout) pattern-match BcnHelpArticle's renderer; inline **bold**
// and `code` in text/items/fixes are formatted at build time (escape → replace →
// set:html) since Astro won't process markup inside interpolated strings.
//
// Typography: a serif display layer (var(--font-decorative), Besley) carries the
// two display tiers — the release version number and the headline story titles;
// everything else stays on the sans body face (inherited from the app root). The
// hierarchy is weight- and size-driven and the ink is monochrome — no status
// colour anywhere; the "Latest" marker is a quiet gray text label, not a chip, and
// the only colour that surfaces is the house link colour on actual links. Prose is
// held to a ~42rem reading measure so text never runs the full content column.
//
// bcn-lego-checked: no esa-* lego renders a changelog / release stream — checked
// Ecology (esa-card is a bare container; esa-icon is composed INSIDE here) and
// Beacon (no release-notes primitive). The callout icon and the code/bold spans are
// token-driven content typography, legitimately bespoke rendering.
import EsaIcon from '@esa/ecology/esa-icon.astro';
import { RELEASES } from '../../data/release-notes';

// Inline formatter for the two markdown-lite patterns the copy uses: **bold** and
// `code`. Escape HTML first (content may hold <, >, &), then swap the patterns —
// code before bold so a ** inside a code span stays literal. Rendered via set:html.
const escapeHtml = (s: string): string =>
  s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

const formatInline = (s: string): string =>
  escapeHtml(s)
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');

// "June 2, 2026" for the meta line; ISO stays on <time datetime> (BcnHelpBar's
// fmtLong pattern — T00:00:00 pins local midnight so the date never shifts a day).
const fmtDate = (iso: string): string =>
  new Date(`${iso}T00:00:00`).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<section class="bcn-release-stream" aria-label="Release notes">
  {RELEASES.map((release) => (
    <article
      class="bcn-release"
      id={release.anchor}
      aria-labelledby={`${release.anchor}-heading`}
    >
      <header class="bcn-release__header">
        {/* Sketch pattern — a small, quiet meta line sits ABOVE the serif version:
            the "Latest" marker (newest release only), the date, and any patch note. */}
        <p class="bcn-release__meta">
          {release.latest && <span class="bcn-release__latest">Latest</span>}
          <time class="bcn-release__date" datetime={release.date}>{fmtDate(release.date)}</time>
          {release.patchNote && <span class="bcn-release__patch">{release.patchNote}</span>}
        </p>
        <h2 class="bcn-release__version" id={`${release.anchor}-heading`}>
          {release.version}
        </h2>
      </header>

      {release.headlines.length > 0 && (
        <ul class="bcn-release__headlines">
          {release.headlines.map((h) => (
            <li class="bcn-release__headline">
              <h3 class="bcn-release__headline-title">
                {h.entryId ? (
                  <a class="bcn-release__headline-link" href={`#${release.anchor}-${h.entryId}`}>
                    {h.title}
                  </a>
                ) : (
                  h.title
                )}
              </h3>
              <p class="bcn-release__headline-text" set:html={formatInline(h.text)} />
            </li>
          ))}
        </ul>
      )}

      {release.sections.map((section) => (
        <section class="bcn-release__group">
          <h3 class="bcn-release__group-title">{section.title}</h3>
          <div class="bcn-release__entries">
            {section.entries.map((entry) => (
              <div class="bcn-release__entry" id={`${release.anchor}-${entry.id}`}>
                <div class="bcn-release__entry-head">
                  <h4 class="bcn-release__entry-title">{entry.title}</h4>
                  {entry.flag && (
                    <span class="bcn-release__flag">flag<code>{entry.flag}</code></span>
                  )}
                  {entry.applies && (
                    <span class="bcn-release__applies">{entry.applies}</span>
                  )}
                </div>
                <div class="bcn-release__blocks">
                  {entry.blocks.map((block) => {
                    if (block.kind === 'p') {
                      return <p class="bcn-release__p" set:html={formatInline(block.text)} />;
                    }
                    if (block.kind === 'bullets') {
                      return (
                        <ul class="bcn-release__bullets">
                          {block.items.map((item) => (
                            <li class="bcn-release__bullet" set:html={formatInline(item)} />
                          ))}
                        </ul>
                      );
                    }
                    if (block.kind === 'callout') {
                      return (
                        <aside class="bcn-release__callout">
                          <span class="bcn-release__callout-icon"><EsaIcon name="info" size="sm" /></span>
                          <p class="bcn-release__callout-text" set:html={formatInline(block.text)} />
                        </aside>
                      );
                    }
                    return null;
                  })}
                </div>
              </div>
            ))}
          </div>
        </section>
      ))}

      {release.fixes.length > 0 && (
        <details class="bcn-release__fixes">
          <summary class="bcn-release__fixes-summary">
            Fixes &amp; small improvements ({release.fixes.length})
          </summary>
          <ul class="bcn-release__fixes-list">
            {release.fixes.map((f) => (
              <li class="bcn-release__fix" set:html={formatInline(f)} />
            ))}
          </ul>
        </details>
      )}
    </article>
  ))}
</section>

<style>
  /* Token-driven throughout; the parent page owns the outer canvas. Each release is
     held to a readable measure and centered so prose never runs edge-to-edge,
     whatever width the page hands the stream. */
  .bcn-release-stream {
    display: flex;
    flex-direction: column;
  }

  .bcn-release {
    max-inline-size: 46rem;
    margin-inline: auto;
    inline-size: 100%;
    /* Breathing room for hash-jump landings; the scroll container itself already
       sits below the fixed topbar (AppShell's .modern-layout__body padding). */
    scroll-margin-top: var(--spacing-500);
    padding-block: var(--spacing-800);
  }
  /* Releases below the first carry a hairline separator — a rule, never a
     status border. */
  .bcn-release + .bcn-release {
    border-top: 1px solid var(--color-border-light);
  }
  .bcn-release:first-child { padding-block-start: var(--spacing-500); }

  /* ── Version header ─────────────────────────────────────────────── */
  .bcn-release__header {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-150);
    margin-block-end: var(--spacing-600);
  }
  /* The quiet meta line above the version: Latest · date · patch note. Small sans,
     never bold, middot-separated. */
  .bcn-release__meta {
    margin: 0;
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    font-size: 0.875rem;
    line-height: 1.4;
    color: var(--color-text-tertiary);
  }
  .bcn-release__latest {
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
  }
  .bcn-release__latest::after {
    content: '·';
    margin-inline: var(--spacing-200);
    color: var(--color-text-muted);
  }
  .bcn-release__patch { color: var(--color-text-muted); }
  .bcn-release__patch::before {
    content: '·';
    margin-inline: var(--spacing-200);
    color: var(--color-text-muted);
  }
  /* Serif display tier — the release number. Besley at ~30px (type-size-600),
     tight leading, a hair of negative tracking for the large optical size. */
  .bcn-release__version {
    margin: 0;
    font-family: var(--font-decorative);
    font-size: var(--type-size-600);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
  }

  /* ── Headlines — the big stories (richest tier), serif-titled ─────── */
  .bcn-release__headlines {
    list-style: none;
    margin: 0 0 var(--spacing-700);
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-600);
  }
  .bcn-release__headline {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-200);
  }
  /* Serif display tier — the headline title. Besley ~21px, medium weight; the serif
     voice and the spacing carry the tier (no number chips, no colour). */
  .bcn-release__headline-title {
    margin: 0;
    font-family: var(--font-decorative);
    font-size: clamp(1.1875rem, 1.05rem + 0.7vw, 1.3125rem);
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.005em;
    color: var(--color-text-primary);
  }
  .bcn-release__headline-link {
    color: inherit;
    text-decoration: none;
  }
  .bcn-release__headline-link:hover {
    color: var(--color-text-link);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .bcn-release__headline-text {
    margin: 0;
    max-inline-size: 42rem;
    font-size: 1rem;
    line-height: var(--line-height-normal);
    color: var(--color-text-secondary);
  }

  /* ── Area groups + entries ──────────────────────────────────────── */
  .bcn-release__group + .bcn-release__group { margin-block-start: var(--spacing-700); }

  /* Readable area label — normal case, 17px semibold, a hairline underscoring it as
     a section divider. Deliberately NOT an ornamental uppercase micro-label. */
  .bcn-release__group-title {
    margin: 0 0 var(--spacing-400);
    padding-block-end: var(--spacing-200);
    border-bottom: 1px solid var(--color-border-light);
    font-size: 1.0625rem;
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-secondary);
  }

  .bcn-release__entries {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-500);
  }
  .bcn-release__entry {
    scroll-margin-top: var(--spacing-500);
  }
  .bcn-release__entry-head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--spacing-150) var(--spacing-300);
    margin-block-end: var(--spacing-300);
    max-inline-size: 42rem;
  }
  .bcn-release__entry-title {
    margin: 0;
    font-size: 1rem;
    font-weight: var(--font-weight-semibold);
    line-height: 1.4;
    color: var(--color-text-primary);
  }
  /* Feature-flag note — quiet neutral chip, the flag name in mono (genuine
     technical meta, so 13px is legitimate). */
  .bcn-release__flag {
    display: inline-flex;
    align-items: baseline;
    gap: var(--spacing-100);
    padding: 2px var(--spacing-200);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-100);
    background: var(--color-surface);
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
  }
  .bcn-release__flag code {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }
  .bcn-release__applies {
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
  }

  /* ── Blocks (p / bullets / callout) — held to the reading measure ── */
  .bcn-release__blocks {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-400);
    max-inline-size: 42rem;
  }
  .bcn-release__p {
    margin: 0;
    font-size: 1rem;
    line-height: var(--line-height-normal);
    color: var(--color-text-primary);
  }
  .bcn-release__bullets {
    margin: 0;
    padding-inline-start: var(--spacing-500);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-200);
  }
  .bcn-release__bullet {
    font-size: 1rem;
    line-height: var(--line-height-normal);
    color: var(--color-text-primary);
  }
  .bcn-release__bullet::marker { color: var(--color-text-tertiary); }
  /* Quiet neutral note box — leading icon + text. Sunken surface + hairline, no
     colour, no left border. */
  .bcn-release__callout {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: start;
    gap: var(--spacing-300);
    padding: var(--spacing-400);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-200);
    background: var(--color-surface-sunken);
  }
  .bcn-release__callout-icon {
    display: inline-flex;
    margin-block-start: 2px;
    color: var(--color-text-secondary);
  }
  .bcn-release__callout-text {
    margin: 0;
    font-size: 1rem;
    line-height: var(--line-height-normal);
    color: var(--color-text-primary);
  }

  /* ── Fixes — de-emphasized small print, collapsed by default ─────── */
  .bcn-release__fixes {
    margin-block-start: var(--spacing-600);
  }
  .bcn-release__fixes-summary {
    cursor: pointer;
    font-size: 0.9375rem;
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
    list-style-position: inside;
  }
  .bcn-release__fixes-summary:hover { color: var(--color-text-primary); }
  .bcn-release__fixes-list {
    margin: var(--spacing-300) 0 0;
    padding-inline-start: var(--spacing-500);
    max-inline-size: 42rem;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-200);
  }
  .bcn-release__fix {
    font-size: 0.875rem;
    line-height: var(--line-height-normal);
    color: var(--color-text-tertiary);
  }
  .bcn-release__fix::marker { color: var(--color-border-strong); }

  /* Injected inline spans from the formatter (set:html bypasses Astro scoping;
     :global under the component root keeps them bounded here). */
  .bcn-release :global(strong) { font-weight: var(--font-weight-semibold); color: var(--color-text-primary); }
  .bcn-release :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    padding: 1px 5px;
    border-radius: var(--radius-100);
    background: var(--color-surface-sunken);
    color: var(--color-text-primary);
  }

  @media (max-width: 32rem) {
    .bcn-release { padding-block: var(--spacing-700); }
  }
</style>
