---
// <BcnNodeDetail> — the row side-panel body for one work-breakdown node. Reads
// top-to-bottom in the locked order (Andy, decision 5):
//   Identity → Timing → Funding → Roll-up (parents only) → constraints/notes (collapsed).
//
// EDITABLE: a Task's Timing section is esa-select month/year pairs that write
// through the gantt's wbApi (bars + roll-up brackets re-derive live); the Funding
// section's dollar cells are esa-text-field legos (see BcnFundingPlan). The client
// script below keeps every panel's derived text (spans, water years, roll-up
// counts) in sync after any model change — elements it patches carry data-live
// hooks; the roll-up meter is rebuilt via bcn-rollup classes (globally styled).
//
// bcn-lego-checked: this is a COMPOSITION of legos — bcn-key-value (identity/timing
// rows), bcn-status-chip (task status), bcn-funding-plan (dollars/water-year),
// bcn-rollup-summary (the legible parent roll-up), esa-select (month/year pickers),
// and the esa-collapsible lego for the collapsed constraints/notes. No reinvented
// primitive; the only page-side CSS is section-stacking glue. bcn-node-detail is the
// reusable home for the panel body.
import EsaCollapsible from '@esa/ecology/esa-collapsible.astro';
import BcnKeyValue from './BcnKeyValue.astro';
import BcnStatusChip from './BcnStatusChip.astro';
import BcnFundingPlan from './BcnFundingPlan.astro';
import BcnRollupSummary from './BcnRollupSummary.astro';
import {
  TIER_META,
  TASK_STATUS_META,
  FIELD_SEASON_META,
  monthLabel,
  waterYearOf,
  fieldSeasonOf,
  type HierNode,
  type NodeRollUp,
} from '../../data/fish-model';
import { SCHEDULE_START_YEAR, SCHEDULE_END_YEAR } from '../../data/fish-schedule';

interface Props {
  node: HierNode;
  rollup: NodeRollUp;
  parentName?: string;
}
const { node, rollup, parentName } = Astro.props;

const tier = TIER_META[node.tier];
const isTask = node.tier === 'task';
const isParent = node.children.length > 0;

// Timing values: a Task uses its own months; a parent shows its rolled-up span.
const startMonth = isTask ? node.startMonth : rollup.startMonth;
const endMonth = isTask ? node.endMonth : rollup.endMonth;
const wyStart = startMonth ? waterYearOf(startMonth) : undefined;
const wyEnd = endMonth ? waterYearOf(endMonth) : undefined;
const wyLabel = wyStart ? (wyStart === wyEnd ? `WY${wyStart}` : `WY${wyStart}–WY${wyEnd}`) : '—';
const startSeason = startMonth ? FIELD_SEASON_META[fieldSeasonOf(startMonth)] : undefined;
const endSeason = endMonth ? FIELD_SEASON_META[fieldSeasonOf(endMonth)] : undefined;
const seasonHint =
  startSeason && endSeason
    ? startSeason === endSeason
      ? `Field season: ${startSeason.label}`
      : `Field seasons: ${startSeason.label} → ${endSeason.label}`
    : 'Set a start and end month to place this task on the gantt.';

// Month/year picker options (esa-select hydrates the JSON attribute).
const MONTH_NAMES = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const monthOptsJson = JSON.stringify(MONTH_NAMES.map((label, i) => ({ value: String(i + 1).padStart(2, '0'), label })));
const yearOptsList = [];
for (let y = SCHEDULE_START_YEAR; y < SCHEDULE_END_YEAR; y++) yearOptsList.push({ value: String(y), label: String(y) });
const yearOptsJson = JSON.stringify(yearOptsList);

// A task's scheduled span, as water years — the funding table offers those rows.
const spanYears: number[] = [];
if (isTask && node.startMonth && node.endMonth) {
  const a = waterYearOf(node.startMonth);
  const b = Math.max(a, waterYearOf(node.endMonth));
  for (let wy = a; wy <= b; wy++) spanYears.push(wy);
}

// Roll-up child label (plural of the child tier: studies / sub-studies / tasks).
const childTier = node.children[0]?.tier;
const pluralize = (w: string) => (w.endsWith('y') ? `${w.slice(0, -1)}ies` : `${w}s`);
const childLabel = childTier ? pluralize(TIER_META[childTier].label.toLowerCase()) : '';

const st = node.status ? TASK_STATUS_META[node.status] : undefined;
const hasNotes = Boolean(node.notes) || Boolean(node.constraints?.length);
---

<div class="bcn-detail">
  <!-- ── 1 · Identity ── -->
  <section class="bcn-detail__section">
    <h3 class="bcn-detail__title">Identity</h3>
    <div class="bcn-detail__identity">
      <span class="bcn-detail__id">{node.id}</span>
      <span class="bcn-detail__tier">{tier.label}</span>
    </div>
    <div class="bcn-detail__rows">
      <div data-live="name"><BcnKeyValue label="Name" value={node.name || '—'} /></div>
      <BcnKeyValue label="COA reference" value={node.coaRef ?? '—'} hint="ITP Condition of Approval — reference label, not the record id" />
      {node.tier !== 'program' && <div data-live="parent"><BcnKeyValue label="Parent" value={parentName ?? '—'} /></div>}
    </div>
  </section>

  <!-- ── 2 · Timing (fish-study calendar: water years + field seasons) ── -->
  <section class="bcn-detail__section">
    <h3 class="bcn-detail__title">Timing</h3>
    {isTask ? (
      <div class="bcn-detail__rows">
        <div class="bcn-detail__sched" role="group" aria-label="Task schedule">
          <div class="bcn-detail__sched-grid">
            <esa-select label="Start month" size="sm" placeholder="Month" options={monthOptsJson} data-wb-field="start" data-part="month"></esa-select>
            <esa-select label="Start year" size="sm" placeholder="Year" options={yearOptsJson} data-wb-field="start" data-part="year"></esa-select>
            <esa-select label="End month" size="sm" placeholder="Month" options={monthOptsJson} data-wb-field="end" data-part="month"></esa-select>
            <esa-select label="End year" size="sm" placeholder="Year" options={yearOptsJson} data-wb-field="end" data-part="year"></esa-select>
          </div>
          <span class="bcn-detail__sched-hint" data-live="season">{seasonHint}</span>
        </div>
        <div data-live="wy"><BcnKeyValue label="Water years" value={wyLabel} /></div>
        <BcnKeyValue label="Owner" value={node.owner ?? '—'} />
        {st && (
          <div class="bcn-detail__status">
            <span class="bcn-detail__status-lbl">Status</span>
            <BcnStatusChip status={node.status!} label={st.label} hex={st.hex} />
          </div>
        )}
      </div>
    ) : (
      <div class="bcn-detail__rows">
        <div data-live="span"><BcnKeyValue label="Rolled-up span" value={`${monthLabel(startMonth)} – ${monthLabel(endMonth)}`} hint="min start → max end across all tasks in this branch" /></div>
        <div data-live="wy"><BcnKeyValue label="Water years" value={wyLabel} /></div>
      </div>
    )}
  </section>

  <!-- ── 3 · Funding (CDFW dollars per water year; tasks sum upward) ── -->
  <section class="bcn-detail__section">
    <h3 class="bcn-detail__title">Funding plan</h3>
    <BcnFundingPlan rollup={rollup} ownFunding={node.funding} spanYears={spanYears} />
  </section>

  <!-- ── 4 · Roll-up (PARENT nodes only) ── -->
  {isParent && (
    <section class="bcn-detail__section">
      <h3 class="bcn-detail__title">Status roll-up</h3>
      <BcnRollupSummary rollup={rollup} childCount={node.children.length} childLabel={childLabel} />
    </section>
  )}

  <!-- ── 5 · Constraints / notes (collapsed by default) ── -->
  <section class="bcn-detail__section bcn-detail__section--flush">
    <EsaCollapsible title="Constraints & notes" flush open={false}>
      {hasNotes ? (
        <div class="bcn-detail__notes">
          {node.constraints && node.constraints.length > 0 && (
            <ul class="bcn-detail__constraints">
              {node.constraints.map((c) => <li>{c}</li>)}
            </ul>
          )}
          {node.notes && <p class="bcn-detail__note">{node.notes}</p>}
        </div>
      ) : (
        <p class="bcn-detail__note bcn-detail__note--empty">None recorded.</p>
      )}
    </EsaCollapsible>
  </section>
</div>

<script>
  import '@esa/ecology/esa-select';
  import {
    TASK_STATUS_META,
    HEALTH_META,
    TIER_META,
    monthLabel,
    waterYearOf,
    fieldSeasonOf,
    FIELD_SEASON_META,
  } from '../../data/fish-model';
  import type { HierNode, NodeRollUp } from '../../data/fish-model';

  type WbApi = {
    getNode(id: string): HierNode | undefined;
    parentOf(id: string): HierNode | null;
    rollupOf(id: string): NodeRollUp | undefined;
    setTaskSchedule(id: string, startMonth: string, endMonth: string): void;
  };
  const getApi = (): WbApi | undefined =>
    (document.querySelector('.bcn-wb') as (HTMLElement & { wbApi?: WbApi }) | null)?.wbApi;

  const pluralize = (w: string) => (w.endsWith('y') ? `${w.slice(0, -1)}ies` : `${w}s`);
  const setText = (root: ParentNode, sel: string, text: string) => {
    const el = root.querySelector<HTMLElement>(sel);
    if (el) el.textContent = text;
  };

  const wyLabelOf = (start?: string, end?: string): string => {
    if (!start) return '—';
    const a = waterYearOf(start);
    const b = end ? waterYearOf(end) : a;
    return a === b ? `WY${a}` : `WY${a}–WY${b}`;
  };

  function syncTiming(panel: HTMLElement, node: HierNode, r: NodeRollUp) {
    const start = node.tier === 'task' ? node.startMonth : r.startMonth;
    const end = node.tier === 'task' ? node.endMonth : r.endMonth;
    if (node.tier === 'task') {
      const sel = (field: string, part: string) =>
        panel.querySelector(`esa-select[data-wb-field="${field}"][data-part="${part}"]`) as
          | (HTMLElement & { value: string | string[] })
          | null;
      const sm = sel('start', 'month');
      if (sm) sm.value = start ? start.slice(5) : '';
      const sy = sel('start', 'year');
      if (sy) sy.value = start ? start.slice(0, 4) : '';
      const em = sel('end', 'month');
      if (em) em.value = end ? end.slice(5) : '';
      const ey = sel('end', 'year');
      if (ey) ey.value = end ? end.slice(0, 4) : '';
      const ss = start ? FIELD_SEASON_META[fieldSeasonOf(start)] : undefined;
      const es = end ? FIELD_SEASON_META[fieldSeasonOf(end)] : undefined;
      setText(
        panel,
        '[data-live="season"]',
        ss && es
          ? ss === es
            ? `Field season: ${ss.label}`
            : `Field seasons: ${ss.label} → ${es.label}`
          : 'Set a start and end month to place this task on the gantt.',
      );
    } else {
      setText(panel, '[data-live="span"] .bcn-key-value__val', `${monthLabel(start)} – ${monthLabel(end)}`);
    }
    setText(panel, '[data-live="wy"] .bcn-key-value__val', wyLabelOf(start, end));
  }

  // Re-derives the parent roll-up meter (chip, segmented bar, count line). The
  // bar/count children are rebuilt — bcn-rollup styles are global for this reason.
  function syncRollup(panel: HTMLElement, node: HierNode, r: NodeRollUp) {
    const root = panel.querySelector<HTMLElement>('.bcn-rollup');
    if (!root) return;
    const childTier = node.children[0]?.tier;
    const childLabel = childTier ? pluralize(TIER_META[childTier].label.toLowerCase()) : 'children';
    setText(root, '.bcn-rollup__from', `Rolled up from ${node.children.length} ${childLabel}`);
    const agg = TASK_STATUS_META[r.aggregate];
    const chip = root.querySelector<HTMLElement>('.bcn-status-chip');
    if (chip) {
      chip.dataset.status = r.aggregate;
      // Fish-study statuses have no --st-* theme token — the ramp hex IS the value.
      chip.style.setProperty('--_chip', agg.hex);
      setText(chip, '.bcn-status-chip__label', agg.label);
    }
    const bar = root.querySelector<HTMLElement>('.bcn-rollup__bar');
    if (bar) {
      bar.setAttribute(
        'aria-label',
        `${r.taskCount} tasks: ${r.onTrack} on track, ${r.atRisk} at risk, ${r.blocked} blocked, ${r.complete} complete`,
      );
      const segs = [
        { count: r.blocked, hex: HEALTH_META.blocked.hex, label: 'blocked' },
        { count: r.atRisk, hex: HEALTH_META['at-risk'].hex, label: 'at risk' },
        { count: r.onTrack, hex: HEALTH_META['on-track'].hex, label: 'on track' },
        { count: r.complete, hex: TASK_STATUS_META.complete.hex, label: 'complete' },
      ]
        .filter((s) => s.count > 0)
        .map((s) => {
          const seg = document.createElement('span');
          seg.className = 'bcn-rollup__seg';
          seg.style.width = `${(s.count / Math.max(r.taskCount, 1)) * 100}%`;
          seg.style.setProperty('--_c', s.hex);
          seg.title = `${s.count} ${s.label}`;
          return seg;
        });
      bar.replaceChildren(...segs);
    }
    const counts = root.querySelector<HTMLElement>('.bcn-rollup__counts');
    if (counts) {
      const mk = (count: number, label: string, hex: string) => {
        const span = document.createElement('span');
        span.className = 'bcn-rollup__count';
        const dot = document.createElement('span');
        dot.className = 'bcn-rollup__dot';
        dot.style.setProperty('--_c', hex);
        span.append(dot, `${count} ${label}`);
        return span;
      };
      const total = document.createElement('span');
      total.className = 'bcn-rollup__total';
      total.textContent = `${r.taskCount} ${r.taskCount === 1 ? 'task' : 'tasks'}`;
      const parts = [
        total,
        mk(r.onTrack, 'on track', HEALTH_META['on-track'].hex),
        mk(r.atRisk, 'at risk', HEALTH_META['at-risk'].hex),
        mk(r.blocked, 'blocked', HEALTH_META.blocked.hex),
      ];
      if (r.complete > 0) parts.push(mk(r.complete, 'complete', TASK_STATUS_META.complete.hex));
      counts.replaceChildren(...parts);
    }
  }

  function syncPanel(panel: HTMLElement) {
    const api = getApi();
    if (!api) return;
    const id = panel.dataset.nodePanel ?? '';
    const node = api.getNode(id);
    const r = api.rollupOf(id);
    if (!node || !r) return;
    setText(panel, '.bcn-detail__id', node.id);
    setText(panel, '.bcn-detail__tier', TIER_META[node.tier].label);
    setText(panel, '[data-live="name"] .bcn-key-value__val', node.name || '—');
    const parentVal = panel.querySelector<HTMLElement>('[data-live="parent"] .bcn-key-value__val');
    if (parentVal) parentVal.textContent = api.parentOf(id)?.name ?? '—';
    syncTiming(panel, node, r);
    syncRollup(panel, node, r);
  }

  // ONE delegated listener for the month/year pickers: resolve the pair into
  // 'YYYY-MM', keep start ≤ end, write through wbApi (bars re-derive live).
  document.addEventListener('change', (e) => {
    const el = e.target as HTMLElement & { value?: string | string[] };
    if (!(el instanceof HTMLElement) || el.tagName !== 'ESA-SELECT' || !el.dataset.wbField) return;
    const panel = el.closest('[data-node-panel]') as HTMLElement | null;
    const api = getApi();
    if (!panel || !api) return;
    const id = panel.dataset.nodePanel ?? '';
    const node = api.getNode(id);
    if (!node || node.tier !== 'task') return;
    const value = String((e as CustomEvent).detail?.value ?? el.value ?? '');
    if (!value) return;
    const edge = el.dataset.wbField; // 'start' | 'end'
    const base = (edge === 'start' ? node.startMonth : node.endMonth) ?? node.startMonth ?? node.endMonth ?? '2029-04';
    let [y, m] = base.split('-');
    if (el.dataset.part === 'month') m = value;
    else y = value;
    let start = node.startMonth;
    let end = node.endMonth;
    if (edge === 'start') start = `${y}-${m}`;
    else end = `${y}-${m}`;
    if (!start) start = end;
    if (!end) end = start;
    if (start! > end!) {
      if (edge === 'start') end = start;
      else start = end;
    }
    api.setTaskSchedule(id, start!, end!);
  });

  // Keep the visible panel's derived text in sync with every model change, and
  // (re)fill a panel's controls whenever it is opened.
  document.addEventListener('wb-model-change', () => {
    const panel = document.querySelector<HTMLElement>('[data-node-panel]:not([hidden])');
    if (panel) syncPanel(panel);
  });
  document.addEventListener('wb-node-select', (e) => {
    const id = (e as CustomEvent).detail?.id as string;
    const panel = document.querySelector<HTMLElement>(`[data-node-panel="${id}"]`);
    if (panel) syncPanel(panel);
  });
</script>

<style>
  .bcn-detail { display: flex; flex-direction: column; gap: var(--spacing-500); }
  .bcn-detail__section { display: flex; flex-direction: column; gap: var(--spacing-300); }
  .bcn-detail__section--flush { border-top: 1px solid var(--color-border-light); padding-top: var(--spacing-200); }

  .bcn-detail__title { margin: 0; font-size: var(--form-font-size-md); font-weight: var(--font-weight-semibold); color: var(--color-text-secondary); }

  .bcn-detail__identity { display: flex; align-items: center; gap: var(--spacing-200); flex-wrap: wrap; }
  .bcn-detail__id { font-family: var(--font-mono); font-size: var(--type-size-200); font-weight: var(--font-weight-semibold); color: var(--color-commitment); background: color-mix(in srgb, var(--color-commitment) 12%, white); padding: 2px var(--spacing-250); border-radius: var(--radius-100); }
  .bcn-detail__tier { font-size: var(--type-size-100); font-weight: var(--font-weight-medium); color: var(--color-text-tertiary); }

  .bcn-detail__rows { display: flex; flex-direction: column; gap: var(--spacing-300); }

  .bcn-detail__sched { display: flex; flex-direction: column; gap: var(--spacing-200); }
  .bcn-detail__sched-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-200) var(--spacing-300); }
  .bcn-detail__sched-hint { font-size: 0.8125rem; color: var(--color-text-tertiary); }

  .bcn-detail__status { display: flex; align-items: center; gap: var(--spacing-200); flex-wrap: wrap; }
  .bcn-detail__status-lbl { font-size: var(--form-font-size-md); font-weight: var(--font-weight-medium); color: var(--form-label-color); }

  .bcn-detail__notes { display: flex; flex-direction: column; gap: var(--spacing-200); }
  .bcn-detail__constraints { margin: 0; padding-left: var(--spacing-400); display: flex; flex-direction: column; gap: var(--spacing-100); font-size: var(--type-size-200); color: var(--color-text-secondary); }
  .bcn-detail__note { margin: 0; font-size: var(--type-size-200); color: var(--color-text-secondary); line-height: 1.55; }
  .bcn-detail__note--empty { color: var(--color-text-tertiary); font-style: italic; }
</style>
