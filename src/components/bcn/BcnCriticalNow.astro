---
// <BcnCriticalNow> — the "most critical right now" surface: the page's answer to
// "what should I do next?". Criticality — NOT "needs action" — is the elevation
// criterion, so this is a SHORT set of genuinely critical items drawn project-wide
// (a critical item on a non-starred component still surfaces). Each item is a
// first-class ENTITY — an observation, an action, or a report — rendered as a
// tangible entity CARD: a NEUTRAL type-icon tile gives it object-ness (Andy,
// round 3: no per-type color coding — color lives in the severity data, not the
// chrome), prod icon vocabulary (Action = radar), and actions carry their
// commitment-ID as the mono code chip prefixing the title (the BcnCommitmentRow
// idiom). The whole card is the link to the entity.
//
// Composes the legos: EsaCard (shell), EsaIcon (type + chevron glyphs), BcnCount
// (the neutral header count). The entity card + severity marker are composition
// inside this component; severity color is value-driven via `--_s`.
//
// bcn-lego-checked: no esa-* lego is an "entity card with a type-icon tile + severity
// marker" — esa-card is a static shell, esa-badge/esa-pill are atoms. Checked the
// spoke's own slim-entity precedent (BcnObservationCard / BcnCommitmentRow) and matched
// it. bcn-critical-now is the reusable home; every control inside it is a lego.
import EsaCard from '@esa/ecology/esa-card.astro';
import EsaIcon from '@esa/ecology/esa-icon.astro';
import BcnCount from './BcnCount.astro';
import { withBase } from '../../lib/base';
import type { CriticalItem, EntityType, CriticalTier } from '../../data/project-dashboard';

interface Props {
  items: CriticalItem[];
}
const { items } = Astro.props;

const linkHref = (href: string) => (href.startsWith('/') ? withBase(href) : href);

// Entity type → label + Lucide glyph, in PROD's icon vocabulary (Action = radar,
// Report = the reporting area's clipboard-list; Observation = eye).
const EYE =
  '<path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/>';
const RADAR =
  '<path d="M19.07 4.93A10 10 0 0 0 6.99 3.34"/><path d="M4 6h.01"/><path d="M2.29 9.62A10 10 0 1 0 21.31 8.35"/><path d="M16.24 7.76A6 6 0 1 0 8.23 16.67"/><path d="M12 18h.01"/><path d="M17.99 11.66A6 6 0 0 1 15.77 16.67"/><circle cx="12" cy="12" r="2"/><path d="m13.41 10.59 5.66-5.66"/>';
const CLIPBOARD_LIST =
  '<rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/>';
const ENTITY: Record<EntityType, { label: string; paths: string }> = {
  observation: { label: 'Observation', paths: EYE },
  action: { label: 'Action', paths: RADAR },
  report: { label: 'Report', paths: CLIPBOARD_LIST },
};
const TIER: Record<CriticalTier, { label: string; hex: string }> = {
  critical: { label: 'Critical', hex: 'var(--color-danger)' },
  urgent: { label: 'Urgent', hex: 'var(--color-warning)' },
};
---

<EsaCard title="Most critical right now">
  <BcnCount slot="actions" value={items.length} label={`${items.length} critical items`} />

  <div class="bcn-crit">
    <ul class="bcn-crit__list">
      {
        items.map((item) => {
          const e = ENTITY[item.entityType];
          const t = TIER[item.tier];
          return (
            <li>
              <a class="bcn-crit__card" href={linkHref(item.href)}>
                <span class="bcn-crit__icon" aria-hidden="true">
                  <EsaIcon name="entity" size="md" paths={e.paths} />
                </span>

                <span class="bcn-crit__body">
                  <span class="bcn-crit__type">{e.label}</span>
                  <span class="bcn-crit__title">
                    {item.code && <span class="bcn-crit__code">{item.code}</span>}
                    {item.title}
                  </span>
                  <span class="bcn-crit__where">{item.where}</span>
                </span>

                <span class="bcn-crit__right">
                  <span class="bcn-crit__sev">
                    <span class="bcn-crit__sev-dot" style={`--_s: ${t.hex};`} aria-hidden="true" />
                    {t.label}
                  </span>
                  <span class:list={['bcn-crit__timing', { 'bcn-crit__timing--late': item.late }]}>
                    {item.timing}
                  </span>
                  <EsaIcon name="chevron-right" size="sm" class="bcn-crit__chev" />
                </span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</EsaCard>

<style>
  .bcn-crit { display: flex; flex-direction: column; gap: var(--spacing-400); }

  .bcn-crit__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-300);
  }

  /* The entity card — a tangible object: crisp border, neutral icon tile,
     hover lift. */
  .bcn-crit__card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--spacing-400);
    padding: var(--spacing-300) var(--spacing-400);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-300);
    text-decoration: none;
    color: inherit;
    transition: border-color 150ms ease, box-shadow 150ms ease, transform 150ms ease;
  }
  .bcn-crit__card:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-100, 0 2px 12px 0 rgba(0, 0, 0, 0.06));
    transform: translateY(-1px);
  }

  /* Type-icon tile — neutral chrome (no per-type tint; color lives in the data). */
  .bcn-crit__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: var(--radius-200);
    background: var(--color-surface-sunken);
    color: var(--color-text-secondary);
  }

  .bcn-crit__body { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .bcn-crit__type {
    font-size: var(--type-size-150);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-secondary);
  }
  .bcn-crit__title {
    font-size: var(--type-size-200);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
  }
  /* Commitment-ID chip prefixing an action's title — the BcnCommitmentRow code
     idiom. 13px = the meta floor for ID chips; no token exists at this step. */
  .bcn-crit__code {
    display: inline-block;
    margin-right: var(--spacing-200);
    padding: 1px var(--spacing-150);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: var(--font-weight-semibold);
    color: var(--color-commitment);
    background: color-mix(in srgb, var(--color-commitment) 12%, white);
    border-radius: var(--radius-100);
    vertical-align: 1px;
  }
  .bcn-crit__where { font-size: var(--type-size-150); color: var(--color-text-tertiary); }

  .bcn-crit__right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--spacing-100);
    flex-shrink: 0;
    text-align: right;
  }
  .bcn-crit__sev {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-150);
    font-size: var(--type-size-150);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-secondary);
  }
  .bcn-crit__sev-dot {
    width: 9px;
    height: 9px;
    border-radius: var(--radius-full);
    background: var(--_s);
    flex-shrink: 0;
  }
  .bcn-crit__timing { font-size: var(--type-size-150); color: var(--color-text-tertiary); white-space: nowrap; }
  .bcn-crit__timing--late { color: var(--color-danger); font-weight: var(--font-weight-semibold); }
  .bcn-crit__chev { color: var(--color-text-muted); }
  .bcn-crit__card:hover .bcn-crit__chev { color: var(--color-primary); }

  @media (max-width: 640px) {
    .bcn-crit__card { grid-template-columns: auto 1fr; }
    .bcn-crit__right {
      grid-column: 2;
      flex-direction: row;
      align-items: center;
      flex-wrap: wrap;
      text-align: left;
    }
  }
</style>
