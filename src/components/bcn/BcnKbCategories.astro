---
// <BcnKbCategories> — the browse surface of the Help & Guidance page: a DENSE
// documentation index (no cards, no icon chips), then an A–Z glossary. It is the
// page's primary way to find an article; each entry deep-links the reading-pane
// sibling via a `#article-<id>` hash.
//
// Layout: the seven categories (contract order: General, Getting Started, Tracking,
// Monitoring, Reporting, Data Catalog, Settings & Configuration) flow into a
// multi-column CSS-`columns` index — a modest normal-case heading per category over a
// compact list of its article links (title + terse one-liner). Below, a quiet
// "Glossary" heading over the glossary terms A–Z (`glossaryArticles()`), a flowing
// multi-column list of bare-term links. Chrome is hairlines + whitespace only — no
// card borders, no hover-lift, no colored left borders.
//
// Data-bound like BcnTrackingZone: reads HELP_CATEGORIES + articlesByCategory +
// glossaryArticles directly — the category set and article counts follow the data.
//
// Search hooks: the section is [data-kb-index]; every article row and glossary term
// carries [data-kb-entry] + data-title/data-summary; category groups carry
// [data-kb-cat] and id="category-<id>"; the glossary is [data-kb-glossary]. The
// controller (kb-browser.ts) live-filters against these while a query is active.
// Each category group keeps id="category-<id>" so #category-<id> deep-links (the Aldo
// drawer, external links) scroll to it natively (scroll-margin clears the topbar).
//
// bcn-lego-checked: this is a bespoke documentation INDEX — a text-dense list of
// links grouped by category plus an A–Z term list. No esa-* lego models it:
// esa-card/esa-link-column are card/box surfaces (the card chrome Andy rejected);
// esa-sidebar-nav renders ornamental micro-label group headings and filled-badge
// hints, not quiet normal-case headings + terse one-liners; esa-pillbox is tag
// chips. Checked Ecology + Beacon (prod has no KB index). Every link is a plain
// anchor; the only chrome is token-driven type + hairlines. bcn-kb-categories is the
// reusable home.
import { HELP_CATEGORIES, articlesByCategory, glossaryArticles } from '../../data/help-center';

const groups = HELP_CATEGORIES.map((c) => ({ ...c, articles: articlesByCategory(c.id) }));
const glossary = glossaryArticles();
---

<section class="bcn-kbc" data-kb-index aria-labelledby="bcn-kbc-index-title">
  <div class="bcn-kbc__block">
    <h2 id="bcn-kbc-index-title" class="bcn-kbc__section-title type-section-title">Browse by category</h2>
    <div class="bcn-kbc__index">
      {
        groups.map((cat) => (
          <section class="bcn-kbc__cat" id={`category-${cat.id}`} data-kb-cat={cat.id}>
            <h3 class="bcn-kbc__cat-title">{cat.title}</h3>
            <ul class="bcn-kbc__list" role="list">
              {cat.articles.map((a) => (
                <li class="bcn-kbc__row" data-kb-entry data-title={a.title} data-summary={a.summary}>
                  <a class="bcn-kbc__link" href={`#article-${a.id}`} data-article-link={a.id}>
                    {a.title}
                  </a>
                  <span class="bcn-kbc__row-summary">{a.summary}</span>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </div>

  <section class="bcn-kbc__block bcn-kbc__glossary" data-kb-glossary aria-labelledby="bcn-kbc-gloss-title">
    <h2 id="bcn-kbc-gloss-title" class="bcn-kbc__section-title type-section-title">Glossary</h2>
    <ul class="bcn-kbc__terms" role="list">
      {
        glossary.map((a) => (
          <li class="bcn-kbc__term" data-kb-entry data-title={a.title} data-summary={a.summary}>
            <a class="bcn-kbc__term-link" href={`#article-${a.id}`} data-article-link={a.id}>
              {a.title}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</section>

<style>
  /* Dense documentation index — no card chrome; hairlines + whitespace only. */
  .bcn-kbc {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-600);
  }

  .bcn-kbc__block {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-400);
  }

  /* Section heading — readable words, normal case, primary text. */
  .bcn-kbc__section-title {
    margin: 0;
    color: var(--color-text-primary);
  }

  /* ── category index: the seven groups flow into balanced text columns ── */
  .bcn-kbc__index {
    columns: 20rem 3;
    column-gap: var(--spacing-700);
  }

  /* One category group — kept whole within a column. */
  .bcn-kbc__cat {
    break-inside: avoid;
    margin-block-end: var(--spacing-500);
    scroll-margin-top: 5rem; /* #category-<id> lands clear of the app topbar */
  }
  .bcn-kbc__cat[hidden] { display: none; }

  /* Category heading — 17px semibold, normal case (deliberate fixed size: the fluid
     roles balloon past 17px on wide viewports; a dense index heading holds steady). */
  .bcn-kbc__cat-title {
    margin: 0 0 var(--spacing-200);
    padding-block-end: var(--spacing-150);
    border-bottom: 1px solid var(--color-border-light);
    font-size: 1.0625rem;
    font-weight: var(--font-weight-semibold);
    line-height: 1.3;
    color: var(--color-text-primary);
  }

  .bcn-kbc__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-200);
  }

  /* One article entry: title link over a terse one-liner. Tight leading, small rhythm. */
  .bcn-kbc__row { display: flex; flex-direction: column; gap: 1px; }
  .bcn-kbc__row[hidden] { display: none; }

  .bcn-kbc__link {
    font-size: 0.9375rem; /* 15px — dense-index list size */
    font-weight: var(--font-weight-medium);
    line-height: 1.35;
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color 120ms ease;
  }
  .bcn-kbc__link:hover {
    color: var(--bcn-aldo-600, #06736f);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .bcn-kbc__link:focus-visible {
    outline: 2px solid var(--bcn-aldo, #08908b);
    outline-offset: 2px;
    border-radius: var(--radius-100);
  }

  .bcn-kbc__row-summary {
    font-size: 0.8125rem; /* 13px terse one-liner */
    line-height: 1.4;
    color: var(--color-text-secondary);
  }

  /* ── glossary: A–Z term links, flowing into narrow text columns ── */
  .bcn-kbc__glossary { padding-block-start: var(--spacing-500); border-top: 1px solid var(--color-border); }
  .bcn-kbc__glossary[hidden] { display: none; }

  .bcn-kbc__terms {
    list-style: none;
    margin: 0;
    padding: 0;
    columns: 12rem;
    column-gap: var(--spacing-600);
  }
  .bcn-kbc__term { break-inside: avoid; margin-block-end: var(--spacing-150); }
  .bcn-kbc__term[hidden] { display: none; }

  .bcn-kbc__term-link {
    font-size: 0.9375rem; /* 15px */
    line-height: 1.4;
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color 120ms ease;
  }
  .bcn-kbc__term-link:hover {
    color: var(--bcn-aldo-600, #06736f);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .bcn-kbc__term-link:focus-visible {
    outline: 2px solid var(--bcn-aldo, #08908b);
    outline-offset: 2px;
    border-radius: var(--radius-100);
  }
</style>
