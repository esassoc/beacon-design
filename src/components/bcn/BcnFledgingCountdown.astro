---
// <BcnFledgingCountdown> — the species-keyed fledging countdown.
//
// Christy's most-asked field question: "how long before this nest fledges so we
// can get back in to do our work?" A TIGHT horizontal band: a compact "~Nd to
// fledge" on the left, a single dated rail (Observed → Est. hatch → Est. fledge)
// with a fill up to today, and the guidance caveat as a legible noted line.
// It is GUIDANCE (±buffer), not a guarantee — find.fledgeNote carries the caveat.
//
// bcn-lego-checked: NO esa-* lego renders a multi-node dated rail with a progress
// fill — checked the full catalog (esa-progress-bar is a single 0..1 bar; esa-stat/
// esa-card are static). Checked Beacon prod (no fledging-timeline component — the
// gap this prototype closes). Justified bespoke viz; composes esa-icon (the note).
//
// Date math runs in the frontmatter (SSR / build time), NOT the forbidden runtime
// Date.now. The host only mounts this when find.fledgeDate exists.
import EsaIcon from '@esa/ecology/esa-icon.astro';
import type { Find } from '../../data/monitoring';
import { TODAY } from '../../data/monitoring';

interface Props {
  find: Find;
  today?: string;
}
const { find, today = TODAY } = Astro.props;

const observedDate = find.observedDate;
const hatchDate = find.hatchDate ?? observedDate;
const fledgeDate = find.fledgeDate ?? observedDate;
const daysToFledge = find.daysToFledge ?? 0;

const ms = (iso: string) => Date.parse(iso);
const span = ms(fledgeDate) - ms(observedDate);
const frac = (iso: string) => (span > 0 ? Math.min(1, Math.max(0, (ms(iso) - ms(observedDate)) / span)) : 0);
const todayPct = `${(frac(today) * 100).toFixed(1)}%`;
const hatchPct = `${(frac(hatchDate) * 100).toFixed(1)}%`;
const fledged = daysToFledge <= 0;
const reachedHatch = frac(today) >= frac(hatchDate);

const fmtDate = (iso: string) =>
  new Date(`${iso}T00:00:00`).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });

const INFO = '<circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>';
---

<div class="bcn-fledge" data-fledged={String(fledged)}>
  <div class="bcn-fledge__band">
    {/* Compact focal count (left). */}
    <div class="bcn-fledge__count">
      <span class="bcn-fledge__num">{fledged ? 'Fledged' : <>~{daysToFledge}<span class="bcn-fledge__unit">d</span></>}</span>
      <span class="bcn-fledge__caption">{fledged ? 'nest is clear' : 'to fledge'}</span>
    </div>

    {/* Dated rail (right). */}
    <div
      class="bcn-fledge__rail"
      role="img"
      aria-label={`Observed ${fmtDate(observedDate)}, est. hatch ${fmtDate(hatchDate)}, est. fledge ${fmtDate(fledgeDate)}; ~${daysToFledge} days to fledge`}
    >
      <div class="bcn-fledge__track">
        <span class="bcn-fledge__fill" style={`width: ${todayPct};`}></span>
        <span class="bcn-fledge__dot" data-reached="true" style="left: 0%;"></span>
        <span class="bcn-fledge__dot" data-reached={String(reachedHatch)} style={`left: ${hatchPct};`}></span>
        <span class="bcn-fledge__dot bcn-fledge__dot--end" data-reached={String(fledged)} style="left: 100%;"></span>
        {!fledged && <span class="bcn-fledge__today" style={`left: ${todayPct};`} aria-hidden="true"></span>}
      </div>
      <div class="bcn-fledge__caps">
        <span class="bcn-fledge__cap bcn-fledge__cap--start">
          <span class="bcn-fledge__cap-label">Observed</span>
          <span class="bcn-fledge__cap-date">{fmtDate(observedDate)}</span>
        </span>
        <span class="bcn-fledge__cap bcn-fledge__cap--mid" style={`left: ${hatchPct};`}>
          <span class="bcn-fledge__cap-label">Est. hatch</span>
          <span class="bcn-fledge__cap-date">{fmtDate(hatchDate)}</span>
        </span>
        <span class="bcn-fledge__cap bcn-fledge__cap--end">
          <span class="bcn-fledge__cap-label">Est. fledge</span>
          <span class="bcn-fledge__cap-date">{fmtDate(fledgeDate)}</span>
        </span>
      </div>
    </div>
  </div>

  {/* Guidance caveat — an info-led note, legible (not crammed). */}
  {find.fledgeNote && (
    <p class="bcn-fledge__note">
      <EsaIcon name="info" size="xs" paths={INFO} />
      <span>{find.fledgeNote}</span>
    </p>
  )}
</div>

<style>
  .bcn-fledge { display: flex; flex-direction: column; gap: var(--spacing-300); }

  .bcn-fledge__band {
    display: flex;
    align-items: center;
    gap: var(--spacing-500);
  }

  /* ── Compact focal count (left) ── */
  .bcn-fledge__count {
    flex-shrink: 0;
    display: flex;
    align-items: baseline;
    gap: var(--spacing-150);
    min-width: 5.5rem;
  }
  .bcn-fledge__num {
    font-family: var(--font-decorative);
    font-size: var(--type-size-400);
    font-weight: var(--font-weight-bold);
    line-height: 1;
    color: var(--color-secondary);
    font-variant-numeric: tabular-nums;
  }
  .bcn-fledge__unit { font-size: 0.7em; font-weight: var(--font-weight-semibold); }
  .bcn-fledge__caption {
    font-size: var(--type-size-150);
    color: var(--color-text-secondary);
    white-space: nowrap;
  }
  .bcn-fledge[data-fledged='true'] .bcn-fledge__num {
    font-size: var(--type-size-300);
    color: var(--color-success);
  }

  /* ── Dated rail (right) ── */
  .bcn-fledge__rail {
    position: relative;
    flex: 1;
    min-width: 0;
    height: 48px;
  }
  .bcn-fledge__track {
    position: absolute;
    top: 7px;
    left: 7px;
    right: 7px;
    height: 6px;
    border-radius: var(--radius-full);
    background: var(--color-border);
  }
  .bcn-fledge__fill {
    position: absolute;
    inset: 0 auto 0 0;
    height: 100%;
    border-radius: var(--radius-full);
    background: var(--color-secondary);
  }
  .bcn-fledge__dot {
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 12px;
    height: 12px;
    border-radius: var(--radius-full);
    background: var(--color-surface);
    border: 2px solid var(--color-border-strong);
    z-index: 1;
  }
  .bcn-fledge__dot[data-reached='true'] {
    background: var(--color-secondary);
    border-color: var(--color-secondary);
  }
  .bcn-fledge__dot--end[data-reached='true'] {
    background: var(--color-success);
    border-color: var(--color-success);
  }
  .bcn-fledge__today {
    position: absolute;
    top: 50%;
    width: 3px;
    height: 18px;
    transform: translate(-50%, -50%);
    border-radius: var(--radius-full);
    background: var(--color-secondary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-secondary) 16%, transparent);
    z-index: 2;
  }

  .bcn-fledge__caps { position: absolute; top: 20px; left: 7px; right: 7px; height: 28px; }
  .bcn-fledge__cap {
    position: absolute;
    display: flex;
    flex-direction: column;
    gap: 1px;
    white-space: nowrap;
  }
  .bcn-fledge__cap--start { left: 0; align-items: flex-start; text-align: left; }
  .bcn-fledge__cap--mid { transform: translateX(-50%); align-items: center; text-align: center; }
  .bcn-fledge__cap--end { right: 0; align-items: flex-end; text-align: right; }
  .bcn-fledge__cap-label {
    font-size: var(--type-size-150);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
  }
  .bcn-fledge__cap-date {
    font-size: var(--type-size-100);
    color: var(--color-text-secondary);
    font-variant-numeric: tabular-nums;
  }

  /* Guidance caveat — info-led, legible. */
  .bcn-fledge__note {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-150);
    margin: 0;
    font-size: var(--type-size-150);
    line-height: 1.45;
    color: var(--color-text-secondary);
  }
  .bcn-fledge__note :global(.esa-icon) { flex-shrink: 0; margin-top: 1px; color: var(--color-text-tertiary); }
</style>
