---
// <BcnKbBrowser> — the article browser of the Help & Guidance page (/prototypes/help):
// a left rail of category groups + article links beside a reading pane that shows ONE
// article at a time. Hash-routed (#article-<id> / #category-<id>) so the Aldo guidance
// drawer can deep-link to an exact article. Behavior lives in ./kb-browser.ts.
//
// Frame: the .sidebar layout primitive (rail 260px, content min 60%; stacks on narrow
// viewports). Every article body is pre-rendered <hidden> via <BcnHelpArticle> so search
// reads titles/summaries straight from the DOM and the JS bundle carries no content.
//
// bcn-lego-checked: the rail is an owned quiet list, NOT esa-sidebar-nav. Checked the lego
// (node_modules/@esa/ecology/src/components/esa-sidebar-nav.ts): it DOES support grouped
// items (item.group) + programmatic active state and renders real <a href>, but it fights
// this browser on three counts — (1) its group heading is the banned ornamental micro-label
// (11px uppercase, letter-spaced), (2) a per-item hint can only be a filled badge pill, not
// quiet 13-14px secondary "How-to"/"Glossary" text, and (3) live search needs <mark>
// substring highlighting inside link text + data-title/data-summary matching, both
// impossible across its shadow-DOM, property-driven boundary. esa-empty-state IS the lego
// for the welcome (custom BcnAldoMark in its icon slot); BcnHelpArticle renders every body.
// Checked Ecology (esa-sidebar-nav, esa-empty-state) + Beacon. bcn-kb-browser is the
// reusable article-browser home.
import EsaEmptyState from '@esa/ecology/esa-empty-state.astro';
import BcnAldoMark from './BcnAldoMark.astro';
import BcnHelpArticle from './BcnHelpArticle.astro';
import { HELP_CATEGORIES, HELP_ARTICLES, articlesByCategory } from '../../data/help-center';

const kindLabel = (kind: 'howto' | 'glossary') => (kind === 'howto' ? 'How-to' : 'Glossary');
---

<section class="bcn-kb sidebar" data-kb-browser>
  <nav class="bcn-kb__rail" aria-label="Help articles">
    <ul class="bcn-kb__groups" role="list">
      {HELP_CATEGORIES.map((cat) => (
        <li class="bcn-kb__group" id={`category-${cat.id}`} data-kb-group={cat.id}>
          <h2 class="bcn-kb__group-title">{cat.title}</h2>
          <ul class="bcn-kb__items" role="list">
            {articlesByCategory(cat.id).map((a) => (
              <li class="bcn-kb__item">
                <a
                  class="bcn-kb__link"
                  href={`#article-${a.id}`}
                  data-article-link={a.id}
                  data-title={a.title}
                  data-summary={a.summary}
                >
                  <span class="bcn-kb__link-title">{a.title}</span>
                  <span class="bcn-kb__link-kind">{kindLabel(a.kind)}</span>
                </a>
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ul>
  </nav>

  <div class="bcn-kb__pane" data-kb-pane>
    <div class="bcn-kb__welcome" data-kb-welcome>
      <EsaEmptyState
        title="Pick an article"
        description="Choose a topic from the list, or search above. Every term and how-to in Beacon lives here."
        size="lg"
      >
        <BcnAldoMark slot="icon" size="lg" animated />
      </EsaEmptyState>
    </div>

    {HELP_ARTICLES.map((a) => (
      <article class="bcn-kb__article" data-article-id={a.id} hidden>
        <BcnHelpArticle article={a} headingLevel="h2" />
      </article>
    ))}
  </div>
</section>

<script>
  import { setupKbBrowser } from './kb-browser';
  setupKbBrowser();
</script>

<style>
  /* Frame: the .sidebar primitive, tuned to a 260px rail + 60%-min reading column.
     Its flex-wrap makes the rail stack above the pane on narrow viewports for free. */
  .bcn-kb {
    --sidebar-width: 260px;
    --sidebar-content-min: 60%;
    --gap: var(--spacing-600, 2rem);
  }

  /* ── left rail ── */
  .bcn-kb__rail {
    position: sticky;
    top: var(--spacing-500, 1.5rem);
    align-self: start;
    max-block-size: calc(100vh - var(--spacing-700, 3rem));
    overflow-y: auto;
  }
  .bcn-kb__groups { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--spacing-500, 1.5rem); }
  .bcn-kb__group[hidden] { display: none; }

  .bcn-kb__group-title {
    margin: 0 0 var(--spacing-200, 0.5rem);
    padding-inline: var(--spacing-300, 0.75rem);
    font-size: var(--type-size-300, 1rem);
    font-weight: var(--font-weight-semibold, 600);
    color: var(--color-text-primary);
    line-height: 1.3;
  }

  .bcn-kb__items { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1px; }
  .bcn-kb__item[hidden] { display: none; }

  .bcn-kb__link {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--spacing-200, 0.5rem) var(--spacing-300, 0.75rem);
    border-radius: var(--radius-200, 8px);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: background 0.1s ease, color 0.1s ease;
  }
  .bcn-kb__link:hover { background: var(--color-surface-sunken); color: var(--color-text-primary); }
  .bcn-kb__link:focus-visible {
    outline: var(--focus-ring-width, 2px) solid var(--focus-ring-color, var(--bcn-aldo, #08908b));
    outline-offset: 2px;
  }
  /* Active = a quiet Aldo-green tint (never a colored left border). */
  .bcn-kb__link.is-active { background: var(--bcn-aldo-50, #e8f6f5); }
  .bcn-kb__link.is-active .bcn-kb__link-title { color: var(--bcn-aldo-600, #06736f); font-weight: var(--font-weight-semibold, 600); }

  .bcn-kb__link-title {
    font-size: var(--type-size-200, 0.875rem);
    font-weight: var(--font-weight-medium, 500);
    color: inherit;
    line-height: 1.35;
  }
  /* Kind hint — genuine meta, so 13px secondary is honest here (not a body role). */
  .bcn-kb__link-kind { font-size: 13px; color: var(--color-text-tertiary); }

  /* Search hits — injected by kb-browser.ts, so :global reaches the <mark> nodes. */
  .bcn-kb__link-title :global(mark) {
    background: var(--bcn-aldo-100, #cfeceb);
    color: inherit;
    border-radius: 2px;
    padding: 0 1px;
  }

  /* ── reading pane ── */
  /* Generous min-height keeps the frame stable so switching articles never jumps the page. */
  .bcn-kb__pane { min-block-size: 60vh; }

  .bcn-kb__welcome { display: grid; place-items: center; min-block-size: 60vh; }
  .bcn-kb__welcome[hidden] { display: none; }

  .bcn-kb__article { max-inline-size: 70ch; }
  .bcn-kb__article[hidden] { display: none; }
</style>
