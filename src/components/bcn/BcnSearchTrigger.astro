---
// <BcnSearchTrigger> — the topbar global-search affordance: a button STYLED as a search
// input (leading magnifier + muted placeholder + "/" hint), centered in the app bar. It
// is a trigger, not a real field — clicking it (or pressing "/") opens <BcnOmniSearch>. It
// carries [data-omni-trigger], the hook omni-search.client wires to open the palette.
//
// bcn-lego-checked: no esa-* lego is an omnibox TRIGGER field — esa-text-field is a real
// bordered/labelled input (wrong semantics: this submits nothing and opens an overlay),
// and esa-icon-button is icon-only. cb-fish hit the same gap (cbf-search-field) and filed
// it as a hub need. Checked Ecology + Beacon; bcn-search-trigger is the reusable home.
import EsaIcon from '@esa/ecology/esa-icon.astro';

interface Props {
  placeholder?: string;
}
const { placeholder = 'Search…' } = Astro.props;
---

<button class="bcn-search-trigger" type="button" data-omni-trigger aria-label="Search" aria-keyshortcuts="/">
  <EsaIcon name="search" size="sm" />
  <span class="bcn-search-trigger__placeholder">{placeholder}</span>
  <span class="bcn-search-trigger__kbd" aria-hidden="true">
    <kbd>/</kbd>
  </span>
</button>

<style>
  .bcn-search-trigger {
    display: flex;
    align-items: center;
    gap: var(--spacing-200);
    width: 100%;
    max-width: 520px;
    margin: 0 auto; /* centered in the topbar's center zone */
    padding: var(--spacing-150) var(--spacing-300);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-200);
    cursor: text;
    transition: border-color 150ms ease, background 150ms ease;
  }
  .bcn-search-trigger:hover {
    border-color: var(--color-primary-border);
    background: var(--color-surface-raised, var(--color-surface));
  }
  .bcn-search-trigger:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
  .bcn-search-trigger :global(.esa-icon) {
    flex: none;
    color: var(--color-text-tertiary);
  }
  .bcn-search-trigger__placeholder {
    flex: 1;
    min-width: 0;
    text-align: left;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: var(--type-size-200);
    color: var(--color-text-tertiary);
  }
  .bcn-search-trigger__kbd {
    display: inline-flex;
    gap: 2px;
    flex: none;
  }
  .bcn-search-trigger__kbd kbd {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 18px;
    padding: 0 4px;
    font-family: inherit;
    font-size: 11px;
    font-weight: var(--font-weight-medium);
    color: var(--color-text-tertiary);
    background: var(--color-surface-sunken);
    border: 1px solid var(--color-border);
    border-radius: 4px;
  }

  /* On a tight app bar, drop the placeholder text to an icon+hint pill. */
  @media (max-width: 720px) {
    .bcn-search-trigger__placeholder { display: none; }
    .bcn-search-trigger { max-width: max-content; }
  }
</style>
