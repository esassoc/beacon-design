---
// <BcnKbGlossary> — the A–Z glossary section of the Help & Guidance home: every
// glossary-kind term as a bare link, sorted A–Z, flowing into narrow text columns.
// Kept deliberately spare (Andy: "Glossary is excellent") — no cards, no summaries,
// no icons, just terms. Each term deep-links the reading-pane sibling via #article-<id>.
//
// Extracted verbatim in spirit from the former dense-index component: same bare-term,
// flowing-column layout; only the interactive accent moved from the (banned) light Aldo
// tint to the house link color.
//
// bcn-lego-checked: a bare A–Z term index is not any esa-* lego — esa-link-column is a
// titled card of links with card chrome; esa-pillbox is tag chips; esa-badge is a
// status token. Checked Ecology + Beacon (prod has no glossary surface). Every term is
// a plain anchor; the only chrome is token type + a hairline. bcn-kb-glossary is the home.
import { glossaryArticles } from '../../data/help-center';

const glossary = glossaryArticles();
---

<section class="bcn-kbg" aria-labelledby="bcn-kbg-title">
  <h2 id="bcn-kbg-title" class="bcn-kbg__title type-section-title">Glossary</h2>
  <ul class="bcn-kbg__terms" role="list">
    {
      glossary.map((a) => (
        <li class="bcn-kbg__term">
          <a class="bcn-kbg__link" href={`#article-${a.id}`}>{a.title}</a>
        </li>
      ))
    }
  </ul>
</section>

<style>
  /* A–Z term links flowing into narrow text columns; a hairline sets it apart above. */
  .bcn-kbg {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-400);
    padding-block-start: var(--spacing-500);
    border-top: 1px solid var(--color-border);
  }

  .bcn-kbg__title {
    margin: 0;
    color: var(--color-text-primary);
  }

  .bcn-kbg__terms {
    list-style: none;
    margin: 0;
    padding: 0;
    columns: 12rem;
    column-gap: var(--spacing-600);
  }
  .bcn-kbg__term {
    break-inside: avoid;
    margin-block-end: var(--spacing-150);
  }

  .bcn-kbg__link {
    font-size: 0.9375rem; /* 15px — dense term list */
    line-height: 1.4;
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color 120ms ease;
  }
  .bcn-kbg__link:hover {
    color: var(--color-text-link);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .bcn-kbg__link:focus-visible {
    outline: 2px solid var(--color-text-link);
    outline-offset: 2px;
    border-radius: var(--radius-100);
  }
</style>
