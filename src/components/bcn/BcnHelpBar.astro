---
// <BcnHelpBar> — Aldo's home: a floating utility pill fixed to the bottom-center of the
// viewport (Figma-toolbar energy — a dark GLASS surface, deliberately distinct from the white
// app chrome, with an inner hairline + soft lift). The What's-new popover it opens stays a
// white content surface. Mounted app-wide in the AppShell chrome. Left → right: the primary "Guidance"
// affordance (the Aldo mark + label), a hairline divider, an icon-only Search button, and a
// "What's new" icon-button with an unread dot that opens a popover of recent release notes.
//
// Wiring is by data-* hook, composed BLIND against siblings — this component adds NO open
// behavior for search or the guidance drawer; it only advertises the hooks the siblings
// already listen on, plus its own local what's-new state:
//   • [data-help-trigger] — the route-aware guidance drawer (sibling) opens on clicks here.
//   • [data-omni-trigger] — the existing global omni-search palette opens on clicks here.
//   • [data-whatsnew]     — LOCAL only: the first click marks WHATS_NEW seen (localStorage
//                           'bcn-whats-new-seen' = newest entry date) and hides the dot.
//
// bcn-lego-checked: the floating bottom-center utility BAR has no esa-* equivalent — esa-app-bar
// is the fixed TOP chrome strip, not a detached toolbar (checked Beacon — none), so the pill
// shell + its internal layout is this component's own composition glue. The "Guidance" control
// is a BRANDED affordance (the animated BcnAldoMark + a text label); esa-button / esa-icon-button
// only accept a Lucide `icon` NAME, not a custom SVG mark, so it is bespoke. Everything else IS a
// lego: esa-icon-button (Search + What's-new triggers), esa-tooltip (Search hint), and
// esa-popover (the What's-new panel, anchored above the trigger). bcn-help-bar is the
// reusable home. Panel entries are text-only — serif title + sans blurb, no icon chips.
//
// The What's-new trigger uses 'notepad-text' — the release-notes glyph, matching the
// Release Notes page title. esa-icon-button forwards only a registry `icon` name (no
// custom `paths` passthrough), so the glyph was registered in the ecology icon-registry.
import BcnAldoMark from './BcnAldoMark.astro';
import EsaIconButton from '@esa/ecology/esa-icon-button.astro';
import { WHATS_NEW } from '../../data/help-center';
import { RELEASES } from '../../data/release-notes';
import { withBase } from '../../lib/base';

const newestDate = WHATS_NEW[0]?.date ?? '';

// The release-notes page; each entry deep-links to its release via `#${entry.anchor}`.
// The panel header frames the entries with the latest release (mirrors the page's own
// quiet "Latest · date" meta line).
const releaseNotesHref = withBase('/prototypes/release-notes');
const latest = RELEASES.find((r) => r.latest) ?? RELEASES[0];

// "Jun 2, 2026" — the release date for the panel header meta line.
const fmtLong = (iso: string): string =>
  new Date(`${iso}T00:00:00`).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<div class="bcn-help-bar" data-help-bar data-newest={newestDate} role="toolbar" aria-label="Help &amp; utilities">
  <!-- Primary: Guidance — the Aldo mark + visible label; opens the guidance drawer via hook. -->
  <button type="button" class="bcn-help-bar__guidance" data-help-trigger aria-haspopup="dialog">
    <BcnAldoMark size="sm" />
    <span class="bcn-help-bar__guidance-label">Guidance</span>
  </button>

  <span class="bcn-help-bar__divider" aria-hidden="true"></span>

  <!-- Search — icon-only; the tooltip host also carries the omni-search open hook. -->
  <esa-tooltip class="bcn-help-bar__tooltip" text="Search" position="above" data-omni-trigger>
    <EsaIconButton icon="search" label="Search" size="md" />
  </esa-tooltip>

  <!-- What's new — icon-only trigger + unread dot; esa-popover panel opens above the bar. -->
  <esa-popover class="bcn-help-bar__popover" position="top" trigger="click" offset={12}>
    <span class="bcn-help-bar__whatsnew" data-whatsnew>
      <EsaIconButton icon="notepad-text" label="What's new" size="md" />
      {WHATS_NEW.length > 0 && (
        <span class="bcn-help-bar__dot" data-whatsnew-dot aria-hidden="true"></span>
      )}
    </span>

    <div slot="content" class="bcn-help-bar__panel">
      <header class="bcn-help-bar__panel-header">
        <p class="bcn-help-bar__panel-title">What's new</p>
        <p class="bcn-help-bar__panel-release">
          {latest.version} · <time datetime={latest.date}>{fmtLong(latest.date)}</time>
        </p>
      </header>
      <ul class="bcn-help-bar__panel-list">
        {WHATS_NEW.map((entry) => (
          <li class="bcn-help-bar__panel-item">
            <a class="bcn-help-bar__panel-link" href={`${releaseNotesHref}#${entry.anchor}`}>
              <p class="bcn-help-bar__panel-item-title">{entry.title}</p>
              <p class="bcn-help-bar__panel-item-blurb">{entry.blurb}</p>
            </a>
          </li>
        ))}
      </ul>
      <div class="bcn-help-bar__panel-footer">
        <a class="bcn-help-bar__panel-all" href={releaseNotesHref}>
          All release notes<span class="bcn-help-bar__panel-all-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </esa-popover>
</div>

<script>
  // Register the Lit legos used above (idempotent — each guards its own customElements.define),
  // then own the What's-new unread-dot lifecycle. esa-popover handles open/close, Esc, and
  // outside-click for the panel; this script only persists the "seen" state.
  import '@esa/ecology/esa-popover';
  import '@esa/ecology/esa-tooltip';

  const SEEN_KEY = 'bcn-whats-new-seen';
  const bar = document.querySelector<HTMLElement>('[data-help-bar]');

  if (bar) {
    const newest = bar.dataset.newest ?? '';
    const dot = bar.querySelector<HTMLElement>('[data-whatsnew-dot]');
    const trigger = bar.querySelector<HTMLElement>('[data-whatsnew]');

    const readSeen = (): string | null => {
      try {
        return localStorage.getItem(SEEN_KEY);
      } catch {
        return null;
      }
    };
    const writeSeen = (value: string): void => {
      try {
        localStorage.setItem(SEEN_KEY, value);
      } catch {
        /* localStorage unavailable (private mode) — dot simply won't persist */
      }
    };

    // Already caught up on the newest note → no dot.
    if (dot && newest && readSeen() === newest) dot.hidden = true;

    // First open marks the newest note seen and retires the dot for this browser.
    trigger?.addEventListener('click', () => {
      if (dot && !dot.hidden && newest) {
        writeSeen(newest);
        dot.hidden = true;
      }
    });
  }
</script>

<style>
  /* The floating pill. position:fixed with only `left` set keeps it shrink-to-fit, so the bar
     occupies just its own box — clicks outside the pill pass through to the page. */
  /* Dark glass — the design-principles carve-out: a floating tool reads distinct from the
     white app chrome. Semantic dark-glass tokens; opaque fallback where blur is unsupported. */
  .bcn-help-bar {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1000; /* under the z-1100 topbar; the guidance drawer overlay sits at 1300 */
    display: flex;
    align-items: center;
    gap: var(--spacing-100);
    padding: var(--spacing-100) var(--spacing-150);
    color: var(--bcn-helpbar-fg);
    background: var(--bcn-helpbar-bg);
    -webkit-backdrop-filter: blur(14px) saturate(1.4);
    backdrop-filter: blur(14px) saturate(1.4);
    border: 1px solid var(--bcn-helpbar-border);
    border-radius: var(--radius-400, 14px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.28); /* dark chrome needs more lift; shadows aren't tokenized here */
  }
  /* No backdrop-filter support (either prefix) → opaque dark fallback. */
  @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
    .bcn-help-bar {
      background: var(--bcn-helpbar-bg-solid);
    }
  }
  /* Honor a reduced-transparency preference — drop the blur, go solid. */
  @media (prefers-reduced-transparency: reduce) {
    .bcn-help-bar {
      background: var(--bcn-helpbar-bg-solid);
      -webkit-backdrop-filter: none;
      backdrop-filter: none;
    }
  }

  /* Primary: Guidance — branded affordance, quiet neutral hover on the dark shell. */
  .bcn-help-bar__guidance {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-150);
    height: 40px;
    padding: 0 var(--spacing-250, 0.625rem);
    border: 0;
    border-radius: var(--radius-200, 8px);
    background: transparent;
    color: var(--bcn-helpbar-fg);
    font-family: inherit;
    font-size: var(--type-size-200, 0.9375rem);
    font-weight: var(--font-weight-medium);
    line-height: 1;
    cursor: pointer;
    transition: background var(--transition-fast, 150ms ease);
  }
  .bcn-help-bar__guidance:hover {
    background: var(--bcn-helpbar-hover-bg);
  }
  .bcn-help-bar__guidance:focus-visible {
    outline: 2px solid var(--bcn-helpbar-fg); /* light foreground — visible on the dark shell, monochrome (no aldo tint) */
    outline-offset: 2px;
  }
  .bcn-help-bar__guidance-label {
    white-space: nowrap;
  }

  .bcn-help-bar__divider {
    flex: none;
    width: 1px;
    height: 22px;
    margin: 0 var(--spacing-050, 2px);
    background: var(--bcn-helpbar-divider);
  }

  /* Icon triggers inherit the 40px hit target + focus ring from esa-icon-button. The tooltip
     and popover hosts are inline wrappers, so they don't disturb the flex row. */
  .bcn-help-bar__tooltip,
  .bcn-help-bar__popover {
    display: inline-flex;
  }
  /* Theme the icon-button legos to the dark zone. esa-icon-button already exposes the hook
     --icon-button-bg-hover and draws its focus outline from currentColor, so both adapt to the
     zone by construction — we only point the hook at the zone token and drive the glyph tone
     (muted at rest, full-strength on hover/focus, which also brightens the currentColor ring). */
  .bcn-help-bar :global(.esa-icon-button) {
    color: var(--bcn-helpbar-fg-muted);
    --icon-button-bg-hover: var(--bcn-helpbar-hover-bg);
  }
  .bcn-help-bar :global(.esa-icon-button:hover),
  .bcn-help-bar :global(.esa-icon-button:focus-visible) {
    color: var(--bcn-helpbar-fg);
  }

  /* What's-new trigger + unread dot. */
  .bcn-help-bar__whatsnew {
    position: relative;
    display: inline-flex;
  }
  .bcn-help-bar__dot {
    position: absolute;
    top: 7px;
    right: 7px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--bcn-aldo);
    box-shadow: 0 0 0 2px var(--bcn-helpbar-bg-solid); /* ring matches the dark shell so the dot reads punched-out */
    pointer-events: none;
  }
  .bcn-help-bar__dot[hidden] {
    display: none;
  }

  /* What's-new panel — slotted into esa-popover's content. */
  .bcn-help-bar__panel {
    width: 340px;
    max-width: 84vw;
    /* The pill zone sets a light foreground; the popover is a white content surface, so
       re-establish the standard dark-on-white text context for everything inside it. */
    color: var(--color-text-primary);
  }
  /* Header row: the panel label + a quiet release meta line (mirrors the page's
     "Latest · June 2, 2026" treatment) — one date for the set, not a badge per entry. */
  .bcn-help-bar__panel-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--spacing-200);
    margin: 0 0 var(--spacing-300);
  }
  .bcn-help-bar__panel-title {
    margin: 0;
    font-size: var(--type-size-200, 0.9375rem);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
  }
  .bcn-help-bar__panel-release {
    margin: 0;
    font-size: var(--type-size-150, 0.875rem);
    color: var(--color-text-tertiary);
    white-space: nowrap;
  }
  .bcn-help-bar__panel-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-200);
  }
  /* Each entry is a quiet link to its release on the release-notes page: it inherits the
     panel's text tone (never link-blue) and adds a soft hover wash + focus ring. The
     horizontal negative margin lets that wash bleed into the popover's own padding, so
     text stays aligned with the header above and the footer below. */
  .bcn-help-bar__panel-link {
    display: block;
    padding: var(--spacing-150) var(--spacing-150);
    margin: 0 calc(var(--spacing-150) * -1);
    border-radius: var(--radius-200, 8px);
    color: inherit;
    text-decoration: none;
    transition: background var(--transition-fast, 150ms ease);
  }
  .bcn-help-bar__panel-link:hover {
    background: var(--color-surface-sunken);
  }
  .bcn-help-bar__panel-link:focus-visible {
    outline: 2px solid var(--color-text-link);
    outline-offset: 2px;
  }
  /* Serif display tier — the entry title takes the house serif, echoing the release
     page's headline treatment; the blurb stays sans and secondary. */
  .bcn-help-bar__panel-item-title {
    margin: 0 0 2px;
    font-family: var(--font-decorative);
    font-size: 1.0625rem; /* 17px */
    font-weight: var(--font-weight-semibold);
    line-height: 1.3;
    color: var(--color-text-primary);
  }
  .bcn-help-bar__panel-item-blurb {
    margin: 0;
    font-size: var(--type-size-150, 0.875rem);
    font-weight: var(--font-weight-regular, 400);
    line-height: 1.45;
    color: var(--color-text-secondary);
  }
  /* Footer: hairline-topped quiet link to the full release-notes page. */
  .bcn-help-bar__panel-footer {
    margin-top: var(--spacing-300);
    padding-top: var(--spacing-250, 0.625rem);
    border-top: 1px solid var(--color-border);
  }
  .bcn-help-bar__panel-all {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: var(--type-size-150, 0.875rem);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-link);
    text-decoration: none;
  }
  .bcn-help-bar__panel-all:hover {
    text-decoration: underline;
  }
  .bcn-help-bar__panel-all:focus-visible {
    outline: 2px solid var(--color-text-link);
    outline-offset: 2px;
    border-radius: 2px;
  }
  .bcn-help-bar__panel-all-arrow {
    transition: transform 150ms ease;
  }
  .bcn-help-bar__panel-all:hover .bcn-help-bar__panel-all-arrow {
    transform: translateX(2px);
  }
</style>
